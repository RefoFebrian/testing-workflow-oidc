<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_p2p_purchase_order_rfa" model="res.groups">
            <field name="category_id" ref="tw_p2p.module_p2p_purchase_order_button"/>
            <field name="name">TW Button Request Approval P2P Purchase Order</field>
        </record>
        
        <record id="access_tw_p2p_purchase_order_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_p2p.model_tw_p2p_purchase_order"/>
            <field name="name">tw_p2p_purchase_order_rfa</field>
            <field name="group_id" ref="group_tw_p2p_purchase_order_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Cancel Payment -->
        <record id="group_tw_p2p_purchase_order_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_p2p.module_p2p_purchase_order_button"/>
            <field name="name">TW Button Cancel P2P Purchase Order</field>
        </record>        
        <record id="access_tw_p2p_purchase_order_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_p2p.model_tw_p2p_purchase_order"/>
            <field name="name">tw_p2p_purchase_order_cancel_approval</field>
            <field name="group_id" ref="group_tw_p2p_purchase_order_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Reject Payment -->
        <record id="group_tw_p2p_purchase_order_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_p2p.module_p2p_purchase_order_button"/>
            <field name="name">TW Button Reject P2P Purchase Order</field>
        </record>        
        <record id="access_tw_p2p_purchase_order_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_p2p.model_tw_p2p_purchase_order"/>
            <field name="name">tw_p2p_purchase_order_reject_approval</field>
            <field name="group_id" ref="group_tw_p2p_purchase_order_reject_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Confirm Payment -->
        <record id="group_tw_p2p_purchase_order_confirm_approval" model="res.groups">
            <field name="category_id" ref="tw_p2p.module_p2p_purchase_order_button"/>
            <field name="name">TW Button Confirm P2P Purchase Order</field>
        </record>        
        <record id="access_tw_p2p_purchase_order_confirm_approval" model="ir.model.access">
            <field name="model_id" ref="tw_p2p.model_tw_p2p_purchase_order"/>
            <field name="name">tw_p2p_purchase_order_confirm_approval</field>
            <field name="group_id" ref="group_tw_p2p_purchase_order_confirm_approval"/>
            <field name="perm_write">1</field>
        </record>
            
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_p2p_purchase_order_rfa')),
                (4, ref('group_tw_p2p_purchase_order_cancel_approval')),
                (4, ref('group_tw_p2p_purchase_order_reject_approval')),
                (4, ref('group_tw_p2p_purchase_order_confirm_approval')),
            ]" />
        </record>
    </data>
           

</odoo>