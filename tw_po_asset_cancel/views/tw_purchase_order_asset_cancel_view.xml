<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="tw_purchase_order_asset_cancel_view_list" model="ir.ui.view">
            <field name="name">tw.purchase.order.asset.cancel.view.list</field>
            <field name="model">tw.purchase.order.asset.cancel</field>
            <field name="arch" type="xml">
                <list string="PO Asset Cancel">
                    <field name="name" />
                    <field name="company_id" />
                    <field name="division" />
                    <field name="purchase_order_asset_id" />
                    <field name="date" />
                    <field name="state" />
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_purchase_order_asset_cancel_view_form" model="ir.ui.view">
            <field name="name">tw.purchase.order.asset.cancel.view.form</field>
            <field name="model">tw.purchase.order.asset.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <field name="transaction_name" position="after">
                    <field name="purchase_order_asset_id"
                        readonly="state != 'draft'"
                        options="{'no_create': True, 'no_open': True}"
                        domain="[('company_id', '=', company_id), ('division', '=', division)]"
                        required="True"
                        invisible="context.get('default_model_type') != 'tw.purchase.order.asset'" />
                </field>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_po_asset_cancel.group_po_asset_cancel_rfa</attribute>
                </xpath>
                <xpath expr="//button[@name='action_approval']" position="attributes">
                    <attribute name="groups">tw_po_asset_cancel.group_po_asset_cancel_rfa</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Reject')]" position="attributes">
                    <attribute name="groups">tw_po_asset_cancel.group_po_asset_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_po_asset_cancel.group_po_asset_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_po_asset_cancel.group_po_asset_cancel_approval_confirm</attribute>
                </xpath>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_purchase_order_asset_cancel_view_search" model="ir.ui.view">
            <field name="name">tw.purchase.order.asset.cancel.view.search</field>
            <field name="model">tw.purchase.order.asset.cancel</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="purchase_order_asset_id" />
                    <field name="name" />
                    <field name="company_id" />
                    <filter string="Draft" name="state_draft"
                        domain="[('state', '=', 'draft')]" />
                    <filter string="Waiting for Approval" name="state_waiting_for_approval"
                        domain="[('state', '=', 'waiting_for_approval')]" />
                    <filter string="Approved" name="state_approved"
                        domain="[('state', '=', 'approved')]" />
                    <filter string="Confirmed" name="state_confirmed"
                        domain="[('state', '=', 'confirmed')]" />
                    <group expand="1" string="Group By">
                        <filter string="Company" name="group_by_company"
                            domain="[('company_id', '!=', False)]"
                            context="{'group_by': 'company_id'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_tw_purchase_order_asset_cancel" model="ir.actions.act_window">
            <field name="name">PO Asset Cancel</field>
            <field name="res_model">tw.purchase.order.asset.cancel</field>
            <field name="context" eval="
                {
                    'search_default_state_draft': 1,
                    'search_default_state_waiting_for_approval': 1,
                    'search_default_state_approved': 1,
                    'default_model_id': ref('tw_asset_management.model_purchase_order_asset'),
                    'default_model_type': 'tw.purchase.order.asset',
                }
            "/>
            <field name="domain">[('purchase_order_asset_id', '!=', False)]</field>
        </record>

        <record id="tw_purchase_order_asset_cancel_action_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_purchase_order_asset_cancel_view_list"/>
            <field name="act_window_id" ref="action_tw_purchase_order_asset_cancel"/>
        </record>

        <record id="tw_purchase_order_asset_cancel_action_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_purchase_order_asset_cancel_view_form"/>
            <field name="act_window_id" ref="action_tw_purchase_order_asset_cancel"/>
        </record>

    </data>
</odoo>