<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Journal Memorial Read Group -->
        <record id="group_tw_journal_memorial_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Journal Memorial Read</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Journal Memorial Update Group -->
        <record id="group_tw_journal_memorial_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Journal Memorial Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_journal_memorial_read'))]"/>
        </record>

        <!-- Journal Memorial Delete Group -->
        <record id="group_tw_journal_memorial_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Journal Memorial Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_journal_memorial_read'))]"/>
        </record>

        <!-- Add groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_journal_memorial_read')),
                (4, ref('group_tw_journal_memorial_update')),
                (4, ref('group_tw_journal_memorial_delete')),
            ]"/>
        </record>
    </data>
</odoo>
