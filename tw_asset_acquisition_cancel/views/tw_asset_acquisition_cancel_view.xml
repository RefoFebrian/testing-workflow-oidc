<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- List View -->
        <record id="tw_asset_acquisition_cancel_list_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.cancel.list.view</field>
            <field name="model">tw.asset.acquisition.cancel</field>
            <field name="arch" type="xml">
                <list string="Asset Acquisition Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="asset_acquisition_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_asset_acquisition_cancel_form_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.cancel.form.view</field>
            <field name="model">tw.asset.acquisition.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <field name="transaction_name" position="after">
                <field name="asset_acquisition_id"
                    readonly="state != 'draft'"
                    options="{'no_create': True, 'no_open': True}"
                    domain="[('company_id','=',company_id), ('division','=',division), ('state','not in',['draft','cancel'])]"
                    required="True"
                    invisible="context.get('default_model_type') != 'tw.asset.acquisition'"/>
                </field>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_asset_acquisition_cancel.group_asset_acquisition_cancel_rfa</attribute>
                </xpath>
                <xpath expr="//button[@name='action_approval']" position="attributes">
                    <attribute name="groups">tw_asset_acquisition_cancel.group_asset_acquisition_cancel_rfa</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Reject')]" position="attributes">
                    <attribute name="groups">tw_asset_acquisition_cancel.group_asset_acquisition_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_asset_acquisition_cancel.group_asset_acquisition_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_asset_acquisition_cancel.group_asset_acquisition_cancel_approval_confirm</attribute>
                </xpath>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_asset_acquisition_cancel_search_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.cancel.search.view</field>
            <field name="model">tw.asset.acquisition.cancel</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="asset_acquisition_id"/>
                    <field name="name"/>
                    <field name="company_id"/>
                    <filter string="Draft" name="state_draft" domain="[('state','=','draft')]"/>
                    <filter string="Waiting for Approval" name="state_waiting_for_approval" domain="[('state','=','waiting_for_approval')]"/>
                    <filter string="Approved" name="state_approved" domain="[('state','=','approved')]"/>
                    <filter string="Confirmed" name="state_confirmed" domain="[('state','=','confirmed')]"/>
                    <group expand="1" string="Group By">
                        <filter string="Company" name="group_by_company" domain="[('company_id','!=',False)]" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_asset_acquisition_cancel_action" model="ir.actions.server">
            <field name="name">Asset Acquisition Cancel</field>
            <field name="model_id" ref="tw_asset_acquisition_cancel.model_tw_asset_acquisition_cancel"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.asset.acquisition.cancel'].action_asset_acquisition_cancel_tree()
            </field>
        </record>

    </data>
</odoo>