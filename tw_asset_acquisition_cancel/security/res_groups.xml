<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Asset Acquisition Cancel READ -->
        <record id="group_asset_acquisition_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Asset Acquisition Cancel Read</field>
        </record>

        <!-- Asset Acquisition Cancel UPDATE -->
        <record id="group_asset_acquisition_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Asset Acquisition Cancel Update</field>
            <field name="implied_ids" eval="[(4, ref('group_asset_acquisition_cancel_read'))]"/>
        </record>

        <!-- Asset Acquisition Cancel DELETE -->
        <record id="group_asset_acquisition_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Asset Acquisition Cancel Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_asset_acquisition_cancel_read'))]"/>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_asset_acquisition_cancel_read')),
                (4, ref('group_asset_acquisition_cancel_update')),
                (4, ref('group_asset_acquisition_cancel_delete')),
            ]"/>
        </record>
    </data>

</odoo>