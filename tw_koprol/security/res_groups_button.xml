<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- Button Generate Access Token Azure -->
        <record id="group_button_generate_access_token_azure" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Generate Access Token Azure</field>
        </record>

        <record id="access_button_generate_access_token_azure" model="ir.model.access">
            <field name="model_id" ref="model_res_users"/>
            <field name="name">button_generate_access_token_azure</field>
            <field name="group_id" ref="group_button_generate_access_token_azure"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_button_generate_access_token_azure')),
            ]">
			</field> 
		</record>

    </data>
</odoo>