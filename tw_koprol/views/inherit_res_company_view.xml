<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="view_res_company_koprol_form" model="ir.ui.view" >
		    <field name="name">res.company.koprol.form</field>
		    <field name="model">res.company</field>
		    <field name="inherit_id" ref="tw_branch.tw_res_branch_form_view"/>
		    <field name="arch" type="xml">
		    	<xpath expr="//label[@for='profit_centre']" position="before">
					<label for="koprol_code"/>
					<h1>
						<field name="koprol_code" readonly="1"/>
					</h1>
                </xpath>
		    </field>
		</record>
	</data>
</odoo>