<odoo>
	<data>

        <record id="tw_account_period_fiscal_year_account_move_form_view" model="ir.ui.view">
            <field name="name">tw.account.period.fiscal.year.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <field name="ref" position="after">
                    <field name="period_id" required="1" readonly="state == 'posted'" options="{'no_create': True, 'no_open': True}"/>
                </field>
            </field>
        </record>

    </data>
</odoo>