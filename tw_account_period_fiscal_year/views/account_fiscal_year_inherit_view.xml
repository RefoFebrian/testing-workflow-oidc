<odoo>
	<data>

        <record id="tw_account_period_fiscal_year_acc_fiscal_year_list_view" model="ir.ui.view">
            <field name="name">tw.account.period.fiscal.year.acc.fiscal.year.list</field>
            <field name="model">account.fiscal.year</field>
            <field name="inherit_id" ref="om_fiscal_year.view_account_fiscal_year_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="replace">
                    <field name="code"/>
                    <field name="name" string="Fiscal Year"/>
                </field>
                <field name="date_to" position="after">
                    <field name="company_id"/>
                    <field name="state" string="Status" widget="badge" />
                </field>
            </field>
        </record>

        <record id="tw_account_period_fiscal_year_acc_fiscal_year_form_view" model="ir.ui.view">
            <field name="name">tw.account.period.fiscal.year.acc.fiscal.year.form</field>
            <field name="model">account.fiscal.year</field>
            <field name="inherit_id" ref="om_fiscal_year.view_account_fiscal_year_form"/>
            <field name="arch" type="xml">
                <field name="name" position="replace">
                    <field name="name" string="Fiscal Year"/>
                    <field name="code" required="1"/>
                </field>

                <xpath expr="//form/sheet" position="before">
                    <header>
                        <button name="action_create_period" invisible="state != 'draft'" string="Create Monthly Periods" type="object" class="oe_highlight"/>
                        <button name="action_create_period3" invisible="state != 'draft'" string="Create 3 Months Periods" type="object" class="oe_highlight"/>
                        <field name="state" widget="statusbar" nolabel="1"/>
                    </header>
                </xpath>

                <xpath expr="//form/sheet/group[last()]" position="after">
                    <field colspan="4" name="period_ids" nolabel="1" widget="one2many_list">
                        <form string="Period">
                            <group col="4">
                                <field name="name" required="1"/>
                                <field name="code"/>
                                <field name="date_from" required="1"/>
                                <field name="date_to" required="1"/>
                                <field name="special"/>
                                <field name="state" invisible="1"/>
                            </group>
                        </form>
                    </field>
                    <notebook>
                        <page string="Audit Trail">
                            <group>
                                <group>
                                    <field name="create_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="create_date" readonly="1"/>
                                </group>
                                <group>
                                    <field name="write_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                    <field name="write_date" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </xpath>
            </field>
        </record>

    </data>
</odoo>