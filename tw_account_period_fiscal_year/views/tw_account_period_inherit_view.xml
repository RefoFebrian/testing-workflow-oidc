<odoo>
    <data>

        <record id="tw_account_period_fiscal_year_account_period_form_view" model="ir.ui.view">
            <field name="name">tw.account.period.fiscal.year.account.period.form</field>
            <field name="model">tw.account.period</field>
            <field name="inherit_id" ref="tw_account_period.tw_account_period_form_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="fiscalyear_id" required="1" readonly="state == 'done'" options="{'no_create': True, 'no_open': True}"/>
                </field>
                <field name="special" position="after">
                    <field name="company_id" readonly="1" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_company"/>
                </field>
            </field>
        </record>
        
    </data>
</odoo>