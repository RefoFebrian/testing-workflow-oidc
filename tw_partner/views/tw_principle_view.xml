<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for principle Partner -->
    <record id="action_tw_principle_partner" model="ir.actions.act_window">
        <field name="name">Principle</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="tw_partner.view_tw_all_partner_inherit_filter"/>
        <field name="domain">[('company_type','=','company'),('category_id.name','=','Principle')]</field>
        <field name="context" eval="
            {   
                'form_type': 'Principle',
                'is_readonly': True,
                'default_company_type': 'company',
                'default_category_id': [ref('tw_partner.contact_tags_principle')]
            }
        "/>
    </record>
</odoo>
