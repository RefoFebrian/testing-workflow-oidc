<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Summary Report Group -->
        <record id="group_tw_lead_summary_report" model="res.groups">
            <field name="category_id" ref="base.module_category_sales_sales" />
            <field name="name">TW Lead Summary Laporan</field>
        </record>

        <!-- Detailed Report Group -->
        <record id="group_tw_lead_detailed_report" model="res.groups">
            <field name="category_id" ref="base.module_category_sales_sales" />
            <field name="name">TW Lead Detailed Laporan</field>
        </record>

        <!-- Summary Report Access -->
        <record id="access_tw_lead_summary_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_lead_summary_report_wizard" />
            <field name="name">access_tw_lead_summary_report</field>
            <field name="group_id" ref="group_tw_lead_summary_report" />
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Detailed Report Access -->
        <record id="access_tw_lead_detailed_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_lead_detailed_report_wizard" />
            <field name="name">access_tw_lead_detailed_report</field>
            <field name="group_id" ref="group_tw_lead_detailed_report" />
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
    </data>

     <record id="tw_group_pdp_laporan_buku_tamu" model="res.groups">
            <field name="category_id" ref="base.module_category_sales_sales" />
            <field name="name">TW PDP Laporan Buku Tamu</field>
        </record>

        <record id="access_tw_group_pdp_laporan_buku_tamu" model="ir.model.access">
            <field name="model_id" ref="model_tw_lead_detailed_report_wizard" />
            <field name="name">access_tw_group_pdp_laporan_buku_tamu</field>
            <field name="group_id" ref="tw_group_pdp_laporan_buku_tamu" />
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_lead_summary_report')),
                (4, ref('group_tw_lead_detailed_report')),
                (4, ref('tw_group_pdp_laporan_buku_tamu')),
            ]" />
        </record>
    </data>
</odoo>
