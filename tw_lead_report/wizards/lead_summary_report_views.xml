<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lead_report_wizard_form" model="ir.ui.view">
        <field name="name">lead.report.wizard.form</field>
        <field name="model">tw.lead.summary.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Lead Summary Report">
                <sheet>
                    <group>
                        <group>
                            <field name="date_from" string="From Date" required="1"/>
                            <field name="date_to" string="To Date" required="1"/>
                            <field name="company_id" options="{'no_open': True, 'no_create': True}" required="1"/>
                        </group>
                        <group>
                            <field name="team_id" string="Sales Team" options="{'no_open': True, 'no_create': True}" class="oe_inline"/>
                            <field name="user_ids" string="Salesperson(s)" widget="many2many_tags" options="{'no_open': True}" class="oe_inline"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Generate Excel Report" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_lead_report_wizard" model="ir.actions.act_window">
        <field name="name">Lead Summary Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">tw.lead.summary.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'dialog_size': 'medium'}</field>
    </record>

    <!-- Add to Showroom Report menu -->
    <menuitem id="menu_lead_report"
              name="Laporan Lead Summary"
              parent="tw_menu.submenu_tw_showroom_report"
              action="action_lead_report_wizard"
              groups="tw_lead_report.group_tw_lead_summary_report"
              sequence="30"/>
</odoo>
