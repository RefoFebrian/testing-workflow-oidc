<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_lead_detailed_report_wizard_form" model="ir.ui.view">
        <field name="name">lead.detailed.report.wizard.form</field>
        <field name="model">tw.lead.detailed.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Lead Detailed Report">
                <sheet>
                    <group>
                        <group>
                            <field name="start_date" string="Start Date" required="1"/>
                            <field name="state" string="State"/>
                            <field name="data_source" string="Data Source" required="1"/>
                        </group>
                        <group>
                            <field name="end_date" string="End Date" required="1"/>
                        </group>
                    </group>
                    <notebook colspan="5">
                        <page string="Branches">
							<field name="company_ids" colspan="4" nolabel="1">
								<list>
                                    <field name="name"/>
                                    <field name="partner_id"></field>
                                  
                                </list>
                            </field>
						</page>
                    </notebook>
                    <footer>
                        <button name="action_generate_report" string="Generate Excel Report" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="action_lead_detailed_report_wizard" model="ir.actions.act_window">
        <field name="name">Lead Detailed Report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">tw.lead.detailed.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'dialog_size': 'medium'}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_lead_detailed_report"
              name="Laporan Buku Tamu Detail"
              parent="tw_menu.submenu_tw_showroom_report"
              action="action_lead_detailed_report_wizard"
              groups="tw_lead_report.group_tw_lead_detailed_report"
              sequence="35"/>
</odoo>
