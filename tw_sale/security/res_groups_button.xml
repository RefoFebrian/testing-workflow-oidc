<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="tw_sale_button_view_invoice_group" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Sales Order Button View Invoice</field>
        </record>

        <record id="tw_sale_button_view_delivery_group" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Sales Order Button View Delivery</field>
        </record>

        <record id="tw_sale_button_create_invoice_group" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Sales Order Button Create Invoice</field>
        </record>

        <record id="access_tw_sale_order_button_create_invoice_account_move" model="ir.model.access">
            <field name="model_id" ref="tw_sale.model_account_move"/>
            <field name="name">tw_sale_order_button_create_invoice_account_move</field>
            <field name="group_id" ref="tw_sale_button_create_invoice_group"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_sale_order_button_create_invoice_account_move_line" model="ir.model.access">
            <field name="model_id" ref="tw_sale.model_account_move_line"/>
            <field name="name">tw_sale_order_button_create_invoice_account_move_line</field>
            <field name="group_id" ref="tw_sale_button_create_invoice_group"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>


        <record id="tw_sale_button_confirm_group" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Sales Order Button Confirm</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_sale_button_view_invoice_group')),
                (4,ref('tw_sale_button_view_delivery_group')),
                (4,ref('tw_sale_button_create_invoice_group')),
                (4,ref('tw_sale_button_confirm_group')),
            ]" />
        </record>
    </data>

</odoo>
