<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_sale_order_branch_form_view" model="ir.ui.view">
            <field name="name">tw.sale.order.branch.inherit.form</field>
            <field name="model">res.company</field>
            <field name="inherit_id" ref="base.view_company_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="is_so_unit_pick_then_invoice" />
                    <field name="is_so_sparepart_pick_then_invoice" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>