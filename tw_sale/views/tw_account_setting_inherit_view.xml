<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_sale_order_account_setting_form_view" model="ir.ui.view">
            <field name="name">tw.sale.order.account.setting.inherit.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
            <field name="arch" type="xml">
                <!-- Add a new Sales page after the Backoffice page -->
                <xpath expr="//group[@name='sales_order_container']" position="inside">
                    <group name="sales_config_group">
                        <h3 class="o_stat_info" colspan="2" style="margin-top:0px;">
                            <span class="text-success">Sales Order</span>
                        </h3>
                        <field name="journal_sales_unit_id" options="{'no_create':True}" string="Journal Unit Sales"/>
                        <field name="journal_sales_sparepart_id" options="{'no_create':True}" string="Journal Sparepart Sales"/>
                    </group>
                    <group name="sales_order_cancel">
                        <h3 class="o_stat_info" colspan="2" style="margin-top:0px;">
                            <span class="text-success">Journal Cancel</span>
                        </h3>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>