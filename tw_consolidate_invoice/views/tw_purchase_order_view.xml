<odoo>
	<data>

		<!-- Inherited Form View -->
			<record id="tw_inherit_purchase_order_consolidate_invoice_form_view" model="ir.ui.view">
				<field name="name">tw.purchase.order.form</field>
				<field name="model">purchase.order</field>
				<field name="inherit_id" ref="purchase.purchase_order_form" />
				<field name="arch" type="xml">

					<xpath expr="//field[@name='order_line']/list//field[@name='qty_invoiced']" position="after">
						<field name="consolidated_qty" string="Consolidated" readonly="1" column_invisible="parent.state not in ('purchase','done')"/>
					</xpath>


				</field>
			</record>

	</data>
</odoo>
