<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_consolidate_invoice_tree" model="ir.ui.view">
            <field name="name">tw.consolidate.invoice.tree</field>
            <field name="model">tw.consolidate.invoice</field>
            <field name="arch" type="xml">
                <list string="Consolidate Invoice" default_order="id desc">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="partner_id"/>
                    <field name="date"/>
                    <field name="state" widget="badge" decoration-warning="state == 'confirm'" decoration-success="state == 'done'"/>
                </list>
            </field>
        </record>

        <record id="view_tw_consolidate_invoice_form" model="ir.ui.view">
            <field name="name">tw.consolidate.invoice.form</field>
            <field name="model">tw.consolidate.invoice</field>
            <field name="arch" type="xml">
                <form string="Consolidate Invoice">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1 invisible="name"><span>Draft</span></h1>
                            <h1 invisible="not name"><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" readonly="state != 'draft'" options="{'no_open': True, 'no_create': True}"/>
                                <field name="partner_id" required="1" readonly="state != 'draft'" options="{'no_open': True, 'no_create': True}"/>
                                <field name="invoice_ids" required="1" readonly="state != 'draft'" widget="many2many_tags" options="{'no_create': True}" 
                                    domain="[
                                        ('company_id', '=', company_id),
                                        ('division', '=', division),
                                        ('partner_id', '=', partner_id),
                                        ('move_type', '=', 'in_invoice'),
                                        ('state', '=', 'posted'),
                                        ('is_consolidated', '=', False)]"/>
                                <field name="purchase_order_ids" readonly="1" invisible="not invoice_ids" force_save="1" widget="many2many_tags" options="{'no_create': True}"/>
                                <div style="color:red;" invisible="not purchase_order_ids or state != 'draft'">
                                    <br/>
                                    <b>*Consolidate Invoice tidak bisa di cancel!</b> <br/>
                                    Pastikan <b>invoice fisik sudah diterima</b> dan pastikan <b>QTY dan harga sudah sesuai</b> sebelum melakukan consolidate.
                                    <br/>
                                </div>
                            </group>
                            <group>
                                <field name="picking_domain" invisible="1"/>
                                <field name="division" required="1" readonly="state != 'draft'"/>
                                <field name="date" required="1" readonly="1" force_save="1"/>
                                <field name="picking_ids" required="1" readonly="state != 'draft'" domain="picking_domain" widget="many2many_tags" options="{'no_create': True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Consolidate Lines">
                                <field name="line_ids" readonly="state != 'draft'">
                                    <list editable="top" create="0" delete="0">
                                        <field name="purchase_order_id" readonly="1" force_save="1"/>
                                        <field name="lot_ids" widget="many2many_tags" readonly="1" force_save="1"/>
                                        <field name="product_id" readonly="1" force_save="1"/>
                                        <field name="qty" required="1" readonly="1" force_save="1"/>
                                        <field name="invoice_line_id" readonly="1" force_save="1" optional="hide"/>
                                        <field name="stock_move_id" readonly="1" force_save="1" optional="hide"/>
                                        <field name="invoice_qty" readonly="1" force_save="1" optional="hide"/>
                                        <field name="move_qty" readonly="1" force_save="1" optional="hide"/>
                                        <field name="unit_price" readonly="1" force_save="1"/>
                                        <field name="untaxed_price" readonly="1" force_save="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_date" readonly="1"/>
                                        <field name="create_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="confirm_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                    </group>
                                    <group>
                                        <field name="write_date" readonly="1"/>
                                        <field name="write_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_consolidate_invoice_showroom" model="ir.actions.act_window">
            <field name="name">Consolidate Invoice</field>
            <field name="res_model">tw.consolidate.invoice</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="tw_consolidate_invoice_workshop" model="ir.actions.act_window">
            <field name="name">Consolidate Invoice</field>
            <field name="res_model">tw.consolidate.invoice</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
