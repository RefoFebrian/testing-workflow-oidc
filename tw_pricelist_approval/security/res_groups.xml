<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_product_pricelist_version_approval_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Product Pricelist Version Approval Read</field>
        </record>

        <record id="access_tw_product_pricelist_version_update" model="ir.model.access">
            <field name="model_id" ref="tw_approval.model_tw_approval_line"/>
            <field name="name">tw_product_pricelist_version_approval update</field>
            <field name="group_id" ref="group_tw_product_pricelist_version_approval_update"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="tw_pricelist.group_tw_product_pricelist_version_update" model="res.groups">
            <field name="implied_ids" eval="[
               	(4, ref('group_tw_product_pricelist_version_approval_update')),
				]"/>
        </record>


    <!-- Pricelist Cancel Approval -->
		
        <record id="group_tw_product_pricelist_version_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Pricelist Version Cancel Approval</field>
        </record>
          
        <record id="access_tw_product_pricelist_version_cancel_approval_write" model="ir.model.access">
            <field name="model_id" ref="tw_approval.model_tw_approval_line"/>
            <field name="name">tw_product_pricelist_version_cancel_approval_line write</field>
            <field name="group_id" ref="group_tw_product_pricelist_version_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>
                
        <record id="access_tw_product_pricelist_version_cancel_write" model="ir.model.access">
            <field name="model_id" ref="model_tw_product_pricelist_version"/>
            <field name="name">tw_product_pricelist_version_cancel write</field>
            <field name="group_id" ref="group_tw_product_pricelist_version_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>
    </data>
</odoo>