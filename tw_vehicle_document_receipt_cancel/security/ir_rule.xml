<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Document Receipt Cancel Multi-Company Rule -->
        <record id="tw_vehicle_document_receipt_cancel_rule" model="ir.rule">
            <field name="name">Vehicle Document Receipt Cancel multi-company</field>
            <field name="model_id" ref="tw_vehicle_document_receipt_cancel.model_tw_vehicle_document_receipt_cancel"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Ownership Receipt Cancel Multi-Company Rule -->
        <record id="tw_vehicle_ownership_receipt_cancel_rule" model="ir.rule">
            <field name="name">Vehicle Ownership Receipt Cancel multi-company</field>
            <field name="model_id" ref="tw_vehicle_document_receipt_cancel.model_tw_vehicle_ownership_receipt_cancel"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
