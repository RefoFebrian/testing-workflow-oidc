<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_boom_leave_request_list_view" model="ir.ui.view">
            <field name="name">tw.boom.leave.request.list.view</field>
            <field name="model">tw.boom.leave.request</field>
            <field name="arch" type="xml">
                <list string="TW Boom Leave Request">
                    <field name="pic_id"/>
                    <field name="nik_pic"/>
                    <field name="job_id"/>
                    <field name="company_id"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        
        <record id="tw_boom_leave_request_form_view" model="ir.ui.view">
            <field name="name">tw.boom.leave.request.form.view</field>
            <field name="model">tw.boom.leave.request</field>
            <field name="arch" type="xml">
                <form string="TW Boom Leave Request">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="company_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="pic_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="nik_pic" readonly="1"/>
                            <field name="job_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            <label for="start_date" string="Periode"/>
                            <div>
                                <field name="start_date" class="oe_inline" required="1"/> s/d
                                <field name="end_date" class="oe_inline" required="1"/>
                            </div>
                            <field name="reason" required="1"/>
                        </group>
                        <notebook>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" />
                                        <field name="create_date" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" invisible="not write_uid"/>
                                        <field name="write_date" readonly="1" invisible="not write_date"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_boom_leave_request_filter" model="ir.ui.view">
            <field name="name">tw.boom.leave.request.form.view.filter</field>
            <field name="model">tw.boom.leave.request</field>
            <field name="arch" type="xml">
                <search string="BOOM Leave Request">
                    <field name="pic_id"/>
                    <field name="nik_pic"/>
                    <field name="job_id"/>
                    <field name="company_id"/>
                    <group string="Group By..">
                        <filter name="group_by_job_id" string="Job" domain="[]" context="{'group_by': 'job_id'}"/>
                        <filter name="group_by_company_id" string="Branch" domain="[]" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tw_boom_leave_request" model="ir.actions.act_window">
            <field name="name">TW Boom Leave Request</field>
            <field name="res_model">tw.boom.leave.request</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[]</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Create an TW Boom Leave Request.
                </p>
            </field>
        </record>
    </data>
</odoo>