<odoo>
    <data>
      <record id="self_register_home" model="website.page">
        <field name="url"></field>
        <field name="is_published">True</field>
        <field name="website_indexed" eval="True" />
        <field name="name">Self Register</field>
        <field name="type">qweb</field>
        <field name="key">website_self_register.self_register_home</field>
        <field name="arch" type="xml">
            <t t-name="website.self-register">
                <t t-call="website.layout">
                    <main>                        
                        <!-- Search Section -->
                        <!-- <section class="container-custom mt-5">
                            <div class="text-center">
                                <h2 class="mb-3">Cari Plat Kendaraan mu</h2>
                                <p>Silahkan input nomor polisi untuk memastikan kendaraan anda sudah terdaftar pada sistem Honda. Dengan format : <strong>BE2408BAX</strong></p>
                            </div>
                            <div class="d-flex justify-content-center mt-4">
                                <form action="/search_plate" method="POST" class="form-inline">
                                    <div class="search-box-custom">
                                        <input type="text" placeholder="Ketikkan nomor plat mu"/>
                                        <button>Cari</button>
                                    </div>
                                </form>
                            </div>
                        </section> -->

                        <!-- Search Section -->
                        <section class="container-custom mt-5">
                            <div class="text-center search-container">
                                <h2 class="mb-3">Cari Plat Kendaraan mu</h2>
                                <p>Silahkan input nomor polisi untuk memastikan kendaraan anda sudah terdaftar pada sistem Honda. Dengan format: <strong>BE2408BAX</strong></p>
                            </div>
                            <div class="d-flex justify-content-center mt-2">
                                <form onsubmit="return searchPlatNo(event)" method="POST" class="form-inline">
                                    <div class="search-box-custom">
                                        <input name="plat_kendaraan" type="text" placeholder="Ketikkan nomor plat mu" />
                                        <button>Cari</button>
                                    </div>
                                </form>
                            </div>
                        </section>

                        <!-- Modal -->
                        <div id="successModal" class="modal-custom" style="display: none;">
                            <div class="modal-custom-content">
                                <span class="close-button">&#215;</span>
                                <h3 id="title_modal">Yeay, pendaftaran berhasil!</h3>
                                <!-- <p id='message_modal'></p> -->
                                <div class="alert">
                                    <span id="content_modal">🚨 Simpan nomor registrasi ini, ya</span>
                                </div>
                                <div id="registration_number" class="registration-number">
                                    <input type="text" id="registrationNumber" value="SR/DMP/24/10/09891" readonly=""/>
                                    <button onclick="copyToClipboard()">📋 Salin nomor</button>
                                </div>
                                <img id="image_modal_footer" src="/website_self_register/static/img/illustrasi_berhasil.png" alt="High Five" class="high-five-image"/>
                            </div>
                        </div>

            
                        <!-- City Illustration -->
                        <section class="mt-5">
                            <div class="container text-center">
                                <div class="bg_illustrasi" name="bg_illustrasi">
                                    <div id="card_self_register" class="s_card card bg-white w-100" data-snippet="s_card" data-name="Card">
                                    <h4 class="card-header o_default_snippet_text"></h4>
                                    <div class="card-body">
                                        <p class="card-text o_default_snippet_text"><t t-esc="warning_message"/></p>
                                        <div class="container">
                                            <form onsubmit="return postSelfRegister(event)" method="post" enctype="multipart/form-data" data-mark="*" data-pre-fill="true" data-success-page="/thank-you" data-success-mode="redirect">
                                                <div class="s_website_form_rows row s_col_no_bgcolor">
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="ocoo22z85o2j">
                                                                <span class="s_website_form_label_content">Customer</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="Name Customer" required="1" data-fill-with="name" id="name_customer"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="no_telp">
                                                                <span class="s_website_form_label_content">No HP / Telp</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" placeholder="Silahkan masukan No HP / Telp" type="text" name="no_telp" required="1" data-fill-with="name" id="no_telp"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom s_website_form_required" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="ocoo22z85o2j">
                                                                <span class="s_website_form_label_content">Nomor Mesin</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="Nomor Mesin" required="1" data-fill-with="name" id="nomor_mesin"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="og5ubjigsoq">
                                                                <span class="s_website_form_label_content">Nomor Rangka</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="Nomor Rangka" placeholder="" id="nomor_rangka" data-fill-with="phone"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="o0pxrina21jt">
                                                                <span class="s_website_form_label_content">No. Booking Service</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="No. Booking Service" placeholder="" id="no_booking_service" data-fill-with="undefined"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="o8wtx10jbqpa">
                                                                <span class="s_website_form_label_content">Product</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="Product" placeholder="" id="product" data-fill-with="undefined"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="float">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="km">
                                                                <span class="s_website_form_label_content">KM</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input type="number" class="form-control s_website_form_input" step="any" name="KM" placeholder="" id="km" data-fill-with="undefined"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="float">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="choice_keluhan">
                                                                <span class="s_website_form_label_content">Apakah ada Keluhan?</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <select class="form-control s_website_form_input select_field input-company" name="choice_keluhan" id="choice_keluhan" style="" required="">
                                                                    <option value="">(Silahkan Pilih)</option>
                                                                    <option t-attf-value="yes_keluhan">
                                                                        YES
                                                                    </option>
                                                                    <option t-attf-value="no_keluhan">
                                                                        NO
                                                                    </option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div id="service_type_div" data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="float">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="service_type">
                                                                <span class="s_website_form_label_content">Type Service?</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <select class="form-control s_website_form_input select_field input-company" name="service_type" id="service_type" style="">
                                                                    <option value="">(Silahkan Pilih)</option>
                                                                    <option t-attf-value="KPB">
                                                                        KPB
                                                                    </option>
                                                                    <option t-attf-value="REG">
                                                                        Reguler
                                                                    </option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div id="paket_service_div" class="form-group s_website_form_field col-12 s_website_form_custom s_website_form_required" data-type="many2one" data-name="Field">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                        <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="paket_service">
                                                            <span class="s_website_form_label_content">Paket Service</span>
                                                            <span class="s_website_form_mark"> *</span>
                                                        </label>
                                                        <div class="col-sm">
                                                            <select class="form-control s_website_form_input select_field input-company" name="paket_service" id="paket_service">
                                                            <option value="">(Silahkan Pilih)</option>
                                                            <t t-foreach="paket_service" t-as="paket_service">
                                                                <option t-attf-value="#{paket_service.id}">
                                                                <t t-esc="paket_service.name" />
                                                                </option>
                                                            </t>
                                                            </select>
                                                        </div>
                                                        </div>
                                                    </div>
                                                    <div id="paket_service_description_div" class="form-group s_website_form_field col-12 s_website_form_custom s_website_form_required" data-type="many2one" data-name="Field">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                        <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="paket_service_description">
                                                            <span class="s_website_form_label_content">Paket Service Description</span>
                                                            <span class="s_website_form_mark"> *</span>
                                                        </label>
                                                        <div class="col-sm">
                                                            <select class="form-control s_website_form_input select_field input-company" name="paket_service_description" id="paket_service_description">
                                                            <option value="">(Silahkan Pilih)</option>
                                                            <t t-foreach="paket_service_description" t-as="paket_service_description">
                                                                <option t-attf-value="#{paket_service.id}">
                                                                <t t-esc="paket_service.description" />
                                                                </option>
                                                            </t>
                                                            </select>
                                                        </div>
                                                        </div>
                                                    </div>
                                                    <div data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="description_packet_service">
                                                                <span class="s_website_form_label_content">Description Paket Service</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="description_packet_service" placeholder="" id="description_packet_service" data-fill-with="undefined"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div id="keluhan_div" data-name="Field" class="s_website_form_field mb-3 col-12 s_website_form_custom" data-type="char">
                                                        <div class="row s_col_no_resize s_col_no_bgcolor">
                                                            <label class="col-form-label col-sm-auto s_website_form_label" style="width: 200px" for="keluhan">
                                                                <span class="s_website_form_label_content">Keluhan</span>
                                                            </label>
                                                            <div class="col-sm">
                                                                <input class="form-control s_website_form_input" type="text" name="Keluhan" placeholder="" id="keluhan" data-fill-with="undefined"/>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <!-- Privacy Policy Section -->
                                                    <t t-if="privacy_policy_content">
                                                        <input type="hidden" id="privacy_policy_id" t-att-value="privacy_policy_id"/>
                                                        <div class="mb-3 col-12 privacy-policy-section">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="checkbox" id="privacy_policy_checkbox"/>
                                                                <label class="form-check-label" for="privacy_policy_checkbox">
                                                                    Saya telah membaca dan menyetujui
                                                                    <a href="#" id="privacy_policy_link" class="privacy-policy-link">Kebijakan Privasi</a>
                                                                </label>
                                                            </div>
                                                        </div>
                                                    </t>
                                                    <div class="mb-0 py-2 col-12 s_website_form_submit" data-name="Submit Button">
                                                    <div style="width: 200px;" class="s_website_form_label"/>
                                                    <button type="submit" aria-label="form" title="From Self Register" class="btn btn-primary">
                                                        Submit
                                                    </button>
                                                        <span id="s_website_form_result"/>
                                                    </div>
                                                </div>
                                            </form>

                                            <!-- Privacy Policy Modal -->
                                            <t t-if="privacy_policy_content">
                                                <div id="privacyPolicyModal" class="modal-privacy" style="display: none;">
                                                    <div class="modal-privacy-content">
                                                        <div class="modal-privacy-header">
                                                            <h3>Kebijakan Privasi</h3>
                                                            <span class="close-privacy-modal">&#215;</span>
                                                        </div>
                                                        <div class="modal-privacy-body">
                                                            <t t-raw="privacy_policy_content"/>
                                                        </div>
                                                        <div class="modal-privacy-footer">
                                                            <button id="btn_accept_privacy" class="btn btn-primary">Saya Mengerti</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    </main>
                </t>
            </t>
        </field>
      </record>
    </data>
  </odoo>