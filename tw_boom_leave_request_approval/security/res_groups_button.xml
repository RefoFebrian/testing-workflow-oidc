<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Request for Approval -->
        <record id="group_tw_boom_leave_request_rfa" model="res.groups">
            <field name="category_id" ref="tw_boom.tw_module_category_boom"/>
            <field name="name">TW Button Request for Approval BOOM Leave Request</field>
        </record>

        <record id="access_tw_boom_leave_request_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_boom_leave_request.model_tw_boom_leave_request"/>
            <field name="name">tw_boom_leave_request_rfa update</field>
            <field name="group_id" ref="group_tw_boom_leave_request_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Approval -->
        <record id="group_tw_boom_leave_request_approval" model="res.groups">
            <field name="category_id" ref="tw_boom.tw_module_category_boom"/>
            <field name="name">TW Button Approval BOOM Leave Request</field>
        </record>

        <record id="access_tw_boom_leave_request_approval" model="ir.model.access">
            <field name="model_id" ref="tw_boom_leave_request.model_tw_boom_leave_request"/>
            <field name="name">tw_boom_leave_request_approval update</field>
            <field name="group_id" ref="group_tw_boom_leave_request_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Cancel -->
        <record id="group_tw_boom_leave_request_cancel" model="res.groups">
            <field name="category_id" ref="tw_boom.tw_module_category_boom"/>
            <field name="name">TW Button Cancel BOOM Leave Request</field>
        </record>
        <record id="access_tw_boom_leave_request_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_boom_leave_request.model_tw_boom_leave_request"/>
            <field name="name">tw_boom_leave_request_cancel update</field>
            <field name="group_id" ref="group_tw_boom_leave_request_cancel"/>
            <field name="perm_write">1</field>
        </record>


        <!-- reject -->
        <record id="group_tw_boom_leave_request_reject" model="res.groups">
            <field name="category_id" ref="tw_boom.tw_module_category_boom"/>
            <field name="name">TW Button Reject BOOM Leave Request</field>
        </record>
        <record id="access_tw_boom_leave_request_reject" model="ir.model.access">
            <field name="model_id" ref="tw_boom_leave_request.model_tw_boom_leave_request"/>
            <field name="name">tw_boom_leave_request_reject update</field>
            <field name="group_id" ref="group_tw_boom_leave_request_reject"/>
            <field name="perm_write">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_boom_leave_request_rfa')),
                (4, ref('group_tw_boom_leave_request_approval')),
                (4, ref('group_tw_boom_leave_request_cancel')),
                (4, ref('group_tw_boom_leave_request_reject')),
            ]" />
        </record>
    </data>
</odoo>