<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_collecting_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Request Approval Collecting AR/AP</field>
        </record>
        <record id="access_tw_collecting_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_collecting_approval.model_tw_collecting"/>
            <field name="name">tw_collecting_rfa update</field>
            <field name="group_id" ref="group_tw_collecting_rfa"/>
            <field name="perm_write">1</field>
        </record>

        
        <!-- Cancel Payment -->
		
        <record id="group_tw_collecting_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cancel Collecting AR/AP</field>
        </record>
        <record id="access_tw_collecting_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_collecting_approval.model_tw_collecting"/>
            <field name="name">tw_collecting_cancel_approval update</field>
            <field name="group_id" ref="group_tw_collecting_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Reject Payment -->
		
        <record id="group_tw_collecting_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Reject Collecting AR/AP</field>
        </record>
        <record id="access_tw_collecting_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_collecting_approval.model_tw_collecting"/>
            <field name="name">tw_collecting_reject_approval update</field>
            <field name="group_id" ref="group_tw_collecting_reject_approval"/>
            <field name="perm_write">1</field>
        </record>
          

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_collecting_rfa')),
                (4, ref('group_tw_collecting_cancel_approval')),
                (4, ref('group_tw_collecting_reject_approval')),
            ]"/>
        </record>
    </data>

</odoo>
