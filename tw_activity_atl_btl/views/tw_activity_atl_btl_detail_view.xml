<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_activity_atl_btl_line_all_list_view" model="ir.ui.view">
            <field name="name">tw.activity.plan.line.all.list</field>
            <field name="model">tw.activity.atl.btl.line</field>
            <field name="arch" type="xml">
                <list>
                    <field name="company_id"/>
                    <field name="activity_name" width="120%"/>
                    <field name="sales_channel_id"/>
                    <field name="name" width="150%"/>
                    <field name="act_type_id" options="{'no_open':True,'no_create':True}"/>
                    <field name="mapping_activity_id" width="150%" options="{'no_open':True,'no_create':True}"/>
                    <field name="ring_id" width="50%" options="{'no_open':True,'no_create':True}"/>
                    <field name="district_id" width="150%" options="{'no_open':True,'no_create':True}"/>
                    <field name="pic_id" width="120%" options="{'no_open':True,'no_create':True}"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="total_cost"/>
                    <field name="target_unit"/>
                    <field name="target_customer"/>
                    <field name="state" string="Status"/>
                </list>
            </field>
        </record>

        <record id="tw_activity_atl_btl_line_all_form_view" model="ir.ui.view">
            <field name="name">tw.activity.plan.line.all.form</field>
            <field name="model">tw.activity.atl.btl.line</field>
            <field name="arch" type="xml">
                <form>
                    
                    <header>
                        <button name="action_open_activity" string="Open Activity" type="object" class="oe_highlight" invisible="1"/>
                        <button name="action_confirm_lpj" string="Done" type="object" class="oe_highlight" invisible="not context.get('lpj_btl') and state != 'confirmed'" confirm="BTL akan berstatus Done setelah ini, Pastikan semua data LPJ sudah sesuai. Apakah anda yakin ingin melanjutkan proses?" groups="tw_activity_atl_btl.group_confirm_lpj_activity_btl_button"/>
						<button name="action_history_result" string="Refresh History" type="object" invisible="not context.get('outstanding_btl') and state != 'open'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,open,confirmed,done"/>
                    </header>
                    <sheet>
                        <div name="button_box" class="oe_button_box">
                          <button string="Location" class="oe_stat_button" icon="fa-building-o" name="action_view_location" type="object" invisible="not location_id" groups="tw_activity_atl_btl.group_open_loc_activity_btl_button"/>
                        </div>
                        <div class="oe_title" name="title_btl">
                            <field name="activity_id" invisible="1"/>
                            <h1>
                                <field name="name" invisible="not name and (not context.get('outstanding_btl') or not context.get('lpj'))" readonly="1"/>	
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="sales_channel_id" readonly="state not in ('draft','revision')" options="{'no_open':True,'no_create':True}" required="1"/>
                                <field name="sales_channel" invisible="1"/>
                                <field name="act_type_id" readonly="state not in ('draft','revision')" options="{'no_open':True,'no_create':True}" required="1"/>
                                <field name="act_type_code" invisible="1"/>
                                <field name="mapping_activity_id" string="Titik keramaian" options="{'no_open':True,'no_create':True}" readonly="state not in ('draft','revision')" required="1" domain="[('company_id','=',company_id)]"/>
                                <field name="ring_id" options="{'no_open':True,'no_create':True}" readonly="1"/>
                                <field name="is_location"/>
                                <field name="source_pos_location_id" options="{'no_open':True,'no_create':True}" domain="[
                                    ('company_id','=',company_id),
                                    ('btl_loc_type_id.value','=','POS'),]" 
                                    readonly="state not in ('draft','revision')" invisible="not is_location or sales_channel != 'pos'" required="is_location or sales_channel == 'pos'"/>
                                <field name="submission_type" readonly="state not in ('draft','revision')" invisible="is_location == False" required="is_location != False"/>
                                <field name="location_id" options="{'no_open': True, 'no_create': True}" 
                                    domain="[('company_id','=', company_id),
                                             ('usage','=','internal'),
                                             ('btl_loc_type_id.value','in',('Pameran','Channel','Canvasing')),
                                             ('effective_end_date','>=', context_today()),
                                             ]"
                                    readonly="state not in ('draft','revision')" invisible="submission_type != 'update' or not is_location" required="submission_type == 'update'"/>
                                <label for="rent_start_date" string="Periode Rental/Sewa"/>
                                <div>
                                    <field name="rent_start_date"
                                    widget="daterange"
                                    options="{'end_date_field': 'rent_end_date'}"
                                    readonly="state not in ('draft','revision') or (submission_type == 'update' and location_id != False)" required="submission_type == 'new'" />
                                    <field name="rent_end_date" invisible="1" />
                                </div>
                                <field name="rent_note" readonly="1" string="" nolabel="1" invisible="submission_type == 'new' and location_id == False"/>
                                <field name="display_unit" readonly="state not in ('draft','revision')" invisible="is_location == False" required="is_location != False"/>
                                <field name="target_unit" readonly="state not in ('draft','revision')" required="1"/>
                                <field name="target_customer" readonly="state not in ('draft','revision')" required="1"/>
                            </group>
                            <group>
                                <field name="company_id" invisible="1"/>
                                <field name="state" invisible="1"/>
                                <label for="start_date" string="Periode"/>
                                <div>
                                    <field name="start_date"
                                    widget="daterange"
                                    options="{'end_date_field': 'end_date'}"
                                    readonly="state not in ('draft','revision')" required="1" />
                                    <field name="end_date" invisible="1" />
                                </div>
                                <field name="available_pic_ids" invisible="1"/>
                                <field name="pic_id" domain="[('id', 'in', available_pic_ids)]" readonly="state not in ('draft','revision')" options="{'no_open':True,'no_create':True}" required="1"/>
                                <field name="registry_number" string="NIK Employee" readonly="1"/>
                                <field name="job" readonly="1"/>
                                <field name="phone_number" readonly="state not in ('draft','revision')" required="1"/>
                                <field name="activity_name" string="Nama Activity" readonly="state not in ('draft','revision')" invisible="submission_type == 'update'" required="not is_location or submission_type == 'new'"/>
                                <field name="filename_loc_photo" invisible="1"/>
                                <label for="loc_photo_show" string="Foto Lokasi"/>
                                <div>
                                    <field name="loc_photo_show" invisible="not filename_loc_photo" widget="image" style="height: auto; max-width: 70%;"/>
                                    <field name="loc_photo" readonly="state not in ('draft','revision')" 
                                        invisible="not is_location" 
                                        required="act_type_code in ('PM','CH','RS') and not filename_loc_photo" 
                                        filename="filename_loc_photo"/>
                                </div>
                            </group>
                        </group>
                        <group string="Address">
                            <group>
                                <field name="street" readonly="state not in ('draft','revision')" required="is_location"/>
                                <field name="rt" class="oe_inline"/>
                                <field name="rw" class="oe_inline"/>
                            </group>
                            <group>
                                <field name="state_id" options="{'no_open':True,'no_create':True}" readonly="1"/>
                                <field name="city_id" options="{'no_open':True,'no_create':True}" readonly="1"/>
                                <field name="district_id" options="{'no_open':True,'no_create':True}" readonly="1"/>
                                <field name="sub_district_id" options="{'no_open':True,'no_create':True}" readonly="state not in ('draft','revision')"/>
                            </group>
                            <group>
                                <div><b>Titik Koordinat</b></div>
                                <div></div>
                                <field name="lat" required="not is_location and sales_channel == 'pos'" placeholder="Lat"/>
                                <field name="long" required="not is_location and sales_channel == 'pos'" placeholder="Long"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Biaya">
                                <group>
                                    <field name="detail_cost_ids" readonly="state not in ('draft','revision')" string="Detail Biaya">
                                        <list editable="bottom" delete="state not in ('draft','revision')">
                                            <field name="partner_id" required="1" options="{'no_open':True,'no_create':True}"/>
                                            <field name="submission_type_id" required="1" options="{'no_open':True,'no_create':True}"/>
                                            <field name="source_payment_id" options="{'no_open':True,'no_create':True}"/>
                                            <field name="amount" required="1" sum="Total"/>
                                            <field name="tax_id" options="{'no_open':True,'no_create':True}"/>
                                            <field name="tax_amount" readonly="1" sum="Total"/>
                                            <field name="subtotal" sum="Total"/>
                                            <field name="state" invisible="1"/>
                                            <field name="note" required="amount > 0"/>
                                        </list>
                                    </field>
                                </group>
                            </page>
                            <page name="history_activity" string="History Activity">
                                <group name="group_history_activity">
                                    <field name="history_location_ids" string="Unit 3 Bulan Terakhir">
                                        <list create='0' edit='0' delete='0'>
                                            <field name="month"/>
                                            <field name="qty" sum="Total"/>
                                        </list>
                                        <form>
                                            <sheet>
                                                <group>
                                                    <group>
                                                        <field name="month"/>
                                                        <field name="qty"/>
                                                    </group>
                                                </group>
                                                <notebook>
                                                    <page string="Detail Pencapaian">
                                                        <field name="history_detail_ids" nolabel="1">
                                                            <list>
                                                                <field name="product_id" options="{'no_open':True,'no_create':True}"/>
                                                                <field name="categ_id" options="{'no_open':True,'no_create':True}"/>
                                                            </list>
                                                            <form>
                                                                <sheet>
                                                                    <group>
                                                                        <field name="product_id" options="{'no_open':True,'no_create':True}"/>
                                                                        <field name="categ_id" options="{'no_open':True,'no_create':True}"/>
                                                                    </group>
                                                                </sheet>
                                                            </form>
                                                        </field>
                                                    </page>
                                                </notebook>
                                            </sheet>
                                        </form>
                                    </field>
                                </group>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="open_uid" readonly="1"/>
                                        <field name="open_date" readonly="1"/>
                                    </group>
                                    <group>							
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
