<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_payment_request_rfa" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Button Request Approval Payment Request</field>
        </record>
        
        <record id="access_tw_payment_request_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_payment_request.model_tw_payment_request"/>
            <field name="name">tw_payment_request_rfa</field>
            <field name="group_id" ref="group_tw_payment_request_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Cancel Payment -->		
        <record id="group_tw_payment_request_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Button Cancel Payment Request</field>
        </record>
        <record id="access_tw_payment_request_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment_request.model_tw_payment_request"/>
            <field name="name">tw_payment_request_cancel_approval</field>
            <field name="group_id" ref="group_tw_payment_request_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>


                
        <!-- reject Payment -->		
        <record id="group_tw_payment_request_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Button Reject Payment Request</field>
        </record>
        <record id="access_tw_payment_request_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment_request.model_tw_payment_request"/>
            <field name="name">tw_payment_request_reject_approval</field>
            <field name="group_id" ref="group_tw_payment_request_reject_approval"/>
            <field name="perm_write">1</field>
        </record>

        
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_payment_request_rfa')),
                (4, ref('group_tw_payment_request_cancel_approval')),
                (4, ref('group_tw_payment_request_reject_approval')),
            ]"/>
        </record>
    </data>

</odoo>
