<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
       
        <!-- List View PO Asset -->
        <record id="tw_purchase_order_asset_list_view" model="ir.ui.view">
            <field name="name">purchase.order.asset.view.list</field>
            <field name="model">purchase.order.asset</field>
            <field name="priority" eval="2" />
            <field name="arch" type="xml">
                <list string="Purchase Order Assets" decoration-muted="state=='cancel'" sample="1">
                    <field name="priority" widget="priority" nolabel="1" optional="hide" />
                    <field name="name" string="Name" decoration-info="state in ('draft','sent')" optional="show" />
                    <field name="company_id" optional="show"/>
                    <field name="partner_id" optional="show" />
                    <field name="date" optional="show" />
                    <field name="confirm_date" optional="hide"/>
                    <field name="state" widget="badge" decoration-success="state == 'done'" decoration-warning="not confirm_date and state != 'draft'" decoration-info="confirm_date and state != 'done'" optional="show" />
                    <field name="partner_ref" optional="hide" />
                    <field name="date_approve" optional="hide" />
                    <field name="activity_exception_decoration" widget="activity_exception" />
                </list>
            </field>
        </record>

        <!-- Inherited Search View -->
		<record id="tw_inherit_purchase_order_asset_search_view" model="ir.ui.view">
            <field name="name">tw.inherit.purchase.order.asset.search.view</field>
            <field name="model">purchase.order.asset</field>
            <field name="arch" type="xml">
                <search string="Purchase Order Asset">
                    <field name="name" select="True"/>
                    <field name="company_id" select="True"/>
                    <field name="partner_id" select="True"/>
                    <field name="date" select="True"/>
                    <field name="picking_type_id" select="True"/>
                    <field name="order_line" select="True" string="Product Asset" filter_domain="[('order_line.product_id', 'ilike', self)]"/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]" />
                    <filter name="open" string="Open" domain="[('state', '=', 'open')]" />
                    <filter name="purchase" string="Purchase" domain="[('state', '=', 'purchase')]" />
                    <filter name="payment" string="Payment" domain="[('state', '=', 'payment')]" />
                    <filter name="received" string="Received" domain="[('state', '=', 'received')]" />
                    <filter name="outstanding" string="outstanding" domain="[('state', 'not in', [ 'purchase','done'])]" />
                    <group expand="1" string="Group By">
                        <filter string="Branch" name="group_by_branch" domain="[]" context="{'group_by': 'company_id'}"/>
                        <filter string="Date" name="group_by_date" domain="[]" context="{'group_by': 'date: year'}"/>
                        <filter string="Division" name="group_by_division" domain="[]" context="{'group_by': 'division'}"/>
                        <filter string="State" name="group_by_state" domain="[]" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <!-- Form View PO Asset 2-->
        <record id="tw_inherit_purchase_order_asset_form_view" model="ir.ui.view">
            <field name="name">tw.purchase.order.asset.form</field>
            <field name="model">purchase.order.asset</field>
            <field name="inherit_id" ref="purchase.purchase_order_form" />
            <field name="arch" type="xml">
                <button name="action_rfq_send" position="before">
                    <button name="action_confirm" string="Confirm" groups="tw_asset_management.group_tw_asset_po_confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                </button>

                <button name="print_quotation" position="attributes">
                    <attribute name="invisible">state != 'draft' or context.get('is_asset')</attribute>
                </button>

                <button name="button_confirm" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </button>

                <!-- Smart Button in Assets -->
                <button name="action_view_invoice" position="after">
                    <button type="object"  name="action_view_good_receive" class="oe_stat_button" icon="fa-pencil-square-o" invisible="good_receive_ids == 0 or state in ('draft', 'sent', 'to approve') or not context.get('is_asset')">
                        <field name="good_receive_count" widget="statinfo" string="Good Receive Assets"/>
                        <field name='good_receive_ids' invisible="1"/>
                    </button>

                    <button type="object"  name="action_view_collecting" class="oe_stat_button" icon="fa-pencil-square-o" invisible="collecting_count == 0 or state in ('draft', 'sent', 'to approve') or not context.get('is_asset')">
                        <field name="collecting_count" widget="statinfo" string="Collecting Assets"/>
                        <field name='collecting_ids' invisible="1"/>
                    </button>
                </button>

                <xpath expr="//button[@name='action_view_picking']" position="attributes">
					<attribute name="invisible">is_invisible_button or is_shipped or state not in ('purchase', 'done') or incoming_picking_count == 0 or context.get('is_asset')</attribute>
				</xpath>

                <field name="picking_type_id" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </field>

                <field name="purchase_order_type_id" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </field>
                
                <field name="purchase_order_type_id" position="after">
                    <field name="po_type" invisible="not context.get('is_asset')" readonly="state != 'draft'"/>
                </field>
                
                <field name="date_planned" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </field>

                <xpath expr="//div[@name='date_planned_div']" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </xpath>
                
                <xpath expr="//label[@for='date_planned']" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </xpath>
                
                <xpath expr="//div[@name='reminder']" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </xpath>

                <page name="purchase_delivery_invoice" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </page>

                <field name="division" position="attributes">
                    <attribute name="readonly">state != 'draft' or context.get('is_asset')</attribute>
                </field>

                <button name="action_view_invoice" position="attributes">
                    <attribute name="invisible">invoice_count == 0 or state in ('draft', 'sent', 'to approve') or context.get('is_asset')</attribute>
                </button>

                <field name="state" position="attributes">
                    <attribute name="statusbar_visible">draft,open,partial_received,received,partial_payment,payment,purchase</attribute>
                </field>
                
                <!-- TODO: Partner ID ini perlu dicek di PO Normal juga -->
                <field name="partner_id" position="attributes">
                    <attribute name="domain">[('category_id.name','in',('Vendor','General Supplier'))]</attribute>
                </field>

                <page name="products" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </page>

                <page name="products" position="after">
                    <page string="Products Asset" name="products_assets">
                        <field name="tax_country_id" invisible="1"/>
                        <field name="order_line"
                            widget="product_label_section_and_note_field_o2m"
                            mode="list,kanban"
                            context="{'default_state': 'draft'}"
                            readonly="state != 'draft'">
                            <list string="Purchase Order Lines" editable="bottom">
                                <control>
                                    <create name="add_product_control" string="Add a product"/>
                                    <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                    <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    <button name="action_add_from_catalog" string="Catalog" type="object" class="px-4 btn-link" context="{'order_id': parent.id}"/>
                                </control>
                                <field name="tax_calculation_rounding_method" column_invisible="True"/>
                                <field name="display_type" column_invisible="True"/>
                                <field name="company_id" column_invisible="True"/>
                                <field name="currency_id" column_invisible="True"/>
                                <field name="state" column_invisible="True"/>
                                <field name="product_type" column_invisible="True"/>
                                <field name="product_uom" column_invisible="True" groups="!uom.group_uom"/>
                                <field name="product_uom_category_id" column_invisible="True"/>
                                <field name="invoice_lines" column_invisible="True"/>
                                <field name="sequence" widget="handle"/>
                                <field
                                    name="product_id"
                                    widget="product_label_section_and_note_field"
                                    readonly="state in ('purchase', 'to approve', 'done', 'cancel') or is_downpayment"
                                    required="not display_type and not is_downpayment"
                                    options="{'no_create': True}"
                                    context="{'partner_id':parent.partner_id, 'quantity':product_qty, 'company_id': parent.company_id, 'action_name' : 'Non-trade'}"
                                    force_save="1" domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', 'parent_of', parent.company_id), ('categ_id', 'ilike', 'Non-trade')]"/>
                                <field name="is_asset" readonly="1"/>
                                <field name="name" widget="section_and_note_text" optional="show"/>
                                <field name="state_gr" optinal="show" force_save="1" readonly="1"/>
                                <field name="is_cip" optinal="show" readonly="1"/>
                                <field name="asset_category_id" optional="hide" readonly="1"/>
                                <field name="product_qty" readonly="is_downpayment or is_cip"/>
                                <field name="qty_received_manual" column_invisible="True"/>
                                <field name="qty_received_method" column_invisible="True"/>
                                <field name="qty_received" readonly="1" force_save="1" string="Qty Received"/>
                                <field name="qty_remaining" string="Qty Remaining" readonly="1" force_save="1"/>
                                <field name="qty_invoiced" string="Qty Billed"/>
                                <field name="product_uom" string="UoM" groups="uom.group_uom"
                                    readonly="state in ('purchase', 'done', 'cancel') or is_downpayment"
                                    required="not display_type and not is_downpayment"
                                    options="{'no_open': True, 'no_create': True}"
                                    force_save="1" optional="show"/>
                                <field name="price_unit" readonly="qty_invoiced != 0"/>
                                <field name="taxes_id" widget="many2many_tags" domain="[('type_tax_use', '=', 'purchase'), ('company_id', 'parent_of', parent.company_id), ('country_id', '=', parent.tax_country_id), ('active', '=', True)]" context="{'default_type_tax_use': 'purchase', 'search_view_ref': 'account.account_tax_view_search'}" options="{'no_create': True}" optional="show" readonly="is_downpayment"/>
                                <field name="discount" string="Disc.%" width="50px" readonly="qty_invoiced != 0" optional="hide"/>
                                <field name="price_subtotal" string="Amount"/>
                            </list>
                            <form string="Purchase Order Line">
                                    <field name="tax_calculation_rounding_method" invisible="1"/>
                                    <field name="state" invisible="1"/>
                                    <field name="display_type" invisible="1"/>
                                    <field name="company_id" invisible="1"/>
                                    <group invisible="display_type">
                                        <group>
                                            <field name="product_uom_category_id" invisible="1"/>
                                            <field name="product_id"
                                                context="{'partner_id': parent.partner_id}"
                                                widget="many2one_barcode"
                                                domain="[('purchase_ok', '=', True), '|', ('company_id', '=', False), ('company_id', '=', parent.company_id)]"
                                                readonly="state in ('purchase', 'to approve', 'done', 'cancel')"
                                            />
                                            <label for="product_qty"/>
                                            <div class="o_row">
                                                <field name="product_qty"/>
                                                <field name="product_uom" groups="uom.group_uom" required="not display_type and not is_downpayment"/>
                                            </div>
                                            <field name="qty_received_method" invisible="1"/>
                                            <field name="qty_received" string="Received Quantity" invisible="parent.state not in ('purchase', 'done')" readonly="qty_received_method != 'manual'"/>
                                            <field name="qty_invoiced" string="Billed Quantity" invisible="parent.state not in ('purchase', 'done')"/>
                                            <field name="product_packaging_qty" invisible="not product_id or not product_packaging_id" groups="product.group_stock_packaging"/>
                                            <field name="product_packaging_id" invisible="not product_id" context="{'default_product_id': product_id, 'list_view_ref':'product.product_packaging_tree_view', 'form_view_ref':'product.product_packaging_form_view'}" groups="product.group_stock_packaging" />
                                            <field name="price_unit"/>
                                            <field name="discount"/>
                                            <field name="taxes_id" widget="many2many_tags" domain="[('type_tax_use', '=', 'purchase'), ('company_id', 'parent_of', parent.company_id), ('country_id', '=', parent.tax_country_id)]" options="{'no_create': True}"/>
                                        </group>
                                        <group>
                                            <field name="analytic_distribution" widget="analytic_distribution"
                                                groups="analytic.group_analytic_accounting"
                                                options="{'product_field': 'product_id', 'business_domain': 'purchase_order'}"/>
                                        </group>
                                        <group>
                                        <notebook colspan="4">
                                            <page string="Notes" name="notes">
                                                <field name="name"/>
                                            </page>
                                            <page string="Invoices and Incoming Shipments" name="invoices_incoming_shiptments">
                                                <field name="invoice_lines"/>
                                            </page>
                                        </notebook>
                                        </group>
                                    </group>
                                    <label for="name" string="Section Name (eg. Products, Services)" invisible="display_type != 'line_section'"/>
                                    <label for="name" string="Note" invisible="display_type != 'line_note'"/>
                                    <field name="name" nolabel="1"  invisible="not display_type"/>
                            </form>
                            <kanban class="o_kanban_mobile">
                                <field name="display_type"/>
                                <field name="tax_calculation_rounding_method"/>
                                <templates>
                                    <t t-name="card">
                                        <t t-if="!record.display_type.raw_value">
                                            <div class="row">
                                                <field name="product_id" class="fw-bold col-8"/>
                                                <span class="fw-bold col-4">
                                                    Tax excl.: <field name="price_subtotal" class="float-end"/>
                                                </span>
                                            </div>
                                            <div class="row">
                                                <span class="col-8 text-muted">
                                                    Quantity:
                                                    <field name="product_qty" />
                                                    <field name="product_uom" groups="uom.group_uom" class="small"/>
                                                </span>
                                                <span class="fw-bold col-4" t-if="record.tax_calculation_rounding_method.raw_value === 'round_per_line'">
                                                    Tax incl.: <field name="price_total" />
                                                </span>
                                            </div>
                                            <span class="text-muted">
                                                Unit Price:
                                                <field name="price_unit" />
                                            </span>
                                            <span class="text-muted" t-if="record.discount.raw_value">
                                                Discount: <field name="discount" />%
                                            </span>
                                        </t>
                                        <div t-elif="record.display_type.raw_value === 'line_section' || record.display_type.raw_value === 'line_note'">
                                            <div t-attf-class="{{record.display_type.raw_value === 'line_section' ? 'fw-bold' : 'fst-italic' }}">
                                                <field name="name" />
                                            </div>
                                        </div>
                                    </t>
                                </templates>
                            </kanban>
                        </field>
                        <group>
                            <group>
                                <field colspan="2" name="notes" nolabel="1" placeholder="Define your terms and conditions ..."/>
                            </group>
                            <group class="oe_subtotal_footer">
                                <field name="tax_totals" widget="account-tax-totals-field" nolabel="1" readonly="1"/>
                            </group>
                        </group>
                        <div class="clearfix"/>
                    </page>
                </page>

            </field>
        </record>


        <!-- Form View PO Asset 1 -->
        <record id="tw_inherit_purchase_order_asset_1_view_form" model="ir.ui.view">
            <field name="name">tw.purchase.order.asset.1.form</field>
            <field name="model">purchase.order.asset</field>
            <field name="inherit_id" ref="tw_purchase_order.tw_inherit_purchase_order_form_view"/>
            <field name="arch" type="xml">
                <field name="purchase_order_type_id" position="attributes">
                    <attribute name="invisible">context.get('is_asset')</attribute>
                </field>
            </field>
        </record>
        

        <record id="tw_purchase_order_asset_action_server" model="ir.actions.server">
            <field name="name">Purchase Order Asset</field>
            <field name="path">purchase-order-asset</field>
            <field name="model_id" ref="model_purchase_order_asset"/>
            <field name="binding_view_types">form,list</field>
            <field name="state">code</field>
            <field name="code">
                action = env['purchase.order.asset'].with_context({'is_asset': True,'search_default_outstanding':True}).action_purchase_order_list('Asset')
            </field>
        </record>

    </data>

</odoo>
