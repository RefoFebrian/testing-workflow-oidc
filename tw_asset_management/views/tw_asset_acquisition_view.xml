<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===================== -->
        <!-- LIST VIEW             -->
        <!-- ===================== -->
        <record id="tw_asset_acquisition_list_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.list</field>
            <field name="model">tw.asset.acquisition</field>
            <field name="arch" type="xml">
                <list string="Asset Acquisitions" default_order="id desc" decoration-muted="state=='cancel'" sample="1">
                    <field name="name" string="Reference" decoration-info="state == 'draft'"/>
                    <field name="company_id" optional="show"/>
                    <field name="date"/>
                    <field name="partner_id" string="Vendor"/>
                    <field name="good_receive_id" string="Good Receive"/>
                    <field name="product_id" string="Product"/>
                    <field name="qty" string="Qty"/>
                    <field name="amount_total" string="Total Amount"/>
                    <field name="asset_count" string="Assets"/>
                    <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'"/>
                </list>
            </field>
        </record>

        <!-- ===================== -->
        <!-- FORM VIEW             -->
        <!-- ===================== -->
        <record id="tw_asset_acquisition_form_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.form</field>
            <field name="model">tw.asset.acquisition</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <!-- Confirm button WITHOUT confirmation (for new CIP or non-CIP, no asset_register_id, no final_cip) -->
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="c" invisible="state != 'draft' or asset_register_id or is_final_cip" groups="tw_asset_management.group_tw_asset_acquisition_confirm"/>
                        <!-- Confirm button WITH confirmation (for CIP kapitalisasi - asset_register_id filled, not final) -->
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="c" invisible="state != 'draft' or not asset_register_id or is_final_cip" confirm="KONFIRMASI KAPITALISASI CIP: Value akan ditambahkan ke Asset CIP yang dipilih. Pastikan Asset Register sudah benar sebelum melanjutkan!" groups="tw_asset_management.group_tw_asset_acquisition_confirm"/>
                        <!-- Confirm button WITH confirmation (for final CIP) -->
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" data-hotkey="c" invisible="state != 'draft' or not is_final_cip" confirm="PERINGATAN FINAL CIP: Asset CIP akan menjadi Running Asset, depresiasi akan mulai berjalan, dan TIDAK bisa kembali ke status CIP. Apakah anda yakin?" groups="tw_asset_management.group_tw_asset_acquisition_confirm"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="1" confirm="Apakah anda yakin ingin cancel akuisisi ini? Semua asset yang sudah dibuat akan di-cancel dan journal depresiasi akan di-reverse."/>
                        <button name="action_set_to_draft" string="Set to Draft" type="object" invisible="state != 'cancel'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_assets" type="object" class="oe_stat_button" icon="fa-building-o" invisible="asset_count == 0">
                                <field string="Assets" name="asset_count" widget="statinfo"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1 class="d-flex">
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="General Information">
                                <field name="company_id" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="date" readonly="1"/>
                                <field name="partner_id" readonly="1"/>
                                <field name="division" readonly="1"/>
                                <field name="note" readonly="state != 'draft'"/>
                            </group>
                            <group string="Good Receive Reference">
                                <field name="good_receive_id" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="good_receive_line_id" string="Product" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="description" readonly="1"/>
                                <field name="product_id" readonly="1" invisible="1"/>
                                <field name="qty" required="1" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <group string="Asset Configuration">
                                <field name="asset_category_id" required="1" options="{'no_create': True}" readonly="state != 'draft'"/>
                                <field name="is_cip" readonly="1" invisible="1"/>
                                <field name="is_final_cip" string="Final CIP" readonly="state != 'draft'" invisible="not is_cip"/>
                                <field name="asset_register_id" options="{'no_create': True}" readonly="state != 'draft'" invisible="not is_cip"/>
                                <field name="employee_user_id" options="{'no_create': True}" readonly="state != 'draft'" string="PIC Asset"/>
                            </group>
                            <group string="Amount Summary">
                                <field name="amount_base" string="Asset Amount" readonly="1"/>
                                <field name="amount_capitalization" readonly="1"/>
                                <field name="amount_total" readonly="1"/>
                                <field name="amount_per_unit" string="Amount per Asset" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Pengguna Asset" name="users">
                                <group>
                                    <group>
                                        <field name="same_user_all" readonly="state != 'draft'"/>
                                        <field name="same_user_employee_id" required="same_user_all" options="{'no_create': True}" readonly="state != 'draft'" invisible="not same_user_all"/>
                                    </group>
                                </group>
                                <div class="alert alert-info" role="alert" invisible="state != 'draft' or same_user_all">
                                    <strong>Info:</strong> Isi data pengguna dan serial number untuk setiap unit asset. 
                                    Jumlah baris harus sama dengan Quantity (<field name="qty" readonly="1" class="fw-bold"/>).
                                </div>
                                <div class="alert alert-success" role="alert" invisible="state != 'draft' or not same_user_all">
                                    <strong>Info:</strong> Pengguna sama untuk semua unit telah dipilih. Data pengguna otomatis terisi.
                                </div>
                                <field name="user_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="employee_id" required="1" options="{'no_create': True}"/>
                                        <field name="serial_number"/>
                                        <field name="asset_id" readonly="1" optional="hide"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Kapitalisasi" name="capitalization">
                                <field name="capitalization_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="good_receive_id" required="1" options="{'no_create': True, 'no_open': True}" domain="[('company_id', '=', parent.company_id), ('state', 'in', ['open', 'done']), ('is_asset', '=', True)]"/>
                                        <field name="good_receive_line_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="product_id" readonly="1"/>
                                        <field name="description"/>
                                        <field name="qty" required="1"/>
                                        <field name="price_unit" readonly="1" optional="hide"/>
                                        <field name="tax_ids" widget="many2many_tags" options="{'no_create': True}" optional="show"/>
                                        <field name="price_subtotal" readonly="1" string="Subtotal"/>
                                        <field name="price_tax" readonly="1" string="Tax" optional="show"/>
                                        <field name="price_total" readonly="1" string="Total"/>
                                        <field name="price" readonly="1" optional="hide"/>
                                        <field name="price_per_unit" readonly="1"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer">
                                    <field name="amount_capitalization" string="Total Kapitalisasi"/>
                                </group>
                            </page>
                            <page string="Assets" name="assets" invisible="asset_count == 0">
                                <field name="asset_ids" readonly="1">
                                    <list create="0" delete="0">
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="serial_number"/>
                                        <field name="employee_user_id" string="Pengguna"/>
                                        <field name="value"/>
                                        <field name="state" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Lampiran" name="attachments">
                                <field name="attachment_ids" nolabel="1" readonly="state != 'draft'"/>
                            </page>
                            <page string="Journal Items" name="account_move" invisible="not move_id">
                                <field name="move_line_ids" readonly="1" force_save="1"/>
                            </page>
                            <page string="Audit Trail" name="audit_trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="cancel_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="cancel_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ===================== -->
        <!-- SEARCH VIEW           -->
        <!-- ===================== -->
        <record id="tw_asset_acquisition_search_view" model="ir.ui.view">
            <field name="name">tw.asset.acquisition.search</field>
            <field name="model">tw.asset.acquisition</field>
            <field name="arch" type="xml">
                <search string="Search Asset Acquisitions">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/>
                    <field name="partner_id" string="Vendor"/>
                    <field name="good_receive_id"/>
                    <field name="product_id"/>
                    <field name="date"/>
                    <separator/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="done" string="Done" domain="[('state', '=', 'done')]"/>
                    <filter name="cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                    <separator/>
                    <filter name="outstanding" string="Outstanding" domain="[('state', 'in', ['draft', 'confirmed'])]"/>
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_company" context="{'group_by': 'company_id'}"/>
                        <filter string="Vendor" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                        <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                        <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_by_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ===================== -->
        <!-- ACTION                -->
        <!-- ===================== -->
        <record id="tw_asset_acquisition_action" model="ir.actions.act_window">
            <field name="name">Asset Acquisition</field>
            <field name="res_model">tw.asset.acquisition</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                'search_default_outstanding': 1,
                'default_division': 'Umum'
            }</field>
            <field name="search_view_id" ref="tw_asset_acquisition_search_view"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Asset Acquisition
                </p>
                <p>
                    Akuisisi Asset digunakan untuk membuat asset dari Good Receive yang sudah dikonfirmasi.
                    Anda bisa menambahkan kapitalisasi dari GR lain dan mengisi data pengguna beserta serial number.
                </p>
            </field>
        </record>

        <record id="tw_asset_acquisition_list_action_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_asset_acquisition_list_view"/>
            <field name="act_window_id" ref="tw_asset_acquisition_action"/>
        </record>

        <record id="tw_asset_acquisition_form_action_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_asset_acquisition_form_view"/>
            <field name="act_window_id" ref="tw_asset_acquisition_action"/>
        </record>

    </data>
</odoo>
