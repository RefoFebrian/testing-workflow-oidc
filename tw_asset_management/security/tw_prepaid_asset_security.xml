<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Prepaid Asset User Group -->
    <record id="group_tw_prepaid_asset_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">The user will have read access to prepaid assets.</field>
    </record>

    <!-- Prepaid Asset Manager Group -->
    <record id="group_tw_prepaid_asset_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">The manager will have full access to prepaid assets.</field>
        <field name="implied_ids" eval="[(4, ref('group_tw_prepaid_asset_user'))]"/>
    </record>

    <!-- Update existing groups to include prepaid assets -->
    <record id="group_account_asset_manager" model="res.groups">
        <field name="name" eval="'Assets / Manager'" />
        <field name="implied_ids" eval="[(4, ref('group_tw_prepaid_asset_manager'))]"/>
    </record>

    <record id="group_account_asset_user" model="res.groups">
        <field name="name" eval="'Assets / User'" />
        <field name="implied_ids" eval="[(4, ref('group_tw_prepaid_asset_user'))]"/>
    </record>
</odoo>
