<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_asset_po_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Confirm Asset PO</field>
        </record>
        <record id="group_tw_asset_generate_depreciation_entries" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Generate Depreciation Entries</field>
        </record>
        <record id="group_tw_asset_acquisition_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Confirm Asset Acquisition</field>
        </record>
    </data>
    
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_asset_po_confirm')),
                (4,ref('group_tw_asset_generate_depreciation_entries')),
                (4,ref('group_tw_asset_acquisition_confirm')),
            ]">
			</field>
		</record>

        <!-- Access Rights for TW Button Confirm Asset Acquisition -->
        <record id="access_tw_asset_acquisition_confirm_write" model="ir.model.access">
            <field name="model_id" ref="tw_asset_management.model_tw_asset_acquisition"/>
            <field name="name">tw_asset_acquisition write for confirm group</field>
            <field name="group_id" ref="group_tw_asset_acquisition_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_depreciation_line_confirm_write" model="ir.model.access">
            <field name="model_id" ref="om_account_asset.model_account_asset_depreciation_line"/>
            <field name="name">account_asset_depreciation_line write/create for confirm group</field>
            <field name="group_id" ref="group_tw_asset_acquisition_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>
    </data>
    

</odoo>
