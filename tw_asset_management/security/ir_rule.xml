<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">            
        <record id="tw_purchase_order_asset_rule" model="ir.rule">
            <field name="name">tw.purchase.order.asset rule</field>
            <field name="model_id" ref="model_purchase_order_asset"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        
        <record id="tw_good_receive_collecting_rule" model="ir.rule">
            <field name="name">tw.good.receive.collecting rule</field>
            <field name="model_id" ref="model_tw_good_receive_collecting"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

         <record id="account_asset_category_multi_company_rule" model="ir.rule">
            <field name="name">Account Asset Category multi-company</field>
            <field ref="model_account_asset_category" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force"> ['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]</field>
        </record>

        <record id="tw_good_receive_rule" model="ir.rule">
            <field name="name">tw.good.receive rule</field>
            <field name="model_id" ref="model_tw_good_receive"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_asset_acquisition_rule" model="ir.rule">
            <field name="name">tw.asset.acquisition rule</field>
            <field name="model_id" ref="model_tw_asset_acquisition"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

    </data>
 </odoo>
 