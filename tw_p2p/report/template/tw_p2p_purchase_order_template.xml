<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="p2p_purchase_order_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="tw_web.teto_report_layout">
                    <div class="page">
                        <style>
                            table {
                                border-collapse: collapse;
                            }
                            table tr th {
                                border: 1px solid #000;
                                padding: 2px;
                                font-weight: bolder;
                                text-align: center
                            }
                            table tr td {
                                border: 1px solid #000;
                                padding: 3px;
                            }
                        </style>
                        <div class="oe_structure"/>

                        <div class="row">
                            <div class="col-6 ps-1">
                                <div class="row">
                                    <div class="col-12"><strong><span t-field="o.company_id.name"/></strong></div>
                                </div>
                                <div class="row">
                                    <div class="col-12"><span t-esc="print_address(o.company_id.partner_id)"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-4">No. NPWP</div>
                                    <div class="col-8">: &#160;<span t-field="o.company_id.vat"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-4">Tgl Pengukuhan</div>
                                    <div class="col-8">: &#160;<span t-field="o.company_id.establishment_date" t-options='{"format": "dd-MM-yyyy"}'/></div>
                                </div>
                            </div>
                            <div class="col-1"/>
                            <div class="col-5 pe-1">
                                <div class="row">
                                    <div class="col-12"><strong>P2P</strong></div>
                                </div>
                                <div class="row">
                                    <div class="col-4">No</div>
                                    <div class="col-8">: &#160;<span t-field="o.name"/></div>
                                </div>
                                <div class="row">
                                    <div class="col-12"><strong><span t-field="o.dealer_id.name"/></strong></div>
                                </div>
                                <div class="row">
                                    <div class="col-12"><span t-esc="print_address(o.dealer_id)"/></div>
                                </div>
                            </div>
                        </div>

                        <br/>
                        <div class="row p-0 mb-4" style="border: 1px solid #000;">
                            <div class="col-12">
                                <table style="width: 100%; border-bottom: 1px solid #000;" class="table-borderless">
                                    <tr>
                                        <td style="width: 5%; padding-left: 5px;">Type</td>
                                        <td style="width: 45%;">: &#160;<span t-field="o.purchase_order_type_id.name"/></td>
                                        <td style="width: 10%; border-left: 1px solid black; padding-left: 5px;">Tanggal</td>
                                        <td style="width: 40%;">: &#160;<span t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding-left: 5px;">Dealer</td>
                                        <td>: &#160;<span t-field="o.dealer_id.name"/></td>
                                        <td style="border-left: 1px solid black;"></td>
                                        <td></td>
                                    </tr>
                                </table>
                                <div class="row">
                                    <t t-if="o.type_name == 'Additional'">
                                        <table>
                                            <thead>
                                                <tr>
                                                    <th style="width: 5%;">No</th>
                                                    <th>Type</th>
                                                    <th>Description</th>
                                                    <th>Quantity</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-set="index_no" t-value="1"/>
                                                <t t-set="total_qty" t-value="0"/>
                                                <t t-foreach="o.additional_line_ids" t-as="line">
                                                    <tr>
                                                        <td class="text-center"><span t-esc="index_no"/></td>
                                                        <td class="text-start"><span t-field="line.product_id.default_code"/></td>
                                                        <td class="text-start">
                                                            <span t-field="line.product_id.product_tmpl_id.name"/>
                                                            <t t-foreach="line.product_id.product_template_attribute_value_ids" t-as="attribute_value">
                                                                <t t-if="attribute_value.attribute_id.name == 'Color'">
                                                                    <span> (<t t-esc="attribute_value.name"/>)</span>
                                                                </t>
                                                            </t>
                                                        </td>
                                                        <td class="text-end"><span t-field="line.fix_qty"/></td>
                                                    </tr>
                                                    <t t-set="total_qty" t-value="total_qty + (line.fix_qty or 0)"/>
                                                    <t t-set="index_no" t-value="index_no + 1"/>
                                                </t>
                                                <tr style="border-top:1px solid #000;">
                                                    <td colspan="3" class="text-end"><strong>Total</strong></td>
                                                    <td class="text-end"><strong><span t-esc="total_qty"/></strong></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </t>

                                    <t t-elif="o.type_name == 'Fix'">
                                        <table>
                                            <thead>
                                                <tr>
                                                    <th style="width: 5%;">No</th>
                                                    <th>Kode</th>
                                                    <th>Description</th>
                                                    <t t-if="o.division == 'Sparepart'">
                                                        <th>Tent 1 Qty (Prev)</th>
                                                        <th>Fix Qty</th>
                                                        <th>Tent 2 Qty (Prev)</th>
                                                        <th>Tent 1 Qty</th>
                                                        <th>Tent 2 Qty</th>
                                                    </t>
                                                    <t t-elif="o.division == 'Unit'">
                                                        <th>Fix Qty</th>
                                                    </t>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-set="index_no" t-value="1"/>
                                                <t t-set="total_tent1_prev" t-value="0"/>
                                                <t t-set="total_fix_qty" t-value="0"/>
                                                <t t-set="total_tent2_prev" t-value="0"/>
                                                <t t-set="total_tent1" t-value="0"/>
                                                <t t-set="total_tent2" t-value="0"/>

                                                <t t-foreach="o.purchase_line_ids" t-as="line">
                                                    <tr>
                                                        <td class="text-center"><span t-esc="index_no"/></td>
                                                        <td class="text-start"><span t-field="line.product_id.default_code"/></td>
                                                        <td class="text-start">
                                                            <span t-field="line.product_id.product_tmpl_id.name"/>
                                                            <t t-foreach="line.product_id.product_template_attribute_value_ids" t-as="attribute_value">
                                                                <t t-if="attribute_value.attribute_id.name == 'Color'">
                                                                    <span> (<t t-esc="attribute_value.name"/>)</span>
                                                                </t>
                                                            </t>
                                                        </td>
                                                        <t t-if="o.division == 'Sparepart'">
                                                            <td class="text-end"><span t-field="line.tent1_prev_qty"/></td>
                                                            <td class="text-end"><span t-field="line.fix_qty"/></td>
                                                            <td class="text-end"><span t-field="line.tent2_prev_qty"/></td>
                                                            <td class="text-end"><span t-field="line.tent1_qty"/></td>
                                                            <td class="text-end"><span t-field="line.tent2_qty"/></td>
                                                        </t>
                                                        <t t-elif="o.division == 'Unit'">
                                                            <td class="text-end"><span t-field="line.fix_qty"/></td>
                                                        </t>
                                                        
                                                    </tr>

                                                    <t t-set="total_tent1_prev" t-value="total_tent1_prev + (line.tent1_prev_qty or 0)"/>
                                                    <t t-set="total_fix_qty" t-value="total_fix_qty + (line.fix_qty or 0)"/>
                                                    <t t-set="total_tent2_prev" t-value="total_tent2_prev + (line.tent2_prev_qty or 0)"/>
                                                    <t t-set="total_tent1" t-value="total_tent1 + (line.tent1_qty or 0)"/>
                                                    <t t-set="total_tent2" t-value="total_tent2 + (line.tent2_qty or 0)"/>
                                                    <t t-set="index_no" t-value="index_no + 1"/>
                                                </t>

                                                <tr style="border-top:1px solid #000;">
                                                    <th colspan="3" class="text-end">Total</th>
                                                    <t t-if="o.division == 'Sparepart'">
                                                        <th class="text-end"><span t-esc="total_tent1_prev"/></th>
                                                        <th class="text-end"><span t-esc="total_fix_qty"/></th>
                                                        <th class="text-end"><span t-esc="total_tent2_prev"/></th>
                                                        <th class="text-end"><span t-esc="total_tent1"/></th>
                                                        <th class="text-end"><span t-esc="total_tent2"/></th>
                                                    </t>
                                                    <t t-elif="o.division == 'Unit'">
                                                        <th class="text-end"><span t-esc="total_fix_qty"/></th>
                                                    </t>
                                                    
                                                </tr>
                                            </tbody>
                                        </table>
                                    </t>
                                </div>
                            </div>
                        </div>

                        
                        <div class="oe_structure">
                            <table style="width: 100%;" class="table-borderless">
                                <tr>
                                    <td width="5.00%"></td>
                                    <td style="font-size: 12;"><span t-esc="print_employee(o.create_uid.id)"/>,</td>
                                </tr>
                                <tr><td colspan="2" style="height:80px;"></td></tr>
                                <tr>
                                    <td width="5.00%"></td>
                                    <td>_______________________</td>
                                </tr>
                                <tr>
                                    <td></td>
                                    <td style="font-size: 12;"> <span t-esc="print_user()"/>, <span t-esc="time_date(o.date)"/></td>
                                </tr>
                                <tr>
                                    <td></td>
                                    <td style="font-size: 12;">Cetakan Ke : &#160;<span t-esc="print_counter()"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>