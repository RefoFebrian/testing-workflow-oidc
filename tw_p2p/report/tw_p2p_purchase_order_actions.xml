<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_p2p_purchase_order" model="ir.actions.report">
            <field name="name">P2P Purchase Order Report</field>
            <field name="model">tw.p2p.purchase.order</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_p2p.p2p_purchase_order_report</field>
            <field name="report_file">tw_p2p.p2p_purchase_order_report</field>
            <field name="print_report_name">'P2P_Purchase_Order_%s.pdf' % (object.name)</field>
            <field name="domain">[('state', '=', 'confirmed')]</field>
            <field name="paperformat_id" ref="tw_web.tw_report_paperformat_a4"/>
        </record>
        
    </data>
</odoo>
