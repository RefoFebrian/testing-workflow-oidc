<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    	
        <record id="view_tw_p2p_periode_tree" model="ir.ui.view">
            <field name="name">tw.p2p.periode.line.tree</field>
            <field name="model">tw.p2p.periode</field>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <list string="P2P Periode" create="true" editable="top">
                    <field name="active"/>
                    <field name="name" required="1" placeholder="Contoh : 201505" />
                    <field name="start_date" required="1"/>
                    <field name="end_date" required="1"/>
                    <field name="periode_start_date" required="1"/>
                    <field name="periode_end_date" required="1"/>                    
                </list>
            </field>
        </record>    	
 
		<record model="ir.ui.view" id="tw_p2p_periode_form_view">
		    <field name="name">tw.p2p.periode.form</field>
		    <field name="model">tw.p2p.periode</field>
		    <field name="arch" type="xml">
		        <form string="P2P Periode">	        	
		        	<sheet>
			        	<div class="oe_title">
			        		<h2>
				                <label for="name" string="P2P Periode"/>    			
			 				</h2>
			        	</div>       
						<group>   
							<group colspan="2">
								<field name="active"/>
								<field name="name" required="1" placeholder="Contoh : 201505" />
							</group>            
	                    	<group>
                    			<field name="start_date" required="1" />                  			
                    			<field name="end_date" required="1" ></field>
							</group>  
	                    	<group>
                    			<field name="periode_start_date" required="1" />                  			
                    			<field name="periode_end_date" required="1" ></field>
							</group> 							
						</group>	
						
						<notebook colspan="5">
							<page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
									</group>
									<group>							
										<field name="write_uid" readonly="1"></field>
										<field name="write_date" readonly="1"></field>
									</group>
								</group>
							</page>			                    
		                </notebook>				
		           </sheet>
		        </form>
		    </field>
		</record>

 		<record id="view_tw_p2p_periode_filter" model="ir.ui.view">
            <field name="name">p2p.config.list.select</field>
            <field name="model">tw.p2p.periode</field>
            <field name="arch" type="xml">
                <search string="Search P2P Periode">
                    <field name="name"/>
					<field name="start_date"/>
					<field name="end_date"/>
					<field name="periode_start_date"/>
					<field name="periode_end_date"/>
					<filter string="Active" name="filter_active" domain="[('active','=', True)]"/>
					<filter string="Inactive" name="filter_inactive" domain="[('active','=', False)]"/>
					<group expand="0" string="Group By">
						<filter name="name" string="Name" context="{'group_by': 'name'}" />
						<filter name="start_date" string="Start Date" context="{'group_by': 'start_date'}" />
						<filter name="end_date" string="End Date" context="{'group_by': 'end_date'}" />
						<filter name="periode_start_date" string="Periode Start Date" context="{'group_by': 'periode_start_date'}" />
						<filter name="periode_end_date" string="Periode End Date" context="{'group_by': 'periode_end_date'}" />
					</group>
                </search>
            </field>
        </record>		
		<record model="ir.actions.act_window" id="tw_p2p_periode_action">
		    <field name="name">P2P Periode</field>
		    <field name="res_model">tw.p2p.periode</field>
		    <field name="view_mode">list,form</field>
			<field name="context">{'search_default_filter_active': True}</field>
			<field name="domain">[('active', 'in', [True, False])]</field>
		    <field name="search_view_id" ref="view_tw_p2p_periode_filter"/>
		</record>
					
		
    </data>
</odoo>
    