<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    	
        <record id="view_tw_p2p_category_fix_order_list" model="ir.ui.view">
            <field name="name">tw.p2p.category.fix.order.list</field>
            <field name="model">tw.p2p.category.fix.order</field>
            <field eval="1" name="priority"/>
            <field name="arch" type="xml">
                <list string="Category Fix Order" create="true" editable="top">
					<field name="active"/>
                	<field name="name" required="1"/>               	
                </list>
            </field>
        </record>    	
 
		<record model="ir.ui.view" id="view_tw_p2p_category_fix_order_form">
		    <field name="name">tw.p2p.category.fix.order.form</field>
		    <field name="model">tw.p2p.category.fix.order</field>
		    <field name="arch" type="xml">
		        <form string="Category Fix Order">	        	
		        	<sheet>
						<field name="active"/>
			        	<div class="oe_title">
			        		<h2>
				                <label for="name" string="Category Fix Order"/>    			
			 				</h2>
			        	</div>       
						<group>   
							<group colspan="2">
								<field name="name" required="1"/>
							</group>            
						</group>	
						
						<notebook colspan="5">
							<page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
									</group>
									<group>								
										<field name="write_uid" readonly="1"></field>
										<field name="write_date" readonly="1"></field>
									</group>
								</group>
							</page>			                    
		                </notebook>				
		           </sheet>
		        </form>
		    </field>
		</record>

 		<record id="view_tw_p2p_category_fix_order_filter" model="ir.ui.view">
            <field name="name">tw.p2p.category.fix.order.search</field>
            <field name="model">tw.p2p.category.fix.order</field>
            <field name="arch" type="xml">
                <search string="Search Category Fix Order">
                    <field name="name"/> 
					<filter string="Active" name="filter_active" domain="[('active','=', True)]"/>
					<filter string="Inactive" name="filter_inactive" domain="[('active','=', False)]"/>
					<filter name="name" string="Name" domain="[('name', '=', 'value')]" context="{'group_by': 'name'}" />
                </search>
            </field>
        </record>		
		<record model="ir.actions.act_window" id="tw_p2p_category_fix_order_action">
		    <field name="name">Category Fix Order</field>
		    <field name="res_model">tw.p2p.category.fix.order</field>
		    <field name="view_mode">list,form</field>
		    <field name="context">{'search_default_filter_active': True}</field>
			<field name="domain">[('active', 'in', [True, False])]</field>
		    <field name="search_view_id" ref="view_tw_p2p_category_fix_order_filter"/>
		</record>
				
		
    </data>
</odoo>
    
