<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="tw_p2p_product_import_wizard_form_view" model="ir.ui.view">
            <field name="name">Import P2P Product - TEDS 2.0</field>
            <field name="model">tw.p2p.product.import</field>
            <field name="arch" type="xml">
                <form string="Import P2P Product - TEDS 2.0 Format">
                    <!-- Choose State -->
                    <group invisible="state != 'choose'">
                        <group>
                            <separator string="Format File Excel:" colspan="2"/>
                            <div colspan="2">
                                <p><b>Kolom yang diperlukan:</b></p>
                                <ul>
                                    <li><b>A - Product Code:</b> Kode produk (contoh: JZ1, KG0)</li>
                                    <li><b>B - Color Code:</b> Kode warna (contoh: BL, GR, MH)</li>
                                    <li><b>C - Start Date:</b> Tanggal mulai (DD/MM/YYYY)</li>
                                    <li><b>D - End Date:</b> Tanggal akhir (DD/MM/YYYY)</li>
                                </ul>
                            </div>
                        </group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="division"/>
                            <field name="filename" invisible="1"/>
                            <field name="file" filename="filename" string="Upload File Excel"/>
                        </group>
                    </group>

                    <!-- Preview State -->
                    <group invisible="state != 'preview'">
                        <separator string="Preview Data Import (10 data pertama):" colspan="4"/>
                        <field name="preview_data" nolabel="1" colspan="4"/>
                    </group>

                    <!-- Done State -->
                    <group invisible="state != 'done'">
                        <separator string="Hasil Import:" colspan="4"/>
                        <field name="import_result" nolabel="1" colspan="4" readonly="1"/>
                    </group>

                    <field name="state" invisible="1"/>

                    <!-- Footer Buttons -->
                    <footer>
                        <button name="action_preview" string="Preview" type="object" class="btn-secondary" invisible="state != 'choose'"/>
                        <button name="action_import" string="Import" type="object" class="oe_highlight" invisible="state != 'preview'"/>
                        <button name="action_back" string="Kembali" type="object" class="btn-secondary" invisible="state != 'preview'"/>
                        <button string="Tutup" class="btn-secondary" special="cancel" invisible="state != 'done'"/>
                        <button string="Batal" class="oe_link" special="cancel" invisible="state == 'done'"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Server Action for Gear Menu -->
        <record id="action_tw_p2p_product_import_server" model="ir.actions.server">
            <field name="name">Import with TEDS 2.0 Format</field>
            <field name="model_id" ref="tw_p2p.model_tw_p2p_product"/>
            <field name="binding_model_id" ref="tw_p2p.model_tw_p2p_product"/>
            <field name="binding_view_types">form,list</field>
            <field name="state">code</field>
            <field name="code">
action = {
    'name': 'Import P2P Product - TEDS 2.0 Format',
    'type': 'ir.actions.act_window',
    'res_model': 'tw.p2p.product.import',
    'view_mode': 'form',
    'target': 'new',
}
            </field>
        </record>

        <!-- Act Window for Header Button -->
        <record id="action_tw_p2p_product_import_act_window" model="ir.actions.act_window">
            <field name="name">Import P2P Product - TEDS 2.0</field>
            <field name="res_model">tw.p2p.product.import</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    </data>
</odoo>
