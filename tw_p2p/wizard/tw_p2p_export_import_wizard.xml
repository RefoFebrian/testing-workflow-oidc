<?xml version='1.0' encoding='utf-8'?>
<odoo>
	<data>
		<record id="tw_p2p_purchase_order_export_import_wizard_form_view" model="ir.ui.view">
            <field name="name">Export / Import P2P</field>
            <field name="model">tw.p2p.export.import</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form col="4" string="Export / Import">
                    <!-- Upload State -->
                    <group colspan="4" col="4" invisible="state_x not in ('choose',)">
                        <label for="file" string="Lakukan Export File terlebih dahulu"/>
                        <group colspan="2">
                            <field name="purchase_order_type_id" options="{'no_create': True,'no_open': True}" readonly="1"/>
                            <field name="filename" invisible="1"/>
                            <field name="file" filename="filename" string="Upload File"/>
                        </group>
                        <group colspan="2">
                            <field name="upload_date" string="Tanggal" readonly="1"/>
                            <label for="action_export" string="Template Import"/>
                            <div>                   
                                <button name="action_export" type="object" class="oe_highlight" string="Export P2P"/>
                            </div>
                        </group>                            
                    </group>
                    
                    <!-- Preview State -->
                    <group colspan="4" invisible="state_x != 'preview'">
                        <separator colspan="4" string="Preview Data Import (5 data pertama):"/>
                        <field name="preview_data" nolabel="1" colspan="4"/>
                    </group>
                    
                    <field invisible="1" name="state_x"/>                
                    <newline/>    
                    
                    <!-- Result State -->
                    <group col="4" fill="0" invisible="state_x != 'get'">
                        <separator colspan="4" string="Hasil Update data P2P:"/>
                        <div class="oe_title">
                            <h3>
                                <field name="message" readonly="1" class="oe_inline" style="margin-right: 5px; color:#7c7bad;"/>
                            </h3>
                        </div>
                    </group>
                    
                    <!-- Footer Buttons -->
					<footer invisible="state_x == 'get'">
					    <!-- Choose state: Preview button -->
	                    <button name="action_preview" string="Preview" type="object" class="btn-secondary" invisible="state_x != 'choose'"/>
	                    <!-- Preview state: Import and Back buttons -->
	                    <button name="action_import" string="Import" type="object" class="oe_highlight" invisible="state_x != 'preview'"/>
	                    <button name="action_back" string="Kembali" type="object" class="btn-secondary" invisible="state_x != 'preview'"/>
	                    or 
	                    <button string="Cancel" class="oe_link" special="cancel"/>
	                </footer>
                </form>
            </field>
        </record>
                      
    	<record model="ir.actions.act_window" id="tw_p2p_export_import_wizard_action">
		    <field name="name">Export / Import P2P</field>
		    <field name="res_model">tw.p2p.export.import</field>
		    <field name="view_mode">form</field>
		    <field name="target">new</field>
		</record>
		
       	
	</data>
</odoo>