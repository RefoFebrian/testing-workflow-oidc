<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="group_tw_report_intransit_purchase_showroom" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan Intransit Purchase Showroom</field>
        </record>
        
        <record id="group_tw_report_intransit_purchase_workshop" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan Intransit Purchase Workshop</field>
        </record>

        <record id="access_tw_report_intransit_purchase_showroom" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_intransit_purchase" />
            <field name="name">tw_report_intransit_purchase_showroom</field>
            <field name="group_id" ref="group_tw_report_intransit_purchase_showroom" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_report_intransit_purchase_workshop" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_intransit_purchase" />
            <field name="name">tw_report_intransit_purchase_workshop</field>
            <field name="group_id" ref="group_tw_report_intransit_purchase_workshop" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_report_intransit_purchase_showroom')),
				(4,ref('group_tw_report_intransit_purchase_workshop')),
			]"/> 
		</record>

    </data>

</odoo>