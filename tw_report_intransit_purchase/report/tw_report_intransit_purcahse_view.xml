<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_report_intransit_purchase_view_wizard" model="ir.ui.view">
            <field name="name">Report Journal</field>
            <field name="model">tw.report.intransit.purchase</field>
            <field name="arch" type="xml">
               <form string="Intransit Purchase Report">
					<group >
						<group>
							<field name="options" required="1"/>
							<field name="division_showroom" string="Division"
								invisible="not context.get('is_showroom',False) or options != 'detail'" />
							<field name="division_workshop" string="Division"
								invisible="not context.get('is_workshop',False) or options != 'detail'" />
						</group>
						<group>
							<label for="start_date" string="Tanggal"/>	
							<div>
								<field name="start_date" class="oe_inline" required="1"/> - <field name="end_date" class="oe_inline" required="1"/>
							</div>
						</group>
					</group>
			          
			        <notebook colspan="5" >
				        <page string="Branch">
                            <field name="company_ids">
                                <list editable="top">
                                    <field name="name" string="Branch"/>
                                </list>
                            </field>
                        </page>
						<page string="Partners" invisible="options != 'detail'">
							<field name="partner_ids" colspan="4" nolabel="1" options="{'no_create': True}"/>
						</page>
			        </notebook>

                    <footer>
                        <button name="excel_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	    <record id="action_report_intransit_purchase_wizard_showroom" model="ir.actions.act_window">
			<field name="name">Laporan Intransit Beli</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">tw.report.intransit.purchase</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="tw_report_intransit_purchase_view_wizard"/>
			<field name="target">new</field>
			<field name="context">
				{'is_showroom':True}
			</field>
	    </record>

	    <record id="action_report_intransit_purchase_wizard_workshop" model="ir.actions.act_window">
	      <field name="name">Laporan Intransit Beli</field>
	      <field name="type">ir.actions.act_window</field>
	      <field name="res_model">tw.report.intransit.purchase</field>
	      <field name="view_mode">form</field>
	      <field name="view_id" ref="tw_report_intransit_purchase_view_wizard"/>
	      <field name="target">new</field>
		  <field name="context">
				{'is_workshop':True}
			</field>
	    </record>
		 	
    </data>
</odoo>
