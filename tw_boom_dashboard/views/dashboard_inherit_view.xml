<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Dashboard Form View -->
    <record id="dashboard_dashboard_form_view_inherit" model="ir.ui.view">
        <field name="name">dashboard.dashboard.form.view.inherit</field>
        <field name="model">dashboard.dashboard</field>
        <field name="inherit_id" ref="synconics_bi_dashboard.dashboard_dashboard_form_view"/>
        <field name="arch" type="xml">
            <!-- Add Header Domain in the first group -->
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="header_domain" placeholder="e.g. [('state', '!=', 'cancel')]"/>
            </xpath>

            <!-- Add Access Group Domains Page -->
            <xpath expr="//notebook" position="inside">
                <page string="Dynamic Access Rules" name="dynamic_access">
                    <group string="Access Group Domains">
                        <field name="access_line_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="group_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="domain" placeholder="[('field', '=', user.variable)]"/>
                            </list>
                        </field>
                    </group>
                    <div class="alert alert-info" role="alert" style="margin-top: 10px;">
                        <p><strong>Note:</strong> These domains are appended to <strong>all</strong> charts in this dashboard using an <code>AND</code> operation. You can use dynamic variables like <code>user</code>, <code>context</code>, and <code>uid</code>.</p>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
