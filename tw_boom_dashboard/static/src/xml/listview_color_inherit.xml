<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <!-- Extend base ListView to add column color styling -->
    <t t-name="tw_boom_dashboard.ListViewColor" t-inherit="synconics_bi_dashboard.ListView" t-inherit-mode="extension">
        <!-- Add color to header cells -->
        <xpath expr="//th[@t-foreach='this.state.columns']" position="attributes">
            <attribute name="t-att-style">'position: sticky; top: 0; background: white; z-index: 2; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);' + (column.color and column.color != '#000000' ? ' color: ' + column.color + ';' : '')</attribute>
        </xpath>
        
        <!-- Add color to data cells -->
        <xpath expr="//td[@t-foreach='this.state.columns']" position="attributes">
            <attribute name="t-att-style">column.color and column.color != '#000000' ? 'color: ' + column.color + ';' : ''</attribute>
        </xpath>
    </t>

</templates>
