<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- ========================================== -->
    <!-- KPI LAYOUT OVERRIDES (1-5)                 -->
    <!-- ========================================== -->

    <t t-inherit="synconics_bi_dashboard.KpiLayoutOne" t-inherit-mode="extension" owl="1">
        <xpath expr="//span[contains(@class, 'oe_name')]" position="attributes">
            <attribute name="t-att-style">
                'font-size:' + (state.data.header_font_size || 22) + 'px; ' + 
                'color:' + (state.data.header_font_color || state.data.font_color) + ';'
            </attribute>
        </xpath>
        <xpath expr="//div[@class='h5 mb-1 text-gray-800']/span" position="attributes">
            <attribute name="t-att-style">
                'font-size:' + state.data.font_size + 'px; ' + 
                'color:' + state.data.font_color + ';' + 
                'font-weight:' + (state.data.font_weight_bold || 700) + ';' +
                'font-style:' + (state.data.font_style || 'normal') + ';'
            </attribute>
        </xpath>
    </t>

