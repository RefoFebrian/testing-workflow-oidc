<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="tw_boom_dashboard.QuoteChart" owl="1">
        <div class="quote_chart_container d-flex flex-column justify-content-center h-100" 
             t-att-class="'align-items-' + (props.record.text_align === 'right' ? 'end' : (props.record.text_align === 'left' ? 'start' : 'center'))"
             t-att-style="'background-color:' + (props.record.background_color || 'transparent') + '; padding: 20px; border-radius: 8px;'">
            <div class="quote-content mb-2" t-att-style="'text-align:' + (props.record.text_align || 'center')">
                <strong t-att-style="'color:' + (props.record.font_color || '#000') + '; font-size:' + (props.record.font_size || 20) + 'px; font-style:' + (props.record.font_style || 'italic') + '; font-weight:' + (props.record.font_weight_bold || props.record.font_weight || 400) + '; font-family:' + (props.record.font_family || 'Arial') + ';'">
                    "<span t-esc="state.content"/>"
                </strong>
            </div>
            <div class="quote-author" t-if="state.author" t-att-style="'text-align:' + (props.record.text_align || 'center')">
                <small t-esc="'- ' + state.author" t-att-style="'color:' + (props.record.font_color || '#000') + '; opacity: 0.8; font-size: 14px; font-family:' + (props.record.font_family || 'Arial') + ';'"/>
            </div>
        </div>
    </t>
</templates>
