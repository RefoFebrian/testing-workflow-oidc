<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_work_order_form_inherit_view" model="ir.ui.view">
            <field name="name">tw.work.order.form.inherit.view</field>
            <field name="model">tw.work.order</field>
            <field name="inherit_id" ref="tw_work_order.tw_work_order_form_view"/>
            <field name="arch" type="xml">

                <!-- Add alert in the sheet after the title -->
                <xpath expr="//field[@name='lot_id']" position="before">
                    <field name="is_not_handover" invisible="1"/>
                    <div class="alert alert-info" role="alert" invisible="not is_not_handover">
                        <i class="fa fa-info-circle me-2 oe_inline" title="Perhatian"/>
                        <strong class="oe_inline">Perhatian : </strong>
                        <field name="notif_msg" readonly="1" nolabel="1" class="oe_inline"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
