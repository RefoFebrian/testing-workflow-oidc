<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Upload Wizard Form View -->
        <record id="wizard_tw_upload_payment_request_form" model="ir.ui.view">
            <field name="name">wizard.tw.upload.payment.form</field>
            <field name="model">tw.payment.request.upload</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group colspan="4" col="4">
                            <group colspan="2">
                                <field name="payment_id" readonly="1" required="1"/>
                                <field name="filename" invisible="1"/>
                                <field name="file" filename="filename" string="Upload File"/>
                            </group>
                            <group colspan="2">
                                <label for="action_download_format_file" string="Contoh File"/>
                                <div>
                                    <button name="action_download_format_file" type="object" class="oe_highlight" icon="fa-download" string="Download Contoh"/>
                                </div>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_import_file" string="Import" type="object" class="oe_highlight"/>
                        <button special="cancel" string="Cancel" class="oe_link"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
