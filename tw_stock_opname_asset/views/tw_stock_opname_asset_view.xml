<?xml version='1.0' encoding='utf-8'?>
<odoo>

    <data>
		<record id="view_tw_stock_opname_asset_list" model="ir.ui.view">
			<field name="name">tw.stock.opname.asset.list</field>
			<field name="model">tw.stock.opname.asset</field>
			<field name="arch" type="xml">
				<list string="Stock Opname Asset">
					<field name="name"/>
					<field name="company_id"/>
					<field name="date"/>
					<field name="generate_date"/>
					<field name="state"/>
				</list>
			</field>
		</record>
		
		<record id="view_tw_stock_opname_asset_form" model="ir.ui.view">
			<field name="name">tw.stock.opname.asset.form</field>
			<field name="model">tw.stock.opname.asset</field>
			<field name="arch" type="xml">
				<form string="Stock Opname Asset">
					<header>
	                	<button name="action_generate_stock" invisible="not create_date or generate_date" string="Generate Stock" class="oe_highlight" type="object" groups="tw_stock_opname_asset.group_tw_so_asset_generate_stock_button"/>
	                	<button name="action_post" invisible="state != 'draft'" string="Post" class="oe_highlight" type="object" confirm="Harap pastikan kembali validasi asset sudah sesuai antara fisik dan sitem ! Untuk asset yang tidak tercatat dalam sistem wajib diisi pada kolom Asset Tidak Tercatat Sistem !!!" groups="tw_stock_opname_asset.group_tw_so_asset_posted_button"/>
	                	<button name="action_print_validasi" invisible="state != 'posted'" string="Print Validasi" class="oe_highlight" type="object"/>
	                	<button name="action_bakso" invisible="state != 'posted'" string="Berita Acara SO" type="object"/>
	                	<button name="action_download_excel" type="object" string="Download Excel" invisible="not generate_date"/>
	                	<field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,posted"/>
	                </header>
					<sheet>
						<div class="oe_title">                      
							<h1>
							<field name="name" readonly="1"/>
						</h1>
					</div>
					<group>
						<group>
							<field name="company_id" options="{'no_open':True,'no_create':True}" readonly="create_date" required="1"/>
							<field name="create_date" invisible="1"/>
							<field name="pdi_id" options="{'no_open':True,'no_create':True}" required="1" readonly="state != 'draft'"/>
							<field name="adh_id" options="{'no_open':True,'no_create':True}" required="1" readonly="state != 'draft'"/>
							<field name="soh_id" options="{'no_open':True,'no_create':True}" required="1" readonly="state != 'draft'"/>
							<field name="generate_date" readonly="1" invisible="not generate_date"/>
						</group>
						<group>
							<field name="division" readonly="1" force_save="1"/>
							<field name="date" readonly="1"/>
							<field name="is_pilot" invisible="1" readonly="1"/>
							<field name="category" required="1" readonly="generate_date"/>
							<field name="state_asset" required="1" readonly="generate_date"/>
						</group>
					</group>
					<notebook>
						<page string="Data Stock Asset">
							<field name="detail_ids" nolabel="1" readonly="state != 'draft'">
								<list create="false" delete="false">
									<field name="code" readonly="1"/>
									<field name="register_no" readonly="1"/>
									<field name="name" readonly="1"/>
									<field name="category" readonly="1"/>
									<field name="physical_validation" required="physical_validation or asset_status"/>
									<field name="asset_status" required="physical_validation or asset_status"/>
									<field name="pic_validation_id" options="{'no_open':True,'no_create':True}" required="physical_validation or asset_status"/>
									<field name="validation_location_id" options="{'no_open':True,'no_create':True}" required="physical_validation or asset_status"/>
									<field name="physical_condition" required="physical_validation or asset_status"/>
									<field name="engine_no" readonly="category != 'V'" required="physical_validation and asset_status and category == 'V'"/>
									<field name="description" required="physical_validation == 'fisik_tidak_ada' or asset_status == 'tidak_diketahui'"/>
									<field name="upload_image" widget="image" options="{'size': [100, 100]}" filename="filename_image"/>
									<field name="filename_image" invisible="1"/>
								</list>
							</field>
						</page>
						<page string="Asset Tidak Tercatat Sistem" invisible="not generate_date">
							<field name="other_asset_ids" nolabel="1" readonly="state != 'draft'">
								<list editable="top">
									<field name="name" required="1"/>
									<field name="physical_location" required="1"/>
									<field name="physical_condition" required="1"/>
									<field name="pic_asset_id" options="{'no_open':True,'no_create':True}" required="1"/>
									<field name="engine_no"/>
									<field name="description" required="physical_location in ('Tidak Ada', 'Hilang')"/>
								</list>
							</field>
						</page>
						<page string="Upload Dokumen" invisible="not is_pilot">
							<field name="attachment_ids" nolabel="1" readonly="state != 'draft'"/>
						</page>
						<page name="audit_trail" string="Audit Trail">
							<group>
								<group>
									<field name="create_uid" readonly="1"/>
									<field name="create_date" readonly="1"/>
									<field name="post_uid" readonly="1" invisible="not post_uid"/>
									<field name="post_date" readonly="1" invisible="not post_date"/>
								</group>
								<group>							
									<field name="write_uid" readonly="1"/>
									<field name="write_date" readonly="1"/>
								</group>
							</group>
						</page>		                 
					</notebook>
					</sheet>
				</form>
			</field>
		</record>

		<record id="view_tw_stock_opname_asset_search" model="ir.ui.view">
            <field name="name">tw.stock.opname.asset.list.select</field>
            <field name="model">tw.stock.opname.asset</field>
            <field name="arch" type="xml">
                <search string="Search Stock Opname Asset">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/>
                    <field name="division"/>
					<field name="pdi_id" />
					<field name="adh_id" />
					<field name="soh_id" />
					<field name="detail_ids" string="Kode Asset" filter_domain="[('detail_ids.code','ilike', self)]"/>
					<field name="detail_ids" string="Register No" filter_domain="[('detail_ids.register_no','ilike', self)]"/>
					<field name="detail_ids" string="Nama Asset" filter_domain="[('detail_ids.name','ilike', self)]"/>
					<field name="detail_ids" string="Kategory" filter_domain="[('detail_ids.category','ilike', self)]"/>
					<field name="detail_ids" string="Validasi Fisik" filter_domain="[('detail_ids.physical_validation','ilike', self)]"/>
					<field name="detail_ids" string="Status Asset" filter_domain="[('detail_ids.asset_status','ilike', self)]"/>
					<field name="detail_ids" string="PIC Asset" filter_domain="[('detail_ids.pic_validation_id','ilike', self)]"/>
					<field name="detail_ids" string="Lokasi Validasi" filter_domain="[('detail_ids.validation_location_id','ilike', self)]"/>
					<field name="detail_ids" string="Kondisi Mesin" filter_domain="[('detail_ids.physical_condition','ilike', self)]"/>
					<field name="detail_ids" string="No. Mesin" filter_domain="[('detail_ids.engine_no','ilike', self)]"/>
					<field name="detail_ids" string="Keterangan" filter_domain="[('detail_ids.description','ilike', self)]"/>
					<filter name="draft" string="Draft" domain="[('state', '=', 'draft')]" />
					<filter name="posted" string="Posted" domain="[('state', '=', 'posted')]" />
					<group string="Group By" name="groupby">
                        <filter name="group_by_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_generate_date" string="Generate Date" context="{'group_by': 'generate_date'}"/>
                        <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
						<filter name="group_by_category" string="Category" context="{'group_by': 'category'}"/>
						<filter name="group_by_state_asset" string="State Asset" context="{'group_by': 'state_asset'}"/>
                    </group>
                </search>
            </field>
        </record>

		<record id="action_tw_stock_opname_asset" model="ir.actions.act_window">
        	<field name="name">Asset</field>
			<field name="res_model">tw.stock.opname.asset</field>
			<field name="view_mode">list,form</field>
			<field name="context">{'default_division': 'Umum','search_default_draft':1}</field>		
		    <field name="search_view_id" ref="view_tw_stock_opname_asset_search"/>		
		</record>	

		<record model="ir.ui.view" id="tw_stock_opname_asset_line_form_view">
            <field name="name">tw.stock.opname.asset.line.form.view</field>            
            <field name="model">tw.stock.opname.asset.line</field>            
            <field name="arch" type="xml">
				<form string="Stock Opname Asset Line">
					<group>
						<field name="code" readonly="1"/>
						<field name="name" readonly="1"/>
						<field name="category" readonly="1"/>
						<field name="physical_validation" required="physical_validation or asset_status"/>
						<field name="asset_status" required="physical_validation or asset_status"/>
						<field name="pic_validation_id" options="{'no_open':True,'no_create':True}" required="physical_validation or asset_status"/>
						<field name="validation_location_id" options="{'no_open':True,'no_create':True}" required="physical_validation or asset_status"/>
						<field name="physical_condition" required="physical_validation or asset_status"/>
						<field name="engine_no" readonly="category != 'V'" required="physical_validation and asset_status and category == 'V'"/>
						<field name="description" required="physical_validation == 'fisik_tidak_ada' or asset_status == 'tidak_diketahui'"/>
						<field name="filename_image" invisible="1"/>
					</group>
					<label for="upload_image" string="Upload Image"/>    			
					<div>
						<field name="upload_image" widget="image" class="oe_inline" options="{'size': [200, 200]}" filename="filename_image" required="physical_validation or asset_status"/>
					</div>
		        </form>
            </field>		
		</record>

		<record model="ir.actions.act_window" id="tw_stock_opname_asset_line_action">
		    <field name="name">Stock Opname Asset Line</field>
		    <field name="res_model">tw.stock.opname.asset.line</field>
		    <field name="view_mode">form</field>
		</record>

		<record id="view_tw_stock_opname_asset_line_form" model="ir.actions.act_window.view">
			<field name="view_mode">form</field>
			<field name="view_id" ref="tw_stock_opname_asset_line_form_view"/>
			<field name="act_window_id" ref="tw_stock_opname_asset_line_action"/>
		</record>

    
    </data>
    

</odoo>