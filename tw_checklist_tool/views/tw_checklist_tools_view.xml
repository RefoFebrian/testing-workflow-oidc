<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_checklist_tools_list" model="ir.ui.view">
            <field name="name">tw.checklist.tool.list</field>
            <field name="model">tw.checklist.tools</field>
            <field name="arch" type="xml">
                <list string="Checklist Tools" delete='0'>
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="category_master_tool_id"/>
                    <field name="pic_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="periode_bulan"/>
                    <field name="tahun"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_tw_checklist_tools_form" model="ir.ui.view">
            <field name="name">tw.checklist.tool.form</field>
            <field name="model">tw.checklist.tools</field>
            <field name="arch" type="xml">
                <form string="Checklist Tools" delete='0'>
                    <header>
                        <button name="action_generate_line" string="Generate Checklist" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                        <button name="action_done" string="Done" type="object" invisible="state != 'open'" class="oe_highlight"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,open,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" class="oe_inline" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" readonly="state not in ('draft',)" options="{'no_open':True,'no_create':True}"/>
                                <field name="category_master_tool_id" required="1" readonly="state not in ('draft',)" options="{'no_open':True,'no_create':True}"/>
                                <field name="division" invisible="1"/>
                            </group>
                            <group>
                                <field name="category_name" invisible="1"/>
                                <label for="start_date" string="Date" invisible="category_name == 'Special Tools'"/>
                                <div invisible="category_name == 'Special Tools'">
                                    <field name="start_date" class="oe_inline" required="category_name != 'Special Tools'" readonly="state not in ('draft',)"/>
                                    s/d
                                    <field name="end_date" class="oe_inline" required="category_name != 'Special Tools'" readonly="state not in ('draft',)"/>
                                </div>
                                <label for="periode_bulan" string="Periode" invisible="category_name != 'Special Tools'"/>
                                <div invisible="category_name != 'Special Tools'">
                                    <field name="periode_bulan" class="oe_inline" required="category_name == 'Special Tools'" readonly="state not in ('draft',)"/>
                                    <span style="margin-left: 5px;"></span>
                                    <field name="tahun" class="oe_inline" readonly="1"/>
                                </div>
                                <field name="pic_id" required="1" readonly="state not in ('draft',)" options="{'no_open':True,'no_create':True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Periode Checklist">
                                <field name="line_ids" widget="one2many">
                                    <list create="false" delete="false" open="false">
                                        <field name="date" readonly="1"/>
                                        <field name="week" readonly="1"/>
                                        <button name="action_submit" class="btn btn-primary" string="Submit" type="object" invisible="parent.state != 'open'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_create':True, 'no_open':True}"/>
                                        <field name="write_uid" readonly="1" options="{'no_create':True, 'no_open':True}"/>
                                        <field name="confirm_uid" readonly="1" options="{'no_create':True, 'no_open':True}" invisible="not confirm_uid"/>
                                        <field name="posted_uid" readonly="1" options="{'no_create':True, 'no_open':True}" invisible="not posted_uid"/>
                                    </group>
                                    <group>
                                        <field name="create_date" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="confirm_date" readonly="1" invisible="not confirm_date"/>
                                        <field name="posted_date" readonly="1" invisible="not posted_date"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tw_checklist_tools_line_detail_form" model="ir.ui.view">
            <field name="name">tw.checklist.tool.line.detail.form</field>
            <field name="model">tw.checklist.tools.line</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group colspan="4" col="4">
                            <field name='checklist_id' readonly="1"/>
                            <field name="date" readonly="1" invisible="periode_bulan != False"/>
                            <label for="periode_bulan" string="Periode" invisible="not periode_bulan"/>
                            <div invisible="not periode_bulan">
                                <field name="periode_bulan" class="oe_inline" readonly="1"/>  <field name="tahun" class="oe_inline" readonly="1"/>
                            </div>
                        </group>
                        <notebook>
                            <page string="Detail Checklist Tool">
                                <field name="checklist_detail_ids" nolabel="1" widget="one2many">
                                    <list editable='top' create="false" delete="false">
                                        <field name="product_id" readonly="1" options="{'no_open':True,'no_create':True}"/>
                                        <field name="location_id" readonly="1" options="{'no_open':True,'no_create':True}"/>
                                        <field name="tools_state" required="1" readonly="not context.get('from_submit')"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                        <footer invisible="not context.get('from_submit')">
                            <button string="Save" type="object" class="oe_highlight" name="action_save"/>
                            <button string="Cancel" class="oe_link" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_checklist_tools_filter" model="ir.ui.view">
            <field name="name">tw.checklist.tools.filter</field>
            <field name="model">tw.checklist.tools</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="pic_id"/>
                    <field name="category_master_tool_id"/>
                    <field name="state"/>

                    <filter name="state_draft" domain="[('state','=','draft')]" string="Draft"/>
                    <filter name="state_open" domain="[('state','=','open')]" string="Open"/>
                    <filter name="state_done" domain="[('state','=','done')]" string="Done"/>

                    <group expand="1" string="Group By">
                        <filter string="Branch" name="company_ids" context="{'group_by':'company_id'}"/>
                        <filter string="Category" name="category_master_tool_id" context="{'group_by':'category_master_tool_id'}"/>
                        <filter string="State" name="state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_checklist_tools_action" model="ir.actions.act_window">
            <field name="name">Checklist Tool</field>
            <field name="res_model">tw.checklist.tools</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_company_ids': 1, 'search_default_state_draft': 1, 'search_default_state_open': 1}
            </field>
        </record>

        <record id="paperformat_checklist_tool" model="report.paperformat">
            <field name="name">Checklist Tool</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">280</field>
            <field name="page_width">150</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">2</field>
            <field name="margin_bottom">2</field>
            <field name="margin_left">2</field>
            <field name="margin_right">2</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">2</field>
            <field name="dpi">80</field>
        </record>

        <record id="print_checklist_tool" model="ir.actions.report">
            <field name="name">Print Checklist Tool</field>
            <field name="model">tw.checklist.tools</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_checklist_tool.print_checklist_tool_id</field>
            <field name="report_file">tw_checklist_tool.print_checklist_tool_id</field>
            <field name="paperformat_id" ref="tw_checklist_tool.paperformat_checklist_tool"/>
        </record>

    </data>
</odoo>