<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_master_tools_list" model="ir.ui.view">
            <field name="name">tw.master.tool.list</field>
            <field name="model">tw.master.tools</field>
            <field name="arch" type="xml">
                <list string="Master Tools" delete="0">
                    <field name="company_id"/>
                    <field name="pic_id"/>
                    <field name="category_master_tool_id"/>
                    <field name="location_id"/>
                </list>
            </field>
        </record>

        <record id="view_tw_master_tools_form" model="ir.ui.view">
            <field name="name">tw.master.tool.form</field>
            <field name="model">tw.master.tools</field>
            <field name="arch" type="xml">
                <form string="Master Tools" delete="0">
                    <sheet>
                        <group>
                            <group col="2">
                                <field name="company_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="pic_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="category_master_tool_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="location_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Tools" name="tools_line">
                                <field name="tw_master_tools_line_ids" context="{'default_tw_master_tools_id': id}" nolabel="1" mode="list,kanban" options="{'no_create': True, 'no_edit': True, 'no_open': True}">
                                    <list string="Tools" editable="bottom" delete="1">
                                        <field name="product_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="qty_tool" required="1"/>
                                        <field name="filename_upload" column_invisible="1"/>
                                        <field name="files_upload" filename="filename_upload"/>
                                        <field name="filename" readonly="1" invisible="filename_upload == False"/>
                                        <field name="files" widget="binary" column_invisible="1"/>
                                        <button name="export_file" string="Download" type="object" icon="fa-download" class="btn-primary" invisible="not files"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Import Tools">
                                <group>
                                    <group>
                                        <field name="file" filename="filename" string="Upload File"/>
                                        <field name="filename" invisible="1"/>
                                        <button name="action_import_tools_line" string="Import" type="object" class="btn-primary"/>
                                    </group>
                                    <group>
                                        <label for="action_download_format_file" string="Contoh File"/>
                                        <div>
                                            <button name="action_download_format_file" type="object" class="btn-primary" string="Download Contoh"/>
                                        </div>
                                    </group>
                                </group>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="write_uid" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="create_date" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_master_tools_filter" model="ir.ui.view">
            <field name="name">tw.master.tools.filter</field>
            <field name="model">tw.master.tools</field>
            <field name="arch" type="xml">
                <search string="Search">
                    <field name="company_id"/>
                    <field name="pic_id"/>
                    <field name="category_master_tool_id"/>
                    <field name="location_id"/>
                    <group expand="1" string="Group By">
                        <filter string="Branch" name="company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="PIC" name="pic_id" context="{'group_by': 'pic_id'}"/>
                        <filter string="Category" name="category_master_tool_id" context="{'group_by': 'category_master_tool_id'}"/>
                        <filter string="Location" name="location_id" context="{'group_by': 'location_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_master_tools_action" model="ir.actions.act_window">
            <field name="name">Master Tools</field>
            <field name="res_model">tw.master.tools</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>