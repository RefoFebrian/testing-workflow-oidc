<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Read Group -->
        <record id="group_fpo_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Other Read</field>
        </record>

        <!-- Update Group -->
        <record id="group_fpo_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Other Update</field>
        </record>

        <!-- Delete Group -->
        <record id="group_fpo_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Other Delete</field>
        </record>


        <!-- Read Access -->
        <record id="access_fpo_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_other"/>
            <field name="name">tw_faktur_pajak_other read</field>
            <field name="group_id" ref="group_fpo_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Update Access -->
        <record id="access_fpo_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_other"/>
            <field name="name">tw_faktur_pajak_other update</field>
            <field name="group_id" ref="group_fpo_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Delete Access -->
        <record id="access_fpo_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_other"/>
            <field name="name">tw_faktur_pajak_other delete</field>
            <field name="group_id" ref="group_fpo_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <!-- System Admin gets all access -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_fpo_read')),
                (4, ref('group_fpo_update')),
                (4, ref('group_fpo_delete')),
            ]"/>
        </record>
    </data>
</odoo>
