<odoo>
    <data noupdate="1">
        <!-- Post Button Group -->
        <record id="group_fpo_post" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Faktur Pajak Other Post</field>
            <field name="implied_ids" eval="[(4, ref('group_fpo_read'))]"/>
        </record>

        
    </data>
    <data>
        <!-- System Admin gets all access -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_fpo_post')),
            ]"/>
        </record>
    </data>
</odoo>