<odoo>
  <data>
    <!-- explicit list view definition -->

    <record id="tw_attendance_list_view" model="ir.ui.view">
      <field name="name">tw.attendance.list</field>
      <field name="model">tw.attendance</field>
      <field name="arch" type="xml">
        <list string="Absensi" create="0" edit="0">
          <field name="employee_id"/>
          <field name="check_in"/>
          <field name="check_out"/>
          <field name="workplace_in_id"/>
          <field name="workplace_out_id"/>
          <field name="radius_in"/>
          <field name="radius_out"/>
          <field name="lat_in"/>
          <field name="long_in"/>
          <field name="lat_out"/>
          <field name="long_out"/>
        </list>
      </field>
    </record>

    <!-- Form View -->
    <record id="tw_attendance_form_view" model="ir.ui.view">
      <field name="name">tw.attendance.form</field>
      <field name="model">tw.attendance</field>
      <field name="arch" type="xml">
        <form string="Absensi" create="0" edit="0" delete="0">
          <sheet>
            <group>
              <group>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="check_in"/>
                <field name="check_out"/>
              </group>
              <group>
                <field name="workplace_in_id"/>
                <field name="workplace_out_id"/>
                <field name="work_hours"/>
                <field name="work_mins"/>
                <field name="work_secs"/>
              </group>
            </group>
            <group string="Location Details">
              <group>
                <field name="lat_in"/>
                <field name="long_in"/>
                <field name="radius_in"/>
              </group>
              <group>
                <field name="lat_out"/>
                <field name="long_out"/>
                <field name="radius_out"/>
              </group>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <!-- actions opening views on models -->

    <record id="tw_hr_attendance.action_window" model="ir.actions.act_window">
      <field name="name">Absensi</field>
      <field name="res_model">tw.attendance</field>
      <field name="view_mode">list,form</field>
      <field name="path">attendance</field>
    </record>

    <!-- Attendance Action View -->
    <record id="tw_employee_attendance_action" model="ir.actions.server">
        <field name="name">Attendance</field>
        <field name="model_id" ref="tw_hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">
            action = env['tw.attendance'].action_attendance_tree()
        </field>
    </record>
  </data>
</odoo>