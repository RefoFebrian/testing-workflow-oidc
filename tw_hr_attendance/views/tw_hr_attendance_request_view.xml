<odoo>
    <data>

        <record id="tw_attendance_request_view_tree" model="ir.ui.view">
            <field name="name">tw.attendance.request.list</field>
            <field name="model">tw.attendance.request</field>
            <field name="arch" type="xml">
                <list string="Attendance Request" create="1">
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'wfa'" decoration-success="state in ('approved','confirmed')" decoration-danger="state == 'rejected'"/>
                </list>
            </field>
        </record>
        
        <record id="tw_attendance_request_view_search" model="ir.ui.view">
            <field name="name">tw.attendance.request.search</field>
            <field name="model">tw.attendance.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="employee_id"/>
                    <filter name="date_today" string="Today" domain="[('date','=',context_today().strftime('%%Y-%%m-%%d'))]"/>
                    <separator/>
                    <filter name="state_wfa" string="Waiting for Approval" domain="[('state', '=', 'wfa')]"/>
                    <filter name="state_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="state_rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
                    <separator/>
                    <group string="Group By">
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_attendance_request_view_form" model="ir.ui.view">
            <field name="name">tw.attendance.request.form</field>
            <field name="model">tw.attendance.request</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Absensi">
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,wfa,approved,confirmed"/>
                        <button name="action_rfa" type="object" invisible="state != 'draft'" string="Request for Approval" class="oe_highlight"/>
                        <button name="action_approve" type="object" invisible="state != 'wfa'" icon="fa-check" string="Approve" class="oe_highlight"/>
                        <button name="action_reject" type="object" invisible="state != 'wfa'" icon="fa-remove" string="Reject"/>
                        <button name="action_confirm" type="object" invisible="state != 'approved'" string="Confirm" class="oe_highlight"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="employee_id" string="Employee"/>
                            <h1>
                                <field name="employee_id" required="1" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date" readonly="1"/>
                            </group>
                        </group>
                        <group string="Reject" invisible="state != 'rejected'">
                            <field name="reject_reason" string="Reason" readonly="1"/>
                            <field name="reject_uid" readonly="1"/>
                            <field name="reject_date" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Request Lines" name="request_lines">
                                <field name="request_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom">
                                        <field name="date"/>
                                        <field name="start_date"/>
                                        <field name="end_date"/>
                                        <field name="work_place_id" required="1"/>
                                        <field name="reason"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail" invisible="not create_uid">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                                <group>
                                    <group>
                                        <field name="approve_uid" readonly="1" invisible="not approve_uid"/>
                                        <field name="approve_date" readonly="1" invisible="not approve_date"/>
                                    </group>
                                    <group>
                                        <field name="confirm_uid" readonly="1" invisible="not confirm_uid"/>
                                        <field name="confirm_date" readonly="1" invisible="not confirm_date"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_attendance_request_reject_view_form" model="ir.ui.view">
            <field name="name">tw.attendance.request.reject.form</field>
            <field name="model">tw.attendance.request</field>
            <field name="arch" type="xml">
                <form string="Rejection">
                    <sheet>
                        <group>
                            <group>
                                <field name="reject_reason" required="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_reject_confirm" type="object" string="Reject" class="oe_highlight"/>
                        <button special="cancel" string="Cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="tw_attendance_request_action">
            <field name="name">Request Attendance</field>
            <field name="res_model">tw.attendance.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname":1}</field>
        </record>

        <record model="ir.actions.act_window" id="tw_attendance_request_action_by_hr_action">
            <field name="name">Request Attendance by HR</field>
            <field name="res_model">tw.attendance.request</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                'readonly_by_pass': 1,
                'search_default_fieldname': 1
            }</field>
        </record>

    
    </data>
</odoo>