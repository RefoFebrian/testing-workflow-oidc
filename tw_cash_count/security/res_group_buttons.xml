<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">    
        <record id="group_tw_cash_count_generate_stock_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cash Count Generate</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cash_count_read'))]"/>
        </record>     
        <record id="group_tw_cash_count_posted_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cash Count Post</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cash_count_read'))]"/>
        </record>     
        <record id="group_tw_cash_count_update_plafon_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cash Count Update Plafon</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cash_count_read'))]"/>
        </record>     
        <record id="group_tw_cash_count_approved_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cash Count Approved</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cash_count_read'))]"/>
        </record>     
        
        <record id="group_tw_cash_count_cancel_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cash Count Cancel</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cash_count_read'))]"/>
        </record>     

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_cash_count_generate_stock_button')),
                (4,ref('group_tw_cash_count_posted_button')),
                (4,ref('group_tw_cash_count_update_plafon_button')),
                (4,ref('group_tw_cash_count_approved_button')),
                (4,ref('group_tw_cash_count_cancel_button')),
			]"/> 
		</record>
    </data>
</odoo>