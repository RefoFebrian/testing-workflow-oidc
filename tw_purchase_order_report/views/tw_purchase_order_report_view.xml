<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_purchase_order_report_form_view" model="ir.ui.view">
            <field name="name">tw.purchase.order.report.form</field>
            <field name="model">tw.purchase.order.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report" create="false" delete="false">
                    <group col="2" colspan="2">
                        <group>
						    <field name="options" required="1"/>
                            <label for="start_date" string="Periode"/> 
                            <div>
                                <field name="start_date" class="oe_inline" placeholder="Start"/> - 
                                <field name="end_date" class="oe_inline" placeholder="End"/>
                            </div>
                        </group>
                        <group>
						    <field name="division" required="1"/>
						    <field name="state" required="1"/>
						    <field name="invoice_state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branch">
                            <field name="company_ids" options="{'no_open': True,'no_create': True}">
                                <list editable="top">
                                    <field name="name" readonly="1"/>
                                    <field name="code" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Partner">
                            <field name="partner_ids" options="{'no_open': True,'no_create': True}">
                                <list editable="top">
                                    <field name="name" readonly="1"/>
                                    <field name="code" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Product">
                            <field name="product_ids" domain="[('division', '=', division)]" options="{'no_open': True,'no_create': True}">
                                <list editable="top">
                                    <field name="name" readonly="1"/>
                                    <field name="default_code" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_purchase_order_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Pembelian</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.purchase.order.report</field>
            <field name="view_id" ref="tw_purchase_order_report_form_view"/>
            <field name="target">new</field>
        </record>

	  	<record id="tw_purchase_order_showroom_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Pembelian</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.purchase.order.report</field>
            <field name="view_id" ref="tw_purchase_order_report_form_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Unit'}</field>
        </record>

	  	<record id="tw_purchase_order_workshop_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Pembelian</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.purchase.order.report</field>
            <field name="view_id" ref="tw_purchase_order_report_form_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Sparepart'}</field>
        </record>

    </data>
</odoo>