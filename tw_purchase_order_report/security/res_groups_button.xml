<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_purchase_order_print_showroom" model="res.groups">
            <field name="name">TW Print Purchase Order Showroom</field>
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order"/>
        </record>

        <record id="group_tw_purchase_order_print_workshop" model="res.groups">
            <field name="name">TW Print Purchase Order Workshop</field>
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order"/>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_order_print_showroom')),
                (4, ref('group_tw_purchase_order_print_workshop'))
            ]"/>
        </record>
    </data>
</odoo>
