<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_purchase_order_laporan_read" model="res.groups">
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order" />
            <field name="name">TW Laporan Pembelian Showroom</field>
        </record>

        <record id="access_tw_purchase_order_laporan_all" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_order_report" />
            <field name="name">access_tw_purchase_order_laporan_all</field>
            <field name="group_id" ref="group_tw_purchase_order_laporan_read" />
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_purchase_order_laporan_workshop_read" model="res.groups">
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order" />
            <field name="name">TW Laporan Pembelian Workshop</field>
        </record>
        <record id="access_tw_purchase_order_laporan_workshop" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_order_report" />
            <field name="name">access_tw_purchase_order_laporan_workshop</field>
            <field name="group_id" ref="group_tw_purchase_order_laporan_workshop_read" />
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_order_laporan_read')),
                (4, ref('group_tw_purchase_order_laporan_workshop_read'))
            ]" />
        </record>
    </data>

</odoo>
