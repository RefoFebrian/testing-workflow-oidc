<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_employee_incentive_rule" model="ir.rule">
            <field name="name">tw.employee.incentive.rule</field>
            <field name="model_id" ref="model_tw_employee_incentive"/>
