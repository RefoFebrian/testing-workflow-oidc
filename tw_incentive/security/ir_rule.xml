            <field name="domain_force">[('company_id', 'parent_of', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="tw_recalculate_incentive_rule" model="ir.rule">
            <field name="name">tw.recalculate.incentive.rule</field>
