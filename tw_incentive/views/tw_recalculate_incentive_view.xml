<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="tw_recalculate_incentive_view_list" model="ir.ui.view">
            <field name="name">tw.recalculate.incentive.list</field>
            <field name="model">tw.recalculate.incentive</field>
            <field name="type">list</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <list string="Recalculate incentive" delete="0">
                    <field name="company_id" />
                    <field name="month" />
                    <field name="year" />
                    <field name="date" />
                    <field name="percentage_remaining_data" string="Calculation Progress" widget="progressbar" />
                    <field name="state" />
                </list>
            </field>
        </record>

        <!-- form view -->
        <record id="tw_recalculate_incentive_view_form" model="ir.ui.view">
            <field name="name">tw.recalculate.incentive.form</field>
            <field name="model">tw.recalculate.incentive</field>
            <field name="type">form</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <form string="recalculate incentive" delete="0">
                    <header>
                        <button name="action_confirm" invisible="state != 'draft'" type="object" class="oe_highlight" string="Confirm" groups="tw_incentive.tw_recalculate_incentive_group_button_confirm" />
                        <button name="action_confirm_without_date_check" invisible="state != 'draft'" type="object" string="Confirm Anyway" groups="tw_incentive.tw_recalculate_incentive_group_button_confirm_admin" />
                        <button name="action_check_outstanding_calculation" invisible="remaining_data == 0" type="object" string="Check Completeness" groups="tw_incentive.tw_recalculate_incentive_group_button_check_completion" />
                        <field name="state" widget="statusbar" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1" force_save="1" />
                                <br />
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" readonly="state != 'draft'" options="{'no_create': True,'no_open':True}" required="1" />
                                <field name="start_date"
									   widget="daterange"
									   options="{'end_date_field': 'end_date'}"
									   readonly="state != 'draft'" required="1" />
								<field name="end_date" invisible="1" />
                                <field name="month" readonly="state != 'draft'" required="0" invisible="1" />
                                <field name="year" readonly="state != 'draft'" required="0" invisible="1" />
                                <field name="reason" readonly="state != 'draft'" required="1" />
                            </group>
                            <group>
                                <field name="date" readonly="1" force_save="1" />
                                <field name="total_data" readonly="1" force_save="1" invisible="state not in ('confirmed','done')" />
                                <field name="remaining_data" readonly="1" force_save="1" invisible="state not in ('confirmed','done')" />
                                <field name="percentage_remaining_data" widget="percentpie" force_save="1" readonly="1" invisible="state not in ('confirmed','done')" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Recalculated Incentive">
                                <field name="incentive_ids">
                                    <list delete="false" create="false" edit="false">
                                        <field name="name" />
                                        <field name="type" />
                                        <field name="transaction_ref" />
                                        <field name="incentive_value" />
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" />
                                        <field name="create_date" readonly="1" />
                                        <field name="confirm_uid" readonly="1" />
                                        <field name="confirm_date" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" />
                                        <field name="write_date" readonly="1" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="tw_recalculate_incentive_view_search" model="ir.ui.view">
            <field name="name">tw.recalculate.incentive.search</field>
            <field name="model">tw.recalculate.incentive</field>
            <field name="arch" type="xml">
                <search string="recalculate incentive">
                    <field name="company_id" select="True" />
                    <field name="month" select="True" />
                    <field name="year" select="True" />
                    <field name="date" select="True" />
                    <filter name="draft" string="draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="confirmed" string="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="done" string="done" domain="[('state', '=', 'done')]"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by':'company_id'}" />
                        <filter string="Month" domain="[]" name="group_by_month" context="{'group_by':'month'}" />
                        <filter string="Year" domain="[]" name="group_by_year" context="{'group_by':'year'}" />
                        <filter string="Date" domain="[]" name="group_by_date" context="{'group_by':'date'}" />
                        <filter string="State" domain="[]" name="group_by_state" context="{'group_by':'state'}" />
                    </group>
                </search>
            </field>
        </record>
        <!-- action window -->
        <record id="tw_recalculate_incentive_action" model="ir.actions.act_window">
            <field name="name">Recalculate Incentive</field>
            <field name="path">tw-recalculate-incentive</field>
            <field name="res_model">tw.recalculate.incentive</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname": 1,'search_default_draft':1,'search_default_confirmed':1}</field>
        </record>

    </data>
</odoo>