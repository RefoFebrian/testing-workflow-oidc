<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="tw_master_incentive_view_list" model="ir.ui.view">
            <field name="name">tw.master.incentive.list</field>
            <field name="model">tw.master.incentive</field>
            <field name="type">list</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <list string="Master incentive" create="false" edit="false" delete="false">
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="sales_category" />
                    <field name="branch_class" />
                    <field name="state" widget="badge"
                           decoration-primary="state == 'draft'"
                           decoration-success="state == 'active'"
                           decoration-danger="state == 'expired'"/>
                </list>
            </field>
        </record>
        <!-- form view -->
        <record id="tw_master_incentive_view_form" model="ir.ui.view">
            <field name="name">tw.master.incentive.form</field>
            <field name="model">tw.master.incentive</field>
            <field name="type">form</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <form string="Master incentive">
                    <header>
                        <button name="action_active"
                                type="object"
                                string="Active"
                                class="oe_highlight"
                                invisible="state != 'draft'"
                                groups="tw_incentive.group_tw_master_incentive_button_active" />
                        <button name="action_expire"
                                type="object"
                                string="Expire"
                                class="oe_highlight"
                                invisible="state != 'active'"
                                groups="tw_incentive.group_tw_master_incentive_button_expire" />
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" readonly="1" nolabel="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="sales_category" options="{'no_create': True,'no_open':True}" required="1" readonly="state != 'draft'" />
                                <field name="branch_class" readonly="sales_category != 'sales_payroll'" force_save="1" options="{'no_create': True,'no_open':True}" />
                                <field name="company_id" groups="base.group_multi_company" options="{'no_create': True,'no_open':True}" />
                            </group>
                            <group></group>
                        </group>
                        <notebook>
                            <page name="incentive_line" string="Incentive">
                                <field name="incentive_line_ids" readonly="state != 'draft'" >
                                    <list editable="bottom">
                                        <field name="quantity" required="1"/>
                                        <field name="cash" required="1"/>
                                        <field name="accumulate_cash" required="1"/>
                                        <field name="credit" required="1"/>
                                        <field name="accumulate_credit" required="1"/>
                                        <field name="reward" required="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="company_id" readonly="1" force_save="1"/>
                                        <field name="create_uid" readonly="1" />
                                        <field name="create_date" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" />
                                        <field name="write_date" readonly="1" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="tw_master_incentive_view_search" model="ir.ui.view">
            <field name="name">tw.master.incentive.search</field>
            <field name="model">tw.master.incentive</field>
            <field name="arch" type="xml">
                <search string="Master incentive">
                    <field name="company_id" select="True" />
                    <field name="sales_category" select="True" />
                    <filter name="draft" string="draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="active" string="active" domain="[('state', '=', 'active')]"/>
                    <filter name="expired" string="expired" domain="[('state', '=', 'expired')]"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by':'company_id'}" />
                        <filter string="Job" domain="[]" name="group_by_sales_category" context="{'group_by':'sales_category'}" />
                        <filter string="Branch Class" domain="[]" name="group_by_branch_class" context="{'group_by':'branch_class'}" />
                        <filter string="State" domain="[]" name="group_by_state" context="{'group_by':'state'}" />
                    </group>
                </search>
            </field>
        </record>
        <!-- action window -->
        <record id="tw_master_incentive_action" model="ir.actions.act_window">
            <field name="name">Master incentive</field>
            <field name="path">tw-master-incentive</field>
            <field name="res_model">tw.master.incentive</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname":1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                Klik create untuk membuat master incentive baru
                </p>
            </field>
        </record>

    </data>
</odoo>