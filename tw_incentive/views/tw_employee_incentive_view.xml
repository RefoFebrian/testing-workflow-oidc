<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="tw_employee_incentive_view_list" model="ir.ui.view">
            <field name="name">tw.employee.incentive.list</field>
            <field name="model">tw.employee.incentive</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <list string="Employee incentive" create="0" edit="0" delete="0">
                    <field name="name" />
                    <field name="company_id" />
                    <field name="employee_id"/>
                    <field name="type" optional="hide" />
                    <field name="date" />
                    <field name="model_name" optional="hide" />
                    <field name="transaction_ref" />
                    <field name="incentive_value" />
                    <field name="incentive_available" optional="hide" />
                    <field name="incentive_outgoing" optional="hide" />
                    <field name="state" widget="badge"
                           decoration-info="state == 'pending'"
                           decoration-success="state == 'earned'"
                           decoration-danger="state in ('cancelled', 'rejected')"
                           decoration-warning="state == 'expired'" />
                </list>
            </field>
        </record>

        <!-- form view -->
        <record id="tw_employee_incentive_view_form" model="ir.ui.view">
            <field name="name">tw.employee.incentive.form</field>
            <field name="model">tw.employee.incentive</field>
            <field name="priority" eval="8" />
            <field name="arch" type="xml">
                <form string="Employee incentive" create="0" edit="0" delete="0">
                    <header>
                        <field name="state" widget="statusbar" />
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only" string="Employee incentive Name" />
                            <h1>
                                <field name="name" />
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="type" />
                                <field name="date" />
                                <field name="model_id" invisible="1" />
                                <field name="model_name" />
                                <field name="transaction_ref" />
                            </group>
                            <group>
                                <field name="employee_id"/>
                                <field name="job_id"/>
                                <field name="incentive_value" />
                                <field name="incentive_available" />
                                <field name="incentive_outgoing" />
                            </group>
                        </group>
                                 
                        <notebook>
                            <page string="History Incentive">
                                <field name="incentive_history_ids">
                                    <list>
                                        <field name="date" />
                                        <field name="description" />
                                        <field name="type" />
                                        <field name="value" />
                                        <field name="state" />
                                    </list>
                                </field>
                            </page>
                            <page string="Incentive Detail">
                                <field name="incentive_detail_ids">
                                    <list delete="0" create="0" edit="0">
                                        <field name="name" />
                                        <field name="value" />
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"></field>
                                        <field name="create_date" readonly="1"></field>
                                    </group>
                                    <group>							
                                        <field name="write_uid" readonly="1"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>
                        </notebook>

                        <div>
                            <field name ="remarks" />                                
                            <br/>
                            Perhitungan berdasarkan master target margin: <field name="master_margin_id" /> dan master incentive: <field name="master_incentive_id" /> 
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="tw_employee_incentive_view_search" model="ir.ui.view">
            <field name="name">tw.employee.incentive.search</field>
            <field name="model">tw.employee.incentive</field>
            <field name="arch" type="xml">
                <search string="Employee incentive">
                    <filter string="Incentive by sales" name="filter_by_type" domain="[('type', '=', 'sale')]" />
                    <filter string="Earned" name="filter_by_state" domain="[('state', '=', 'earned')]" />
                    <filter string="Pending" name="filter_by_state" domain="[('state', '=', 'pending')]" />
                    <filter string="Cancelled" name="filter_by_state" domain="[('state', '=', 'cancelled')]" />
                    <filter string="Expired" name="filter_by_state" domain="[('state', '=', 'expired')]" />
                    <filter string="Rejected" name="filter_by_state" domain="[('state', '=', 'rejected')]" />
                    
                    <field name="name" operator="ilike" />
                    <field name="transaction_ref" operator="ilike" />
                    <field name="employee_id" operator="ilike" />
                    <field name="company_id" operator="ilike" />
                    <field name="date" operator="ilike" />
                    
                    <group string="Group By..">
                        <filter string="Transaction" domain="[]" name="group_by_transaction_ref" context="{'group_by': 'transaction_ref'}" />
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="Employee" domain="[]" name="group_by_employee_id" context="{'group_by': 'employee_id'}"/>
                        <filter string="Date" domain="[]" name="group_by_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- action window -->
        <record id="tw_employee_incentive_action" model="ir.actions.act_window">
            <field name="name">Employee Incentive</field>
            <field name="path">tw-employee-incentive</field>
            <field name="res_model">tw.employee.incentive</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">list,form</field>
            <field name="context">{ 'group_by':'employee_id' }</field>
        </record>

    </data>
</odoo>