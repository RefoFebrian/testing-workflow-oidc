<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_report_team_leader_wizard" model="ir.ui.view">
            <field name="name">tw.report.team.leader.wizard</field>
            <field name="model">tw.report.team.leader</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report Team Leader">
                    <group>
                        <group col="2">
                            <field name="start_date"
                                   widget="daterange"
                                   options="{'end_date_field': 'end_date'}"
                                   required="1" />
                            <field name="end_date" invisible="1" />
                            <field name="report_type" required="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids" colspan="4" nolabel="1" options="{'no_show':True,'no_create':True,'no_open':True}">
                                <list create="1" delete="1" editable="bottom" edit="0">
                                    <field name="code" />
                                    <field name="name" />
                                </list>
                            </field>
                        </page>
                    </notebook>


                    <newline />
                    <group col="4" fill="0">
                        <field name="file" invisible="1" width="100" />
                    </group>
                    <footer>
                        <button name="excel_report" string="Export Data" type="object" class="oe_highlight" />
                        <button string="Cancel" special="cancel" class="btn btn-default" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_team_leader_wizard" model="ir.actions.act_window">
            <field name="name">Laporan Team Leader</field>
            <field name="res_model">tw.report.team.leader</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_report_team_leader_wizard" />
            <field name="target">new</field>
        </record>

    </data>
</odoo>