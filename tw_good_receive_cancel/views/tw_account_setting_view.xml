<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Inherit Account Setting Form to add GR Cancel Journal -->
        <record id="tw_account_setting_form_inherit_gr_cancel" model="ir.ui.view">
            <field name="name">tw.account.setting.form.inherit.gr.cancel</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_asset_adjustment_id']" position="after">
                    <field name="journal_good_receive_cancel_id" options="{'no_create': True, 'no_open': True}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
