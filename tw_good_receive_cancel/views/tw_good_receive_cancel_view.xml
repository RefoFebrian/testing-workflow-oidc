<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_good_receive_cancel_list_view" model="ir.ui.view">
            <field name="name">tw.good.receive.cancel.list</field>
            <field name="model">tw.good.receive.cancel</field>
            <field name="arch" type="xml">
                <list string="Good Receive Cancel" default_order="id desc">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="company_id"/>
                    <field name="good_receive_id"/>
                    <field name="reason"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'waiting_for_approval'" decoration-success="state in ('approved', 'confirmed')"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_good_receive_cancel_form_view" model="ir.ui.view">
            <field name="name">tw.good.receive.cancel.form</field>
            <field name="model">tw.good.receive.cancel</field>
            <field name="arch" type="xml">
                <form string="Good Receive Cancel">
                    <header>
                        <button name="action_request_approval" string="Request Approval" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_confirm" string="Confirm Cancel" type="object" class="oe_highlight" invisible="state != 'approved'" groups="tw_good_receive_cancel.group_good_receive_cancel_confirm"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,confirmed"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="good_receive_id" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="transaction_name" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="division" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group>
                            <field name="reason" placeholder="Alasan pembatalan..." readonly="state != 'draft'"/>
                        </group>
                        <notebook>
                            <page string="Journal Items" invisible="state != 'confirmed'">
                                <field name="move_ids" readonly="1"/>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="approve_uid" readonly="1"/>
                                        <field name="approve_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Catatan">
                                <field name="note" placeholder="Catatan tambahan..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_good_receive_cancel_search_view" model="ir.ui.view">
            <field name="name">tw.good.receive.cancel.search</field>
            <field name="model">tw.good.receive.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Good Receive Cancel">
                    <field name="name"/>
                    <field name="good_receive_id"/>
                    <field name="company_id"/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="waiting" string="Waiting Approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                    <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_company" context="{'group_by': 'company_id'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="tw_good_receive_cancel_action" model="ir.actions.act_window">
            <field name="name">Good Receive Cancel</field>
            <field name="res_model">tw.good.receive.cancel</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_good_receive_cancel_search_view"/>
            <field name="context">{'default_model_type': 'tw.good.receive'}</field>
        </record>

    </data>
</odoo>
