<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- GR Cancel READ -->
        <record id="group_good_receive_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Good Receive Cancel Read</field>
        </record>

        <record id="access_tw_good_receive_cancel_read" model="ir.model.access">
            <field name="model_id" ref="tw_good_receive_cancel.model_tw_good_receive_cancel"/>
            <field name="name">tw_good_receive_cancel read</field>
            <field name="group_id" ref="group_good_receive_cancel_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- GR Cancel UPDATE -->
        <record id="group_good_receive_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Good Receive Cancel Update</field>
            <field name="implied_ids" eval="[(4, ref('group_good_receive_cancel_read'))]"/>
        </record>

        <record id="access_tw_good_receive_cancel_update" model="ir.model.access">
            <field name="model_id" ref="tw_good_receive_cancel.model_tw_good_receive_cancel"/>
            <field name="name">tw_good_receive_cancel update</field>
            <field name="group_id" ref="group_good_receive_cancel_update"/>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- GR Cancel DELETE -->
        <record id="group_good_receive_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Good Receive Cancel Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_good_receive_cancel_read'))]"/>
        </record>

        <record id="access_tw_good_receive_cancel_delete" model="ir.model.access">
            <field name="model_id" ref="tw_good_receive_cancel.model_tw_good_receive_cancel"/>
            <field name="name">tw_good_receive_cancel delete</field>
            <field name="group_id" ref="group_good_receive_cancel_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <!-- GR Cancel CONFIRM -->
        <record id="group_good_receive_cancel_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Good Receive Cancel Confirm</field>
            <field name="implied_ids" eval="[(4, ref('group_good_receive_cancel_update'))]"/>
        </record>

        <!-- System Admin gets all groups -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_good_receive_cancel_read')),
                (4, ref('group_good_receive_cancel_update')),
                (4, ref('group_good_receive_cancel_delete')),
                (4, ref('group_good_receive_cancel_confirm')),
            ]"/>
        </record>

    </data>
</odoo>
