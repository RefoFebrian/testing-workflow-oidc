<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Standalone Form View for Expedition Collecting with Approval -->
        <record id="tw_collecting_expedition_form_view" model="ir.ui.view">
            <field name="name">tw.collecting.expedition.form</field>
            <field name="model">tw.collecting.expedition</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <form string="Collecting Expedition">
                    <header>
                        <button name="action_request_approval" data-hotkey="r" groups="tw_collecting_expedition.group_tw_collecting_expedition_button_rfa" invisible="amount == 0 or state != 'draft'" string="RFA" type="object" class="oe_highlight"/>
                        <button name="action_approval" data-hotkey="a" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight" groups="tw_collecting_expedition.group_tw_collecting_expedition_button_rfa"/>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" groups="tw_collecting_expedition.group_tw_collecting_expedition_button_confirm" invisible="state != 'approved'"/>
                        <button name="%(tw_approval.tw_approval_reject_wizard_action)d" groups="tw_collecting_expedition.group_tw_collecting_expedition_button_reject" invisible="state != 'waiting_for_approval'" string="Reject" type="action" context="{'model_name':'tw.collecting.expedition','update_value':{'state':'draft'}}"/>
                        <button name="%(tw_approval.tw_approval_cancel_wizard_action)d" groups="tw_collecting_expedition.group_tw_collecting_expedition_button_cancel" invisible="state not in ('waiting_for_approval','approved')" string="Cancel Approval" type="action" context="{'model_name':'tw.collecting.expedition','update_value':{'state':'draft'}}"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,confirm"/>
                    </header>
                    <sheet>
                        <field name="currency_id" invisible="1"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1" placeholder="New"/>
                            </h1>
                        </div>
                        <!-- Smart Button for Journal Entry -->
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_journal_entry" type="object" class="oe_stat_button" icon="fa-book" invisible="not collected_move_id">
                                <field name="collected_move_id" invisible="1"/>
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Journal Entry</span>
                                </div>
                            </button>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" string="Branch" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                                <field name="partner_id" string="Expedition" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'" domain="[('category_id.name', '=', 'Expedition')]"/>
                                <field name="stock_inbound_ids" widget="many2many_tags" string="Stock Inbound" required="1" readonly="state != 'draft'" options="{'no_create': True}" domain="[('state', '=', 'done'), ('division', '=', division), ('expedition_id', '=', partner_id), ('date', '&gt;=', date_start), ('date', '&lt;=', date_end)]"/>
                            </group>
                            <group>
                                <field name="division" required="1" readonly="state != 'draft'"/>
                                <field name="date" readonly="1"/>
                                <label for="date_start" string="Date Filter"/>
                                <div class="o_row">
                                    <field name="date_start" nolabel="1" required="1" class="oe_inline" readonly="state != 'draft'"/>
                                    <span class="o_form_label mx-2">-</span>
                                    <field name="date_end" nolabel="1" required="1" class="oe_inline" readonly="state != 'draft'"/>
                                </div>
                            </group>
                            <group>
                                <field name="description" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="is_correction" invisible="1"/>
                            </group>
                            <!-- Amount Summary Group at bottom right -->
                            <group colspan="2" col="2" class="oe_right">
                                <group string="Amount Summary">
                                    <field name="estimated_amount" readonly="1" force_save="1"/>
                                    <field name="amount" string="Billing Amount" readonly="state != 'draft'" required="1"/>
                                    <field name="difference_amount" readonly="1" force_save="1"/>
                                </group>
                            </group>
                        </group>
                        <notebook>
                            <!-- Move Lines Page -->
                            <page string="Move Lines" name="move_lines_tab">
                                <field name="move_line_ids" nolabel="1" colspan="4" readonly="1" force_save="1">
                                    <list string="Move Lines" editable="bottom" create="false" delete="false">
                                        <field name="ref" string="Picking Number" width="180px"/>
                                        <field name="currency_id" column_invisible="1"/>
                                        <field name="name" string="Description"/>
                                        <field name="quantity" string="Qty" sum="Total Qty" width="80px"/>
                                        <field name="credit" string="Amount" sum="Total Amount" options="{'currency_field': 'currency_id'}" width="150px"/>
                                        <field name="matching_number" string="Reconcile ID" column_invisible="parent.state != 'confirm'" width="100px"/>
                                    </list>
                                </field>
                            </page>
                            <!-- Detail Lines Page -->
                            <page string="Detail Items" name="detail_lines_tab">
                                <field name="line_ids" nolabel="1" colspan="4" readonly="1" force_save="1">
                                    <list string="Detail Items" create="false" delete="false">
                                        <field name="picking_id" string="No Picking" width="180px" optional="show" force_save="1"/>
                                        <field name="product_id" string="Product" width="250px" optional="show" force_save="1"/>
                                        <field name="lot_id" string="No Mesin" width="180px" optional="show" force_save="1"/>
                                        <field name="chassis_number" string="No Rangka" width="180px" optional="show" force_save="1"/>
                                        <field name="qty" string="Qty" sum="Total Qty" width="80px" optional="show"/>
                                    </list>
                                </field>
                            </page>
                            <!-- Approval Page -->
                            <page string="Approval" name="approval">
                                <field name="approval_ids"/>
                            </page>
                            <!-- Audit Trail Page -->
                            <page string="Audit Trail" name="audit_trail">
                                <group string="Creation">
                                    <label for="create_uid" string="Created by"/>
                                    <div>
                                        <field name="create_uid" readonly="1" class="oe_inline"/>
                                        <field name="create_date" string="on" readonly="1" class="oe_inline" style="margin-left: 5px;"/>
                                    </div>
                                </group>
                                <group string="Last Updated" groups="base.group_no_one">
                                    <label for="write_uid" string="Last Updated by"/>
                                    <div>
                                        <field name="write_uid" readonly="1" class="oe_inline"/>
                                        <field name="write_date" string="on" readonly="1" class="oe_inline" style="margin-left: 5px;"/>
                                    </div>
                                </group>
                                <group string="Confirmation" invisible="not confirm_uid">
                                    <label for="confirm_uid" string="Confirmed by"/>
                                    <div>
                                        <field name="confirm_uid" readonly="1" class="oe_inline"/>
                                        <field name="confirm_date" string="on" readonly="1" class="oe_inline" style="margin-left: 5px;"/>
                                    </div>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Standalone List View for Expedition Collecting -->
        <record id="tw_collecting_expedition_list_view" model="ir.ui.view">
            <field name="name">tw.collecting.expedition.list</field>
            <field name="model">tw.collecting.expedition</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <list string="Collecting Expedition">
                    <field name="name"/>
                    <field name="company_id" string="Branch"/>
                    <field name="partner_id" string="Expedition"/>
                    <field name="division"/>
                    <field name="date"/>
                    <field name="date_start"/>
                    <field name="date_end"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'waiting_for_approval'" decoration-primary="state == 'approved'" decoration-success="state == 'confirm'" decoration-danger="state == 'cancel'"/>
                </list>
            </field>
        </record>

        <!-- Standalone Search View for Expedition Collecting -->
        <record id="tw_collecting_expedition_search_view" model="ir.ui.view">
            <field name="name">tw.collecting.expedition.search</field>
            <field name="model">tw.collecting.expedition</field>
            <field name="priority">99</field>
            <field name="arch" type="xml">
                <search string="Collecting Expedition">
                    <field name="name"/>
                    <field name="company_id" string="Branch"/>
                    <field name="partner_id" string="Expedition"/>
                    <field name="division"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Waiting Approval" name="waiting_approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirm')]"/>
                    <filter string="Cancelled" name="cancelled" domain="[('state', '=', 'cancel')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_branch" context="{'group_by': 'company_id'}"/>
                        <filter string="Expedition" name="group_expedition" context="{'group_by': 'partner_id'}"/>
                        <filter string="Division" name="group_division" context="{'group_by': 'division'}"/>
                        <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action for Expedition Collecting -->
        <record id="tw_collecting_expedition_action" model="ir.actions.act_window">
            <field name="name">Collecting Expedition</field>
            <field name="res_model">tw.collecting.expedition</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{'search_default_draft': 1, 'default_type': 'liability_payable', 'default_amount_type': 'credit'}"/>
            <field name="view_ids" eval="[
                (5, 0, 0),
                (0, 0, {'view_mode': 'list', 'view_id': ref('tw_collecting_expedition_list_view')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('tw_collecting_expedition_form_view')})
            ]"/>
            <field name="search_view_id" ref="tw_collecting_expedition_search_view"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first Collecting Expedition
                </p>
            </field>
        </record>

        <!-- Menu Item under Non Trade Backoffice -->
        <menuitem id="menu_collecting_expedition" name="Collecting Expedition" parent="tw_menu.submenu_tw_backoffice_non_trade" action="tw_collecting_expedition_action" sequence="132" groups="tw_collecting_expedition.group_tw_collecting_expedition_read"/>

    </data>
</odoo>
