<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Collecting Expedition Read Group -->
        <record id="group_tw_collecting_expedition_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Collecting Expedition Read</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Collecting Expedition Update Group -->
        <record id="group_tw_collecting_expedition_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Collecting Expedition Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_collecting_expedition_read'))]"/>
        </record>

        <!-- Collecting Expedition Delete Group -->
        <record id="group_tw_collecting_expedition_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Collecting Expedition Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_collecting_expedition_read'))]"/>
        </record>

        <!-- Access Rights for tw.collecting.expedition model -->
        <record id="access_tw_collecting_expedition_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition"/>
            <field name="name">tw_collecting_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_collecting_expedition_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition"/>
            <field name="name">tw_collecting_expedition update</field>
            <field name="group_id" ref="group_tw_collecting_expedition_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="access_tw_collecting_expedition_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition"/>
            <field name="name">tw_collecting_expedition delete</field>
            <field name="group_id" ref="group_tw_collecting_expedition_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Access Rights for tw.stock.inbound model -->
        <record id="access_tw_stock_inbound_expedition_read" model="ir.model.access">
            <field name="model_id" ref="tw_stock_inbound.model_tw_stock_inbound"/>
            <field name="name">tw_stock_inbound_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_stock_inbound_expedition_update" model="ir.model.access">
            <field name="model_id" ref="tw_stock_inbound.model_tw_stock_inbound"/>
            <field name="name">tw_stock_inbound_expedition update</field>
            <field name="group_id" ref="group_tw_collecting_expedition_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- Access Rights for tw.approval model -->
        <record id="access_tw_approval_expedition_read" model="ir.model.access">
            <field name="model_id" ref="tw_approval.model_tw_approval"/>
            <field name="name">tw_approval_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="access_tw_approval_line_expedition_read" model="ir.model.access">
            <field name="model_id" ref="tw_approval.model_tw_approval_line"/>
            <field name="name">tw_approval_line_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- Read Access for Related Models -->
        <record id="access_res_company_expedition_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_company"/>
            <field name="name">res_company_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_partner_expedition_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="name">res_partner_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_account_move_expedition_read" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move"/>
            <field name="name">account_move_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_account_move_line_expedition_read" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="name">account_move_line_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_account_account_expedition_read" model="ir.model.access">
            <field name="model_id" ref="account.model_account_account"/>
            <field name="name">account_account_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_account_journal_expedition_read" model="ir.model.access">
            <field name="model_id" ref="account.model_account_journal"/>
            <field name="name">account_journal_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_currency_expedition_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_currency"/>
            <field name="name">res_currency_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_users_expedition_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_users"/>
            <field name="name">res_users_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Access Rights for tw.collecting.expedition.line model -->
        <record id="access_tw_collecting_expedition_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition_line"/>
            <field name="name">tw_collecting_expedition_line read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_collecting_expedition_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition_line"/>
            <field name="name">tw_collecting_expedition_line update</field>
            <field name="group_id" ref="group_tw_collecting_expedition_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="access_tw_collecting_expedition_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_expedition_line"/>
            <field name="name">tw_collecting_expedition_line delete</field>
            <field name="group_id" ref="group_tw_collecting_expedition_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Read Access for stock.picking, stock.lot, product.product (needed by detail lines) -->
        <record id="access_stock_picking_expedition_read" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="name">stock_picking_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_stock_lot_expedition_read" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_lot"/>
            <field name="name">stock_lot_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_product_product_expedition_read" model="ir.model.access">
            <field name="model_id" ref="product.model_product_product"/>
            <field name="name">product_product_expedition read</field>
            <field name="group_id" ref="group_tw_collecting_expedition_read"/>
            <field name="perm_read">1</field>
        </record>

    </data>

    <!-- Add all Collecting Expedition groups to System Admin -->
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_collecting_expedition_read')),
                (4, ref('group_tw_collecting_expedition_update')),
                (4, ref('group_tw_collecting_expedition_delete')),
            ]"/>
        </record>
    </data>
</odoo>
