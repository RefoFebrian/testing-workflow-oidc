<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_signature_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Signature Read</field>
        </record>

        <record id="group_tw_signature_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Signature Update</field>
        </record>

        <record id="group_tw_signature_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Signature Delete</field>
        </record>

        <!-- Access Rights -->
        <record id="access_tw_signature_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_signature"/>
            <field name="name">tw_signature read</field>
            <field name="group_id" ref="group_tw_signature_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_signature_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_signature"/>
            <field name="name">tw_signature update</field>
            <field name="group_id" ref="group_tw_signature_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_signature_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_signature"/>
            <field name="name">tw_signature delete</field>
            <field name="group_id" ref="group_tw_signature_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_signature_read')),
                (4, ref('group_tw_signature_update')),
                (4, ref('group_tw_signature_delete')),
            ]"/>
        </record>
    </data>
</odoo>
