<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<!-- List View -->
		<record id="tw_signature_list_view" model="ir.ui.view">
			<field name="name">tw.signature.list</field>
			<field name="model">tw.signature</field>
			<field name="arch" type="xml">
				<list string="Signature" editable="top">
					<field name="name" required="1"/>
				</list>
			</field>
		</record>
		
		<!-- Form View -->
		<record id="tw_signature_form_view" model="ir.ui.view">
			<field name="name">tw.signature.form</field>
			<field name="model">tw.signature</field>
			<field name="arch" type="xml">
				<form string="Signature">
					<sheet>
						<div class="oe_title">
							<label for="name" string="Signature Name"/>
							<h1>
								<field name="name" placeholder="e.g. JOHN DOE"/>
							</h1>
						</div>
						<notebook>
							<page string="Audit Trail" name="audit_trail">
								<group>
									<group>
										<field name="create_uid" readonly="1" options="{'no_open':True,'no_create_edit':True}"/>
										<field name="create_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1" options="{'no_open':True,'no_create_edit':True}"/>
										<field name="write_date" readonly="1"/>
									</group>
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>
		
		<!-- Search View -->
		<record id="tw_signature_search_view" model="ir.ui.view">
			<field name="name">tw.signature.search</field>
			<field name="model">tw.signature</field>
			<field name="arch" type="xml">
				<search string="Search Signature">
					<field name="name"/>
				</search>
			</field>
		</record>
		
		<!-- Action -->
		<record id="tw_signature_action" model="ir.actions.act_window">
			<field name="name">Signature</field>
			<field name="res_model">tw.signature</field>
			<field name="view_mode">list,form</field>
		</record>
	</data>
</odoo>
