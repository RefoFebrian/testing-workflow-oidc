<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_birojasa_billing_process_approval_request" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
