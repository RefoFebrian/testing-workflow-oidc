        </record>
        <record id="access_tw_birojasa_billing_process_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_birojasa_billing_process_approval.model_tw_birojasa_billing_process"/>
            <field name="name">tw_birojasa_billing_process_approval_reject update</field>
            <field name="group_id" ref="group_tw_birojasa_billing_process_approval_reject"/>
            <field name="perm_write">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
				<field name="implied_ids" eval="[
                (4,ref('group_tw_birojasa_billing_process_approval_cancel')),
                (4,ref('group_tw_birojasa_billing_process_approval_reject')),
                (4,ref('group_tw_birojasa_billing_process_approval_request')),
            ]">
			</field>
		</record>
    </data>
</odoo>
