        </record>
        <record id="access_tw_birojasa_billing_process_approval_request" model="ir.model.access">
            <field name="model_id" ref="tw_birojasa_billing_process_approval.model_tw_birojasa_billing_process"/>
            <field name="name">tw_birojasa_billing_process_approval_request update</field>
            <field name="group_id" ref="group_tw_birojasa_billing_process_approval_request"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_birojasa_billing_process_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Button Cancel Approval Birojasa Billing Process</field>
        </record>
        <record id="access_tw_birojasa_billing_process_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_birojasa_billing_process_approval.model_tw_birojasa_billing_process"/>
            <field name="name">tw_birojasa_billing_process_approval_cancel update</field>
            <field name="group_id" ref="group_tw_birojasa_billing_process_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_birojasa_billing_process_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
