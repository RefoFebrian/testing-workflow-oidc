<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Mutation Request Confirm -->
		<record id="group_tw_mutation_request_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Mutation Request Confirm</field>
        </record>

        <!-- Mutation Request Cancel -->
		<record id="group_tw_mutation_request_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Mutation Request Cancel</field>
        </record>
        
        <record id="access_tw_mutation_request_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_mutation_request"/>
            <field name="name">TW Button Mutation Request Cancel</field>
            <field name="group_id" ref="group_tw_mutation_request_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Mutation Request View Picking -->
        <record id="group_tw_mutation_request_view_picking_showroom" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Mutation Request View Picking Showroom</field>
        </record>

        <record id="group_tw_mutation_request_view_picking_workshop" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Mutation Request View Picking Workshop</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_mutation_request_confirm')),
				(4,ref('group_tw_mutation_request_cancel')),
				(4,ref('group_tw_mutation_request_view_picking_showroom')),
				(4,ref('group_tw_mutation_request_view_picking_workshop')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>