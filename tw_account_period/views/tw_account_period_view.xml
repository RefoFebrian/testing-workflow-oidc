<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_account_period_list_view" model="ir.ui.view">
            <field name="name">tw.account.period.list</field>
            <field name="model">tw.account.period</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Account Period">
                    <field name="company_id"/>
                    <field name="name"/>
					<field name="code"/>
					<field name="date_from"/>
					<field name="date_to"/>
					<field name="special"/>
					<field name="state" widget="badge" decoration-muted="state == 'done'" decoration-success="state == 'draft'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_account_period_form_view" model="ir.ui.view">
            <field name="name">tw.account.period.form</field>
            <field name="model">tw.account.period</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Account Period">
                    <header>
                        <button name="action_close_period" invisible="state != 'draft'" string="Close Period" type="object" class="oe_highlight"/>
                        <button name="action_draft_period" invisible="state != 'done'" string="Re-Open Period" type="object"/>
                        <field name="state" widget="statusbar" nolabel="1"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <label for="date_from" string="Duration"/>
                                <div>
                                    <field name="date_from" readonly="state == 'done'" required="1" class="oe_inline" nolabel="1"/> -
                                    <field name="date_to" readonly="state == 'done'" required="1" nolabel="1" class="oe_inline"/>
                                </div>
                            </group>
                            <group>
                                <field name="code"/>
                                <field name="company_id"/>
                                <field name="special"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_account_period_search_view" model="ir.ui.view">
            <field name="name">tw.account.period.search</field>
            <field name="model">tw.account.period</field>
            <field name="arch" type="xml">
                <search string="Account Period">
                    <field name="name" filter_domain="['|', ('name','ilike',self), ('code','ilike',self)]" string="Period" select="True"/>
                    <field name="code"/>
                    <filter string="To Close" name="state_draft" domain="[('state','=','draft')]" icon="terp-dialog-close"/>
                    <group expand="1" string="Group By">
                        <filter string="Period" name="group_by_period" domain="[]" context="{'group_by': 'date_from: year'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_account_period_action" model="ir.actions.server">
            <field name="name">Periods</field>
            <field name="model_id" ref="tw_account_period.model_tw_account_period"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.account.period'].action_account_period_tree()
            </field>
        </record>
        
    </data>
</odoo>