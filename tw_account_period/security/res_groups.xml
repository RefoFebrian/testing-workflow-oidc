<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- Master Account Period Group Read -->
        <record id="group_tw_account_period_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Master Account Period Read</field>
        </record>
        <record id="access_tw_account_period_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_period"/>
            <field name="name">tw_account_period read</field>
            <field name="group_id" ref="group_tw_account_period_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Master Account Period Group Update -->
        <record id="group_tw_account_period_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Master Account Period Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_period_read'))]"/>
        </record>
        <record id="access_tw_account_period_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_period"/>
            <field name="name">tw_account_period update</field>
            <field name="group_id" ref="group_tw_account_period_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Master Account Period Group Delete -->
        <record id="group_tw_account_period_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Master Account Period Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_period_read'))]"/>
        </record>
        <record id="access_tw_account_period_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_period"/>
            <field name="name">tw_account_period delete</field>
            <field name="group_id" ref="group_tw_account_period_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_account_period_read')),
                (4,ref('group_tw_account_period_update')),
                (4,ref('group_tw_account_period_delete')),
            ]"/>
        </record>
    </data>
</odoo>