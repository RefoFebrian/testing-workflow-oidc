<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="tw_ir_cron_generate_popeye_statements_bank_bca" model="ir.cron">
            <field name="name">Popeye Bank Mutation BCA</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=2, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="model_id" ref="model_tw_api_configuration"/>
            <field name="code">model.schedule_popeye_statements(None, None, None, 'bca')</field>
            <field eval="False" name="active"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
    </data>
</odoo>