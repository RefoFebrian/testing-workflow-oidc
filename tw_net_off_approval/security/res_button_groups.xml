<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_net_off_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Request Approval Net Off</field>
        </record>
        
        <record id="access_tw_net_off_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_net_off.model_tw_net_off"/>
            <field name="name">tw_net_off RFA</field>
            <field name="group_id" ref="group_tw_net_off_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Cancel Payment -->
		
        <record id="group_tw_net_off_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cancel Net Off</field>
        </record>
        <record id="access_tw_net_off_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_net_off.model_tw_net_off"/>
            <field name="name">tw_net_off Cancel Approval</field>
            <field name="group_id" ref="group_tw_net_off_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        
        <!-- Reject Payment -->
		
        <record id="group_tw_net_off_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Reject Net Off</field>
        </record>
        <record id="access_tw_net_off_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_net_off.model_tw_net_off"/>
            <field name="name">tw_net_off Reject Approval</field>
            <field name="group_id" ref="group_tw_net_off_reject_approval"/>
            <field name="perm_write">1</field>
        </record>
          

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_net_off_rfa')),
                (4, ref('group_tw_net_off_cancel_approval')),
                (4, ref('group_tw_net_off_reject_approval')),
            ]"/>
        </record>
    </data>

</odoo>
