<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="view_tw_sale_discount_items_upload" model="ir.ui.view">
			<field name="name">tw.sale.discount.items.upload.view</field>
			<field name="model">tw.sale.discount.items.upload</field>
			<field name="arch" type="xml">
				<form string="Upload Discount">
					<sheet>
                        <group>
                            <field name="categ_ids" widget="many2many_tags" required="1" options="{'no_create':True}"/>
                            <field name="file" filename="filename" string="Upload File"/>
                            <field name="filename" invisible="1"/>
                            <field name="upload_date" readonly="1"/>
                        </group>
					</sheet>
                    <footer>
 		                <button name="action_upload" string="Upload" type="object" class="oe_highlight"/>
		                or
  		                <button string="Cancel" class="oe_link" special="cancel"/>
		            </footer>
				</form>
			</field>
		</record>

        <record id="tw_sale_order_discount_upload_menuitem" model="ir.actions.act_window">
            <field name="name">Upload Master Discount</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.sale.discount.items.upload</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tw_sale_discount_items_upload"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>