<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="view_tw_sale_discount_items_list" model="ir.ui.view">
            <field name="name">tw.sale.discount.items.list</field>
            <field name="model">tw.sale.discount.items</field>
            <field name="arch" type="xml">
            	<list string="Master Discount" editable="top">
                    <field name="categ_id" required="1" options="{'no_create':True,'no_open':True}" string="Category"/>
                    <field name="product_id" options="{'no_create':True,'no_open':True}" string="Specific Products" domain="[('categ_id', 'child_of', categ_id)]"/>
                    <field name="additional" required="1"/>
                    <field name="fix" required="1"/>
                    <field name="topup" required="1"/>
                    <field name="simpart" required="1"/>
                    <field name="hotline" required="1"/>
            	</list>
            </field>
        </record>

        <record id="tw_sale_discount_items_search" model="ir.ui.view">
            <field name="name">tw.sale.discount.items.search</field>
            <field name="model">tw.sale.discount.items</field>
            <field name="arch" type="xml">
                <search string="Search Master Discount">
                    <field name="categ_id"/>
                    <field name="product_id"/>
                    <filter name="category" string="Category" domain="[('categ_id', '=', 'value')]" context="{'group_by': 'categ_id'}" />
                </search>
            </field>
        </record>

        <record id="action_tw_sale_discount_items" model="ir.actions.act_window">
			<field name="name">Master Discount</field>
			<field name="res_model">tw.sale.discount.items</field>
			<field name="view_mode">list,form</field>
		</record>
    </data>
</odoo>