<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="view_tw_master_ahass_top_list" model="ir.ui.view" >
            <field name="name">tw.master.ahass.top.list</field>
            <field name="model">tw.master.ahass.top</field>
            <field name="arch" type="xml">
            	<list string="Master AHASS TOP">
                    <field name="partner_id"/>
                </list>
            </field>
        </record>

        <record id="view_tw_master_ahass_top_form" model="ir.ui.view">
			<field name="name">tw.master.ahass.top.form</field>
			<field name="model">tw.master.ahass.top</field>
			<field name="arch" type="xml">
				<form>
					<sheet>
						<group>
							<group>
								<field name="partner_id" required="1" options="{'no_create':True,'no_open':True}"/>
							</group>
						</group>
					 	<notebook>
					 		<page string="Detail">
					 			<field name="master_ahass_top_ids">
					 				<list editable="top">
										<field name="categ_id" options="{'no_create':True,'no_open':True}" string="Category"/>
										<field name="discount_cash_id" required="1" options="{'no_create':True,'no_open':True}" string="Discount Cash"/>
					 				</list>
					 			</field>
					 		</page>
							<page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
									</group>
								</group>
							</page>
			            </notebook>
					</sheet>
				</form>
			</field>
		</record>

		<record id="tw_master_ahass_top_search" model="ir.ui.view">
            <field name="name">tw.master.ahass.top.search</field>
            <field name="model">tw.master.ahass.top</field>
            <field name="arch" type="xml">
                <search string="Search Master Discount AHASS TOP">
        			<field name="partner_id"/>
					<group string="Group By">
                        <filter string="Dealer" domain="[]" name="group_by_dealer" context="{'group_by':'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_master_ahass_top_action" model="ir.actions.act_window">
			<field name="name">Master AHASS TOP</field>
			<field name="res_model">tw.master.ahass.top</field>
			<field name="view_mode">list,form</field>
		</record>
    </data>
</odoo>