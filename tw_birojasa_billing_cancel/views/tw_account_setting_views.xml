<odoo>
    <data>
  
      <record id="tw_birojasa_billing_cancel_branch_setting_form_view" model="ir.ui.view">
          <field name="name">tw.birojasa.billing.cancel.branch.setting.inherit.form</field>
          <field name="model">tw.account.setting</field>
          <field name="inherit_id" ref="tw_birojasa_billing_process.tw_account_settings_birojasa_inherit_view"/>
          <field name="arch" type="xml">
              <xpath expr="//group[@name='birojasa_journal_cancel']" position="inside">
                  <field name="journal_birojasa_billing_cancel_id" options="{'no_create': True}"/>
              </xpath>
          </field>
      </record>
  
    </data>
  </odoo>
  