			<field name="perm_write">1</field>
		</record>
		
		<record id="tw_master_target_margin_line_access_button_confirmed_update" model="ir.model.access">
			<field name="model_id" ref="tw_incentive.model_tw_master_target_margin_line"/>
			<field name="name">button_confirmed_tw_master_target_margin_line update"</field>
			<field name="group_id" ref="tw_profit_before_tax_group_button_confirmed"/>
			<field name="perm_create">1</field>
			<field name="perm_write">1</field>
		</record>

		<!-- Approved Input Net Margin Line -->
		<record id="tw_profit_before_tax_line_group_button_approved" model="res.groups">
			<field name="category_id" ref="tw_profit_before_tax.tw_module_category_profit_before_tax"/>
			<field name="name">TW Button Approved Input Net Margin Line</field>
		</record>

		<record id="tw_profit_before_tax_line_access_button_approved_read" model="ir.model.access">
			<field name="model_id" ref="model_tw_profit_before_tax_line"/>
