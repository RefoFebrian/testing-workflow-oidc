		</record>

		<record id="tw_profit_before_tax_line_access_button_rejected_read" model="ir.model.access">
			<field name="model_id" ref="model_tw_profit_before_tax_line"/>
			<field name="name">button_rejected_tw_profit_before_tax_line read"</field>
			<field name="group_id" ref="tw_profit_before_tax_line_group_button_rejected"/>
			<field name="perm_write">1</field>
		</record>
    </data>
	
	<data>
 		<record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('tw_profit_before_tax_group_button_approved')),
				(4,ref('tw_profit_before_tax_group_button_rejected')),
				(4,ref('tw_profit_before_tax_line_group_button_approved')),
				(4,ref('tw_profit_before_tax_line_group_button_rejected')),
				]" />
		</record>
	</data>
