		</record>

		<!-- Rejected Input Net Margin Line -->
		<record id="tw_profit_before_tax_line_group_button_rejected" model="res.groups">
			<field name="category_id" ref="tw_profit_before_tax.tw_module_category_profit_before_tax"/>
