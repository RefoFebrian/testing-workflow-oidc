<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_birojasa_billing_process_report_view" model="ir.ui.view">
            <field name="name">tw.birojasa.billing.process.report.wizard</field>
            <field name="model">tw.birojasa.billing.process.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report PRBJ">
                    <group>
                        <group>
                            <field name="biro_jasa_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <label for="start_date" string="Date"/>
                            <div>
                                <field name="start_date" class="oe_inline" required="1"/>
                                <field name="end_date" class="oe_inline" required="1"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
							<field name="company_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
								<list decoration-muted="1" limit="100" editable="top">
									<field name="code" force_save="1"/>
									<field name="name" force_save="1"/>
								</list>
							</field>
						</page>
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_birojasa_billing_process_report_action" model="ir.actions.act_window">
            <field name="name">Laporan PRBJ</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.birojasa.billing.process.report</field>
            <field name="view_id" ref="tw_birojasa_billing_process_report_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>