<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_vehicle_document_report_view" model="ir.ui.view">
            <field name="name">tw.vehicle.document.report.wizard</field>
            <field name="model">tw.vehicle.document.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report Vehicle Document">
                    <group>
                        <group>
                            <field name="options" required="1"/>
                            <label for="start_date" string="Date" invisible="options not in ('lead_time','tracking_document')"/>
                            <div>
                                <field name="start_date" class="oe_inline" invisible="options not in ('lead_time','tracking_document')"/>
                                <field name="end_date" class="oe_inline" invisible="options not in ('lead_time','tracking_document')"/>
                            </div>
                        </group>
                        <group>
                            <field name="lot_ids" widget="many2many_tags"/>
                            <field name="status_lead_time" invisible="options!='lead_time'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="code" force_save="1" readonly="1"/>
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Birojasa">
                            <field name="biro_jasa_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Finco">
                            <field name="finco_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Customer">
                            <field name="customer_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="STNK Location" invisible="options == 'stock_ownership'">
                            <field name="vehicle_registration_location_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="BPKB Location" invisible="options == 'stock_registration'">
                            <field name="vehicle_ownership_location_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}">
                                <list decoration-muted="1" limit="100" editable="top">
                                    <field name="name" force_save="1" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="tw_vehicle_document_report_action" model="ir.actions.act_window">
            <field name="name">Laporan STNK BPKB</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.vehicle.document.report</field>
            <field name="view_id" ref="tw_vehicle_document_report_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>