<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Stock Report Group -->
        <record id="tw_group_tw_vehicle_document_laporan" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Laporan STNK BPKB</field>
        </record>
        <record id="tw_access_tw_vehicle_document_laporan" model="ir.model.access">
            <field name="model_id" ref="tw_vehicle_document_report.model_tw_vehicle_document_report"/>
            <field name="name">tw_vehicle_document_laporan</field>
            <field name="group_id" ref="tw_group_tw_vehicle_document_laporan"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Birojasa Billing Process Report Group -->
        <record id="tw_group_tw_birojasa_billing_process_laporan" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Laporan PRBJ</field>
        </record>
        <record id="tw_access_tw_birojasa_billing_process_laporan" model="ir.model.access">
            <field name="model_id" ref="tw_vehicle_document_report.model_tw_birojasa_billing_process_report"/>
            <field name="name">tw_birojasa_billing_process_laporan</field>
            <field name="group_id" ref="tw_group_tw_birojasa_billing_process_laporan"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_group_tw_vehicle_document_laporan')),
                (4,ref('tw_group_tw_birojasa_billing_process_laporan')),
            ]"/>
        </record>
    </data>
</odoo>