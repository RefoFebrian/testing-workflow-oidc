<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Tree View -->
        <record id="tw_lead_crm_matrix_assignment_list_view" model="ir.ui.view">
            <field name="name">tw.lead.crm.matrix.assignment.list</field>
            <field name="model">tw.lead.crm.matrix.assignment</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Matrix Lead Assignment">
                    <field name="data_source" required="1"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_lead_crm_matrix_assignment_form_view" model="ir.ui.view">
            <field name="name">tw.lead.crm.matrix.assignment.form</field>
            <field name="model">tw.lead.crm.matrix.assignment</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Matrix Lead Assignment">
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="data_source" required="1"/>
                            </h1>
                        </div>
                        <notebook>
                            <page name="line_ids" string="Detail">
                                <field name="line_ids" editable="top">
                                    <list editable="bottom">
                                        <field name="job_id" required="1"/>
                                        <field name="sequence" required="1"/>
                                        <field name="matrix_assignment_id" invisible="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail" invisible="create_uid == False">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_lead_crm_matrix_assignment_search_view" model="ir.ui.view">
            <field name="name">tw.lead.crm.matrix.assignment.search</field>
            <field name="model">tw.lead.crm.matrix.assignment</field>
            <field name="arch" type="xml">
                <search string="Matrix Lead Assignment">
                    <field name="data_source" select="True"/>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_lead_crm_matrix_assignment_action" model="ir.actions.server">
            <field name="name">Matrix Lead Assignment</field>
            <field name="model_id" ref="tw_lead_crm.model_tw_lead_crm_matrix_assignment"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.lead.crm.matrix.assignment'].action_lead_crm_matrix_assignment_tree()
            </field>
        </record>
        
    </data>
</odoo>