            <field name="group_id" ref="group_tw_incentive_partner_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_incentive_partner_line_detail_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_incentive_partner_line_detail" />
            <field name="name">access_tw_incentive_partner_line_detail delete</field>
            <field name="group_id" ref="group_tw_incentive_partner_delete" />
            <field name="perm_unlink">1</field>
        </record>

    </data>
    
    <data noupdate="1">
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_incentive_partner_read')),
                (4, ref('group_tw_incentive_partner_update')),
                (4, ref('group_tw_incentive_partner_delete')),
            ]" />
        </record>
    </data>
</odoo>
