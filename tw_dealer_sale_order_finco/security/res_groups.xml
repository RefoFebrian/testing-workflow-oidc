<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Incentive Finco Line -->
        <record id="group_tw_incentive_partner_read" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order" />
            <field name="name">TW Incentive Finco Line Read</field>
        </record>

        <record id="access_tw_incentive_partner_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_incentive_partner_line" />
            <field name="name">access_tw_incentive_partner_line read</field>
            <field name="group_id" ref="group_tw_incentive_partner_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_incentive_partner_line_detail_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_incentive_partner_line_detail" />
            <field name="name">access_tw_incentive_partner_line_detail read</field>
            <field name="group_id" ref="group_tw_incentive_partner_read" />
            <field name="perm_read">1</field>
        </record>
        
        <record id="group_tw_incentive_partner_update" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order" />
            <field name="name">TW Incentive Finco Line Update</field>
        </record>

        <record id="access_tw_incentive_partner_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_incentive_partner_line" />
            <field name="name">access_tw_incentive_partner_line update</field>
            <field name="group_id" ref="group_tw_incentive_partner_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_incentive_partner_line_detail_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_incentive_partner_line_detail" />
            <field name="name">access_tw_incentive_partner_line_detail update</field>
            <field name="group_id" ref="group_tw_incentive_partner_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_incentive_partner_delete" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order" />
