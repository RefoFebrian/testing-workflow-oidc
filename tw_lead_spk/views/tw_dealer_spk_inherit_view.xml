<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_dealer_spk_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.dealer.spk.inherit.form.view</field>
            <field name="model">tw.dealer.spk</field>
            <field name="inherit_id" ref="tw_spk.tw_dealer_spk_form_view" />
            <field name="arch" type="xml">

                <field name="dso_count" position="before" >
                    <field name="lead_count" invisible="1" />
                </field>
                
                <button name="action_view_so" position="before">
                    <button name="action_view_lead"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text"
                            invisible="lead_count == 0">
                        <field name="lead_count" widget="statinfo" string="Lead"/>
                    </button>
                </button>
            </field>
        </record>
    </data>
</odoo>