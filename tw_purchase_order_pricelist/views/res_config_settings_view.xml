<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_inherit_purchase_form_view" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.purchase</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <setting id="auto_receipt_reminder" position="after">
                <setting id="only_use_pricelist" string="Only Use Pricelist" title="The price of products in the Purchase Order is readonly, if unchecklist then it only defaults, but is not readonly." help="The price of products in the Purchase Order is readonly, if unchecklist then it only defaults, but is not readonly.">
                    <field name="is_only_use_pricelist"/>
                </setting>
            </setting>
        </field>
    </record>
</odoo>