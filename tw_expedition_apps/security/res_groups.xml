<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- TW Monitoring Expedition Apps -->
        <record id="group_tw_monitoring_expedition_apps_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Expedition Apps Read</field>
        </record>
        
        <record id="access_tw_monitoring_expedition_apps_read" model="ir.model.access">
            <field name="model_id" ref="tw_stock.model_stock_picking"/>
            <field name="name">tw_monitoring_expedition_apps read</field>
            <field name="group_id" ref="group_tw_monitoring_expedition_apps_read"/>
            <field name="perm_read">1</field>
        </record> 
                
        <record id="group_tw_monitoring_expedition_apps_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Expedition Apps Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_monitoring_expedition_apps_read'))]"/>                             
        </record>
                        
        <record id="access_tw_monitoring_expedition_apps_update" model="ir.model.access">
            <field name="model_id" ref="tw_stock.model_stock_picking"/>
            <field name="name">tw_monitoring_expedition_apps update</field>
            <field name="group_id" ref="group_tw_monitoring_expedition_apps_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>      

        <record id="group_tw_monitoring_expedition_apps_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Expedition Apps Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_monitoring_expedition_apps_read'))]"/>                             
        </record>
                        
        <record id="access_tw_monitoring_expedition_apps_delete" model="ir.model.access">
            <field name="model_id" ref="tw_stock.model_stock_picking"/>
            <field name="name">tw_monitoring_expedition_apps delete</field>
            <field name="group_id" ref="group_tw_monitoring_expedition_apps_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    <!-- TW Assign Delivery Driver -->
        <record id="group_tw_assign_delivery_driver_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Assign Delivery Driver Read</field>
        </record>
        
        <record id="access_tw_assign_delivery_driver_read" model="ir.model.access">
            <field name="model_id" ref="tw_expedition_apps.model_tw_assign_delivery_driver_wizard"/>
            <field name="name">tw_assign_delivery_driver read</field>
            <field name="group_id" ref="group_tw_assign_delivery_driver_read"/>
            <field name="perm_read">1</field>
        </record> 
                
        <record id="group_tw_assign_delivery_driver_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Assign Delivery Driver Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_assign_delivery_driver_read'))]"/>                             
        </record>
                        
        <record id="access_tw_assign_delivery_driver_update" model="ir.model.access">
            <field name="model_id" ref="tw_expedition_apps.model_tw_assign_delivery_driver_wizard"/>
            <field name="name">tw_assign_delivery_driver update</field>
            <field name="group_id" ref="group_tw_assign_delivery_driver_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>      

        <record id="group_tw_assign_delivery_driver_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Assign Delivery Driver Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_assign_delivery_driver_read'))]"/>                             
        </record>
                        
        <record id="access_tw_assign_delivery_driver_delete" model="ir.model.access">
            <field name="model_id" ref="tw_expedition_apps.model_tw_assign_delivery_driver_wizard"/>
            <field name="name">tw_assign_delivery_driver delete</field>
            <field name="group_id" ref="group_tw_assign_delivery_driver_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_monitoring_expedition_apps_read')),
                (4,ref('group_tw_monitoring_expedition_apps_update')),
                (4,ref('group_tw_monitoring_expedition_apps_delete')),
                (4,ref('group_tw_assign_delivery_driver_read')),
                (4,ref('group_tw_assign_delivery_driver_update')),
                (4,ref('group_tw_assign_delivery_driver_delete')),
                ]" />
        </record>         
    </data>
</odoo>