<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_monitoring_expedition_apps_assigned_list_view" model="ir.ui.view">
            <field name="name">tw.monitoring.expedition.apps.assigned.list.view</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <list string="Monitoring Expedition" create="0" edit="0" delete="0" duplicate="0" default_order="validate_date asc">
                    <field name="name" readonly="1"/>
                    <field name="origin" readonly="1"/>
                    <field name="picking_type_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="company_id" string="Branch" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="partner_id" string="Receive Dealer" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="division" readonly="1"/>
                    <field name="validate_date" readonly="1"/>
                    <field name="delivery_driver_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="assign_driver_date" readonly="1" optional="hide"/>
                    <field name="delivery_state" readonly="1" widget="badge" decoration-danger="delivery_state == 'intransit'" decoration-success="delivery_state == 'delivered'"/>
                </list>
            </field>
        </record>

        <record id="tw_monitoring_expedition_apps_list_view" model="ir.ui.view">
            <field name="name">tw.monitoring.expedition.apps.list.view</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <list string="Monitoring Expedition" create="0" edit="0" delete="0" duplicate="0" default_order="validate_date asc">
                    <header>
                        <button name="action_assign_delivery_driver" string="Assign Delivery Driver" type="object" class="oe_highlight" groups="tw_expedition_apps.group_tw_assign_delivery_driver" display="always"/>
                    </header>
                    <field name="name" readonly="1"/>
                    <field name="origin" readonly="1"/>
                    <field name="picking_type_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="company_id" string="Branch" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="partner_id" string="Receive Dealer" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="division" readonly="1"/>
                    <field name="validate_date" readonly="1"/>
                    <field name="delivery_driver_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="assign_driver_date" readonly="1" optional="hide"/>
                    <field name="delivery_state" readonly="1" widget="badge" decoration-danger="delivery_state == 'intransit'" decoration-success="delivery_state == 'delivered'"/>
                </list>
            </field>
        </record>

        <record id="tw_monitoring_expedition_apps_form_view" model="ir.ui.view">
            <field name="name">tw.monitoring.expedition.apps.form.view</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <form string="Monitoring Expedition" create="0" edit="1" delete="0" duplicate="0">
                    <header>
                        <field name="delivery_state" widget="statusbar" statusbar_visible="draft,intransit,delivered"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1 class="d-flex">
                                <field name="priority" widget="priority" class="me-3"/>
                                <div invisible="id">New <field name="picking_type_code"/></div>
                                <field name="name" invisible="not id"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" string="Branch" placeholder="e.g. Name/Code Dealer" options="{'no_create': True,'no_open': True}" readonly="1"/>
                                <field name="partner_id" string="Receive Dealer" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                <field name="picking_type_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                <field name="location_id" domain="[('company_id', '=', company_id)]" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                <field name="location_dest_id" domain="[('company_id', '=', company_id)]" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                <field name="backorder_id" invisible="not backorder_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="division" placeholder="e.g. Division" options="{'no_create': True,'no_open': True}" readonly="1"/>
                                <field name="date" string="Date" readonly="1"/>
                                <field name="date_done" string="Effective Date" invisible="state != 'done'" readonly="1"/>
                                <field name="origin" string="Source Document" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Operations" name="operations">
                                <field name="move_ids_without_extras" mode="list,kanban"
                                    widget="stock_move_one2many"
                                    readonly="1"
                                    context="{'default_company_id': company_id, 'default_date_deadline': date_deadline, 'picking_type_code': picking_type_code, 'default_picking_id': id, 'form_view_ref': 'stock.view_stock_move_operations', 'address_in_id': partner_id, 'default_picking_type_id': picking_type_id, 'default_location_id': location_id, 'default_location_dest_id': location_dest_id, 'default_partner_id': partner_id}"
                                    add-label="Add a Product">
                                    <list decoration-muted="scrapped == True or state == 'cancel' or (state == 'done' and is_locked == True)" string="Stock Moves" editable="bottom">
                                        <field name="name" column_invisible="True"/>
                                        <field name="company_id" column_invisible="True"/>
                                        <field name="state" readonly="0" column_invisible="True"/>
                                        <field name="is_quantity_done_editable" column_invisible="True"/>
                                        <field name="scrapped" column_invisible="True"/>
                                        <field name="show_details_visible" column_invisible="True"/>
                                        <field name="product_id" required="1" readonly="state != 'draft'" force_save="1" 
                                            options="{'no_create': True,'no_open': True}"
                                            context="{'default_detailed_type': 'product'}" 
                                            domain="[('product_tmpl_id.division','=',parent.division)]"/>
                                        <field name="description_picking" string="Description" optional="hide"/>
                                        <field name="date" optional="hide"/>
                                        <field name="date_deadline" optional="hide"/>
                                        <field name="product_uom_qty" string="Quantity" readonly="parent.state != 'draft'"/>
                                        <field name="qty_available" string="Qty Available" readonly="parent.state != 'draft'"/>
                                        <field name="quantity" string="Qty Request" column_invisible="True"/>
                                    </list>
                                </field>
                            </page>
                            <page name="delivery_info" string="Delivery Info">
                                <group string="Tracking Delivery">
                                    <group>
                                        <field name="delivery_driver_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                        <field name="assign_driver_date" readonly="1"/>
                                        <field name="assign_driver_uid" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                    </group>
                                    <group>
                                        <field name="intransit_date" readonly="1"/>
                                        <field name="intransit_uid" readonly="1" options="{'no_create': True,'no_open': True}"/>
                                        <field name="delivery_date" readonly="1"/>
                                    </group>
                                </group>
                                <group string="Delivery Document">
                                    <field name="filename_upload_image" invisible="1"/>
                                    <field name="file_image_show" widget="image" img_width="200" img_height="200" invisible="filename_upload_image == False"/>
                                    <field name="file_image" invisible="filename_upload_image != False" filename="filename_upload_image"/><br/>
                                </group>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_create': True,'no_open': True}"></field>
                                        <field name="create_date" readonly="1"></field>
                                    </group>
                                    <group>							
                                        <field name="write_uid" readonly="1" options="{'no_create': True,'no_open': True}"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="tw_monitoring_expedition_apps_search_view" model="ir.ui.view">
            <field name="name">tw.monitoring.expedition.apps.search</field>
            <field name="model">stock.picking</field>
            <field name="arch" type="xml">
                <search string="Search Monitoring Expedition">
                    <field name="name"/>
                    <field name="origin"/>
                    <field name="delivery_driver_id"/>
                    <field name="picking_type_id"/>
                    <field name="company_id"/>
                    <field name="partner_id"/>
                    <field name="date"/>
                    <field name="assign_driver_date"/>
                    <field name="delivery_state"/>
                    <filter name="delivery_state_draft" string="Draft" domain="[('delivery_state','=','draft')]"/>
                    <filter name="delivery_state_intransit" string="Intransit" domain="[('delivery_state','=','intransit')]"/>
                    <filter name="delivery_state_delivered" string="Delivered" domain="[('delivery_state','=','delivered')]"/>
                    <filter name="delivery_driver_not_assigned" string="Driver Not Assigned" domain="[('delivery_driver_id','=',False)]"/>
                    <group expand="1" string="Group By">
                        <filter string="Picking Type" name="group_by_picking_type" context="{'group_by':'picking_type_id'}"/>
                        <filter string="Partner" name="group_by_partner" context="{'group_by':'partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tw_monitoring_expedition_apps" model="ir.actions.act_window">
            <field name="name">Monitoring Expedition</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{
                'search_default_delivery_driver_not_assigned': 1, 
                'search_default_group_by_picking_type': 1,
                'search_default_group_by_partner': 1,
            }"/>
            <field name="domain" eval="[
                ('validate_date', '!=', False),
                '|',
                '&amp;',
                ('picking_type_id.code', '=', 'outgoing'),
                '|',
                '|',
                ('mutation_order_id', '!=', False),
                ('sale_order_id', '!=', False),
                ('dealer_sale_order_id', '!=', False),
                ('name', 'ilike', 'MU')
            ]"/>
            <field name="search_view_id" ref="tw_expedition_apps.tw_monitoring_expedition_apps_search_view"/>
        </record>

        <record id="action_tw_monitoring_expedition_apps_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_monitoring_expedition_apps_list_view"/>
            <field name="act_window_id" ref="action_tw_monitoring_expedition_apps"/>
        </record>

        <record id="action_tw_monitoring_expedition_apps_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_monitoring_expedition_apps_form_view"/>
            <field name="act_window_id" ref="action_tw_monitoring_expedition_apps"/>
        </record>
    </data>
</odoo>
