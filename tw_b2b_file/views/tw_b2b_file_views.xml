<odoo>
	<data>
		
		<!-- B2B FILE -->
			<record id="tw_b2b_file_list_view" model="ir.ui.view">
				<field name="name">tw.b2b.file.tree</field>
				<field name="model">tw.b2b.file</field>
				<field name="type">list</field>
				<field eval="10" name="priority" />
				<field name="arch" type="xml">
					<list string="B2B Files" default_order="id desc" edit="false" create="false" delete="false">
						<field name="name"/>
						<field name="ext"/>
						<field name="upload_date" optional="hide"/>
						<field name="create_date" optional="show"/>
						<field name="state"
							   widget="badge"
							   decoration-danger="state == 'error'"
							   decoration-warning="state in ('duplicate', 'partially_error')"
							   decoration-success="state == 'done'"
							   decoration-info="state in ('open', 'batch_loading')"/>
					</list>
				</field>
			</record>

			<record id="tw_b2b_file_form_view" model="ir.ui.view">
				<field name="name">tw.b2b.file.form</field>
				<field name="model">tw.b2b.file</field>
				<field name="arch" type="xml">
					<form string="B2B Files" create="false" delete="false">
						<header>
							<button string="Process"
									name="action_process"
									invisible="state not in ('open', 'batch_loading')"
									type="object"
									data-hotkey="p"
									class="btn btn-info"
									groups="tw_b2b_file.tw_b2b_file_group_button_read_folder_process" />
							<button string="Re-Open"
									name="action_re_open_state"
									invisible="state not in ('partially_error','error')"
									type="object"
									data-hotkey="d"
									class="btn btn-warning"
									groups="tw_b2b_file.tw_b2b_file_group_button_re_open_state" />
							<button string="Close"
									name="action_close"
									invisible="state not in ('partially_error','error','duplicate')"
									type="object"
									data-hotkey="x"
									class="btn btn-danger"
									groups="tw_b2b_file.tw_b2b_file_group_button_re_open_state" />
							<field name="state" widget="statusbar" statusbar_visible="open,done" />
						</header>
						<sheet>
							<div class="oe_title">
								<label for="name" placeholder="File Name" />
								<h1>
									<field name="name" placeholder="e.g. file_name.pmp" required="1" readonly="1"/>
								</h1>
							</div>
							<group>
								<field name="upload_date" readonly="1" />
								<field name="config_id" required="1" readonly="1" options="{'no_open': True, 'no_create': True}"/>
							</group>
							<group string="Content Summary" readonly="1" invisible="state != 'open'">
								<field name="content_open_count"/>
								<field name="content_error_count"/>
								<field name="content_done_count"/>
							</group>
							<group string="Batch Processing" invisible="not batch_file_path">
								<field name="batch_file_path" readonly="1"/>
								<field name="batch_file_size" readonly="1"/>
								<field name="batch_total_records" readonly="1"/>
								<field name="batch_offset" readonly="1"/>
								<field name="batch_limit" readonly="state != 'batch_loading'"/>
							</group>
							<notebook>
								<page name="content_file" string="Content of File">
									<button string="Open Content List"
											name="action_open_content_list"
											type="object"
											class="btn btn-secondary"
											icon="fa-external-link"/>
									<field name="content_file_ids" readonly="1"
										context="{
											'list_view_ref': 'tw_b2b_file.tw_b2b_file_content_list_view',
											'form_view_ref': 'tw_b2b_file.tw_b2b_file_content_form_view'
										}" />
								</page>
								<page string="Audit Trail">
									<group readonly="1">
										<group>
											<field name="create_uid" options="{'no_open': True, 'no_create': True}"/>
											<field name="create_date" />
										</group>
										<group>
											<field name="write_uid" options="{'no_open': True, 'no_create': True}"/>
											<field name="write_date" />
										</group>
									</group>
								</page>
							</notebook>
						</sheet>
					</form>
				</field>
			</record>

			<record id="tw_b2b_file_search_view" model="ir.ui.view">
				<field name="name">tw.b2b.file.search</field>
				<field name="model">tw.b2b.file</field>
				<field name="arch" type="xml">
					<search string="MFT File">
						<field name="name" string="Filename"/>
						<field name="ext"/>
						<field name="upload_date"/>
						<field name="config_id"/>
						<field name="content_file_ids" string="Content" filter_domain="[('content_file_ids.name','ilike',self)]"/> 
						<field name="content_file_ids" string="B2B File" filter_domain="[('content_file_ids.file_id','ilike',self)]"/> 
						<filter string="Outstanding" name="filter_state_outstanding" domain="[('state','in', ('open','batch_loading','error','partially_error'))]"/>
						<filter string="Open" name="filter_state_open" domain="[('state','=', 'open')]"/>
						<filter string="Batch Loading" name="filter_state_batch_loading" domain="[('state','=', 'batch_loading')]"/>
						<filter string="Error" name="filter_state_error" domain="[('state','=', 'error')]"/>
						<filter string="Done" name="filter_state_done" domain="[('state','=', 'done')]"/>
						<group expand="0" string="Group By">
							<filter name="group_by_state" string="Group by State" domain="" context="{'group_by':'state'}"/>
							<filter name="group_by_ext" string="Group by Ext" domain="[]" context="{'group_by':'ext'}"/>
							<filter name="group_by_date" string="Group by Date" domain="[]" context="{'group_by':'upload_date'}"/>
						</group>
					</search>
				</field>
			</record>

			<record model="ir.actions.act_window" id="action_window_tw_b2b_file">
				<field name="name">B2B File</field>
				<field name="res_model">tw.b2b.file</field>
				<field name="view_mode">list,form</field>
				<field name="context">{'search_default_filter_state_outstanding': 1}</field>
			</record>

			<record id="action_read_file_in" model="ir.actions.server">
				<field name="name">Read File In</field>
				<field name="model_id" ref="model_tw_b2b_file"/>
				<field name="binding_model_id" ref="tw_b2b_file.model_tw_b2b_file"/>
				<field name="binding_view_types">list</field>
				<field name="state">code</field>
				<field name="code">model.action_read_folder_in()</field>
			</record>

			<record id="action_process_file" model="ir.actions.server">
				<field name="name">Process File</field>
				<field name="model_id" ref="model_tw_b2b_file"/>
				<field name="binding_model_id" ref="tw_b2b_file.model_tw_b2b_file"/>
				<field name="binding_view_types">list</field>
				<field name="state">code</field>
				<field name="code">model.action_batch_process_file()</field>
			</record>

		<!-- B2B FILE -->

	</data>
</odoo>
