<odoo>
	<data>
		<!-- B2B FILE CONFIGURATION -->
			<record id="tw_b2b_file_config_list_view" model="ir.ui.view">
				<field name="name">tw.b2b.file.config.tree</field>
				<field name="model">tw.b2b.file.config</field>
				<field name="type">list</field>
				<field eval="10" name="priority" />
				<field name="arch" type="xml">
					<list string="B2B File Configuration" editable="top" create="1" delete="1">
						<field name="name" required="1" />
						<field name="separator_id"/>
						<field name="separator_name" column_invisible="1"/>
						<field name="is_process_by_header"/>
						<field name="limit" optional="hide"/>
						<field name="headers" required="1" />
						<field name="index_mapping" required="separator_name == 'index'" placeholder="[4:6],[6:9],[12:30],[:30]"/>
						<field name="description" optional="hide"/>
					</list>
				</field>
			</record>

			<record id="tw_b2b_file_config_search_view" model="ir.ui.view">
				<field name="name">tw.b2b.file.config.search</field>
				<field name="model">tw.b2b.file.config</field>
				<field name="arch" type="xml">
					<search string="B2B File Config">
						<field name="name" string="Filename"/>
						<field name="headers"/>
						<field name="index_mapping"/>
						<group expand="0" string="Group By">
							<filter name="separator_id" string="Group by Separator" domain="" context="{'group_by':'separator_id'}"/>
							<filter name="is_process_by_header" string="Group by Process By Header" domain="[]" context="{'group_by':'is_process_by_header'}"/>
						</group>
					</search>
				</field>
			</record>

			<record id="action_window_tw_b2b_file_config" model="ir.actions.act_window">
				<field name="name">B2B File Config</field>
				<field name="res_model">tw.b2b.file.config</field>
				<field name="view_mode">list</field>
			</record>
		
		<!-- B2B FILE CONFIGURATION -->

	</data>
</odoo>
