<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Disbursement Post -->
		<record id="group_tw_dgi_document_process" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button GET DGI Proses STNK</field>
        </record>

		<record id="group_tw_dgi_document_receipt" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button GET DGI Receipt STNK</field>
        </record>

        <record id="group_tw_dgi_document_receipt_bpkb" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button GET DGI Receipt BPKB</field>
        </record>

        <record id="group_tw_dgi_document_handover" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button GET DGI Handover STNK</field>
        </record>

        <record id="group_tw_dgi_document_handover_bpkb" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button GET DGI Handover BPKB</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_dgi_document_process')),
				(4,ref('group_tw_dgi_document_receipt')),
                (4,ref('group_tw_dgi_document_receipt_bpkb')),
                (4,ref('group_tw_dgi_document_handover')),
                (4,ref('group_tw_dgi_document_handover_bpkb')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>