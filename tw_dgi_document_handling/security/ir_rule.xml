<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- IR Rule: User can only see wizards from their own company -->
        <record id="tw_dgi_proses_stnk_wizard_company_rule" model="ir.rule">
            <field name="name">DGI Proses STNK Wizard: multi-company</field>
            <field name="model_id" ref="model_tw_dgi_proses_stnk_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_dgi_receipt_stnk_wizard_company_rule" model="ir.rule">
            <field name="name">DGI Receipt STNK Wizard: multi-company</field>
            <field name="model_id" ref="model_tw_dgi_receipt_stnk_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        
        <record id="tw_dgi_receipt_bpkb_wizard_company_rule" model="ir.rule">
            <field name="name">DGI Receipt BPKB Wizard: multi-company</field>
            <field name="model_id" ref="model_tw_dgi_receipt_bpkb_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_dgi_handover_stnk_wizard_company_rule" model="ir.rule">
            <field name="name">DGI Handover STNK Wizard: multi-company</field>
            <field name="model_id" ref="model_tw_dgi_handover_stnk_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_dgi_handover_bpkb_wizard_company_rule" model="ir.rule">
            <field name="name">DGI Handover BPKB Wizard: multi-company</field>
            <field name="model_id" ref="model_tw_dgi_handover_bpkb_wizard"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
