<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<!-- List View -->
		<record id="tw_calculator_risk_list_view" model="ir.ui.view">
			<field name="name">tw.calculator.risk.list</field>
			<field name="model">tw.calculator.risk</field>
			<field name="arch" type="xml">
				<list string="Calculator Risk" editable="bottom">
					<field name="financial"/>
					<field name="service_level_agreement"/>
					<field name="percentage"/>
					<field name="code"/>
					<field name="category"/>
					<field name="score"/>
				</list>
			</field>
		</record>

		<!-- Form View -->
		<record id="tw_calculator_risk_form_view" model="ir.ui.view">
			<field name="name">tw.calculator.risk.form</field>
			<field name="model">tw.calculator.risk</field>
			<field name="arch" type="xml">
				<form string="Calculator Risk">
					<sheet>
						<div class="oe_title">
							<h1>
								<field name="code" readonly="1"/>
							</h1>
						</div>
						<group>
							<group>
								<field name="financial"/>
								<field name="service_level_agreement"/>
								<field name="percentage"/>
							</group>
							<group>
								<field name="category"/>
								<field name="score" readonly="1"/>
							</group>
						</group>
						<notebook>
							<page string="Audit Trail" name="audit_trail">
								<group>
									<group>
										<field name="create_uid" readonly="1" options="{'no_open':True,'no_create_edit':True}"/>
										<field name="create_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1" options="{'no_open':True,'no_create_edit':True}"/>
										<field name="write_date" readonly="1"/>
									</group>
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>

		<!-- Search View -->
		<record id="tw_calculator_risk_search_view" model="ir.ui.view">
			<field name="name">tw.calculator.risk.search</field>
			<field name="model">tw.calculator.risk</field>
			<field name="arch" type="xml">
				<search string="Search Calculator Risk">
					<field name="code"/>
					<field name="category"/>
					<group expand="0" string="Group By">
						<filter string="Category" name="group_category" context="{'group_by': 'category'}"/>
					</group>
				</search>
			</field>
		</record>

		<!-- Action -->
		<record id="tw_calculator_risk_action" model="ir.actions.act_window">
			<field name="name">Calculator Risk</field>
			<field name="res_model">tw.calculator.risk</field>
			<field name="view_mode">list,form</field>
		</record>
	</data>
</odoo>
