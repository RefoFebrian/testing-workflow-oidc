<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_calculator_risk_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Calculator Risk Read</field>
        </record>

        <record id="group_tw_calculator_risk_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Calculator Risk Update</field>
        </record>

        <record id="group_tw_calculator_risk_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Calculator Risk Delete</field>
        </record>

        <!-- Access Rights -->
        <record id="access_tw_calculator_risk_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_calculator_risk"/>
            <field name="name">tw_calculator_risk read</field>
            <field name="group_id" ref="group_tw_calculator_risk_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_calculator_risk_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_calculator_risk"/>
            <field name="name">tw_calculator_risk update</field>
            <field name="group_id" ref="group_tw_calculator_risk_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_calculator_risk_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_calculator_risk"/>
            <field name="name">tw_calculator_risk delete</field>
            <field name="group_id" ref="group_tw_calculator_risk_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_calculator_risk_read')),
                (4, ref('group_tw_calculator_risk_update')),
                (4, ref('group_tw_calculator_risk_delete')),
            ]"/>
        </record>
    </data>
</odoo>
