<odoo>
    <data>

        <record id="teds_asset_label_trail_view" model="ir.ui.view">
            <field name="name">teds.asset.label.trail.view</field>
            <field name="model">account.asset.asset</field>
            <field name="inherit_id" ref="om_account_asset.view_account_asset_asset_form" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='register_no']" position="after">
                    <field name="is_labelled" invisible="not is_labelled"/>
                </xpath>

                <xpath expr="//page[@string='Audit Trail']/group/group[2]" position="inside">
                    <field name="labelled_uid" invisible="not is_labelled"/>
                    <field name="labelled_date" invisible="not is_labelled"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
