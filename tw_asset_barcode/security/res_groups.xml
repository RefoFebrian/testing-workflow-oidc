<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
	
    <!-- Barcode Label Asset -->
        <record id="tw_barcode_label_asset_group_read" model="res.groups">
            <field name="category_id"  ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Barcode Labelling Asset Read</field>
        </record>        
        <record id="tw_barcode_label_asset_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset"/>
            <field name="name">tw_barcode_label_asset read</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_read"/>  
            <field name="perm_read">1</field> 
        </record>
        <record id="tw_barcode_label_asset_line_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset_line"/>
            <field name="name">tw_barcode_label_asset_line read</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_read"/>  
            <field name="perm_read">1</field> 
        </record>
                
        <record id="tw_barcode_label_asset_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Barcode Labelling Asset Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_barcode_label_asset_group_read'))]"/>                             
        </record>
        <record id="tw_barcode_label_asset_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset"/>
            <field name="name">tw_barcode_label_asset update</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      
        <record id="tw_barcode_label_asset_line_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset_line"/>
            <field name="name">tw_barcode_label_asset_line update</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      

        <record id="tw_barcode_label_asset_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Barcode Labelling Asset Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_barcode_label_asset_group_read'))]"/>                             
        </record>                        
        <record id="tw_barcode_label_asset_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset"/>
            <field name="name">tw_barcode_label_asset delete</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>
        <record id="tw_barcode_label_asset_line_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_barcode_label_asset_line"/>
            <field name="name">tw_barcode_label_asset_line delete</field> 
            <field name="group_id" ref="tw_barcode_label_asset_group_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>

	</data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('tw_barcode_label_asset_group_read')),
                (4, ref('tw_barcode_label_asset_group_update')),
                (4, ref('tw_barcode_label_asset_group_delete')),
            ]" />
        </record>
    </data>
</odoo>