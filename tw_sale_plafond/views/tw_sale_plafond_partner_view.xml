<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_tw_sale_partner_form" model="ir.ui.view">
        <field name="name">view.tw.sale.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="tw_partner.tw_partner_contact_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='purchase']" position="after">
                <group string="Plafond" name="plafond_group">
                    <field name="credit_limit_unit" string="Unit Credit Limit"/>
                    <field name="credit_limit_sparepart" string="Sparepart Credit Limit"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>