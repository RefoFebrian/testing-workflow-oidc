<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_tw_birojasa_billing_upload_result_wizard_form" model="ir.ui.view">
    <field name="name">tw.birojasa.billing.process.upload.result.wizard.form</field>
    <field name="model">tw.birojasa.billing.process.upload.result.wizard</field>
    <field name="arch" type="xml">
      <form string="Hasil Upload Tagihan Birojasa" create="false" edit="false">
        <sheet>
          <group>
            <field name="upload_filename" readonly="1"/>
          </group>
          <group>
            <field name="summary_success" readonly="1"/>
            <field name="summary_failed" readonly="1"/>
            <field name="summary_skipped" readonly="1"/>
            <field name="summary_text" readonly="1" nolabel="1" widget="text"/>
        </group>
          <notebook>
            <page string="Results s">
              <field name="result_line_ids" nolabel="1" readonly="1">
                <list create="false" edit="false" delete="false" open="false">
                  <field name="branch"/>
                  <field name="biro"/>
                  <field name="status"/>
                </list>
              </field>
            </page>
          </notebook>
          <footer>
            <button string="Close" class="btn-secondary" special="cancel"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>
</odoo>