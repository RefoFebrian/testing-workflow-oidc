<odoo>
    <data>

        <record id="tw_vehicle_document_update_data_list_view" model="ir.ui.view">
            <field name="name">tw.vehicle.document.update.data.list.view</field>
            <field name="model">tw.vehicle.document.update.data</field>
            <field name="arch" type="xml">
                <list string="List Permohonan Ubah Data">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="date"/>
                    <field name="lot_id"/>
                    <field name="old_chassis_no" string="Current Chassis No"/>
                    <field name="new_chassis_no" string="New Chassis No"/>
                    <field name='state'/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_vehicle_document_update_data_form_view" model="ir.ui.view">
            <field name="name">tw.vehicle.document.update.data.form.view</field>
            <field name="model">tw.vehicle.document.update.data</field>
            <field name="arch" type="xml">
                <form string="Form Change Lot">
                    <header>
                        <button name="action_confirm" groups="tw_vehicle_document_update_data.group_button_action_confirm" type="object" string='Confirm' invisible="state != 'draft'" class="oe_highlight"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
                    </header>

                    <sheet>
                        <div class="oe_title">
                            <h2>
                                <span class="oe_inline">Change Data Serial Number </span>
                                <field name="name" class="oe_inline" readonly="1"/>
                            </h2>
                        </div>

                        <group col="2">
                            <group>
                                <field name="company_id" required='1' options="{'no_create': True,'no_open': True}" readonly = "state != 'draft' or name != False" />
                                <field name="division" required="1" readonly ="1" />
                            </group>
                            <group>
                                <field name="lot_id" required="1" readonly = "state != 'draft' or name != False" options="{'no_create': True,'no_open': True}" domain="[('company_id','=',company_id)]"/>
                                <field name="date" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Data Serial Number">
                                <group>
                                    <group string="Current">
                                        <field name="old_partner_id" invisible="1" options="{'no_create': True,'no_open': True}" />
                                        <field name="old_partner_name" invisible="1" />
                                        <field name="old_customer_stnk_id" options="{'no_create': True,'no_open': True}" invisible="1"/>
                                        <field name="old_no_stnk" invisible="1"/>
                                        <field name="old_no_bpkb" invisible="1"/>
                                        <field name="old_no_polisi" invisible="1"/>
                                        <field name="old_name" invisible="1"/>
                                        <field name="old_chassis_no" invisible="1"/>
                                        <field name="old_no_notice" invisible="1"/>
                                        <field name="old_no_faktur" invisible="1"/>

                                        <field name="old_related_partner_id" invisible = "lot_id == False" options="{'no_create': True,'no_open': True}" readonly="1"/>
                                        <field name="old_related_partner_name" invisible = "lot_id == False" readonly="1" />
                                        <field name="old_related_customer_stnk_id" options="{'no_create': True,'no_open': True}" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_no_stnk" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_no_bpkb" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_no_polisi" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_name" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_chassis_no" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_no_notice" invisible = "lot_id == False" readonly="1"/>
                                        <field name="old_related_no_faktur" invisible = "lot_id == False" readonly="1"/>
                                    </group>
                                    <group string="New" readonly= "state != 'draft'" invisible="lot_id == False">
                                        <field name="new_partner_id" readonly = "state != 'draft'" invisible="lot_id == False" domain="[('id','!=',old_partner_id)]" options="{'no_create': True,'no_open': True}" />
                                        <field name="new_partner_name" readonly = "state != 'draft'" invisible="lot_id == False" />
                                        <field name="new_customer_stnk_id" options="{'no_create': True}" readonly = "state != 'draft'" invisible="lot_id == False" domain="[('id','!=',old_customer_stnk_id)]" context="{'form_view_ref': 'tw_partner.tw_customer_partner_form_view', 'res_id': new_customer_stnk_id}"/>
                                        <field name="new_no_stnk" readonly = "state != 'draft'" invisible="lot_id == False"/>
                                        <field name="new_no_bpkb" readonly = "state != 'draft'" invisible="lot_id == False"/>
                                        <field name="new_no_polisi" readonly = "state != 'draft'" invisible="lot_id == False"/>
                                        <field name="new_name" readonly = "state != 'draft'" invisible="lot_id == False"/>
                                        <field name="new_chassis_no" readonly = "state != 'draft'" invisible="lot_id == False"/>
                                        <field name="new_no_notice" readonly="state != 'draft'" invisible= "lot_id ==False"/>
                                        <field name="new_no_faktur" readonly="state != 'draft'" invisible="lot_id == False"/>
                                    </group>
                                </group>
                                <field name="note" placeholder="Add an internal note..." class="oe_inline" readonly="state !='draft'" invisible="lot_id == False"/>
                            </page>

                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>

                    <chatter>
                        <field name="message_ids"/>
                        <field name="activity_ids"/>
                    </chatter>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_vehicle_document_update_data_search_view" model="ir.ui.view">
            <field name="name">tw.vehicle.document.update.data.search.view</field>
            <field name="model">tw.vehicle.document.update.data</field>
            <field name="arch" type="xml">
                <search string="Search Change Lot">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/>
                    <field name='division'/>
                    <field name='lot_id'/>
                    <field name='date'/>
                    <field name='old_chassis_no'/>
                    <field name='new_chassis_no'/>
                    <field name='new_name'/>
                    <filter name="Outstanding" string="Outstanding" domain="[('state','in',['draft,waiting_for_approval','approved'])]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_company" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_date" string="Tanggal" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="tw_vehicle_document_update_data_action" model="ir.actions.act_window">
            <field name="name">Change Data Serial Number</field>
            <field name="res_model">tw.vehicle.document.update.data</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_vehicle_document_update_data_search_view"/>
            <field name="context">{'search_default_Outstanding':1}</field>
        </record>

    </data>
</odoo>
