<odoo>
    <data>
        <record  id="tw_stock_production_lot_change_lot_form_view" model="ir.ui.view">
            <field name="name">tw.stock.production.lot.change.lot.form.view</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form" />
            <field name="arch" type="xml">
                <xpath expr='//page[@name="description"]' position='after'>
                    <page string="Pengubahan Data">
                        <field name="change_lot_ids" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="company_id"/>
                                <field name="division"/>
                                <field name="date"/>
                                <field name="state"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
