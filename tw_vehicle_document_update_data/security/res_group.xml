        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_vehicle_document_update_data_read')),
                (4,ref('group_tw_vehicle_document_update_data_update')),
                (4,ref('group_tw_vehicle_document_update_data_delete')),
