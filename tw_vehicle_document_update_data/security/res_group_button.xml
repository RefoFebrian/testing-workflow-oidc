<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_button_action_request" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Button RFA - Change Data Serial Number</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_document_update_data_read'))]"/>
        </record>
        <record id="accsess_button_action_request" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_document_update_data"></field>
            <field name="name">button_action_request</field>
            <field name="group_id" ref="group_button_action_request"></field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_button_action_cancel" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Button Cancel - Change Data Serial Number</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_document_update_data_read'))]"/>
        </record>
        <record id="accsess_button_action_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_document_update_data"></field>
            <field name="name">button_action_cancel</field>
            <field name="group_id" ref="group_button_action_cancel"></field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_button_action_confirm" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Button Confirm - Change Data Serial Number</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_document_update_data_read'))]"/>
        </record>
        <record id="accsess_button_action_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_document_update_data"></field>
            <field name="name">button_action_confirm</field>
            <field name="group_id" ref="group_button_action_confirm"></field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_button_action_request')),
                (4,ref('group_button_action_cancel')),
                (4,ref('group_button_action_confirm')),
                ]"/>
        </record>

    </data>
</odoo>