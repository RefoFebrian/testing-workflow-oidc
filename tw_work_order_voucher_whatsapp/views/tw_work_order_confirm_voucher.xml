<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_work_order_confirm_voucher_view" model="ir.ui.view">
            <field name="name">tw.work.order.confirm.voucher</field>
            <field name="model">tw.work.order</field>
            <field name="arch" type="xml">
                <form string="Confirm Voucher">
                    <group>
                        <label for="otp_validation" string="Masukkan Kode OTP"/>
                        <div>
                            <field name="otp_validation" class="oe_inline"/> <button name="action_send_otp_voucher" type="object" string="Send OTP" class="oe_inline oe_highlight"/>
                        </div>
                    </group>
                    <footer>
                        <button name="action_confirm_otp_voucher" string="Confirm" type="object" class="oe_highlight"/>
                        <button string="Close" special="cancel" class="btn-secondary"/>
		            </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>