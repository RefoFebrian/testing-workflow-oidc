<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="tw_work_order_voucher_whatsapp_view_form" model="ir.ui.view">
        <field name="name">tw.work.order.voucher.whatsapp</field>
        <field name="model">tw.work.order</field>
        <field name="inherit_id" ref="tw_work_order.tw_work_order_form_view" />
        <field name="arch" type="xml">
			<field name="company_id" position="after">
				<field name="otp_code" invisible="1"/>
				<field name="otp_validation" invisible="1"/>
			</field>
			<xpath expr="//button[@name='action_open']" position="before">
				<button name="action_view_confirm_voucher" string="Confirm Voucher" type="object" class="oe_highlight" invisible="state in ('done', 'cancel', 'unused') or not otp_code or otp_validation"/>
			</xpath>
			<xpath expr="//sheet/notebook" position="before">
				<field name="is_voucher" invisible="1"/>
				<div class="alert alert-info" role="alert" invisible="not is_voucher">
					<i class="fa fa-info-circle me-2"/>
					<span>Kode OTP voucher <strong>Terverifikasi</strong></span>
				</div>
			</xpath>
        </field>
    </record>
</odoo>