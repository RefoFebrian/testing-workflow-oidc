<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_settings_dso_bbn_inherit_view" model="ir.ui.view">
            <field name="name">tw.account.settings.dso.bbn.inherit.view</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='dealer_sales_order_container']" position="inside">
                    <group name="journal_bbn" colspan="2">
                        <h3 class="o_stat_info" colspan="2" style="margin-top:20px;">
                            <span class="text-success">Bea Balik Nama</span>
                        </h3>
                        <field name="account_dso_sales_bbn_id" options="{'no_quick_create': True}" />
                        <field name="journal_dso_purchase_bbn_id" options="{'no_quick_create': True}" />
                        <label for="is_accrue_proses_bbn" string="Accrue Proses BBN?" />
                        <div class="d-flex">
                            <field name="is_accrue_proses_bbn" class="me-3"/>
                            <field name="accrue_bbn_process" invisible="is_accrue_proses_bbn == False" required="is_accrue_proses_bbn == True"/>
                        </div>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>