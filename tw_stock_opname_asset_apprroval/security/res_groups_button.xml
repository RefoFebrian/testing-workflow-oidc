<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_tw_so_asset_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Request Approval Stock Opname Asset</field>
        </record>

        <record id="access_tw_so_asset_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname_asset.model_tw_stock_opname_asset"/>
            <field name="name">tw_so_asset_approval_rfa update</field>
            <field name="group_id" ref="group_tw_so_asset_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_so_asset_approval_done" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Stock Opname Asset</field>
        </record>

        <record id="access_tw_so_asset_approval_done" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname_asset.model_tw_stock_opname_asset"/>
            <field name="name">tw_so_asset_approval_done update</field>
            <field name="group_id" ref="group_tw_so_asset_approval_done"/>
            <field name="perm_write">1</field>
        </record>
             
        <record id="group_tw_so_asset_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Stock Opname Asset</field>
        </record>
        <record id="access_tw_so_asset_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname_asset.model_tw_stock_opname_asset"/>
            <field name="name">tw_so_asset_approval_cancel update</field>
            <field name="group_id" ref="group_tw_so_asset_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

                     
        <record id="group_tw_so_asset_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Stock Opname Asset</field>
        </record>
        <record id="access_tw_so_asset_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname_asset.model_tw_stock_opname_asset"/>
            <field name="name">tw_so_asset_approval_reject update</field>
            <field name="group_id" ref="group_tw_so_asset_approval_reject"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_so_asset_approval_rfa')),
                (4,ref('group_tw_so_asset_approval_done')),
                (4,ref('group_tw_so_asset_approval_cancel')),
                (4,ref('group_tw_so_asset_approval_reject')),
            ]">
            </field>
        </record>
    </data>
</odoo>
