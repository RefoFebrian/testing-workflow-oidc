<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_stock_lot_puchase_form_view" model="ir.ui.view">
            <field name="name">tw.stock.lot.puchase.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="tw_stock.tw_stock_lot_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='receive_group']" position="inside">
                    <field name="purchase_order_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>