<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
          <!-- Asset Adjustment READ -->
          <record id="group_asset_adjustment_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Asset Adjustment Read</field>
        </record>

        <record id="access_tw_asset_adjustment_read" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment" />
            <field name="name">tw_asset_adjustment read</field>
            <field name="group_id" ref="group_asset_adjustment_read" />
            <field name="perm_read">1</field>
        </record>
        
        <record id="access_tw_asset_adjustment_account_move_line_read" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move_line" />
            <field name="name">tw_asset_adjustment_account_move_line read</field>
            <field name="group_id" ref="group_asset_adjustment_read" />
            <field name="perm_read">1</field>
        </record>
        
        <record id="access_tw_asset_adjustment_account_move_line_read" model="ir.model.access">
            <field name="model_id" ref="om_account_asset.model_account_asset_asset" />
            <field name="name">tw_asset_adjustment_account_move_line read</field>
            <field name="group_id" ref="group_asset_adjustment_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_asset_adjustment_line_read" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment_line" />
            <field name="name">tw_asset_adjustment_line read</field>
            <field name="group_id" ref="group_asset_adjustment_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- Asset Adjustment UPDATE -->
        <record id="group_asset_adjustment_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Asset Adjustment Update</field>
            <field name="implied_ids" eval="[(4, ref('group_asset_adjustment_read'))]" />
        </record>

        <record id="access_tw_asset_adjustment_update" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment" />
            <field name="name">tw_asset_adjustment update</field>
            <field name="group_id" ref="group_asset_adjustment_update" />
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="access_tw_asset_adjustment_line_update" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment_line" />
            <field name="name">tw_asset_adjustment_line update</field>
            <field name="group_id" ref="group_asset_adjustment_update" />
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- Asset Adjustment DELETE -->
        <record id="group_asset_adjustment_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Asset Adjustment Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_asset_adjustment_read'))]" />
        </record>        

        <record id="access_tw_asset_adjustment_delete" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment" />
            <field name="name">tw_asset_adjustment delete</field>
            <field name="group_id" ref="group_asset_adjustment_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_asset_adjustment_line_delete" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment_line" />
            <field name="name">tw_asset_adjustment_line delete</field>
            <field name="group_id" ref="group_asset_adjustment_delete" />
            <field name="perm_unlink">1</field>
        </record>    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_asset_adjustment_read')),
                (4, ref('group_asset_adjustment_update')),
                (4, ref('group_asset_adjustment_delete')),
            ]" />
        </record>
    </data>

</odoo>
