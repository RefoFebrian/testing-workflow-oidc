<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data> 
    	
		<record model="ir.ui.view" id="tw_asset_adjustment_list_view">
		    <field name="name">tw.asset.adjustment.list.view</field>
		    <field name="model">tw.asset.adjustment</field>
		    <field name="arch" type="xml">
		        <list string="List Asset Adjustment" default_order="id desc">
		        	<field name="name"/>
		        	<field name="date"/>
		            <field name="company_id"/>
					<field name="asset_id"/>
		            <field name="state" widget="badge" decoration-success="state == 'post'" decoration-muted="state == 'draft'"/>
		        </list>
		     </field>
		</record>
		    	
		<record model="ir.ui.view" id="tw_asset_adjustment_form_view">
		    <field name="name">tw.asset.adjustment.form.view</field>
		    <field name="model">tw.asset.adjustment</field>
		    <field name="arch" type="xml">
				<form>
					<header>
						<button name="post_adjustment" groups="tw_asset_adjustment.group_tw_asset_adjustment_post" invisible="state != 'draft'" string="Post" type="object" class="oe_highlight"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,post"/>
	           		</header>
					<sheet>
	        			<div class="oe_title">
							<h1 invisible="create_date"><span>Draft</span></h1>
							<h1 invisible="not create_date"><field name="name" readonly="1"/></h1>
	 					</div>
						<group>
							<group>
								<field name="company_id" required="1" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
								<field name="asset_id" domain="[('company_id','=',company_id),('state','!=','closed')]" options="{'no_create': True,'no_open': True}" required="1" readonly="state != 'draft'"/>
							</group>  
							<group>
								<field name="division" required="1" invisible="1"/>	
								<field name="date" readonly="1"/>
							</group>  
							<group>
								<separator string="Current Data"/>
								<field name="company_id" readonly="1" options="{'no_create': True,'no_open': True}" force_save="1"/>
								<field name="employee_user_id" options="{'no_create': True,'no_open': True}" readonly="1" force_save="1"/>
								<field name="product_id" readonly="1"/>
								<field name="category_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
								<field name="number_depreciation" readonly="1"/>
								<field name="purchase_value" readonly="1"/>
								<field name="purchase_date" readonly="1"/>
							</group>  
							<group>
								<separator string="New Data"/>
								<field name="new_company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
								<field name="new_employee_user_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
								<field name="new_category_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
								<field name="new_number_depreciation" readonly="state != 'draft'"/>
								<field name="new_purchase_value" readonly="state != 'draft'"/>
								<field name="new_purchase_date" readonly="state != 'draft'"/>
								<field name="bool_journal_branch" readonly="state != 'draft'"/>
								<field name="bool_journal_category" readonly="state != 'draft'"/>
								<field name="bool_journal_gross_value" readonly="state != 'draft'"/>
							</group>  
						</group>
	                    <notebook colspan="5">
							<page string="Kapitalisasi">
								<field name="capitalization_line_ids" readonly="state != 'draft'">
									<list editable="bottom">
										<field name="good_receive_id" required="1" options="{'no_create': True, 'no_open': True}" domain="[('company_id', '=', parent.company_id), ('state', 'in', ['open', 'done'])]"/>
										<field name="good_receive_line_id" string="Product" required="1" options="{'no_create': True, 'no_open': True}" domain="[('picking_id', '=', good_receive_id), ('qty_acquisition_available', '&gt;', 0)]"/>
										<field name="product_id" column_invisible="1"/>
										<field name="description"/>
										<field name="qty" required="1"/>
										<field name="price_unit" readonly="1" optional="hide"/>
										<field name="price" readonly="1"/>
										<field name="price_per_unit" readonly="1"/>
									</list>
								</field>
								<group class="oe_subtotal_footer">
									<field name="amount_capitalization" string="Total Kapitalisasi"/>
								</group>
							</page>
	                        <page string="Journal Items" invisible="state == 'draft'">
	                        	<field name="move_ids" readonly="1"/>
	                        </page>  
							<page name="audit_trail" string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
										<field name="confirm_uid" readonly="1"/>
										<field name="confirm_date" readonly="1"/>
									</group>
								</group>
							</page>
	                    </notebook>
					</sheet>
				</form>	
		    </field>
		</record>

		<record id="tw_asset_adjustment_search_view" model="ir.ui.view">
            <field name="name">tw.asset.adjustment.search</field>
            <field name="model">tw.asset.adjustment</field>
            <field name="arch" type="xml">
                <search string="Search Asset Adjustment">
                    <field name="name" string="Nomor Transaksi"/>
					<field name="date"/>
                    <field name="company_id"/>
                    <field name="asset_id"/>
                    <field name="product_id"/>
					<field name="category_id" string="Old Category"/>
					<field name="new_category_id" string="New Category"/>
					<field name="new_company_id" string="New Company"/>
					<field name="move_ids" string="Journal Entry" filter_domain="[('move_ids.move_name','ilike',self)]"/>
					<field name="move_ids" string="Account" filter_domain="[('move_ids.account_id','ilike',self)]"/>
					<field name="move_ids" string="Partner" filter_domain="[('move_ids.partner_id','ilike',self)]"/>
					<field name="move_ids" string="Reference" filter_domain="[('move_ids.ref','ilike',self)]"/>
					<field name="move_ids" string="Label" filter_domain="[('move_ids.name','ilike',self)]"/>
					<filter name="draft" string="draft" domain="[('state', '=', 'draft')]" />
					<filter name="post" string="posted" domain="[('state', '=', 'post')]" />
					<filter name="outstanding" string="Outstanding" domain="[('state', '!=', 'post')]" />
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_company" context="{'group_by': 'company_id'}"/>
						<filter string="New Branch" name="group_by_new_company" context="{'group_by': 'new_company_id'}"/>
                        <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
						<filter string="Date" name="group_by_date" context="{'group_by': 'date'}"/>
						<filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
						<filter string="Old Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
						<filter string="New Category" name="group_by_new_category" context="{'group_by': 'new_category_id'}"/>
                    </group>
                </search>
            </field>
        </record>
		
 		
		<record model="ir.actions.act_window" id="tw_asset_adjustment_action">
		    <field name="name">Asset Adjustment</field>
		    <field name="res_model">tw.asset.adjustment</field>
		    <field name="view_mode">list,form</field>
		    <field name="search_view_id" ref="tw_asset_adjustment_search_view"/>
			<field name="context" eval="{'search_default_outstanding':True}" />
		</record>			
        	        		
	</data>
</odoo>