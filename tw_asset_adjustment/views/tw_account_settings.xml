<odoo>
    <data>
      <record id="tw_asset_adjustment_account_setting_inherit_form_view" model="ir.ui.view">
          <field name="name">tw.asset.adjustment.account.setting.inherit.view.form</field>
          <field name="model">tw.account.setting</field>
          <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
          <field name="arch" type="xml">
            <xpath expr="//group[@name='assets_group']" position="inside">  
                <field name="journal_asset_adjustment_id" options="{'no_create': True}"/>
            </xpath>
          </field>
      </record>
    </data>
</odoo>
  