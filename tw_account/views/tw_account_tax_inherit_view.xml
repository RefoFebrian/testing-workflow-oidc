<odoo>
    <data>
        <record id="tw_account_tax_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.account.tax.inherit.form</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='advanced_options']/group/group[1]/field[@name='company_id']" position="replace">
                    <field name="company_id" invisible="1"/>
                </xpath>
                <field name="active" position="before">
                    <field name="company_id" readonly="0" required="0" options="{'no_create': True}"/>
                </field>
            </field>
        </record>
        
        <record id="tw_account_tax_inherit_list_view" model="ir.ui.view">
            <field name="name">tw.account.tax.inherit.list</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="attributes">
                    <attribute name="default_order">active desc,name</attribute>
                </xpath>
                <field name="company_id" position="before">
                    <field name="amount"/>
                    <field name="price_include_override"/>
                </field>
            </field>
        </record>
    </data>
</odoo>