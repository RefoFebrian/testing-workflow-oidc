<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_account_journal_form_view" model="ir.ui.view">
            <field name="name">tw.account.journal.form</field>
            <field name="model">account.journal</field>
            <field name="inherit_id" ref="account.view_account_journal_form" />
            <field name="arch" type="xml">
                <field name="default_account_type" position="after">
                    <field name="default_debit_account_id" domain="[('company_ids', 'parent_of', company_id)]" placeholder="e.g. Debit Account" options="{'no_create':True}"/>
                    <field name="default_credit_account_id" domain="[('company_ids', 'parent_of', company_id)]" placeholder="e.g. Credit Account" options="{'no_create':True}"/>
                </field>
                <field name="type" position="after">
                    <field name="currency_id" required="1" options="{'no_create': True}"/>
                    <field name="partner_id" invisible="1"/>
                </field>
                <group name="bank_account_number" position="attributes">
                    <attribute name="invisible">type not in ('bank','edc','general','credit')</attribute>
                </group>
                <field name="bank_account_id" position="before">
                    <field name="partner_id" required="type in ('bank','edc')" options="{'no_create': True}"/>
                </field>
                <field name="default_account_id" position="attributes">
                    <attribute name="required">0</attribute>
                </field>

                <field name="bank_account_id" position="attributes">
                    <attribute name="domain">[('partner_id', '=', partner_id)]</attribute>
                    <attribute name="invisible">type not in ('bank','edc','general','credit')</attribute>
                    <attribute name="required">type in ('bank')</attribute>
                </field>
                <xpath expr="//group/group[2]/field[@name='company_id']" position="replace">
                    <field name="company_id" readonly="0" required="1" options="{'no_create': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>