<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--Invoices -->
        <record id="group_tw_invoice_confirm_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Invoice Confirm</field>
        </record>

        <record id="group_tw_invoice_validate_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Invoice Validate</field>
        </record>

        <record id="group_tw_invoice_cancel_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Invoice Cancel</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_invoice_confirm_button')),
                (4, ref('group_tw_invoice_validate_button')),
                (4, ref('group_tw_invoice_cancel_button')),
            ]"/>
        </record>
    </data>

</odoo>
