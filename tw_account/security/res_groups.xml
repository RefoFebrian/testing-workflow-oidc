<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="tw_module_category_account" model="ir.module.category">
            <field name="name">TW Account</field>
        </record>

        <record id="group_tw_accounting_menu_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Accounting Menu Read</field> 
        </record> 

        <record id="group_tw_account_account_form_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Chart of Account Form Read</field> 
        </record> 

        <record id="group_tw_account_journal_form_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Account Journal Form Read</field> 
        </record> 

        <record id="group_tw_account_move_form_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Account Move Form Read</field> 
        </record> 
        
        <record id="group_tw_account_tax_form_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Account Tax Form Read</field> 
        </record> 

        <record id="group_tw_account_invoicing_read" model="res.groups">
           <field name="category_id" ref="tw_account.tw_module_category_account"/>
           <field name="name">TW Invoicing</field> 
        </record> 

    </data>

    <data>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_account_account_form_read')),
                (4,ref('group_tw_account_journal_form_read')),
                (4,ref('group_tw_account_move_form_read')),
                (4,ref('group_tw_account_tax_form_read')),
                (4,ref('group_tw_accounting_menu_read')),
                (4,ref('group_tw_account_invoicing_read')),
            ]"/>
        </record>

    </data>
</odoo>