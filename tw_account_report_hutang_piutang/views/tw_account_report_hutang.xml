<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_report_hutang_view" model="ir.ui.view">
			<field name="name">tw.account.report.hutang.view</field>
			<field name="model">tw.account.report.hutang</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string="Laporan Hutang">
					<group>
					    <group>
						    <field name="option" required="1"/>
						    <field name="date"/>
                            <label for="start_date" string="Tanggal JTP"/>
                            <div>
                                <field name="start_date" class="oe_inline"/>&#160;-&#160;
                                <field name="end_date" class="oe_inline"/>
                            </div>
                        </group>
					    <group>
						    <field name="division"/>
						    <field name="status"/>
                            <label for="trx_start_date" string="Transaction Date"/>
                            <div>
                                <field name="trx_start_date" class="oe_inline"/>&#160;-&#160;
                                <field name="trx_end_date" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branch">
                            <field name="company_ids">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="code"/>
                                </list>
                            </field>
                        </page>
                        <page string="Partner">
                            <field name="partner_ids">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="code"/>
                                </list>
                            </field>
                        </page>
                        <page string="Account">
                            <field name="account_ids">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="code"/>
                                </list>
                            </field>
                        </page>
                        <page string="Journal">
                            <field name="journal_ids">
                                <list editable="top">
                                    <field name="name"/>
                                    <field name="code"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_download" type="object" string="Download" icon="fa-download" class="oe_highlight"/>
                        <button special="cancel" string="Cancel" class="oe_link"/>
                    </footer>
                </form>
			</field>
		</record>

		<record id="action_tw_account_report_hutang" model="ir.actions.act_window">
			<field name="name">Laporan Hutang</field> 
			<field name="res_model">tw.account.report.hutang</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="tw_account_report_hutang_view"/>
			<field name="target">new</field>
		</record>
    </data>
</odoo>
