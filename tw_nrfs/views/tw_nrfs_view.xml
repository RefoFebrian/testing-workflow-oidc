<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <!-- NRFS -->
        <record id="tw_nrfs_list_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.list</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
            	<list string="Outstanding NRFS" create="0" delete="0">
            		<field name="name" />
                    <field name="origin" />
                    <field name="nrfs_date" />
                    <field name="product_id" />
                    <field name="branch_partner_id"/>
                    <field name="state" />
            	</list>
            </field>
        </record>

        <record id="tw_nrfs_form_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.form</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
            	<form string="Outstanding NRFS" create="0" delete="0">
            		<header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'approved'" groups="tw_nrfs.tw_nrfs_confirm_group_button_read,tw_nrfs.tw_nrfs_admin_confirm_group_button_read"/>
                        <button name="action_cancel" string="Cancel" invisible="state != 'draft'" type="object" groups="tw_nrfs.tw_nrfs_cancel_group_button_read"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,done" readonly="1" />
                    </header>
            		<sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1" invisible="name == False" class="oe_inline" />
                            </h1>
                        </div>
						<group>
                            <group>
                                <field name="company_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}" />
                                <field name="origin" readonly="1" />
                                <field name="product_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                                <field name="backorder_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}" />
                                <field name="is_send_to_ahm" readonly="state != 'draft'" string="Send MFT"/>
                            </group>
                            <group>
                                <field name="nrfs_date" readonly="1" />
                                <field name="examiner_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}" domain="[('company_id', '=', company_id)]"/>
                                <field name="nrfs_type" readonly="1"/>
                                <field name="vehicle_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="driver_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                                <field name="expedition_ship" readonly="1"/>
                            </group>
                            <group string="Estimasi Penanganan" name="est_penanganan">
                                <field name="branch_partner_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                                <field name="est_completion_date" readonly="1" />
                                <field name="act_completion_date" readonly="1" />
                            </group>
                        </group>
                        <notebook>
                            <page name="detail" string="Detail">
                                <field name="line_ids" nolabel="1" readonly="state != 'draft'" context="{'default_product_unit_id': product_id,'default_rel_partner_id': branch_partner_id}">
                                    <list editable="top">
                                        <field name="product_unit_id" column_invisible="1" />
                                        <field name="rel_partner_id" column_invisible="1" />
                                        <field name="available_sparepart_ids" column_invisible="1" />
                                        <field name="product_sparepart_id" required="1" options="{'no_open':True, 'no_create': True}" domain="[('id', 'in', available_sparepart_ids)]"/>
                                        <field name="description" readonly="1" />
                                        <field name="qty" required="1" />
                                        <field name="indication_ids" required="1" options="{'no_open':True, 'no_create': True}" widget="many2many_tags" />
                                        <field name="reason_ids" required="1" options="{'no_open':True, 'no_create': True}" widget="many2many_tags" />
                                    </list>
                                </field>
                            </page>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" />
                                        <field name="create_date" readonly="1" />
                                        <field name="confirm_uid" readonly="1" />
                                        <field name="confirm_date" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" />
                                        <field name="write_date" readonly="1" />
                                        <field name="cancel_uid" readonly="1" invisible="cancel_uid == False" />
                                        <field name="cancel_date" readonly="1" invisible="cancel_date == False" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
            		</sheet>
            	</form>
            </field>
        </record>

        <record id="tw_nrfs_search_view" model="ir.ui.view">
            <field name="name">tw.nrfs.search</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
                <search string="Search NRFS">
                    <field name="name" string="Nomor NRFS"/>
                    <field name="nrfs_type" string="Tipe NRFS"/>
                    <field name="origin" string="Source Document"/>
                    <field name="nrfs_date" string="Date"/>
                    <field name="line_ids" string="Parts Bermasalah" filter_domain="line_ids.product_sparepart_id" />
                    <field name="branch_partner_id"/>
					<filter string="Cancelled" name="cancel" domain="[('state','=','cancel')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Waiting for Approval" name="rfa" domain="[('state','=','rfa')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="In Progress" name="in_progress" domain="[('state','=','in_progress')]"/>
                    <filter string="Done" name="done" domain="[('state','=','done')]"/>
					<group string="Group By" name="groupby">
                        <filter name="name_groupby" string="No NFRS" context="{'group_by': 'name'}"/>
                        <filter name="state_groupby" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'nrfs_date'}"/>
                        <filter name="product_id_groupby" string="Tipe Unit" context="{'group_by': 'product_id'}"/>
                        <filter name="group_by_branch_partner_id" string="AHASS Vendor" context="{'group_by': 'branch_partner_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_nrfs_md_action" model="ir.actions.act_window">
            <field name="name">Outstanding NRFS</field>
            <field name="res_model">tw.nrfs</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                "default_division": "Unit",
                "search_default_draft": 1,
                "search_default_rfa": 1,
                "search_default_approved": 1,
                "search_default_confirmed": 1,
                "search_default_in_progress": 1,
            }</field>
            <field name="search_view_id" ref="tw_nrfs.tw_nrfs_search_view" />
            <field name="domain">[('division', '=', 'Unit')]</field>
        </record>

        <record id="tw_nrfs_md_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_nrfs_list_view"/>
            <field name="act_window_id" ref="tw_nrfs_md_action"/>
        </record>

        <record id="tw_nrfs_md_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_nrfs_form_view"/>
            <field name="act_window_id" ref="tw_nrfs_md_action"/>
        </record>
    </data>
</odoo>