<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_master_penanganan_unit_md_list" model="ir.ui.view">
            <field name="name">tw.master.penanganan_unit_md.list</field>
            <field name="model">tw.selection</field>
            <field name="arch" type="xml">
                <list string="Master Penanganan Unit MD" create="1" delete="1" editable="top">
                    <field name="name" required="1" string="Penanganan Unit MD Name"/>
                    <field name="value" required="1"/>
                    <field name="type" readonly="1" force_save="1"/>
                </list>
            </field>
        </record>

        <record id="action_tw_master_penanganan_unit_md" model="ir.actions.act_window">
            <field name="name">Master Penanganan Unit MD</field>
            <field name="res_model">tw.selection</field>
            <field name="view_mode">list</field>
            <field name="domain">[('type','=','PenangananUnitMd')]</field>
            <field name="context">{'default_type': 'PenangananUnitMd'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No master penanganan unit md found. Let's create one!
                </p>
            </field>
        </record>

        <record id="tw_master_penanganan_unit_md_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tw_master_penanganan_unit_md_list"/>
            <field name="act_window_id" ref="action_tw_master_penanganan_unit_md"/>
        </record>
    </data>
</odoo>