<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_master_penyebab_list" model="ir.ui.view">
            <field name="name">tw.master.penyebab.list</field>
            <field name="model">tw.selection</field>
            <field name="arch" type="xml">
                <list string="Master Penyebab" create="1" delete="1" editable="top">
                    <field name="name" required="1" string="Penyebab Name"/>
                    <field name="value" required="1"/>
                    <field name="type" readonly="1" force_save="1"/>
                </list>
            </field>
        </record>

        <record id="action_tw_master_penyebab" model="ir.actions.act_window">
            <field name="name">Master Penyebab</field>
            <field name="res_model">tw.selection</field>
            <field name="view_mode">list</field>
            <field name="domain">[('type','=','PenyebabNrfs')]</field>
            <field name="context">{'default_type': 'PenyebabNrfs'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No master penyebab found. Let's create one!
                </p>
            </field>
        </record>

        <record id="tw_master_penyebab_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tw_master_penyebab_list"/>
            <field name="act_window_id" ref="action_tw_master_penyebab"/>
        </record>
    </data>
</odoo>