<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">    
        <record id="group_wip_validasi" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">WIP Work Order Validasi</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_work_order_wip_read'))]"/>
        </record>  		
		
		<record id="group_wip_confirm_button" model="res.groups">
	        <field name="category_id" ref="tw_base.tw_role"/>
	        <field name="name">WIP Work Order Confirm</field>
	        <field name="implied_ids" eval="[(4, ref('group_tw_work_order_wip_read'))]"/>
	    </record>  

	    <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_wip_confirm_button')),
				(4,ref('group_wip_validasi')),
			]"/> 
		</record>
    </data>
</odoo>