<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_work_order_wip_list_view" model="ir.ui.view">
			<field name="name">tw.work.order.wip.list</field>
			<field name="model">tw.work.order.wip</field>
			<field name="arch" type="xml">
				<list>
					<field name="name" />
					<field name="company_id" />
					<field name="date" />
					<field name="qty_wip" />
					<field name="state" />
				</list>
			</field>
		</record>



		<record id="tw_work_order_wip_view_form" model="ir.ui.view">
			<field name="name">tw.work.order.wip.form</field>
			<field name="model">tw.work.order.wip</field>
			<field name="arch" type="xml">
				<form>
					<header>
						<button name="action_get_wip" invisible="generate_date != False"
							string="Get WIP" class="oe_highlight" type="object" />
						<button name="action_confirm" invisible="state != 'approved'"
							string="Confirm" class="oe_highlight" type="object"
							groups="tw_work_order_wip.group_wip_confirm_button" />
						<button name="action_back_to_draft" invisible="state != 'rejected'"
							string="Back to Draft" class="oe_highlight" type="object"/>
						<field name="state" widget="statusbar"
							statusbar_visible="draft,done" />
					</header>
					<sheet>
						<div class="oe_title">
							<h1>
								<field name="name" readonly="1" />
							</h1>
						</div>
						<group>
							<group>
								<field name="company_id" required="1"
									readonly="(state != 'draft') or generate_date"
									options="{'no_open':True,'no_create':True}" />
								<field name="qty_wip" readonly="1" />
							</group>
							<group>
								<field name="date" readonly="1" />
								<field name="generate_date" invisible="generate_date == False"
									readonly="1" />
							</group>
						</group>
						<notebook>
							<page string="Detail WIP" name="page_detail_wip">
								<field name="detail_ids" nolabel="1">
									<list editable="bottom" create="false" delete="false">
										<field name="wo_id"
											options="{'no_open':True,'no_create':True}" readonly="1" />
										<field name="tgl_wo" readonly="1" />
										<field name="aging" readonly="1" />
										<field name="plate_number" readonly="1" />
										<field name="state_wo" readonly="1" />
										<field name="status_wo" readonly="1" />
										<field name="type_wo" readonly="1" />
										<field name="motorbike_physics" required="1"
											readonly="validation_status != 'draft'" />
										<field name="description" required="1"
											readonly="validation_status != 'draft'" />
										<field name="validation_status" column_invisible="1" />
										<field name="is_validasi_adh"
											groups="tw_work_order_wip.group_wip_validasi"
											readonly="validation_status == 'done'"
											required="validation_status == 'open'" />
									</list>
								</field>
							</page>
							<page string="WIP tidak tercatat di Sistem">
								<field name="other_ids" readonly="state in ['approved','done']">
									<list editable="bottom">
										<field name="tgl_wo" required="1"
											readonly="validation_status != 'draft'" />
										<field name="aging" readonly="1" force_save="1"/>
										<field name="plate_number" required="1"
											readonly="validation_status != 'draft'" />
										<field name="type_wo" required="1"
											readonly="validation_status != 'draft'" />
										<field name="motorbike_physics" required="1"
											readonly="validation_status != 'draft'" />
										<field name="description" required="1"
											readonly="validation_status != 'draft'" />
										<field name="validation_status" invisible="1" />
										<field name="is_validasi_adh"
											groups="tw_work_order_wip.group_wip_validasi"
											readonly="validation_status == 'done'"
											required="validation_status == 'open'" />
									</list>
								</field>
							</page>
							<page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1" />
										<field name="create_date" readonly="1" />
										<field name="generate_uid" readonly="1" />
										<field name="generate_date" readonly="1" />
									</group>
									<group>
										<field name="write_uid" readonly="1" />
										<field name="write_date" readonly="1" />
										<field name="confirm_uid" readonly="1"
											invisible="confirm_uid == False" />
										<field name="confirm_date" readonly="1"
											invisible="confirm_date == False" />>
									</group>
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>

		<record id="tw_work_order_wip_search_view" model="ir.ui.view">
		<field name="name">tw.work.order.wip.search.view</field>
		<field name="model">tw.work.order.wip</field>
		<field name="arch" type="xml">
			<search string="Search WIP">
			<field name='name' />
			<field name='company_id' />
			<field name='qty_wip' />
			<field name='date' />
			<field name='generate_date' />
			<filter string="Draft" name="state_draft" domain="[('state','=','draft')]" />
			<filter string="Done" name="state_done" domain="[('state','=','done')]" />
			<group expand="0" string="Group By">
				<filter string="Branch" name="group_by_branch" domain="[]"
				context="{'group_by': 'company_id'}" />
				<filter name="date" string="Date" context="{'group_by': 'date'}" />
				<filter name="name" string="Name" context="{'group_by': 'name'}" />
			</group>
			</search>
		</field>
		</record>

		<record id="tw_work_order_wip_action" model="ir.actions.act_window">
			<field name="name">WIP</field>
			<field name="res_model">tw.work.order.wip</field>
			<field name="view_mode">list,form</field>
		</record>

	</data>
</odoo>