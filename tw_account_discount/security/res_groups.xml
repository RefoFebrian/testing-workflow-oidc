<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_tw_account_discount_read" model="res.groups">
            <field name="name">TW Account Discount Read</field>
            <field name="category_id" ref="tw_account.tw_module_category_account" />
        </record>

        <record id="access_tw_account_discount_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_discount" />
            <field name="name">tw_account_discount read</field>
            <field name="group_id" ref="group_tw_account_discount_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_account_move_discount_read" model="ir.model.access">
