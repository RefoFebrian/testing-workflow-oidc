<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_approval_matrix_branch_rule" model="ir.rule">
            <field name="name">tw.approval.matrix branch rule</field>
            <field name="model_id" ref="model_tw_approval_matrix"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_approval_line_branch_rule" model="ir.rule">
            <field name="name">tw.approval.line branch rule</field>
            <field name="model_id" ref="model_tw_approval_line"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mail_activity_rule_user_read" model="ir.rule">
            <field name="name">mail.activity: read own activity</field>
            <field name="model_id" ref="mail.model_mail_activity"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
    </data>
</odoo>
