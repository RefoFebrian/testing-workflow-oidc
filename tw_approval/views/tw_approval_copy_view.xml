<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
    
        <record id="tw_copy_approval_wizard_view" model="ir.ui.view">
            <field name="name">Copy Approval</field>
            <field name="model">tw.approval.copy</field>
            <field name="arch" type="xml">
            
                <form string="Copy Approval" version="7">
                	<group col="4" colspan="4">
                        <field name="branch_from_id" required="1" options="{'no_create':True, 'no_open':True}"/>
	                    <field name="branch_to_id" required="1" options="{'no_create':True, 'no_open':True}"/>
	                    <field name="approval_type" required="1"/>
	                    <field name="form_id" required="1"/>
	                    <field name="division" required="1"/>
                    </group>
                    <footer>
                        <button name="action_copy" string="Copy" type="object" class="oe_highlight"/>
                        or
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
                
            </field>
        </record>
        
        <record id="action_tw_copy_approval" model="ir.actions.act_window">
			<field name="name">Copy Approval</field>
			<field name="type">ir.actions.act_window</field>
			<field name="res_model">tw.approval.copy</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="tw_copy_approval_wizard_view"/>
			<field name="target">new</field>
	    </record>
		
		
    </data>
</odoo>