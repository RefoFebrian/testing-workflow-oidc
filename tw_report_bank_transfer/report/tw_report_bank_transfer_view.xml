<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_report_bank_transfer_form" model="ir.ui.view">
        <field name="name">tw.report.bank.transfer.form</field>
        <field name="model">tw.report.bank.transfer</field>
        <field name="arch" type="xml">
            <form string="Report Bank Transfer">
                <group>
                    <group>
                        <label for="start_date" string="Tanggal"/>
                        <div class="o_row">
                            <field name="start_date" widget="date" class="oe_inline"/>
                            <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                            <field name="end_date" widget="date" class="oe_inline"/>
                        </div>
                    </group>
                </group>
                <notebook>
                    <page string="Branch">
                        <field name="company_ids"/>
                    </page>
                </notebook>
                <footer>
                    <button name="action_print_report" string="Export Report" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tw_report_bank_transfer" model="ir.actions.act_window">
        <field name="name">Report Bank Transfer</field>
        <field name="res_model">tw.report.bank.transfer</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
