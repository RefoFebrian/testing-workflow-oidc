<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_p2p_stock_distribution_form_view" model="ir.ui.view">
            <field name="name">tw.p2p.stock.distribution.form</field>
		    <field name="model">tw.p2p.purchase.order</field>
            <field name="inherit_id" ref="tw_p2p.tw_p2p_purchase_form_view"/>
            <field name="arch" type="xml">
                <button name="action_view_po" position="after">
                    <button name="action_view_sd" type="object" class="oe_stat_button" icon="fa-truck" invisible="not stock_distribution_id">
                        <div>
                            <div>Stock Distribution</div>
                            <field name="stock_distribution_id" widget="statinfo" nolabel="1"/>
                        </div>
                    </button>
                </button>

               <field name="purchase_order_id" position="after">
                    <field name="stock_distribution_id" options="{'no_create': True,'no_open': True}" invisible="1"/>
               </field>
            </field>
            </record>
    </data>
</odoo>
