<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_bank_transfer_cancel_rfa_approve" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button RFA Bank Transfer Cancel</field>
        </record>

        <record id="access_tw_bank_transfer_cancel_rfa_approve" model="ir.model.access">
            <field name="model_id" ref="model_tw_bank_transfer_cancel"/>
            <field name="name">tw_bank_transfer_cancel_rfa_approve update</field>
            <field name="group_id" ref="group_tw_bank_transfer_cancel_rfa_approve"/>
            <field name="perm_write">1</field>
        </record>
    
        <record id="group_tw_bank_transfer_cancel_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Bank Transfer Cancel</field>
        </record>

        <record id="access_tw_bank_transfer_cancel_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_bank_transfer_cancel"/>
            <field name="name">tw_bank_transfer_cancel_approval_cancel update</field>
            <field name="group_id" ref="group_tw_bank_transfer_cancel_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_bank_transfer_cancel_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Bank Transfer Cancel</field>
        </record>

        <record id="access_tw_bank_transfer_cancel_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_bank_transfer_cancel"/>
            <field name="name">tw_bank_transfer_cancel_confirm update</field>
            <field name="group_id" ref="group_tw_bank_transfer_cancel_confirm"/>
            <field name="perm_write">1</field>
        </record>
    
    </data>

    <data>
    
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_bank_transfer_cancel_rfa_approve')),
                (4,ref('group_tw_bank_transfer_cancel_approval_cancel')),
                (4,ref('group_tw_bank_transfer_cancel_confirm')),
            ]">
			</field>
		</record>
    
    </data>
    
    

</odoo>
