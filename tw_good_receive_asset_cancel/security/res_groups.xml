<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- GR Asset Cancel READ -->
        <record id="group_gr_asset_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel Read</field>
        </record>

        <!-- GR Asset Cancel UPDATE -->
        <record id="group_gr_asset_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel Update</field>
            <field name="implied_ids" eval="[(4, ref('group_gr_asset_cancel_read'))]" />
        </record>

        <!-- GR Asset Cancel DELETE -->
        <record id="group_gr_asset_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_gr_asset_cancel_read'))]" />
        </record>

        <!-- GR Asset Cancel Button Groups -->
        <record id="group_gr_asset_cancel_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel RFA</field>
            <field name="implied_ids" eval="[(4, ref('group_gr_asset_cancel_read'))]" />
        </record>

        <record id="group_gr_asset_cancel_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel Approval Cancel</field>
            <field name="implied_ids" eval="[(4, ref('group_gr_asset_cancel_read'))]" />
        </record>

        <record id="group_gr_asset_cancel_approval_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW GR Asset Cancel Approval Confirm</field>
            <field name="implied_ids" eval="[(4, ref('group_gr_asset_cancel_read'))]" />
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_gr_asset_cancel_read')),
                (4, ref('group_gr_asset_cancel_update')),
                (4, ref('group_gr_asset_cancel_delete')),
                (4, ref('group_gr_asset_cancel_rfa')),
                (4, ref('group_gr_asset_cancel_approval_cancel')),
                (4, ref('group_gr_asset_cancel_approval_confirm')),
            ]" />
        </record>
    </data>

</odoo>