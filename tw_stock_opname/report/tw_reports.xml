        <record id="action_berita_acara_stock_opname" model="ir.actions.report">
            <field name="name">Berita Acara Stock Opname Unit</field>
            <field name="model">tw.stock.opname.baso.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_stock_opname.berita_acara_stock_opname</field>
