<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject Part Sales-specific DGI reference fields into base DGI Info popup -->
    <record id="view_tw_dgi_info_wizard_form_inherit_ps" model="ir.ui.view">
        <field name="name">tw.dgi.info.wizard.form.inherit.ps</field>
        <field name="model">tw.dgi.info.wizard</field>
        <field name="inherit_id" ref="tw_dgi.view_tw_dgi_info_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='dgi_reference_group']" position="inside">
                <field name="md_reference_ps" invisible="not md_reference_ps"/>
            </xpath>
        </field>
    </record>
</odoo>
