<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    <!-- Assets Mutation -->
        <record id="group_asset_mutation_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Mutation Asset Read</field>
        </record>        
        <record id="access_asset_mutation_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation"/>
            <field name="name">tw_asset_mutation read</field>
            <field name="group_id" ref="group_asset_mutation_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_asset_mutation_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation_line"/>
            <field name="name">tw_asset_mutation_line read</field>
            <field name="group_id" ref="group_asset_mutation_read"/>
            <field name="perm_read">1</field>
        </record>
    
       
        <record id="group_asset_mutation_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Mutation Asset Update</field>
			<field name="implied_ids" eval="[(4, ref('group_asset_mutation_read'))]"/>
        </record>
        <record id="access_tw_asset_mutation_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation"/>
            <field name="name">tw_asset_mutation update</field>
            <field name="group_id" ref="group_asset_mutation_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="access_tw_asset_mutation_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation_line"/>
            <field name="name">tw_asset_mutation_line update</field>
            <field name="group_id" ref="group_asset_mutation_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        
        <record id="group_asset_mutation_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Mutation Asset Delete</field>
			<field name="implied_ids" eval="[(4, ref('group_asset_mutation_read'))]"/>
        </record>        
		<record id="access_tw_asset_mutation_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation"/>
            <field name="name">tw_asset_mutation delete</field>
            <field name="group_id" ref="group_asset_mutation_delete"/>
            <field name="perm_unlink">1</field>
        </record>
		<record id="access_tw_asset_mutation_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation_line"/>
            <field name="name">tw_asset_mutation_line delete</field>
            <field name="group_id" ref="group_asset_mutation_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    <!-- Asset Distribution -->
    <record id="group_asset_distribution_read" model="res.groups">
        <field name="category_id" ref="tw_base.tw_module_category_asset"/>
        <field name="name">tw Asset Distribution Read</field>
    </record>        
    <record id="access_asset_distribution_read" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution"/>
        <field name="name">tw_asset_distribution read</field>
        <field name="group_id" ref="group_asset_distribution_read"/>
        <field name="perm_read">1</field>
    </record>
    <record id="access_asset_distribution_line_read" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution_line"/>
        <field name="name">tw_asset_distribution_line read</field>
        <field name="group_id" ref="group_asset_distribution_read"/>
        <field name="perm_read">1</field>
    </record>

   
    <record id="group_asset_distribution_update" model="res.groups">
        <field name="category_id" ref="tw_base.tw_module_category_asset"/>
        <field name="name">tw Asset Distribution Update</field>
        <field name="implied_ids" eval="[(4, ref('group_asset_distribution_read'))]"/>
    </record>
    <record id="access_tw_asset_distribution_update" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution"/>
        <field name="name">tw_asset_distribution update</field>
        <field name="group_id" ref="group_asset_distribution_update"/>
        <field name="perm_create">1</field>
        <field name="perm_write">1</field>
    </record>
    <record id="access_tw_asset_distribution_line_update" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution_line"/>
        <field name="name">tw_asset_distribution_line update</field>
        <field name="group_id" ref="group_asset_distribution_update"/>
        <field name="perm_create">1</field>
        <field name="perm_write">1</field>
    </record>
    
    
    <record id="group_asset_distribution_delete" model="res.groups">
        <field name="category_id" ref="tw_base.tw_module_category_asset"/>
        <field name="name">tw Asset Distribution Delete</field> 
        <field name="implied_ids" eval="[(4, ref('group_asset_distribution_read'))]"/>
    </record>        
    <record id="access_tw_asset_distribution_delete" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution"/>
        <field name="name">tw_asset_distribution delete</field>
        <field name="group_id" ref="group_asset_distribution_delete"/>
        <field name="perm_unlink">1</field>
    </record>
    <record id="access_tw_asset_distribution_line_delete" model="ir.model.access">
        <field name="model_id" ref="model_tw_asset_distribution_line"/>
        <field name="name">tw_asset_distribution_line delete</field>
        <field name="group_id" ref="group_asset_distribution_delete"/>
        <field name="perm_unlink">1</field>
    </record>

    </data>

    <data>

    <!-- Add all access to admin -->
    <record id="tw_base.group_system_admin" model="res.groups">
        <field name="implied_ids" eval="[
            (4,ref('group_asset_mutation_read')),	
            (4,ref('group_asset_mutation_update')),	
            (4,ref('group_asset_mutation_delete')),				
            (4,ref('group_asset_distribution_read')),	
            (4,ref('group_asset_distribution_update')),	
            (4,ref('group_asset_distribution_delete')),				
        ]"/> 
    </record>

    </data>
</odoo>
