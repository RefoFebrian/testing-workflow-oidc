<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Asset Mutation -->
        <record id="group_tw_asset_mutation_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Button Confirm Asset Mutation</field>
        </record>

        <record id="access_tw_asset_mutation_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_mutation"/>
            <field name="name">tw_asset_mutation_confirm update</field>
            <field name="group_id" ref="group_tw_asset_mutation_confirm"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Asset Distribution -->
        <record id="group_tw_asset_distribution_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset" />
            <field name="name">TW Button Confirm Asset Distribution</field>
        </record>

        <record id="access_tw_asset_distribution_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_distribution"/>
            <field name="name">tw_asset_distribution_confirm update</field>
            <field name="group_id" ref="group_tw_asset_distribution_confirm"/>
            <field name="perm_write">1</field>
        </record>
        <record id="access_tw_asset_distribution_line_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_distribution_line"/>
            <field name="name">tw_asset_distribution_line_confirm update</field>
            <field name="group_id" ref="group_tw_asset_distribution_confirm"/>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_picking_distribution_confirm" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_picking"/>
            <field name="name">stock_picking distribution_confirm create</field>
            <field name="group_id" ref="group_tw_asset_distribution_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_move_distribution_confirm" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_move"/>
            <field name="name">stock_move distribution_confirm create</field>
            <field name="group_id" ref="group_tw_asset_distribution_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
	</data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_asset_mutation_confirm')),
                (4,ref('group_tw_asset_distribution_confirm')),
            ]">
			</field>
		</record>
	</data>
</odoo>