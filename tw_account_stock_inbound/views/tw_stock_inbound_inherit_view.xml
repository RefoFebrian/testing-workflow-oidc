<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_stock_inbound_form_view" model="ir.ui.view">
            <field name="name">tw.account.stock.inbound.form</field>
            <field name="model">tw.stock.inbound</field>
            <field name="inherit_id" ref="tw_stock_inbound.tw_stock_inbound_form_view" />
            <field name="arch" type="xml">
                <!-- Add Accrue Expedition smart button inside the existing button_box -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_moves" type="object" class="oe_stat_button" icon="fa-book" invisible="move_count == 0">
                        <field name="move_count" widget="statinfo" string="Accrue Expedition"/>
                    </button>
                </xpath>
                <field name="division" position="after">
                    <field name="pricelist_type_id" options="{'no_create': True,'no_open': True}" invisible="pricelist_type_id == False" readonly="1"/>
                    <field name="volume" readonly="1" invisible="volume == False"/>
                </field>
            </field>
        </record>
    </data>
</odoo>