<odoo>
  <data>
    <record id="tw_stock_inbound_account_setting_inherit_form_view" model="ir.ui.view">
        <field name="name">tw.stock.inbound.account.setting.inherit.view.form</field>
        <field name="model">tw.account.setting</field>
        <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_3']" position="before">
                <page string="Warehouse" name="account_warehouse">
                  <group string="Warehouse">
                    <field name="journal_expedition_id" options='{"no_create": True}'/>
                  </group>
                </page>
            </xpath>
        </field>
    </record>
  </data>
</odoo>
