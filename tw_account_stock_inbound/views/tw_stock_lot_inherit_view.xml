<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_stock_lot_freight_cost_form_view" model="ir.ui.view">
            <field name="name">tw.stock.lot.freight.cost.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock_account.view_production_lot_form_stock_account" />
            <field name="arch" type="xml">
                <field name="company_currency_id" position="after">
                    <field name="freight_cost" widget="monetary" options="{'currency_field': 'company_currency_id'}" readonly="1"/>
                </field>
            </field>
        </record>
    </data>
</odoo>