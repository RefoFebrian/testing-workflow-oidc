<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Approval Business Trip -->
        <record id="group_tw_business_trip_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">RFA Business Trip</field>
        </record>
        <record id="access_tw_business_trip_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="model_tw_business_trip"/>
            <field name="name">tw_business_trip_approval_rfa update</field>
            <field name="group_id" ref="group_tw_business_trip_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_business_trip_approval_approved" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Approve Business Trip</field>
        </record>
        <record id="access_tw_business_trip_approval_approved" model="ir.model.access">
            <field name="model_id" ref="model_tw_business_trip"/>
            <field name="name">tw_business_trip_approval_approved update</field>
            <field name="group_id" ref="group_tw_business_trip_approval_approved"/>
            <field name="perm_write">1</field>
        </record>
             
        <record id="group_tw_business_trip_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Cancel Business Trip</field>
        </record>
        <record id="access_tw_business_trip_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_business_trip"/>
            <field name="name">tw_business_trip_approval_cancel update</field>
            <field name="group_id" ref="group_tw_business_trip_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>
                     
        <record id="group_tw_business_trip_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Reject Business Trip</field>
        </record>
        <record id="access_tw_business_trip_approval_reject" model="ir.model.access">
            <field name="model_id" ref="model_tw_business_trip"/>
            <field name="name">tw_business_trip_approval_reject update</field>
            <field name="group_id" ref="group_tw_business_trip_approval_reject"/>
            <field name="perm_write">1</field>
        </record>
        
	</data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_business_trip_approval_rfa')),
                (4,ref('group_tw_business_trip_approval_approved')),
                (4,ref('group_tw_business_trip_approval_cancel')),
                (4,ref('group_tw_business_trip_approval_reject')),
            ]">
			</field>
		</record>
	</data>
</odoo>