<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_business_trip_approval_form_view" model="ir.ui.view">
			<field name="name">tw.business.trip.approval.form</field>
			<field name="model">tw.business.trip</field>
			<field name="type">form</field>
			<field name="inherit_id" ref="tw_business_trip.view_tw_business_trip_form"/>
			<field name="arch" type="xml">
				<xpath expr="//button[@name='action_departed']" position="before">
					<button name="action_rfa" string="RFA" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_business_trip_approval.group_tw_business_trip_approval_rfa"/>
					<button name="action_approval" string="Approve" type="object" class="oe_highlight" invisible="state != 'waiting_for_approval'"/>
					<button name="action_reject_or_cancel" string="Reject" type="object" invisible="state != 'waiting_for_approval'" context="{'window_title': 'Reject'}"/>
				</xpath>

                <xpath expr="//field[@name='state']" position="replace">
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,departed,arrived,done" readonly="1"/>
                </xpath>

				<xpath expr="//page[@name='detail_kegiatan']" position="after">
					<page string="Approval">
						<field name="approval_ids" readonly="True"/>
					</page>
				</xpath>
			</field>
		</record>
	</data>
</odoo>