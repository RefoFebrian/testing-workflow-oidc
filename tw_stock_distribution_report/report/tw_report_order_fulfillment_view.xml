<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_report_order_fulfillment_view_wizard" model="ir.ui.view">
            <field name="name">Laporan Order Fulfillment</field>
            <field name="model">tw.report.order.fulfillment.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Laporan Order Fulfillment">
                    <group>
                        <group>
                            <field name="trx_type" required="1" />
                            <field name="division" />
                        </group>
                        <group>
                            <label for="start_date" string="Tanggal" />
                            <div>
                                <field name="start_date" class="oe_inline" required="1"/> s/d <field name="end_date" required="1"
                                    class="oe_inline" />
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids">
                                <list editable="top">
                                    <field name="name" string="Branch"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="excel_report" string="Export Report" type="object" class="oe_highlight" />
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>

                </form>
            </field>
        </record>

        <record id="action_report_order_fulfillment_wizard" model="ir.actions.act_window">
            <field name="name">Laporan Order Fulfillment</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.report.order.fulfillment.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_report_order_fulfillment_view_wizard" />
            <field name="target">new</field>
        </record>
    </data>
</odoo>