<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="group_stock_distribution_report_showroom_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan Stock Distribution Showroom Read</field>
        </record>

        <record id="group_stock_distribution_report_workshop_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan Stock Distribution Workshop Read</field>
        </record>

        <record id="access_tw_stock_distribution_report_showroom" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_distribution_report" />
            <field name="name">tw_stock_distribution_report read</field>
            <field name="group_id" ref="group_stock_distribution_report_showroom_read" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_stock_distribution_report_workshop" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_distribution_report" />
            <field name="name">tw_stock_distribution_report read</field>
            <field name="group_id" ref="group_stock_distribution_report_workshop_read" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="group_stock_distribution_report_order_fulfillment_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan Order Fulfillment Read</field>
        </record>

        <record id="access_tw_stock_distribution_report_order_fulfillment" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_order_fulfillment_wizard" />
            <field name="name">tw_stock_distribution_report_order_fulfillment read</field>
            <field name="group_id" ref="group_stock_distribution_report_order_fulfillment_read" />
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids"
                eval="[
                    (4,ref('group_stock_distribution_report_showroom_read')),
                    (4,ref('group_stock_distribution_report_workshop_read')),
                    (4,ref('group_stock_distribution_report_order_fulfillment_read')),
                ]" />
        </record>
    </data>


</odoo>