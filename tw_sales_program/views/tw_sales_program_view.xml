<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_sales_program_list_view" model="ir.ui.view">
            <field name="name">tw.sales.program.list</field>
            <field name="model">tw.sales.program</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Master Sales Program" default_order="id desc">
                    <field name="company_id"/>
                    <field name="name"/>
					<field name="division"/>
					<field name="sales_program_type_id"/>
					<field name="start_date"/>
					<field name="end_date"/>
					<field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_sales_program_form_view" model="ir.ui.view">
            <field name="name">tw.sales.program.form</field>
            <field name="model">tw.sales.program</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Master Sales Program">
 		        	<header>
		        		<field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved" statusbar_colors='{"draft": "red", "approved": "blue"}'/>
		        	</header>
                    <sheet>
                        <group>
                            <group>
                                <field name="company_id" required="1" readonly="state not in ('draft', 'on_revision')" options="{'no_create': True, 'no_open': True}"/>
                                <field name="division" required="1" readonly="state not in ('draft', 'on_revision')" options="{'no_create': True, 'no_open': True}"/>
                                <field name="area_id" required="sales_program_type_name != 'Program Voucher'" invisible="sales_program_type_name == 'Program Voucher'" readonly="state not in ('draft', 'on_revision')" options="{'no_create': True, 'no_open': True}"/>
                                <field name="name" required="1" readonly="state not in ('draft', 'on_revision')"/>
                                <label for="start_date" string="Periode"/>
                                    <div>
                                        <field name="start_date" class="oe_inline" nolabel="1" required="1" readonly="state not in ('draft', 'on_revision')"/> -
                                        <field name="end_date" nolabel="1" class="oe_inline" required="1" readonly="state not in ('draft', 'editable', 'on_revision')"/>
                                    </div>
                                <field name="partner_ref" required="sales_program_type_name in ('Program Subsidi Barang', 'Program Subsidi')" invisible="sales_program_type_name not in ('Program Subsidi Barang', 'Program Subsidi')" readonly="state not in ('draft', 'on_revision')"/>
                                <!-- <field name="subsidy_type" required="sales_program_type_name == 'Program Subsidi'" invisible="sales_program_type_name != 'Program Subsidi'" readonly="state not in ('draft', 'on_revision')"/> -->
                            </group>
                            <group>
                                <field name="sales_program_type_id" required="1" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="sales_program_type_name" invisible="1" readonly="1"/>
                                <field name="active" readonly="state not in ('draft', 'on_revision')"/>
                                <field name="note" invisible="sales_program_type_name == 'Program Voucher'" readonly="state not in ('draft', 'on_revision')"/>
                                <label for="promo_value" string="Nilai Promo"/>
                                <div>
                                    <field name="promo_value" class="oe_inline" nolabel="1"/>
                                    <button name="button_dummy" invisible="state != 'draft'" string="(update)" type="object" class="oe_edit_only oe_link" nolabel="1"/>
                                </div>
                            </group>
                        </group>
                        <notebook>
                            <page name="sales_program_lines" string="Sales Program Lines">
                                <field colspan="4" name="line_ids" nolabel="1" context="{'default_sales_program_type_id': sales_program_type_id}" readonly="state not in ('draft', 'on_revision')"/>
                            </page>
                            <page name="sales_program_lines_import" string="Import Sales Program" invisible="state != 'draft'">
                                <group>
                                    <group>
                                        <field name="file" filename="filename" string="Upload File"/>
                                        <field name="filename" invisible="1"/>
                                        <button name="action_import" string="Import" type="object" class="oe_highlight"/>
                                    </group>
                                    <group>
                                        <label for="action_download_format_file" string="Contoh File"/>
                                        <div>
                                            <button name="action_download_format_file" type="object" class="oe_highlight" icon="fa-download" string="Download Contoh"/>
                                        </div>
                                    </group>
                                </group>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
			    </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_sales_program_search_view" model="ir.ui.view">
            <field name="name">tw.sales.program.search</field>
            <field name="model">tw.sales.program</field>
            <field name="arch" type="xml">
                <search string="Master Sales Program">
                    <field name="name" select="True"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="area_id"/>
        			<!-- <field name="subsidy_type"/> -->
                     <group expand="0" string="Group By">
						<filter string="Branch" name="group_by_branch" icon="terp-go-month" domain="[]"
							context="{'group_by':'company_id'}" />
                        <filter string="Division" name="group_by_division" icon="terp-go-month" domain="[]"
							context="{'group_by':'division'}" />
						<filter string="Start Date" name="group_by_start_date" icon="terp-go-month" domain="[]"
							context="{'group_by':'start_date'}" />
                        <filter string="End Date" name="group_by_end_date" icon="terp-go-month" domain="[]"
							context="{'group_by':'end_date'}" />
					</group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_sales_program_subsidi_barang_action" model="ir.actions.server">
            <field name="name">Subsidi Barang</field>
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.sales.program'].action_sales_program_tree()
            </field>
        </record>
        
        <!-- Action View -->
        <record id="tw_sales_program_program_subsidi_action" model="ir.actions.server">
            <field name="name">Program Subsidi</field>
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.sales.program'].action_sales_program_tree(category='program_subsidi')
            </field>
        </record>
        
        <!-- Action View -->
        <record id="tw_sales_program_program_voucher_action" model="ir.actions.server">
            <field name="name">Program Voucher</field>
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.sales.program'].action_sales_program_tree(category='program_voucher')
            </field>
        </record>
        
    </data>
</odoo>