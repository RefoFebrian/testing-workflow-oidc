<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_b2b_file_server_configuration_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.file.server.configuration.list</field>
            <field name="model">tw.api.configuration</field>
            <field name="arch" type="xml">
                <list string="Configuration MFT File Server">
                    <field name="config_options_id" string="Configuration Local Folder"/>
                    <field name="base_url"/>
                    <field name="username"/>
                    <field name="folder_path_remote"/>
                </list>
            </field>
        </record>
        
        <record id="tw_b2b_file_server_configuration_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.file.server.configuration.form</field>
            <field name="model">tw.api.configuration</field>
            <field name="arch" type="xml">
                <form string="Configuration MFT File Server">
                    <sheet>
                        <group>
                            <field name="config_options_id" string="Configuration Local Folder" required="1" options="{'no_create': True,'no_open':True}"/>
                            <field name="base_url" required="1"/>
                            <field name="port" required="1"/>
                            <field name="username" required="1"/>
                            <field name="password" required="1" password="1"/>
                            <field name="folder_path_remote" required="1"/>
                            <field name="folder_path_local" required="1"/>
                        </group>
                        <notebook>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"></field>
                                        <field name="create_date" readonly="1"></field>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_b2b_file_server_configuration_action" model="ir.actions.act_window">
            <field name="name">Configuration MFT Server</field>
            <field name="res_model">tw.api.configuration</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{'default_api_type_id': ref('tw_b2b_file_management.tw_selection_type_api_mft_windows')}" />
            <field name="domain" eval="[('api_type_id', '=', ref('tw_b2b_file_management.tw_selection_type_api_mft_windows'))]"/>
        </record>

        <record id="tw_b2b_file_server_configuration_action_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_b2b_file_management.tw_b2b_file_server_configuration_list_view"/>
            <field name="act_window_id" ref="tw_b2b_file_server_configuration_action"/>
        </record>

        <record id="tw_b2b_file_server_configuration_action_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_b2b_file_management.tw_b2b_file_server_configuration_form_view"/>
            <field name="act_window_id" ref="tw_b2b_file_server_configuration_action"/>
        </record>
	</data>
</odoo>