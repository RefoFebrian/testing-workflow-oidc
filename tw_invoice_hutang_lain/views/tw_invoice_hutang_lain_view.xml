<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_invoice_hutang_lain_list_view" model="ir.ui.view">
            <field name="name">tw.invoice.hutang.lain.list</field>
            <field name="model">tw.invoice.hutang.lain</field>
            <field name="arch" type="xml">
                <list string="Invoice Hutang Lain" default_order="date desc, id desc">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="branch_id"/>
                    <field name="partner_id"/>
                    <field name="division"/>
                    <field name="amount" sum="Total"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'draft'"
                           decoration-warning="state == 'waiting_for_payment'"
                           decoration-success="state == 'paid'"
                           decoration-danger="state == 'cancel'"/>
                </list>
            </field>
        </record>

        <record id="tw_invoice_hutang_lain_form_view" model="ir.ui.view">
            <field name="name">tw.invoice.hutang.lain.form</field>
            <field name="model">tw.invoice.hutang.lain</field>
            <field name="arch" type="xml">
                <form string="Invoice Hutang Lain">
                    <header>
                        <button name="action_rfp" string="Request For Payment" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_invoice_hutang_lain.group_tw_invoice_hutang_lain_update"/>
                        <button name="action_paid" string="Paid" type="object" class="oe_highlight" invisible="state != 'waiting_for_payment'" groups="tw_invoice_hutang_lain.group_tw_invoice_hutang_lain_update"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state in ('paid', 'cancel')" groups="tw_invoice_hutang_lain.group_tw_invoice_hutang_lain_update"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_payment,paid"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_hutang_lain" type="object" class="oe_stat_button" icon="fa-bars" invisible="not hutang_lain_id">
                                <div class="o_stat_info">
                                    <span class="o_stat_text">Hutang Lain</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1 invisible="not name">
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="branch_id" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                                <field name="partner_type" readonly="state != 'draft'"/>
                                <field name="partner_id" readonly="state != 'draft'" options="{'no_quick_create': True}"/>
                                <field name="no_hp" required="1" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="division" readonly="state != 'draft'"/>
                                <field name="amount" required="1" readonly="state != 'draft'"/>
                                <field name="description" readonly="state != 'draft'"/>
                            </group>
                        </group>
                        <group string="Accounting">
                            <group>
                                <field name="journal_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                                <field name="account_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="currency_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="company_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="hutang_lain_id" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="paid_uid" readonly="1"/>
                                        <field name="paid_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="cancel_uid" readonly="1"/>
                                        <field name="cancel_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_invoice_hutang_lain_search_view" model="ir.ui.view">
            <field name="name">tw.invoice.hutang.lain.search</field>
            <field name="model">tw.invoice.hutang.lain</field>
            <field name="arch" type="xml">
                <search string="Invoice Hutang Lain">
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="branch_id"/>
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="waiting_for_payment" string="Waiting For Payment" domain="[('state', '=', 'waiting_for_payment')]"/>
                    <filter name="paid" string="Paid" domain="[('state', '=', 'paid')]"/>
                    <filter name="cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                </search>
            </field>
        </record>

        <record id="tw_invoice_hutang_lain_action" model="ir.actions.act_window">
            <field name="name">Invoice Hutang Lain</field>
            <field name="res_model">tw.invoice.hutang.lain</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_invoice_hutang_lain_search_view"/>
        </record>
    </data>
</odoo>
