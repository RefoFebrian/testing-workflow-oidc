<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_account_setting_invoice_hutang_lain_inherit_view" model="ir.ui.view">
            <field name="name">tw.account.setting.invoice.hutang.lain.inherit.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='account_backoffice']" position="inside">
                    <group>
                        <group string="Hutang Lain" name="backoffice_hutang_lain">
                            <field name="hutang_lain_account_line_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
