<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Invoice Hutang Lain -->
        <record id="group_tw_invoice_hutang_lain_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Invoice Hutang Lain Read</field>
        </record>

        <record id="access_tw_invoice_hutang_lain_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_invoice_hutang_lain"/>
            <field name="name">tw_invoice_hutang_lain read</field>
            <field name="group_id" ref="group_tw_invoice_hutang_lain_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_invoice_hutang_lain_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Invoice Hutang Lain Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_invoice_hutang_lain_read'))]"/>
        </record>

        <record id="access_tw_invoice_hutang_lain_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_invoice_hutang_lain"/>
            <field name="name">tw_invoice_hutang_lain update</field>
            <field name="group_id" ref="group_tw_invoice_hutang_lain_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_invoice_hutang_lain_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Invoice Hutang Lain Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_invoice_hutang_lain_read'))]"/>
        </record>

        <record id="access_tw_invoice_hutang_lain_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_invoice_hutang_lain"/>
            <field name="name">tw_invoice_hutang_lain delete</field>
            <field name="group_id" ref="group_tw_invoice_hutang_lain_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_invoice_hutang_lain_read')),
                (4, ref('group_tw_invoice_hutang_lain_update')),
                (4, ref('group_tw_invoice_hutang_lain_delete')),
            ]"/>
        </record>
    </data>
</odoo>
