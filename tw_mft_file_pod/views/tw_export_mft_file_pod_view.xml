<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <!-- Wizard View -->
        <record id="tw_export_mft_file_pod_wizard_view" model="ir.ui.view">
            <field name="name">tw.export.mft.file.pod.wizard</field>
            <field name="model">tw.export.mft.file.pod</field>
            <field name="arch" type="xml">
                <form>
                	<sheet>
                        <group invisible="state == 'get'">
                            <group>
                                <field name="options" required="1"/>
                                <label for="start_date" string="Periode"/>
                                <div>
                                    <field name="start_date" required="1" class="oe_inline"/> -
                                    <field name="end_date" required="1" class="oe_inline"/>
                                </div>
                                <div>
                                    <span style="font-weight: bold; color: #006400;">
                                        &#160;Tanggal Pengiriman Otomatis selanjutnya
                                    </span>
                                    <field name="nextcall_date" readonly="1" force_save="1" nolabel="1"/>
                                </div>
                                <field name="is_skip_scheduler"/>
                            </group>
                            <group>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>
		                <field invisible="1" name="state"/>
		                <newline/>    
		                <group col="4" fill="0" invisible="state != 'get'">
		                    <separator colspan="4" string="Generate Export MFT File POD Success ..." invisible="state == 'choose'"/>
		                </group>
		                <footer>
		                    <button name="action_export" invisible="state == 'get'" string="Export Data" type="object" class="oe_highlight"/>
		                    <button string="Cancel" invisible="state == 'get'" class="oe_link" special="cancel" />
		                </footer>
	                </sheet>
	            </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_export_mft_file_pod_action" model="ir.actions.server">
            <field name="name">Export MFT File POD</field>
            <field name="model_id" ref="tw_mft_file_pod.model_tw_export_mft_file_pod"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.export.mft.file.pod'].action_export_mft_file_pod_tree()
            </field>
        </record>
	     
	</data>
</odoo>