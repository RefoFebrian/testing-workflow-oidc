<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Partner Drawdown Group Read -->
        <record id="group_partner_drawdown_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Partner Drawdown Read</field>
        </record>

        <record id="access_partner_drawdown_read" model="ir.model.access">
            <field name="model_id" ref="model_partner_drawdown_upload_wizard"/>
            <field name="name">drawdown.partner.read</field>
            <field name="group_id" ref="tw_sale_drawdown.group_partner_drawdown_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
        <record id="access_partner_update" model="ir.model.access">
            <field name="model_id" ref="model_res_partner"/>
            <field name="name">res.partner.update</field>
            <field name="group_id" ref="tw_sale_drawdown.group_partner_drawdown_read"/>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="group_partner_drawdown_master" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Partner Drawdown Master</field>
        </record>
        <record id="access_partner_drawdown_master" model="ir.model.access">
            <field name="model_id" ref="model_partner_drawdown_upload_wizard"/>
            <field name="name">drawdown.partner.master</field>
            <field name="group_id" ref="tw_sale_drawdown.group_partner_drawdown_master"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data noupdate="1">
        <!-- Add all access to admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_sale_drawdown.group_partner_drawdown_read')),
                (4,ref('tw_sale_drawdown.group_partner_drawdown_master')),				
            ]"/> 
        </record>
    </data>
</odoo>
