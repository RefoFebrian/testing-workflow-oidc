<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record model="ir.rule" id="tw_mutation_order_rule">
            <field name="name">tw mutation order company rule</field>
            <field name="model_id" ref="model_tw_mutation_order"/>
            <field name="domain_force"> ['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]</field>
        </record>

        <record model="ir.rule" id="tw_mutation_order_incoming_shipment_rule">
            <field name="name">tw mutation order incoming ship company rule</field>
            <field name="model_id" ref="model_stock_lot"/>
            <field name="domain_force">['|', ('company_id','in',company_ids + [False]), ('company_transfer_id','in',company_ids)]</field>
        </record>

    </data>
</odoo>

