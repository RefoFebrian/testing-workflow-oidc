<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_asset_lending_rule" model="ir.rule">
            <field name="name">tw_asset_lending branch rule</field>
            <field name="model_id" ref="model_tw_asset_lending"/>
            <field name="domain_force">[('company_id','in',[b.id for b in user.company_id])]</field>
        </record>
        <record id="tw_asset_return_rule" model="ir.rule">
            <field name="name">tw_asset_return branch rule</field>
            <field name="model_id" ref="model_tw_asset_return"/>
            <field name="domain_force">[('company_id','in',[b.id for b in user.company_id])]</field>
        </record>
    </data>
</odoo>
