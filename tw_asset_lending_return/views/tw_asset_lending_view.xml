<?xml version='1.0' encoding='utf-8'?>
<odoo>
	<data>
    <!-- Peminjaman Aset -->
        <record id="tw_asset_lending_view_tree" model="ir.ui.view">
            <field name="name">tw.asset.lending.tree</field>
            <field name="model">tw.asset.lending</field>
            <field name="arch" type="xml">
            	<list string="Peminjaman Aset">
                    <field name="company_id"/>
                    <field name="inter_company_id"/>
            		<field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="state"/>
            	</list>
            </field>
        </record>
        
        <record id="tw_asset_lending_view_form" model="ir.ui.view">
            <field name="name">tw.asset.lending.form</field>
            <field name="model">tw.asset.lending</field>
            <field name="arch" type="xml">
            	<form string="Peminjaman Aset">
            		<header>
                        <button name="action_confirm" string="Confirm" invisible="state != 'draft'" type="object" class="oe_highlight"/>                        
                        <field name="state" widget="statusbar" statusbar_visible="draft,open,partially_returned,done" readonly="1"/>
                    </header>
            		<sheet>
                        <div class="oe_title">
                            <h1>
                                Peminjaman Aset 
                                <field name="name" readonly="1" invisible="not name" class="oe_inline"/>
                            </h1>
                        </div>
						<group>
                            <group>
                                <field name="company_id" required="1" readonly="state != 'draft' or name" options="{'no_create': True, 'no_open': True}"/>
                                <field name="employee_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                                <field name="job_id" force_save="1" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="inter_company_id" required="1" readonly="state != 'draft' or name" options="{'no_create': True, 'no_open': True}"/>
                                <field name="division" required="1" readonly="state != 'draft'"/>
                                <field name="date" readonly="1" required="1"/>
                                <label for="start_date" string="Periode Pinjam"/>
                                <div>
                                    <field name="start_date" readonly="state != 'draft'" required="1" class="oe_inline" style="margin-right: 3px;"/> s/d
                                    <field name="end_date" readonly="state != 'draft'" required="1" class="oe_inline"/>
                                </div>
                            </group>
                        </group>
                        <notebook>
                            <page name="detail_asset" string="Detail">
                                <field name="item_ids" nolabel="1" readonly="state != 'draft'">
                                    <list editable="top">
                                        <field name="asset_id" domain="[('company_id','=',parent.inter_company_id)]" required="1" options="{'no_open':True, 'no_create': True}"/>
                                        <field name="employee_id" readonly="1" options="{'no_open':True, 'no_create': True}"/>
                                        <field name="employee_user_id" domain="[('company_id','=',parent.company_id)]" options="{'no_open':True, 'no_create': True}"/>
                                        <field name="asset_code" required="1" readonly="1" invisible="1"/>
                                        <field name="asset_location_id" readonly="1" options="{'no_open':True, 'no_create': True}"/>
                                        <field name="asset_engine_no" required="1" force_save="1"/>
                                        <field name="asset_chassis_no" required="1" force_save="1"/>
                                        <field name="asset_year" required="1" readonly="1" force_save="1"/>
                                        <field name="condition_rent" required="1" force_save="1"/>
                                        <field name="reason_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                        <field name="note"/>
                                        <field name="state" invisible="1"/>
                                        <field name="rent_date" invisible="1"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <div class="oe_title">
                                                <h1>
                                                    <field name="asset_id" readonly="1" options="{'no_open':True, 'no_create': True}"/>
                                                </h1>
                                            </div>
                                            <group>
                                                <group>
                                                    <field name="asset_code" readonly="1" force_save="1"/>
                                                    <field name="asset_year" readonly="1" force_save="1"/>
                                                    <field name="reason_id" readonly="1" force_save="1"/>
                                                    <field name="note" readonly="1" force_save="1"/>
                                                </group>
                                                <group>
                                                    <field name="asset_location_id" readonly="1" options="{'no_open':True, 'no_create': True}"/>
                                                    <field name="asset_engine_no" readonly="1" force_save="1"/>
                                                    <field name="asset_chassis_no" readonly="1" force_save="1"/>
                                                </group>
                                                <group string="Peminjaman" name="peminjaman_detail">
                                                    <field name="rent_date" readonly="1" force_save="1"/>
                                                    <field name="condition_rent" readonly="1" force_save="1"/>
                                                </group>
                                                <group string="Pengembalian" name="pengembalian_detail">
                                                    <field name="return_date" readonly="1" force_save="1"/>
                                                    <field name="condition_return" readonly="1" force_save="1"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Audit Trail">
                                                    <group>
                                                        <group>
                                                            <field name="create_uid" readonly="1"/>
                                                            <field name="create_date" readonly="1"/>
                                                        </group>
                                                        <group>
                                                            <field name="write_uid" readonly="1"/>
                                                            <field name="write_date" readonly="1"/>
                                                        </group>
                                                    </group>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
            		</sheet>
            	</form>
            </field>
        </record>

        <record id="tw_asset_lending_search_view" model="ir.ui.view">
            <field name="name">tw.asset.lending.search</field>
            <field name="model">tw.asset.lending</field>
            <field name="arch" type="xml">
                <search string="Search Peminjaman Aset">
                    <field name="name" string="Nomor Transaksi"/>
                    <field name="company_id" string="Branch"/>
                    <field name="inter_company_id" string="Pinjam Ke"/>
                    <field name="employee_id" string="Penanggung Jawab"/>
                    <field name="date"/>
                    <field name="start_date"/>
                    <field name="job_id"/>
                    <field name="item_ids" string="Asset" filter_domain="[('item_ids.asset_id','ilike', self)]"/>
                    <field name="item_ids" string="Asset Code" filter_domain="[('item_ids.asset_code','ilike', self)]"/>
                    <field name="item_ids" string="Lokasi Asset" filter_domain="[('item_ids.asset_location_id','ilike', self)]"/>
                    <field name="item_ids" string="Nomor Mesin" filter_domain="[('item_ids.asset_engine_no','ilike', self)]"/>
                    <field name="item_ids" string="Nomor Rangka" filter_domain="[('item_ids.asset_chassis_no','ilike', self)]"/>
                    <field name="item_ids" string="Kondisi Saat Dipinjam" filter_domain="[('item_ids.condition_rent','ilike', self)]"/>
                    <field name="item_ids" string="Alasan pinjam" filter_domain="[('item_ids.reason_id','ilike', self)]"/>
                    <field name="item_ids" string="Keterangan" filter_domain="[('item_ids.note','ilike', self)]"/>
                    <field name="item_ids" string="Tanggal Pinjam" filter_domain="[('item_ids.rent_date','ilike', self)]"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Running" name="open" domain="[('state','=','open')]"/>
                    <filter string="Returned" name="done" domain="[('state','=','done')]"/>
                    <filter string="Partially Returned" name="partially_returned" domain="[('state','=','partially_returned')]"/>
                    <filter string="Returned" name="done" domain="[('state','=','done')]"/>
                    <filter string="Outstanding" name="outstanding" domain="[('state','!=','done')]"/>
                    <group string="Group By" name="groupby">
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="group_by_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                        <filter name="group_by_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                        <filter name="group_by_inter_company" string="Pinjaman ke" context="{'group_by': 'inter_company_id'}"/>
                        <filter name="group_by_division" string="Divisi" context="{'group_by': 'division'}"/>
                    </group>
                </search>
            </field>
        </record>
        
    <!-- Action -->
        <record id="tw_asset_lending_action" model="ir.actions.act_window">
            <field name="name">Peminjaman Aset</field>
            <field name="res_model">tw.asset.lending</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'readonly_by_pass': 1,'search_default_outstanding':1}</field>
            <field name="search_view_id" ref="tw_asset_lending_search_view"/>
        </record>

    
    </data>
</odoo>