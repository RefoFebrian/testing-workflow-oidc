<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="tw_inherit_account_asset_asset_form_view" model="ir.ui.view">
		<field name="name">tw.inherit.account.asset.asset.lending.form.view</field>
		<field name="model">account.asset.asset</field>
		<field name="inherit_id" ref="om_account_asset.view_account_asset_asset_form" />
		<field name="arch" type="xml">

			<page name="depreciation_board" position="after">
				<page name="lending_assets" string="History Peminjaman">
					<field name="lending_asset_ids" nolabel="1" widget="one2many_list" readonly="1">
						<list>
							<field name="rent_id" string="Nomor Peminjaman" readonly="1"/>
							<field name="rent_date" string="Tgl Peminjaman" readonly="1"/>
							<field name="condition_rent" string="Kondisi Saat Dipinjam" readonly="1"/>
							<field name="return_date" string="Tgl Kembali" readonly="1"/>
							<field name="condition_return" string="Kondisi Saat Dikembalikan" readonly="1"/>
							<field name="state" string="Status" readonly="1"/>
						</list>
					</field>
				</page>
			</page>

		</field>
	</record>

</odoo>
