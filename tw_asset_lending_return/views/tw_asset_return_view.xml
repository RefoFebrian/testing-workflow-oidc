<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
    <!-- Pengembalian Aset -->
        <record id="tw_asset_return_view_list" model="ir.ui.view">
            <field name="name">tw.asset.return.tree</field>
            <field name="model">tw.asset.return</field>
            <field name="arch" type="xml">
            	<list string="Pengembalian Aset">
                    <field name="company_id"/>
            		<field name="name"/>
                    <field name="date"/>
                    <field name="state"/>
            	</list>
            </field>
        </record>
        
        <record id="tw_asset_return_view_form" model="ir.ui.view">
            <field name="name">tw.asset.return.form</field>
            <field name="model">tw.asset.return</field>
            <field name="arch" type="xml">
            	<form string="Pengembalian Aset">
            		<header>
                        <button name="action_confirm" string="Confirm" invisible="state not in ['draft']" type="object" class="oe_highlight"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed" readonly="1"/>
                    </header>
            		<sheet>
                        <div class="oe_title">
                            <h1>
                                Pengembalian Aset 
                                <field name="name" readonly="1" invisible="not name" class="oe_inline"/>
                            </h1>
                        </div>
						<group>
                            <group>
                                <field name="company_id" required="1" readonly="state != 'draft' or name" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="date" readonly="1" required="1" force_save="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detail">
                                <field name="item_ids" nolabel="1" readonly="state != 'draft'">
                                    <list editable="top">
                                        <field name="rent_id" required="1" options="{'no_open':True, 'no_create': True}" />
                                        <field name="rent_line_id" required="1" options="{'no_open':True, 'no_create': True}" />
                                        <field name="asset_id" invisible="1" force_save="1"/>
                                        <field name="employee_user_id" readonly="1" force_save="1"/>
                                        <field name="asset_code" readonly="1" force_save="1"/>
                                        <field name="asset_location_id" readonly="1" options="{'no_open':True, 'no_create': True}" force_save="1"/>
                                        <field name="asset_engine_no" readonly="1" force_save="1"/>
                                        <field name="asset_chassis_no" readonly="1" force_save="1"/>
                                        <field name="asset_year" readonly="1" force_save="1"/>
                                        <field name="rent_date" readonly="1" force_save="1"/>
                                        <field name="condition_rent" required="1" readonly="0" force_save="1"/>
                                        <field name="note" />
                                    </list>
                                    <form>
                                        <sheet>
                                            <div class="oe_title">
                                                <h1>
                                                    <field name="asset_id" readonly="1" options="{'no_open':True, 'no_create': True}" />
                                                </h1>
                                            </div>
                                            <group>
                                                <group>
                                                    <field name="asset_code" readonly="1"  force_save="1"/>
                                                    <field name="asset_year" readonly="1"  force_save="1"/>
                                                    <field name="note" readonly="1"  force_save="1"/>
                                                </group>
                                                <group>
                                                    <field name="asset_location_id" readonly="1" options="{'no_open':True, 'no_create': True}"  force_save="1"/>            
                                                    <field name="asset_engine_no" readonly="1"  force_save="1"/>
                                                    <field name="asset_chassis_no" readonly="1"  force_save="1"/>
                                                </group>
                                                <group string="Peminjaman">
                                                    <field name="rent_date" readonly="1"  force_save="1"/>
                                                    <field name="condition_rent" readonly="1"  force_save="1"/>
                                                    <field name="rent_line_id" invisible="1"  force_save="1"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Audit Trail">
                                                    <group>
                                                        <group>
                                                            <field name="create_uid" readonly="1" />
                                                            <field name="create_date" readonly="1" />
                                                        </group>
                                                        <group>
                                                            <field name="write_uid" readonly="1" />
                                                            <field name="write_date" readonly="1" />
                                                        </group>
                                                    </group>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
            		</sheet>
            	</form>
            </field>
        </record>

        <record id="tw_asset_return_search_view" model="ir.ui.view">
            <field name="name">tw.asset.return.search</field>
            <field name="model">tw.asset.return</field>
            <field name="arch" type="xml">
                <search string="Search Pengembalian Aset">
                    <field name="name" string="Nomor Transaksi"/>
                    <field name="company_id"/>
                    <field name="employee_id"/>
                    <field name="date"/>
                    <field name="item_ids" string="No Peminjaman" filter_domain="[('item_ids.rent_id','ilike', self)]"/>
                    <field name="item_ids" string="Asset Yang Dipinjam" filter_domain="[('item_ids.rent_line_id','ilike', self)]"/>
                    <field name="item_ids" string="Asset" filter_domain="[('item_ids.asset_id','ilike', self)]"/>
                    <field name="item_ids" string="Asset Code" filter_domain="[('item_ids.asset_code','ilike', self)]"/>
                    <field name="item_ids" string="Lokasi Asset" filter_domain="[('item_ids.asset_location_id','ilike', self)]"/>
                    <field name="item_ids" string="Nomor Mesin" filter_domain="[('item_ids.asset_engine_no','ilike', self)]"/>
                    <field name="item_ids" string="Nomor Rangka" filter_domain="[('item_ids.asset_chassis_no','ilike', self)]"/>
                    <field name="item_ids" string="Kondisi Saat Dipinjam" filter_domain="[('item_ids.condition_rent','ilike', self)]"/>
                    <field name="item_ids" string="Keterangan" filter_domain="[('item_ids.note','ilike', self)]"/>
                    <field name="item_ids" string="Tanggal Pinjam" filter_domain="[('item_ids.rent_date','ilike', self)]"/>
                    
                    <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]" />
                    <filter name="confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]" />
                    <group string="Group By" name="groupby">
                        <filter name="group_by_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                        <filter name="group_by_state" string="State" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_asset_return_action" model="ir.actions.act_window">
            <field name="name">Pengembalian Aset</field>
            <field name="res_model">tw.asset.return</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'readonly_by_pass': 1,'search_default_draft':1}</field>
            <field name="search_view_id" ref="tw_asset_return_search_view"/>
        </record>

    </data>
</odoo>