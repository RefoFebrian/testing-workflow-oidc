<odoo>
    <data>

        <record model="ir.ui.view" id="tw_payment_inherit_approval_form_view">
            <field name="name">tw.payment.inherit.approval.form</field>
            <field name="model">tw.account.payment</field>
            <field name="inherit_id" ref="tw_payment.tw_account_payment_form_view"/>
            <field name="arch" type="xml">
                    <xpath expr="//sheet" position="inside">
                        <field name="has_debit_lines" invisible="1"/>
                    </xpath>

                    <field name="state" position="replace">
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,paid"/>
                    </field>

                    <button name="action_post" position="attributes">
                        <attribute name="invisible">state != 'approved' and not (state == 'draft' and type == 'customer_payment' and not has_debit_lines)</attribute>
                    </button>
                    
                    <button name="action_post" position="after">
                        <button name="action_request_approval" data-hotkey="r" groups="tw_payment_approval.group_tw_payment_rfa" invisible="state != 'draft' or (type == 'customer_payment' and not has_debit_lines)" string="RFA" type="object" class="oe_highlight"/>
                        <button name="action_approval" data-hotkey="a" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight"/>
                        <button name="%(tw_approval.tw_approval_reject_wizard_action)d" invisible="state != 'waiting_for_approval'" string="Reject" type="action" context="{'model_name':'tw.account.payment','update_value':{'state':'draft'}}"/>
                        <button name="%(tw_approval.tw_approval_cancel_wizard_action)d" invisible="state not in ('waiting_for_approval','approved')" string="Cancel Approval" groups="tw_payment_approval.group_tw_payment_cancel_approval" type="action" context="{'model_name':'tw.account.payment','update_value':{'state':'draft'}}"/>																		
                    </button>

                    <page name="audit_trail" position="before">
                        <page string="Approval">
                            <field name="approval_ids" />
                        </page>
                    </page>
                    <page name="audit_trail_customer_payment" position="before">
                        <page string="Approval">
                            <field name="approval_ids" />
                        </page>
                    </page>
            </field>
        </record>
      
        <record model="ir.ui.view" id="tw_payment_inherit_approval_search_view">
            <field name="name">tw.payment.inherit.approval.search</field>
            <field name="model">tw.account.payment</field>
            <field name="inherit_id" ref="tw_payment.tw_account_payment_search_view"/>
            <field name="arch" type="xml">
                <filter name="draft" position="after">
                    <filter string="Waiting Approval" name="waiting_approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                </filter>
            </field>
        </record>
        
        <record id="tw_payment.tw_customer_payment_action" model="ir.actions.act_window">
            <field name="context" eval="
                {
                    'default_payment_type': 'inbound',
                    'default_type': 'customer_payment',
                    'default_partner_type': 'customer',
                    'search_default_inbound_filter': 1,
                    'search_default_draft': 1,
                    'search_default_waiting_approval': 1,
                    'search_default_approved': 1,
                    'default_move_journal_types': ('bank', 'cash'),
                    'display_account_trust': True,
                    'action_id': ref('tw_payment.tw_customer_payment_action'),
                }
            " />
        </record>

        <record id="tw_payment.tw_supplier_payment_action" model="ir.actions.act_window">
            <field name="context" eval="
                {
                    'default_payment_type': 'outbound',
                    'default_type': 'supplier_payment',
                    'default_partner_type': 'supplier',
                    'search_default_outbound_filter': 1,
                    'search_default_draft': 1,
                    'search_default_waiting_approval': 1,
                    'search_default_approved': 1,
                    'default_move_journal_types': ('bank', 'cash'),
                    'display_account_trust': True,
                    'action_id': ref('tw_payment.tw_supplier_payment_action'),
                }
            " />
        </record>

    </data>
</odoo>
