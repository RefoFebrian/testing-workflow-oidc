<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_payment_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Request Approval Payment</field>
        </record>

        <record id="access_tw_payment_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_payment_rfa</field>
            <field name="group_id" ref="group_tw_payment_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Cancel Payment -->
		
        <record id="group_tw_payment_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Approval Payment</field>
        </record>

        <record id="access_tw_payment_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_payment_cancel_approval</field>
            <field name="group_id" ref="group_tw_payment_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>
          
                
        <!-- reject Payment -->
		
        <record id="group_tw_payment_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Approval Payment</field>
        </record>

        <record id="access_tw_payment_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_payment_reject_approval</field>
            <field name="group_id" ref="group_tw_payment_reject_approval"/>
            <field name="perm_write">1</field>
        </record>
          

        <!-- Recieve Payment -->
		
        <record id="group_tw_receive_payment_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Hutang Lain RFA</field>
        </record>

        <record id="access_tw_receive_payment_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_receive_payment_rfa</field>
            <field name="group_id" ref="group_tw_receive_payment_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Cancel Payment -->
		
        <record id="group_tw_receive_payment_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Receive Payment</field>
        </record>

        <record id="access_tw_receive_payment_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_receive_payment_cancel_approval</field>
            <field name="group_id" ref="group_tw_receive_payment_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Reject Payment -->
        <record id="group_tw_receive_payment_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Receive Payment</field>
        </record>

        <record id="access_tw_receive_payment_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_payment.model_tw_account_payment"/>
            <field name="name">tw_receive_payment_reject_approval</field>
            <field name="group_id" ref="group_tw_receive_payment_reject_approval"/>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_payment_rfa')),
                (4, ref('group_tw_payment_cancel_approval')),
                (4, ref('group_tw_payment_reject_approval')),
                (4, ref('group_tw_receive_payment_rfa')),
                (4, ref('group_tw_receive_payment_cancel_approval')),
                (4, ref('group_tw_receive_payment_reject_approval')),
            ]"/>
        </record>
    </data>

</odoo>
