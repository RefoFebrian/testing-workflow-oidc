<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Wizard Form View -->
        <record id="tw_dgi_lead_wizard_form_view" model="ir.ui.view">
            <field name="name">tw.dgi.lead.wizard.form</field>
            <field name="model">tw.dgi.lead.wizard</field>
            <field name="arch" type="xml">
                <form string="Sync Lead dari DGI">
                    <group>
                        <group string="Filter">
                            <field name="company_id" required="1" options="{'no_create': True, 'no_open': True}" domain="[('parent_id', '!=', False)]"/>
                            <field name="from_time" required="1"/>
                            <field name="to_time" required="1"/>
                        </group>
                        <group string="Optional Filter">
                            <field name="id_prospect"/>
                            <field name="sales_id"/>
                        </group>
                    </group>
                    <group string="Result">
                        <field name="found_count" readonly="1"/>
                    </group>
                    <group string="Process Log" invisible="not process_log">
                        <field name="process_log" readonly="1" nolabel="1" widget="text" colspan="2"/>
                    </group>
                    <footer>
                        <button name="action_get_dgi_data" string="Sync dari DGI" type="object" class="btn-primary"/>
                        <button string="Tutup" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="tw_dgi_lead_wizard_action" model="ir.actions.act_window">
            <field name="name">Sync Lead DGI</field>
            <field name="res_model">tw.dgi.lead.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <!-- Menu under tw.lead or Sales menu -->
        <!-- Uncomment and adjust parent menu as needed -->
        <!--
        <menuitem id="tw_dgi_lead_sync_menu" name="Sync Lead dari DGI" action="tw_dgi_lead_wizard_action" parent="tw_lead.tw_lead_menu_root" sequence="100"/>
        -->
    </data>
</odoo>
