<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        =============================================================
        DGI Lead Endpoint Configurations
        
        Endpoint untuk sync Prospect/Lead dari DGI API
        Satu endpoint per API Config (HSO, ASP, DAM, DAW, NPM, SINSEN)
        =============================================================
        -->

        <!-- ==================== HSO ==================== -->
        <record id="tw_endpoint_dgi_prospect_hso" model="tw.endpoint.configuration">
            <field name="code">dgi_prospect</field>
            <field name="version">1</field>
            <field name="url_path">prsp/read</field>
            <field name="method">post</field>
            <field name="config_id" ref="tw_dgi.tw_api_config_dgi_hso"/>
            <field name="mode">read</field>
            <field name="target_model_id" ref="tw_lead.model_tw_lead"/>
            <field name="dgi_division_id" ref="tw_dgi.tw_selection_division_dgi_h1"/>
        </record>

