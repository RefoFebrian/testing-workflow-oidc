<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <data>
    	<record id="tw_laporan_rincian_kendaraan_view" model="ir.ui.view">
            <field name="name">tw.laporan.rincian.kendaraan.view</field>
            <field name="model">tw.laporan.rincian.kendaraan</field>
            <field name="arch" type="xml">
                <form string="Laporan Rincian Kendaraan">
                	<sheet>
                		<group>
                            <group>
                                <label for="start_date" string="Periode"/>
                                <div>
                                    <field name="start_date" class="oe_inline" required="1"/> - <field name="end_date" class="oe_inline" required="1"/>
                                </div>
                            </group>
                            <group>
                				<field name="tgl_beli" string="Date" readonly="1"/>
                 			</group>
                		</group>
                        <notebook colspan="5"> 
                            <page string="Branches">
                                <field name="company_ids" colspan="4" nolabel="1"/>
                            </page>
                        </notebook> 
                		<footer>
			                <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/> Or
			                <button string="Cancel" class="oe_link" special="cancel" />
			            </footer>
                	</sheet>
                </form>
            </field>
        </record>  

        <record id="tw_laporan_rincian_kendaraan_action" model="ir.actions.act_window">
            <field name="name">Laporan Rincian Kendaraan</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.laporan.rincian.kendaraan</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
	    </record>

	    <menuitem id="tw_laporan_rincian_kendaraan_menuitem"  parent="tw_menu.submenu_tw_showroom_report" sequence="101"  action="tw_laporan_rincian_kendaraan_action" groups="tw_laporan_rincian_kendaraan.group_tw_laporan_rincian_kendaraan_read"/> 
    </data>

</odoo>
