<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- TW NRFS Sparepart Read -->
        <record id="tw_nrfs_sparepart_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Outstanding NRFS Sparepart Read</field>
        </record>

        <record id="tw_nrfs_sparepart_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs" />
            <field name="name">tw_nrfs read</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_nrfs_sparepart_line_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_line" />
            <field name="name">tw_nrfs_line read</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_read" />
            <field name="perm_read">1</field>
        </record>
        
    <!-- TW NRFS Sparepart Update -->
        <record id="tw_nrfs_sparepart_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Outstanding NRFS Sparepart Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_nrfs_sparepart_group_read'))]" /> 
        </record>

        <record id="tw_nrfs_sparepart_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs" />
            <field name="name">tw_nrfs update</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_nrfs_sparepart_line_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_line" />
            <field name="name">tw_nrfs_line update</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    <!-- TW NRFS Sparepart Delete -->
        <record id="tw_nrfs_sparepart_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Outstanding NRFS Sparepart Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_nrfs_sparepart_group_read'))]" />
        </record>

        <record id="tw_nrfs_sparepart_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs" />
            <field name="name">tw_nrfs delete</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_nrfs_sparepart_line_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_line" />
            <field name="name">tw_nrfs_line delete</field>
            <field name="group_id" ref="tw_nrfs_sparepart_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

    <!-- Admin Menus -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_nrfs_sparepart_group_read')),
   	            (4,ref('tw_nrfs_sparepart_group_update')),
   	            (4,ref('tw_nrfs_sparepart_group_delete'))
            ]" />
        </record>
    </data>
</odoo>