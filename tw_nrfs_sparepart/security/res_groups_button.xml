            <field name="group_id" ref="tw_nrfs_sparepart_validate_group_button_read"/>
            <field name="perm_write">1</field>
        </record>
        
    <!-- Include in admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_nrfs_sparepart_validate_group_button_read')),
            ]"/> 
        </record> 
    </data>
</odoo>