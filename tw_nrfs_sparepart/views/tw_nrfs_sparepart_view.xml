<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    <!-- NRFS Sparepart -->
        <record id="tw_nrfs_sparepart_list_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.sparepart.list</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
            	<list string="Outstanding NRFS" create="0" delete="0">
            		<field name="name" />
                    <field name="nrfs_date" />
                    <field name="product_id" />
                    <field name="branch_partner_id"/>
                    <field name="state" />
            	</list>
            </field>
        </record>

        <record id="tw_nrfs_sparepart_form_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.sparepart.form</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
            	<form string="Outstanding NRFS" create="0" delete="0">
            		<header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_nrfs.tw_nrfs_confirm_group_button_read"/>
                        <button name="action_validate" string="Validate" type="object" class="oe_highlight" invisible="state != 'confirmed'" groups="tw_nrfs_sparepart.tw_nrfs_sparepart_validate_group_button_read"/>
                        <button name="action_cancel" string="Cancel" invisible="state != 'draft'" type="object" />
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done" readonly="1" />
                    </header>
            		<sheet>
                        <div class="oe_button_box" name="button_box">
                        </div>
                        <div class="oe_title" name="name_title">
                            <h1>
                                <field name="name" readonly="1" invisible="name == False" class="oe_inline" />
                            </h1>
                        </div>
						<group>
                            <group>
                                <field name="company_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}" />
                                <field name="origin" readonly="1" />
                                <field name="examiner_id" required="1" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                                <field name="claim_to" required="state == 'draft'" readonly="state != 'draft'"/>
                                <field name="claim_type" required="state == 'confirmed'" readonly="state != 'confirmed' or claim_to == 'Expedisi'" force_save="1"/>
                                <field name="partner_id" required="claim_type == 'disposal'" invisible="claim_type != 'disposal'" readonly="state != 'confirmed'" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="nrfs_date" readonly="1" />
                                <field name="vehicle_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="driver_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                            </group>
                        </group>
                        <notebook>
                            <page name="detail" string="Detail">
                                <field name="line_ids" nolabel="1" readonly="state != 'draft'">
                                    <list editable="bottom" create="0" delete="0">
                                        <field name="product_sparepart_id" readonly="1" options="{'no_open':True, 'no_create': True}" domain="[('categ_id.name', '=', 'Sparepart')]"/>
                                        <field name="qty" readonly="1" />
                                        <field name="annotation" string="Keterangan Rusak" required="1" />
                                    </list>
                                </field>
                            </page>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" />
                                        <field name="create_date" readonly="1" />
                                        <field name="confirm_uid" readonly="1" />
                                        <field name="confirm_date" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" />
                                        <field name="write_date" readonly="1" />
                                        <field name="cancel_uid" readonly="1" invisible="cancel_uid == False" />
                                        <field name="cancel_date" readonly="1" invisible="cancel_date == False" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
            		</sheet>
            	</form>
            </field>
        </record>

        <record id="tw_nrfs_sparepart_search_view" model="ir.ui.view">
            <field name="name">tw.nrfs.sparepart.search</field>
            <field name="model">tw.nrfs</field>
            <field name="arch" type="xml">
                <search string="Search NRFS">
                    <field name="name" string="Nomor NRFS"/>
                    <field name="origin" string="Source Document"/>
                    <field name="claim_to" string="Claim To"/>
                    <field name="claim_type" string="Claim Type"/>
                    <field name="partner_id" string="Partner"/>
                    <field name="product_id"/>
                    <field name="line_ids" string="Parts Bermasalah" filter_domain="line_ids.product_sparepart_id" />
                    <field name="branch_partner_id" />
                    <field name="nrfs_date" />
					<filter string="Cancelled" name="cancel" domain="[('state','=','cancel')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="Done" name="done" domain="[('state','=','done')]"/>
					<group string="Group By" name="groupby">
                        <filter name="state_groupby" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="name_groupby" string="No NRFS" context="{'group_by': 'name'}"/>
                        <filter name="date" string="Date" context="{'group_by': 'nrfs_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_nrfs_sparepart_action" model="ir.actions.act_window">
            <field name="name">Outstanding NRFS Sparepart</field>
            <field name="res_model">tw.nrfs</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                "default_division": "Sparepart",
                "search_default_draft": 1,
                "search_default_confirmed": 1,
            }</field>
            <field name="search_view_id" ref="tw_nrfs_sparepart.tw_nrfs_sparepart_search_view" />
            <field name="domain">[('division', '=', 'Sparepart')]</field>
        </record>

        <record id="tw_nrfs_sparepart_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_nrfs_sparepart_list_view"/>
            <field name="act_window_id" ref="tw_nrfs_sparepart_action"/>
        </record>

        <record id="tw_nrfs_sparepart_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_nrfs_sparepart_form_view"/>
            <field name="act_window_id" ref="tw_nrfs_sparepart_action"/>
        </record>
    </data>
</odoo>