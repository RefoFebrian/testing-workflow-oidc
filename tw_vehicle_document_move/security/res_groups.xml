<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Vehicle Document Move Groups -->
        <record id="group_vehicle_document_move_read" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Vehicle Document Move Read</field>
        </record>

        <record id="access_tw_vehicle_document_move_read" model="ir.model.access">
            <field name="name">tw_vehicle_document_move_read</field>
            <field name="model_id" ref="model_tw_vehicle_document_move"/>
            <field name="group_id" ref="group_vehicle_document_move_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_vehicle_document_move_stock_lot_read" model="ir.model.access">
            <field name="name">tw_vehicle_document_move_stock_lot_read</field>
            <field name="model_id" ref="stock.model_stock_lot"/>
            <field name="group_id" ref="group_vehicle_document_move_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_vehicle_document_move_location_read" model="ir.model.access">
            <field name="name">tw_vehicle_document_move_location_read</field>
            <field name="model_id" ref="tw_vehicle_document_location.model_tw_vehicle_document_location"/>
            <field name="group_id" ref="group_vehicle_document_move_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_vehicle_document_move_company_read" model="ir.model.access">
            <field name="name">tw_vehicle_document_move_company_read</field>
            <field name="model_id" ref="base.model_res_company"/>
            <field name="group_id" ref="group_vehicle_document_move_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="tw_vehicle_document.group_vehicle_document_request_read" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_move_read'))]"/>
        </record>

        <!-- Include to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_vehicle_document_move_read')),
                ]"/>
        </record>
                
    </data>
</odoo>
