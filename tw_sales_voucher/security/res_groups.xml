<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sales Voucher READ-->
        <record id="group_tw_sales_voucher_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Sales Voucher Read</field>
        </record>
        
        <record id="access_tw_sales_voucher_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_sales_voucher"/>
            <field name="name">tw_sales_voucher_line_voucher read</field>
            <field name="group_id" ref="group_tw_sales_voucher_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Sales Voucher UPDATE -->
        <record id="group_tw_sales_voucher_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Sales Voucher Update</field>
        </record>
        
        <record id="access_tw_sales_voucher_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_sales_voucher"/>
            <field name="name">tw_sales_voucher_line_voucher update</field>
            <field name="group_id" ref="group_tw_sales_voucher_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Sales Voucher DELETE -->
        <record id="group_tw_sales_voucher_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Sales Voucher Delete</field>
        </record>
        
        <record id="access_tw_sales_voucher_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_sales_voucher"/>
            <field name="name">tw_sales_voucher_line_voucher delete</field>
            <field name="group_id" ref="group_tw_sales_voucher_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_sales_voucher_read')),
                (4, ref('group_tw_sales_voucher_update')),
                (4, ref('group_tw_sales_voucher_delete')),
            ]"/>
        </record>
    </data>
</odoo>