<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Product Template Form View Inheritance -->
        <record id="view_product_template_form_inherit_series" model="ir.ui.view">
            <field name="name">product.template.form.inherit.series</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='categ_id']" position="after">
                    <field name="series_id"
                        required="division == 'Unit'"
                        invisible="division != 'Unit'"
                        options="{'no_create': True, 'no_open': True}"
                        groups="base.group_user"/>  
                </xpath>
            </field>
        </record>
    </data>
</odoo>
