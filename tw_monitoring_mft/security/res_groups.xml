<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- ======================== -->
        <!-- MFT Config Groups        -->
        <!-- ======================== -->

        <!-- MFT Config READ -->
        <record id="group_mft_config_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Config Read</field>
        </record>
        
        <record id="access_tw_mft_config_read" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_config" />
            <field name="name">tw_mft_config read</field>
            <field name="group_id" ref="group_mft_config_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- MFT Config UPDATE -->
        <record id="group_mft_config_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Config Update</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_config_read'))]" />
        </record>

        <record id="access_tw_mft_config_update" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_config" />
            <field name="name">tw_mft_config update</field>
            <field name="group_id" ref="group_mft_config_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- MFT Config DELETE -->
        <record id="group_mft_config_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Config Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_config_read'))]" />
        </record>

        <record id="access_tw_mft_config_delete" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_config" />
            <field name="name">tw_mft_config delete</field>
            <field name="group_id" ref="group_mft_config_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <!-- ======================== -->
        <!-- MFT Log Groups           -->
        <!-- ======================== -->

        <!-- MFT Log READ -->
        <record id="group_mft_log_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Read</field>
        </record>
        
        <record id="access_tw_mft_log_read" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log" />
            <field name="name">tw_mft_log read</field>
            <field name="group_id" ref="group_mft_log_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- MFT Log UPDATE -->
        <record id="group_mft_log_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Update</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_log_read'))]" />
        </record>

        <record id="access_tw_mft_log_update" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log" />
            <field name="name">tw_mft_log update</field>
            <field name="group_id" ref="group_mft_log_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- MFT Log DELETE -->
        <record id="group_mft_log_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_log_read'))]" />
        </record>

        <record id="access_tw_mft_log_delete" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log" />
            <field name="name">tw_mft_log delete</field>
            <field name="group_id" ref="group_mft_log_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <!-- ======================== -->
        <!-- MFT Log Detail Groups    -->
        <!-- ======================== -->

        <!-- MFT Log Detail READ -->
        <record id="group_mft_log_detail_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Detail Read</field>
        </record>
        
        <record id="access_tw_mft_log_detail_read" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log_detail" />
            <field name="name">tw_mft_log_detail read</field>
            <field name="group_id" ref="group_mft_log_detail_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- MFT Log Detail UPDATE -->
        <record id="group_mft_log_detail_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Detail Update</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_log_detail_read'))]" />
        </record>

        <record id="access_tw_mft_log_detail_update" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log_detail" />
            <field name="name">tw_mft_log_detail update</field>
            <field name="group_id" ref="group_mft_log_detail_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- MFT Log Detail DELETE -->
        <record id="group_mft_log_detail_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW MFT Log Detail Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_mft_log_detail_read'))]" />
        </record>

        <record id="access_tw_mft_log_detail_delete" model="ir.model.access">
            <field name="model_id" ref="tw_monitoring_mft.model_tw_mft_log_detail" />
            <field name="name">tw_mft_log_detail delete</field>
            <field name="group_id" ref="group_mft_log_detail_delete" />
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <!-- Assign all MFT groups to system admin -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_mft_config_read')),
                (4, ref('group_mft_config_update')),
                (4, ref('group_mft_config_delete')),
                (4, ref('group_mft_log_read')),
                (4, ref('group_mft_log_update')),
                (4, ref('group_mft_log_delete')),
                (4, ref('group_mft_log_detail_read')),
                (4, ref('group_mft_log_detail_update')),
                (4, ref('group_mft_log_detail_delete')),
            ]" />
        </record>
    </data>

</odoo>
