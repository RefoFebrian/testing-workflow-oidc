<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Scheduled Action for MFT Monitoring -->
        <record id="ir_cron_mft_monitoring" model="ir.cron">
            <field name="name">MFT Monitoring - Fetch Data</field>
            <field name="model_id" search="[('model', '=', 'tw.mft.config')]"/>
            <field name="state">code</field>
            <field name="code">model._cron_fetch_mft_data()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
