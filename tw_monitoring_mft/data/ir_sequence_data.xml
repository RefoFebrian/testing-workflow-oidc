<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for MFT Log -->
        <record id="seq_tw_mft_log" model="ir.sequence">
            <field name="name">MFT Log Sequence</field>
            <field name="code">tw.mft.log</field>
            <field name="prefix">MFT/%(y)s%(month)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
