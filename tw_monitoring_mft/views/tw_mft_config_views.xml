<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- ===================== -->
        <!-- MFT CONFIG VIEWS      -->
        <!-- ===================== -->

        <!-- List View -->
        <record id="tw_mft_config_view_list" model="ir.ui.view">
            <field name="name">tw.mft.config.view.list</field>
            <field name="model">tw.mft.config</field>
            <field name="arch" type="xml">
                <list string="MFT Configurations">
                    <field name="filetype"/>
                    <field name="transtype"/>
                    <field name="listtype"/>
                    <field name="listtypecode"/>
                    <field name="api_config_id"/>
                    <field name="last_fetch_date"/>
                    <field name="active" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_mft_config_view_form" model="ir.ui.view">
            <field name="name">tw.mft.config.view.form</field>
            <field name="model">tw.mft.config</field>
            <field name="arch" type="xml">
                <form string="MFT Configuration">
                    <header>
                        <button name="action_fetch_data" string="Fetch Data" type="object" class="btn-primary" icon="fa-download"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_logs" type="object" class="oe_stat_button" icon="fa-list">
                                <field name="log_count" widget="statinfo" string="Logs"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group string="File Configuration">
                                <field name="filetype"/>
                                <field name="transtype"/>
                                <field name="status"/>
                                <field name="active" invisible="1"/>
                            </group>
                            <group string="List Configuration">
                                <field name="listtype"/>
                                <field name="listtypecode"/>
                            </group>
                        </group>
                        <group>
                            <group string="API Configuration">
                                <field name="api_config_id" options="{'no_create': True}"/>
                                <field name="limit"/>
                                <field name="date_range_days"/>
                                <field name="auto_fetch_detail"/>
                            </group>
                            <group string="Status">
                                <field name="last_fetch_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Endpoints" name="endpoints">
                                <group>
                                    <field name="endpoint_get_data"/>
                                    <field name="endpoint_get_detail"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_mft_config_view_search" model="ir.ui.view">
            <field name="name">tw.mft.config.view.search</field>
            <field name="model">tw.mft.config</field>
            <field name="arch" type="xml">
                <search string="Search MFT Configurations">
                    <field name="filetype"/>
                    <field name="api_config_id"/>
                    <separator/>
                    <filter string="Active" name="filter_active" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Transaction Type" name="group_transtype" context="{'group_by': 'transtype'}"/>
                        <filter string="API Config" name="group_api" context="{'group_by': 'api_config_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="tw_mft_config_action" model="ir.actions.act_window">
            <field name="name">MFT Configurations</field>
            <field name="res_model">tw.mft.config</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_mft_config_view_search"/>
            <field name="context">{'search_default_filter_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first MFT Configuration
                </p>
                <p>
                    Configure file types to monitor from Portal AHM.
                </p>
            </field>
        </record>

    </data>

</odoo>
