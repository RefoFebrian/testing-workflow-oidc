<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- Tree View -->
        <record id="tw_ring_kecamatan_list_view" model="ir.ui.view">
            <field name="name">tw.ring.kecamatan.tree</field>
            <field name="model">tw.ring.kecamatan</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Ring Kecamatan" delete="0">
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_ring_kecamatan_form_view" model="ir.ui.view">
            <field name="name">tw.ring.kecamatan.form</field>
            <field name="model">tw.ring.kecamatan</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Ring Kecamatan">
                    <div class="oe_title" name="header">
                        <label for="company_id" class="oe_edit_only" string="Branch"/>
                        <h1><field name="company_id" string="Branch" required="1" options="{'no_create': True, 'no_open': True}"/></h1>
                    </div>
                    <sheet>
                        <notebook>
                            <page string="Ring Kecamatan Detail">
                                <field name="ring_kecamatan_line_ids">
                                    <list editable="top">
                                        <field name="city_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="district_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="sub_district_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="ring_id" string="Ring" required="1" options="{'no_show': True, 'no_create': True, 'no_open': True}"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_ring_kecamatan_search_view" model="ir.ui.view">
            <field name="name">tw.ring.kecamatan.search</field>
            <field name="model">tw.ring.kecamatan</field>
            <field name="arch" type="xml">
                <search string="Ring Kecamatan">
                    <field name="name" select="True"/>
                    <field name="company_id" select="True"/>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_ring_kecamatan_action" model="ir.actions.server">
            <field name="name">Ring Kecamatan</field>
            <field name="model_id" ref="tw_ring.model_tw_ring_kecamatan"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.ring.kecamatan'].action_ring_kecamatan_tree()
            </field>
        </record>
        
    </data>
</odoo>