<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Master Ring Group Read -->
        <record id="group_tw_ring_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Ring Read</field>
        </record>
        <record id="access_tw_ring_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_ring"/>
            <field name="name">tw_ring read</field>
            <field name="group_id" ref="group_tw_ring_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Master Ring Group Update -->
        <record id="group_tw_ring_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Ring Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_ring_read'))]"/>
        </record>
        <record id="access_tw_ring_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_ring"/>
            <field name="name">tw_ring update</field>
            <field name="group_id" ref="group_tw_ring_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Master Ring Group Delete -->
        <record id="group_tw_ring_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Ring Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_ring_read'))]"/>
        </record>
        <record id="access_tw_ring_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_ring"/>
            <field name="name">tw_ring delete</field>
            <field name="group_id" ref="group_tw_ring_delete"/>
            <field name="perm_unlink">1</field>
        </record>

