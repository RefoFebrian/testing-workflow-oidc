        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_ring_read')),
                (4,ref('group_tw_ring_update')),
                (4,ref('group_tw_ring_delete')),
                (4,ref('group_tw_ring_kecamatan_read')),
                (4,ref('group_tw_ring_kecamatan_update')),
                (4,ref('group_tw_ring_kecamatan_delete')),
            ]"/>
