<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_dgi_invoice_cron_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Dgi Invoice Cron Read</field>
        </record>

        <record id="access_tw_dgi_invoice_cron_read" model="ir.model.access">
            <field name="model_id" ref="tw_dgi_account.model_tw_dgi_invoice_cron"/>
            <field name="name">tw_dgi_invoice_cron read</field>
            <field name="group_id" ref="group_tw_dgi_invoice_cron_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_dgi_invoice_cron_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Dgi Invoice Cron Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_dgi_invoice_cron_read'))]"/>
        </record>

        <record id="access_tw_dgi_invoice_cron_update" model="ir.model.access">
            <field name="model_id" ref="tw_dgi_account.model_tw_dgi_invoice_cron"/>
            <field name="name">tw_dgi_invoice_cron update</field>
            <field name="group_id" ref="group_tw_dgi_invoice_cron_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_dgi_invoice_cron_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Dgi Invoice Cron Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_dgi_invoice_cron_read'))]"/>
        </record>

        <record id="access_tw_dgi_invoice_cron_delete" model="ir.model.access">
            <field name="model_id" ref="tw_dgi_account.model_tw_dgi_invoice_cron"/>
            <field name="name">tw_dgi_invoice_cron delete</field>
            <field name="group_id" ref="group_tw_dgi_invoice_cron_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Button Group for Sync DGI Invoice (INV1 & INV2) -->
        <record id="tw_dgi_invoice_button_group" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW DGI Invoice Button</field>
        </record>

    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_dgi_invoice_cron_read')),
                (4, ref('group_tw_dgi_invoice_cron_update')),
                (4, ref('group_tw_dgi_invoice_cron_delete')),
                (4, ref('tw_dgi_invoice_button_group')),
            ]"/>
        </record>
    </data>
</odoo>
