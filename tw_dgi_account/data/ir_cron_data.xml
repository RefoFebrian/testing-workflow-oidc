<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Auto Sync DGI Invoice -->
        <record id="ir_cron_auto_sync_dgi_invoice" model="ir.cron">
            <field name="name">Auto Sync DGI Invoice (INV1 &amp; INV2)</field>
            <field name="model_id" ref="model_tw_dgi_invoice_cron"/>
            <field name="state">code</field>
            <field name="code">model.schedulle_send_dgi_invoice(limit=100)</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron Auto Retry Error DGI Invoice -->
        <record id="ir_cron_auto_retry_error_dgi_invoice" model="ir.cron">
            <field name="name">Auto Retry Error DGI Invoice (INV1 &amp; INV2)</field>
            <field name="model_id" ref="model_tw_dgi_invoice_cron"/>
            <field name="state">code</field>
            <field name="code">model.schedulle_retry_dgi_invoice_error(limit=100)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
