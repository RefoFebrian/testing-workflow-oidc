<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tw_dealer_sale_order_dgi_inherit_form" model="ir.ui.view">
        <field name="name">tw.dealer.sale.order.dgi.inherit.form</field>
        <field name="model">tw.dealer.sale.order</field>
        <field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_order_view_form"/>
        <field name="arch" type="xml">
            <header position="inside">
                <button name="action_send_dgi_invoice_h1" string="Sync DGI Invoice" type="object" class="oe_highlight"
                    invisible="state != 'done' or dgi_invoice_status == 'done'"
                    groups="tw_dgi_account.tw_dgi_invoice_button_group"/>
            </header>
            <xpath expr="//notebook" position="inside">
                <page string="DGI Integration" name="dgi_integration">
                    <group>
                        <group>
                            <field name="dgi_invoice_status" readonly="1"/>
                            <field name="dgi_err_count_inv" readonly="1"/>
                        </group>
                        <group>
                            <field name="dgi_invoice_error_log" widget="text" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
