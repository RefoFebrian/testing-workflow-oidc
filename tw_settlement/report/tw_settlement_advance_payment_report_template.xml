<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="settlement_advance_payment_report" name="Advance Payment Report">
            <t t-call="web.html_container">
                <t t-call="tw_web.teto_report_layout">
                    <t t-call="tw_web.teto_report_styles_base" />
                    <t t-foreach="docs" t-as="o">
                        <div class="page font-sm">
                            <div class="oe_structure">

                                <div class="row">
                                    <div class="col-12">
                                        Dicetak oleh <t t-esc="user.name" /> pada tanggal <t t-esc="print_datetime()" />
                                    </div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-6">
                                        <t t-call="tw_web.teto_report_partner_address">
                                            <t t-set="partner" t-value="o.company_id.partner_id" />
                                        </t>
                                    </div>
                                    <div class="col-6">
                                        <table class="table-borderless">
                                            <tr>
                                                <td>No</td>
                                                <td>:</td>
                                                <td><t t-esc="o.name" /></td>
                                            </tr>
                                            <tr>
                                                <td>Tanggal</td>
                                                <td>:</td>
                                                <td><span t-field="o.date" t-options="{'widget': 'date', 'format': 'dd-MM-yyyy'}" /></td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                                <div class="row my-1">
                                    <div class="col-12 text-center">PENYELESAIAN BON SEMENTARA</div>
                                </div>
                                <div class="row my-1 border">
                                    <div class="col-12">
                                        <div class="row my-1" t-if="context.get('print_state') == 'draft'">
                                            <div class="col-6">
                                                <table class="table-borderless" width="100%">
                                                    <tr>
                                                        <td width="30%">Dibayar Kepada</td>
                                                        <td>:</td>
                                                        <td><t t-esc="o.employee_id.name" /></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Keterangan</td>
                                                        <td>:</td>
                                                        <td><t t-esc="o.advance_payment_id.description" /></td>
                                                    </tr>
                                                </table>
                                            </div>
                                            <div class="col-6">
                                                <table class="table-borderless" width="70%">
                                                    <tr>
                                                        <td>No. BS</td>
                                                        <td>:</td>
                                                        <td class="text-end"><t t-esc="o.advance_payment_id.name" /></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Jumlah</td>
                                                        <td>:</td>
                                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(o.amount_avp)" /></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Kembali</td>
                                                        <td>:</td>
                                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(o.amount_gap)" /></td>
                                                    </tr>
                                                </table>
                                            </div>
                                        </div>
                                        <div class="row my-1">
                                            <div class="col-12">
                                                <table class="teto-table-content">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 5%;">No</th>
                                                            <th>Rekening</th>
                                                            <th>Keterangan</th>
                                                            <th>Jumlah</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <t t-set="number" t-value="1" />
                                                        <tr t-foreach="o.settlement_line_ids" t-as="line">
                                                            <td class="text-center"><t t-esc="number" /></td>
                                                            <td><t t-esc="line.account_id.name" /></td>
                                                            <td><t t-esc="o.description" /></td>
                                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(line.price_subtotal)" /></td>
                                                            <t t-set="number" t-value="number + 1" />
                                                        </tr>
                                                    </tbody>
                                                    <tfoot>
                                                        <tr>
                                                            <th colspan="3">Total</th>
                                                            <th class="text-end"><t t-esc="'{:,.2f}'.format(o.amount_total)" /></th>
                                                        </tr>
                                                        <tr>
                                                            <td colspan="4" class="text-end">
                                                                Terbilang: ## <t t-esc="terbilang(o.amount_total)" /> ##
                                                            </td>
                                                        </tr>
                                                    </tfoot>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row my-3 border" style="height: 7rem" t-if="context.get('print_state') == 'draft'">
                                    <div class="col text-center">Disetujui oleh</div>
                                    <div class="col text-center">Administrasi</div>
                                    <div class="col text-center">Finance</div>
                                    <div class="col text-center">Kasir</div>
                                    <div class="col text-center">Penerima</div>
                                </div>

                                <div class="row my-3" t-elif="context.get('print_state') == 'done'">
                                    <div class="col-6 text-center">
                                        Mengetahui<br /><br /><br /><br />
                                        (................................)
                                    </div>
                                    <div class="col-6 text-center">
                                        Penerima<br /><br /><br /><br />
                                        (................................)
                                    </div>
                                </div>

                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>

        <record id="action_settlement_advance_payment_report" model="ir.actions.report">
            <field name="name">Print Settlement Advance Payment</field>
            <field name="model">tw.settlement</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_settlement.settlement_advance_payment_report</field>
            <field name="report_file">tw_settlement.settlement_advance_payment_report</field>
            <field name="print_report_name">'Settlement_Advance_Payment_%s.pdf' % (object.name)</field>
            <field name="paperformat_id" ref="tw_web.tw_report_paperformat_a4"/>
            <field name="binding_type">report</field>
        </record>

    </data>
</odoo>