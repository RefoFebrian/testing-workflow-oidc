<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Field Category Report Group -->
        <record id="group_tw_settlement_button_print_settlement_advance_payment" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Print Settlement Advance Payment</field>
        </record>

        <record id="group_tw_settlement_confirm_button" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Settlement</field>
        </record>
        <record id="access_tw_settlement_confirm_button" model="ir.model.access">
            <field name="name">tw_access_tw_settlement_confirm_button</field>
            <field name="model_id" ref="tw_settlement.model_tw_settlement"/>
            <field name="group_id" ref="tw_settlement.group_tw_settlement_confirm_button"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Add groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_settlement_button_print_settlement_advance_payment')),
                (4, ref('group_tw_settlement_confirm_button')),
            ]"/>
        </record>
    </data>
</odoo>
