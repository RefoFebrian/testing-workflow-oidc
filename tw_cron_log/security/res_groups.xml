<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- Cron Log READ -->
        <record id="group_cron_log_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Cron Log Read</field>
        </record>
        
        <record id="access_tw_cron_log_read" model="ir.model.access">
            <field name="model_id" ref="tw_cron_log.model_tw_cron_log" />
            <field name="name">tw_cron_log read</field>
            <field name="group_id" ref="group_cron_log_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- Cron Log UPDATE -->
        <record id="group_cron_log_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Cron Log Update</field>
            <field name="implied_ids" eval="[(4, ref('group_cron_log_read'))]" />
        </record>

        <record id="access_tw_cron_log_update" model="ir.model.access">
            <field name="model_id" ref="tw_cron_log.model_tw_cron_log" />
            <field name="name">tw_cron_log update</field>
            <field name="group_id" ref="group_cron_log_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Cron Log DELETE -->
        <record id="group_cron_log_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Cron Log Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_cron_log_read'))]" />
        </record>

        <record id="access_tw_cron_log_delete" model="ir.model.access">
            <field name="model_id" ref="tw_cron_log.model_tw_cron_log" />
            <field name="name">tw_cron_log delete</field>
            <field name="group_id" ref="group_cron_log_delete" />
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <!-- Assign all cron log groups to system admin -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_cron_log_read')),
                (4, ref('group_cron_log_update')),
                (4, ref('group_cron_log_delete')),
            ]" />
        </record>
    </data>

</odoo>
