<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- System Parameter for duplicate delay (in hours) -->
        <record id="tw_cron_log_duplicate_delay" model="ir.config_parameter">
            <field name="key">tw_cron_log.duplicate_delay_hours</field>
            <field name="value">1</field>
        </record>

        <!-- Sequence for tw.cron.log -->
        <record id="tw_cron_log_sequence" model="ir.sequence">
            <field name="name">Cron Error Log Sequence</field>
            <field name="code">tw.cron.log</field>
            <field name="prefix">CRON-ERR/%(month)s%(year)s/</field>
            <field name="padding">6</field>
        </record>

    </data>
</odoo>
