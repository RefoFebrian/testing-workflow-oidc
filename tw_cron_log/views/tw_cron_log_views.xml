<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>

        <!-- List View -->
        <record id="tw_cron_log_view_list" model="ir.ui.view">
            <field name="name">tw.cron.log.view.list</field>
            <field name="model">tw.cron.log</field>
            <field name="arch" type="xml">
                <list string="Cron Error Logs" create="0" delete="0" default_order="id desc">
                    <field name="name"/>
                    <field name="cron_id"/>
                    <field name="model_id"/>
                    <field name="error_message" widget="char"/>
                    <field name="log_time"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_cron_log_view_form" model="ir.ui.view">
            <field name="name">tw.cron.log.view.form</field>
            <field name="model">tw.cron.log</field>
            <field name="arch" type="xml">
                <form string="Cron Error Log" create="0" edit="0">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Cron Information">
                                <field name="cron_id" options="{'no_create': True, 'no_open': False}"/>
                                <field name="model_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="log_time"/>
                                <field name="method_name" string="Method"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Error Message" name="error_message">
                                <field name="error_message" nolabel="1" readonly="1"/>
                            </page>
                            <page string="Traceback" name="traceback">
                                <field name="error_detail" nolabel="1" readonly="1" widget="ace" options="{'mode': 'python'}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_cron_log_view_search" model="ir.ui.view">
            <field name="name">tw.cron.log.view.search</field>
            <field name="model">tw.cron.log</field>
            <field name="arch" type="xml">
                <search string="Search Cron Error Logs">
                    <field name="name"/>
                    <field name="cron_id"/>
                    <field name="model_id"/>
                    <field name="error_message"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Scheduled Action" name="group_cron" context="{'group_by': 'cron_id'}"/>
                        <filter string="Model" name="group_model" context="{'group_by': 'model_id'}"/>
                        <filter string="Log Date" name="group_date" context="{'group_by': 'log_time:day'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="tw_cron_log_action" model="ir.actions.act_window">
            <field name="name">Cron Error Logs</field>
            <field name="res_model">tw.cron.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_cron_log_view_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No cron errors logged yet.
                </p>
                <p>
                    Errors from scheduled actions will be automatically logged here.
                </p>
            </field>
        </record>

    </data>

</odoo>
