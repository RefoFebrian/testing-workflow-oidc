<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Trial Balance Report Group -->
        <record id="group_trial_balance_report" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Trial Balance</field>
        </record>

        <record id="access_trial_balance_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_trial_balance_report"/>
            <field name="name">tw.trial.balance.report access</field>
            <field name="group_id" ref="group_trial_balance_report"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_trial_balance_report')),
            ]"/>
        </record>
    </data>
</odoo>
