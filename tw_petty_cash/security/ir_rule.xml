<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="tw_petty_cash_out_multi_company_rule" model="ir.rule">
            <field name="name">Petty Cash Out multi-company</field>
            <field ref="model_tw_petty_cash_out" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_petty_cash_in_multi_company_rule" model="ir.rule">
            <field name="name">Petty Cash In multi-company</field>
            <field ref="model_tw_petty_cash_in" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_reimbursement_petty_cash_multi_company_rule" model="ir.rule">
            <field name="name">Reimbursement Petty Cash multi-company</field>
            <field ref="model_tw_reimbursement_petty_cash" name="model_id"/>
            <field eval="True" name="global"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
