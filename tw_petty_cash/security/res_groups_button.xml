<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Petty Cash Out -->

        <record id="group_petty_cash_out_button_recalculate" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Petty Cash Out Recalculate</field>
        </record>
        <record id="group_petty_cash_out_button_recalculate_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_petty_cash_out" />
            <field name="name">petty_cash_out_button_recalculate_access write</field>
            <field name="group_id" ref="group_petty_cash_out_button_recalculate" />
            <field name="perm_write">1</field>
        </record>

        <record id="group_petty_cash_out_button_print" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Petty Cash Out print</field>
        </record>
        <record id="group_petty_cash_out_button_print_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_petty_cash_out" />
            <field name="name">petty_cash_out_button_print_access write</field>
            <field name="group_id" ref="group_petty_cash_out_button_print" />
            <field name="perm_write">1</field>
        </record>
        <record id="group_petty_cash_out_button_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Petty Cash Out Confirm</field>
			<field name="implied_ids" eval="[(4, ref('group_petty_cash_out_read'))]"/>
        </record>

        <record id="group_petty_cash_out_button_confirm_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_petty_cash_out" />
            <field name="name">petty_cash_out_button_confirm_access write</field>
            <field name="group_id" ref="group_petty_cash_out_button_confirm" />
            <field name="perm_write">1</field>
        </record>
        

        <!-- Petty Cash In -->

        <record id="group_petty_cash_in_button_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Petty Cash In Confirm</field>
			<field name="implied_ids" eval="[(4, ref('group_petty_cash_in_read'))]"/>
        </record>

        <record id="group_petty_cash_in_button_confirm_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_petty_cash_in" />
            <field name="name">petty_cash_in_button_confirm_access write</field>
            <field name="group_id" ref="group_petty_cash_in_button_confirm" />
            <field name="perm_write">1</field>
        </record>

        <!-- Reimbursement Petty Cash -->
        
        

        <record id="group_reimbursement_petty_cash_button_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Reimbursement Petty Cash Confirm</field>
			<field name="implied_ids" eval="[(4, ref('group_reimbursement_petty_cash_read'))]"/>
        </record>

        <record id="group_reimbursement_petty_cash_button_confirm_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_reimbursement_petty_cash" />
            <field name="name">reimbursement_petty_cash_button_confirm_access write</field>
            <field name="group_id" ref="group_reimbursement_petty_cash_button_confirm" />
            <field name="perm_write">1</field>
        </record>

        <record id="group_reimbursement_petty_cash_button_print" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Reimbursement Petty Cash print</field>
			<field name="implied_ids" eval="[(4, ref('group_reimbursement_petty_cash_read'))]"/>
        </record>

        <record id="group_reimbursement_petty_cash_button_print_access" model="ir.model.access">
            <field name="model_id" ref="model_tw_reimbursement_petty_cash" />
            <field name="name">reimbursement_petty_cash_button_print_access write</field>
            <field name="group_id" ref="group_reimbursement_petty_cash_button_print" />
            <field name="perm_write">1</field>
        </record>


        <!-- Include to System Admin -->

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_petty_cash_out_button_recalculate')),
                (4,ref('group_petty_cash_out_button_print')),
                (4,ref('group_petty_cash_out_button_confirm')),
                (4,ref('group_petty_cash_in_button_confirm')),
                (4,ref('group_reimbursement_petty_cash_button_confirm')),
                (4,ref('group_reimbursement_petty_cash_button_print')),
                ]"/>
        </record>

    </data>
</odoo>
