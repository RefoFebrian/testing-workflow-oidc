<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="tw_reimburse_petty_cash_report" name="tw_reimburse_petty_cash_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page">
                    <style>
                        .page {
                            font-family: 'Arial', sans-serif;
                            padding: 25px;
                            color: #000;
                            line-height: 1.4;
                        }
                    </style>

                    <table class="header-table"  style="width: 100%;">
                        <tr>
                            <td style="width:65%;vertical-align:top">
                                <div >
                                    <h3>
                                        <t t-if="o.company_id.parent_id"><t t-esc="o.company_id.parent_id.suspend_security().name"/> - </t><t t-esc="o.company_id.name"/>
                                    </h3>
                                    <p><t t-esc="o.company_id.street"/></p>
                                    <p><t t-esc="o.company_id.state_id.name"/></p>
                                </div>
                            </td>
                            <td style="width:35%;vertical-align:top;padding-left:15px">
                                <div >
                                    <h3>PERMINTAAN PEMBAYARAN</h3>
                                    <p>No: <t t-esc="o.name"/></p>
                                    <p>Tanggal: <t t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''"/></p>
                                </div>
                            </td>
                        </tr>
                    </table>
                    <table class="table table-sm mt-3" style="width: 100%; border:1px solid black; border-collapse:collapse;">
                        <thead>
                            <tr style="border-top:1px solid black; border-right:1px solid black;border-left:1px solid black;">
                                <th colspan="2" width="25%" style="text-align:left;padding-left:10px;padding-top:15px;font-weight:normal;"><p>Tempo </p></th>
                                <th colspan="2" width="75%" style="text-align:left;font-weight:normal;"><p>: <span style="padding-left:10px;"><t t-esc="(o.date - o.date).days"/></span></p></th>
                            </tr>
                            <tr style="border-right:1px solid black;border-left:1px solid black;">
                                <th colspan="2" width="25%" style="text-align:left;padding-left:10px;font-weight:normal;"><p>Tanggal JTP</p></th>
                                <th colspan="2" width="75%" style="text-align:left;font-weight:normal;"><p>: <span style="padding-left:10px;"><t t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''"/></span></p></th>
                            </tr>
                            <tr style="border-right:1px solid black;border-left:1px solid black;">
                                <th colspan="2" width="25%" style="text-align:left;padding-left:10px;font-weight:normal;"><p>Supplier</p></th>
                                <th colspan="2" width="75%" style="text-align:left;font-weight:normal;"><p>: <span style="padding-left:10px;"><t t-esc="o.journal_id.name"/></span></p></th>
                            </tr>
                            <!-- <tr style="border-right:1px solid black;border-left:1px solid black;">
                                <th colspan="2" width="25%" style="text-align:left;padding-left:10px;padding-bottom:15px;font-weight:normal;"><p>Payment Method</p></th>
                                <th colspan="2" width="75%" style="text-align:left;font-weight:normal;"><p>: <span style="padding-left:10px;"><t t-esc="o.journal_id.name"/></span></p></th>
                            </tr> -->
                            <tr style="border:1px solid black;">
                                <th style="border:1px solid black;text-align:left; padding-bottom:5px;padding-top:5px; font-weight:normal;">No</th>
                                <th style="border:1px solid black;text-align:left; padding-bottom:5px;padding-top:5px; font-weight:normal;">No Rekening</th>
                                <th style="border:1px solid black;text-align:left; padding-bottom:5px;padding-top:5px; font-weight:normal;">Keterangan</th>
                                <th style="border:1px solid black; text-align:center; padding-bottom:5px;padding-top:5px; font-weight:normal;">Jumlah Harga</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.petty_cash_out_ids" t-as="pco">
                                <tr style="border:1px solid black; padding-bottom:5px;padding-top:5px;">
                                    <td style="border:1px solid black; text-align:left;padding-bottom:5px;padding-top:5px;"><t t-esc="pco_index + 1"/></td>
                                    <td style="border:1px solid black;padding-bottom:5px;padding-top:5px;"><t t-esc="pco.name"/></td>
                                    <td style="border:1px solid black;padding-bottom:5px;padding-top:5px;">
                                        <t t-foreach="pco.petty_cash_out_line_ids" t-as="line">
                                            <div><t t-esc="line.name"/></div>
                                        </t>
                                    </td>
                                    <td style="border:1px solid black; text-align:right;padding-bottom:5px;padding-top:5px;" class="text-end"><t t-esc="'{:,.0f}'.format(pco.amount_real)"/></td>
                                </tr>
                            </t>
                            <tr>
                                <td colspan="2" style="border:1px solid black; text-align:left;padding-bottom:5px;"></td>
                                <td style="border:1px solid black; text-align:left;padding-bottom:5px;">Total</td>
                                <td style="border:1px solid black; text-align:right;padding-bottom:5px;" class="text-end"><t t-esc="'{:,.0f}'.format(o.amount_total)"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <p class="mt-2"><b>### <t t-esc="o.convert_number_format_rupiah()"/> ###</b></p>

                    <table style="width: 100%;">
                        <tbody>
                            <tr>
                                <td style="width:65%;vertical-align:top;padding-left:15px">
                                    <p>Pembuat</p>
                                    <br /><br />
                                    <p>--------------------------------------------</p>
                                    <div class="text-end mt-2">
                                        <t t-esc="o.create_uid.name"/>
                                        <t t-esc="o.write_date.strftime('%d-%m-%Y %H:%M') if o.write_date else ''" />
                                    </div>
                                </td>
                                <td style="width:35%;vertical-align:top;padding-left:15px;margin-right:15px">
                                    <p>Disetujui</p>
                                    <br /><br />
                                    <p>--------------------------------------------</p>
                                    <div class="text-end mt-2">
                                        <!-- <t t-esc="o.create_uid.name"/> --><span>ADH</span>
                                        <t t-esc="o.write_date.strftime('%d-%m-%Y %H:%M') if o.write_date else ''" />
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="paperformat_reimburse_petty_cash" model="report.paperformat">
            <field name="name">Reimburse Petty Cash Report</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="css_margins" eval="True"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

    <record id="action_report_tw_reimburse_petty_cash_report" model="ir.actions.report">
        <field name="name">Reimburse Petty Cash Report</field>
        <field name="model">tw.reimbursement.petty.cash</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tw_petty_cash.tw_reimburse_petty_cash_report</field>
        <field name="report_file">tw_petty_cash.tw_reimburse_petty_cash_report</field>
        <field name="print_report_name">'Reimburse Petty Cash - %s' % object.name</field>
        <field name="paperformat_id" ref="paperformat_reimburse_petty_cash"/>
    </record>

</odoo>
