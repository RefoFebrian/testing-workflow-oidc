<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_petty_cash_type_view_search" model="ir.ui.view">
            <field name="name">tw.petty.cash.type.search</field>
            <field name="model">tw.petty.cash.type</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="petty_cash_type_lines" string="Detail Type Name" filter_domain="[('petty_cash_type_lines.name', 'ilike', self)]"/>
                    <field name="petty_cash_type_lines" string="Detail Type Account" filter_domain="[('petty_cash_type_lines.account_id', 'ilike', self)]"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                </search>
            </field>
        </record>

        <record id="tw_petty_cash_type_view_list" model="ir.ui.view">
            <field name="name">tw.petty.cash.type.list</field>
            <field name="model">tw.petty.cash.type</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
		            <field name="active"/>
                </list>
            </field>
        </record>

        <record id="tw_petty_cash_type_view_form" model="ir.ui.view">
            <field name="name">tw.petty.cash.type.form</field>
            <field name="model">tw.petty.cash.type</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
							<field name="name"/>
							<field name="active"/>
                        </group>
                        <notebook>
		                    <page string="Detail Type">
		                        <field name="petty_cash_type_lines">
		                            <list editable="bottom">
                                		<field name="name" required="1"/>
                                        <field name="account_id" options="{'no_create': True,'no_open': True}" required="1"/>
						             </list>
		                        </field>
		                    </page>
                            <page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
									</group>
								</group>
							</page>
		                </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_petty_cash_type_action" model="ir.actions.act_window">
            <field name="name">Petty Cash Type</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.petty.cash.type</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{
                'search_default_active':'1',
            }" />
        </record>

    </data>
</odoo>
