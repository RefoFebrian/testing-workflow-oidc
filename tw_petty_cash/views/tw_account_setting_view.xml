<odoo>
    <data>
        <record id="tw_petty_cash_account_setting_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.petty.cash.account.setting.inherit.view.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='backoffice_payment_request']" position="after">
                    <group string="Petty Cash" name="backoffice_petty_cash">
                        <field name="pettycash_journal_id" options='{"no_quick_create": True}'/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
