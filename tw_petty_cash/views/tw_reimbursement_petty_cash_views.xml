<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <record id="tw_reimbursement_petty_cash_view_search" model="ir.ui.view">
            <field name="name">tw.reimbursement.petty.cash.search</field>
            <field name="model">tw.reimbursement.petty.cash</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>
		            <field name="date"/>
		            <field name="journal_id"/>
		            <field name="state"/>
					<filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
					<field name="petty_cash_out_ids" string="PCO" filter_domain="[('petty_cash_out_ids.name', 'ilike', self)]"/>
					<field name="petty_cash_out_ids" string="Branch Destination" filter_domain="[('petty_cash_out_ids.branch_destination_id', 'ilike', self)]"/>
					
					<!-- <filter name="waiting_for_approval" string="Waiting For Approval" domain="[('state','=','waiting_for_approval')]"/> -->
					<!-- <filter name="approved" string="Approved" domain="[('state','=','approved')]"/> -->
					<filter name="paid" string="Paid" domain="[('state','=','paid')]"/>
					<filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]"/>
					<filter name="group_by_state" string="Group by State" context="{'group_by':'state'}"/>
					<filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
					<filter name="group_by_division" string="Group by Division" context="{'group_by':'division'}"/>
					<filter name="group_by_journal" string="Group by Payment Method" context="{'group_by':'journal_id'}"/>
                </search>
            </field>
        </record>

        <record id="tw_reimbursement_petty_cash_view_list" model="ir.ui.view">
            <field name="name">tw.reimbursement.petty.cash.list</field>
            <field name="model">tw.reimbursement.petty.cash</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>
		            <field name="date"/>
		            <field name="journal_id"/>
					<field name="confirm_date" />
					<field name="amount_pco"/>
					<field name="amount_total"/>
		            <field name="state" widget="badge"
						decoration-info="state == 'draft'"
                        decoration-success="state == 'paid'"
                        decoration-danger="state == 'cancel'" 
					/>
                </list>
            </field>
        </record>

        <record id="tw_reimbursement_petty_cash_view_form" model="ir.ui.view">
            <field name="name">tw.reimbursement.petty.cash.form</field>
            <field name="model">tw.reimbursement.petty.cash</field>
            <field name="arch" type="xml">
                <form>
					<header>
						<field name="state" widget="statusbar" statusbar_visible="draft,paid"/>

						<button name="%(action_report_tw_reimburse_petty_cash_report)d" string="Print" type="action" class="btn-primary"  groups="tw_petty_cash.group_reimbursement_petty_cash_button_print"/>
	           		</header>
                    <sheet>
						<div class="oe_button_box" name="button_box">
							<button name="action_open_petty_cash_out" type="object" class="oe_stat_button" icon="fa-money" invisible="state != 'paid'">
								<div>
									<div>Open Petty Cash Out</div>
									<field name="petty_cash_out_ids" string="Petty Cash Out" widget="statinfo" nolabel="1"/>
								</div>
							</button>
						</div>
				
						<div class="oe_title">
							<label for="name" string="Reimbursed Petty Cash"/>
							<h1>
								<field name="name" readonly="1"/>
							</h1>
						</div>
                        <group>
							<group>
								<field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft' or name != False"/>
                                <field name="journal_id" required="1" readonly="state != 'draft'" domain="[('type', '=', 'petty_cash'), ('company_id', 'parent_of', company_id)]"/>
							</group>
						    <group>
	                    		<field name="division" required="1" readonly="state != 'draft'" />
	                    		<field name="date" readonly="1"/>
							</group>
						</group>
                        <notebook>
							<page string="Petty Cash Out">
			                    <field name="petty_cash_out_ids" readonly="state != 'draft'" domain="[('company_id', '=', company_id), ('journal_petty_id', '=', journal_id), ('division', '=', division), ('state', '=', 'posted'), ('reimbursed_id', '=', False)]">
			                        <list string="Petty Cash">
										<field name="currency_id" column_invisible="1" />
			                        	<field name="name"/>
			                        	<field name="date"/>
			                        	<field name="branch_destination_id"/>
										<field name="amount" string="Amount PCO" sum="Total Paid Amount" options="{'currency_field': 'currency_id'}"/>
			                            <field name="amount_real" sum="Total Real Amount"/>	                            
			                        </list>
			                    </field>
								<!-- <div style="display: flex; justify-content: flex-end; margin-top: 4px; gap: 16px; padding-right: 12px;">
									<div style="text-align: right;">
										<field name="amount_total" nolabel="1" widget="monetary"/>
									</div>
									<div style="text-align: right;">
										<field name="amount_real_total" nolabel="1" widget="monetary"/>
									</div>
								</div> -->
								<!-- <group class="oe_subtotal_footer oe_right">
										<div class="oe_subtotal_footer_seperator oe_inline">
											<label for="amount_total"/>
										</div>
									<field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator" widget='monetary' />
								</group> -->
								<div class="oe_clear"/>	  
							</page>
							<page string="Document">
								<group readonly="state != 'draft'">
									<field name="document_claim_upload_file" readonly="state not in ('draft','request')" class="oe_edit_only" filename="document_claim_upload_filename" string="Upload"/>
									<field name="document_claim_upload_filename" invisible="1"/>
									<field name="document_claim_file" class="oe_read_only" readonly="1" filename="document_claim_filename" string="Download" invisible="1"/>
									<field name="document_claim_filename" invisible="1"/>
								</group>
							</page>
							<page string="Audit Trail" name="audit_trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
										<field name="confirm_uid" readonly="1"/>
										<field name="confirm_date" readonly="1"/>
									</group>
									<group>							
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
										<field name="cancel_uid" readonly="1"/>
										<field name="cancel_date" readonly="1"/>
									</group>
								</group>
							</page>
						</notebook>
                    </sheet>
					<chatter>
						<field name="message_ids"/>
						<field name="activity_ids"/>
					</chatter>
                </form>
            </field>
        </record>

        <record id="tw_reimbursement_petty_cash_action" model="ir.actions.act_window">
            <field name="name">Reimbursement Petty Cash</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.reimbursement.petty.cash</field>
            <field name="view_mode">list,form</field>
			<field name="context" eval="{'search_default_draft': '1'}" />
        </record>
    
    </data>
</odoo>
