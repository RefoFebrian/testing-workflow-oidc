<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tw_product_category_serial_number_form_view" model="ir.ui.view">
        <field name="name">tw.product.category.serial.number.form.view</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="stock_account.view_category_property_form_stock"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='property_valuation']/.." position="after">
                <field name="is_only_use_pricelist"/>
            </xpath>
        </field>
    </record>
    
</odoo>
