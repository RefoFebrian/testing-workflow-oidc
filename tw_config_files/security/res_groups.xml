<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
    <!-- TW Config Files Groups -->

        <record id="group_tw_config_files_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Saved File Path Config Read</field>
        </record>  

        <record id="access_tw_config_files_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_config_files"/>
            <field name="name">tw_config_files read</field>
            <field name="group_id" ref="group_tw_config_files_read"/>
            <field name="perm_read">1</field>
        </record>
        
        <record id="group_tw_config_files_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Saved File Path Config Update</field>
			<field name="implied_ids" eval="[(4, ref('group_tw_config_files_read'))]"/>
        </record>

        <record id="access_tw_config_files_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_config_files"/>
            <field name="name">tw_config_files update</field>
            <field name="group_id" ref="group_tw_config_files_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
		
        <record id="group_tw_config_files_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Saved File Path Config Delete</field>
			<field name="implied_ids" eval="[(4, ref('group_tw_config_files_read'))]"/>
        </record>

		<record id="access_tw_config_files_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_config_files"/>
            <field name="name">tw_config_files delete</field>
            <field name="group_id" ref="group_tw_config_files_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    <!-- TW Stored Files Groups -->

        <record id="group_tw_stored_files_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Saved Files Read</field>
        </record>

        <record id="access_tw_stored_files_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_wizard"/>
            <field name="name">tw_stored_files read</field>
            <field name="group_id" ref="group_tw_stored_files_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_stored_files_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_line_wizard"/>
            <field name="name">tw_stored_files_line read</field>
            <field name="group_id" ref="group_tw_stored_files_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_stored_files_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Saved Files Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_stored_files_read'))]"/>
        </record>

        <record id="access_tw_stored_files_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_wizard"/>
            <field name="name">tw_stored_files write</field>
            <field name="group_id" ref="group_tw_stored_files_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_stored_files_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_line_wizard"/>
            <field name="name">tw_stored_files_line write</field>
            <field name="group_id" ref="group_tw_stored_files_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_stored_files_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Monitoring Saved Files Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_stored_files_read'))]"/>
        </record>

        <record id="access_tw_stored_files_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_wizard"/>
            <field name="name">tw_stored_files delete</field>
            <field name="group_id" ref="group_tw_stored_files_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_stored_files_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_stored_files_line_wizard"/>
            <field name="name">tw_stored_files_line delete</field>
            <field name="group_id" ref="group_tw_stored_files_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    <!-- TW Stored Files Groups -->
    
        
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_config_files_read')),	
				(4,ref('group_tw_config_files_update')),	
				(4,ref('group_tw_config_files_delete')),
                (4,ref('group_tw_stored_files_read')),
                (4,ref('group_tw_stored_files_update')),
                (4,ref('group_tw_stored_files_delete')),
			]"/> 
		</record>

    </data>
</odoo>