<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">  
	
    <!-- TW Format Upload -->

        <record id="group_tw_format_upload_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Format Upload Read</field>
        </record> 
        
        <record id="access_tw_format_upload_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_format_upload"/>
            <field name="name">tw_format_upload read</field> 
            <field name="group_id" ref="group_tw_format_upload_read"/>  
            <field name="perm_read">1</field> 
        </record> 

        <record id="group_tw_format_upload_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Format Upload Update</field> 
            <field name="implied_ids" eval="[(4, ref('group_tw_format_upload_read'))]"/>                             
        </record>
        
        <record id="access_tw_format_upload_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_format_upload"/>
            <field name="name">tw_format_upload update</field> 
            <field name="group_id" ref="group_tw_format_upload_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      

        <record id="group_tw_format_upload_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Format Upload Delete</field>  
            <field name="implied_ids" eval="[(4, ref('group_tw_format_upload_read'))]"/>                             
        </record>
                        
        <record id="access_tw_format_upload_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_format_upload"/>
            <field name="name">tw_format_upload delete</field> 
            <field name="group_id" ref="group_tw_format_upload_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>
        
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_format_upload_read')),
                (4,ref('group_tw_format_upload_update')),
                (4,ref('group_tw_format_upload_delete')),
                ]" />
        </record>         
    </data>
</odoo>