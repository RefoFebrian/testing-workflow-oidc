<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- tw.format.upload tree view -->
        <record id="tw_format_upload_list_view" model="ir.ui.view">
            <field name="name">tw.format.upload.view.tree</field>
            <field name="model">tw.format.upload</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="filename_format"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <!-- tw.format.upload form view -->
        <record id="tw_format_upload_form_view" model="ir.ui.view">
            <field name="name">tw.format.upload.view.form</field>
            <field name="model">tw.format.upload</field>
            <field name="arch" type="xml">
                <form string="Format Upload">
                    <sheet>
                        <group>
                            <field name="name" required="1"/>
                            <field name="filename_format" invisible="1"/>
                            <field name="filename_upload_format" invisible="1"/>
                            <label for="file_format_show" string="Format File"/>
                            <div>
                                <field name="file_format_show" invisible="filename_format == False" readonly="1" filename="filename_upload_format"/>
                                <field name="file_format" required="filename_format == False" filename="filename_format"/>
                            </div>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_format_upload_filter" model="ir.ui.view">
            <field name="name">tw.format.upload.filter</field>
            <field name="model">tw.format.upload</field>
            <field name="arch" type="xml">
                <search string="Search Format Upload">
                    <field name="name"></field>
                    <field name="filename_format" />
                    <filter name="active" string="Active" domain="[('active', '=', True)]"  />
                    <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"  />
                </search>
            </field>
        </record> 

        <!-- tw.format.upload action window -->
        <record id="tw_format_upload_action" model="ir.actions.act_window">
            <field name="name">Format Upload</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.format.upload</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    <!-- Add Text Here -->
                </p><p>
                    <!-- More details about what a user can do with this object will be OK --> 
                </p>
            </field>
        </record>

        <!-- This Menu Item must have a parent and an action -->
        <menuitem id="menuitem_tw_format_upload" name="Format Upload" parent="tw_menu.submenu_tw_configuration" action="tw_format_upload_action" groups="tw_format_upload.group_tw_format_upload_read" sequence="10"/>
    </data>
</odoo>