<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- TW Selection -->
        <record id="tw_module_category_selection" model="ir.module.category">
            <field name="name">TW Selection</field>
        </record>

        <record id="group_tw_selection_read" model="res.groups">
            <field name="category_id" ref="tw_selection.tw_module_category_selection"/>
            <field name="name">TW Master Selection Read</field>
        </record>

        <record id="access_tw_quest_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_selection"/>
            <field name="name">tw_quest read</field>
            <field name="group_id" ref="group_tw_selection_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_selection_update" model="res.groups">
            <field name="category_id" ref="tw_selection.tw_module_category_selection"/>
            <field name="name">TW Master Selection Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_selection_read'))]"/>
        </record>

        <record id="access_tw_quest_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_selection"/>
            <field name="name">tw_quest update</field>
            <field name="group_id" ref="group_tw_selection_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_selection_delete" model="res.groups">
            <field name="category_id" ref="tw_selection.tw_module_category_selection"/>
            <field name="name">TW Master Selection Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_selection_read'))]"/>
        </record>

        <record id="access_tw_activity_plan_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_selection"/>
            <field name="name">tw_quest delete</field>
            <field name="group_id" ref="group_tw_selection_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
               	(4, ref('group_tw_selection_read')),
                (4, ref('group_tw_selection_update')),
                (4, ref('group_tw_selection_delete')),
				]"/>
        </record>
    </data>
</odoo>