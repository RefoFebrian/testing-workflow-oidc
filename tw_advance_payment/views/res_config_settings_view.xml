<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tw_res_config_settings_attachment_required_advance_payment_form_view" model="ir.ui.view">
        <field name="name">res.config.settings.attachment.required.advance.payment.form.view</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="100"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Place Core Tax at the top of General Settings (above Users) -->
            <xpath expr="//block[1]" position="before">
                <block title="Attachment Required" name="attachment_required_block">
                    <setting id="attachment_required_advance_payment_setting" string="Attachment Required" help="Enable this to use required attachment in advance payment settings.">
                        <field name="attachment_required"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>