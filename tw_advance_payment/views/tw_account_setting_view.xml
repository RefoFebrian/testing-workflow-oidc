<odoo>
    <data>
      <record id="tw_advance_payment_account_setting_inherit_form_view" model="ir.ui.view">
          <field name="name">tw.advance.payment.account.setting.inherit.view.form</field>
          <field name="model">tw.account.setting</field>
          <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
          <field name="arch" type="xml">
              <xpath expr="//group[@name='backoffice_advance_payment']" position="inside">
                  <field name="journal_avp_id" options="{'no_create': True}"/>
              </xpath>
          </field>
      </record>
    </data>
  </odoo>