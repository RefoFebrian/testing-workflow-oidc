        <record id="tw_auto_report_trial_balance" model="tw.report.automation">
            <field name="name">Laporan Trial Balance</field>
            <field name="directory">TrialBalanceReport</field>
            <field name="parameter">{
                'period_id': (
                    self.env['tw.account.period']
                    .search([
                        ('date_from', '=', (datetime.now() + relativedelta(hours=7) - relativedelta(months=1)).replace(day=1).strftime('%Y-%m-%d')),
                        ('date_to', '=', ((datetime.now() + relativedelta(hours=7)).replace(day=1) - relativedelta(days=1)).strftime('%Y-%m-%d'))
                    ], limit=1)
                    .id
                )
            }</field>
            <field name="method">generate_trial_balance_report</field>
            <field name="ext">xlsx</field>
            <field name="config_id" ref="tw_auto_report.tw_auto_report_config_files_auto_report" />
            <field name="model_id" ref="tw_trial_balance_report.model_tw_trial_balance_report" />
            <field name="state">confirmed</field>
