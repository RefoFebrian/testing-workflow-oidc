<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_target_sales_people_view_list" model="ir.ui.view">
            <field name="name">tw.target.sales.people.view.list</field>
            <field name="model">tw.target.sales.people</field>
            <field name="arch" type="xml">
                <list>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="tw_target_sales_people_view_form" model="ir.ui.view">
            <field name="name">tw.target.sales.people.view.form</field>
            <field name="model">tw.target.sales.people</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="company_id" required="1" options="{'no_open':True,'no_create':True}"/>
                            <field name="job_id" required="1" options="{'no_open':True,'no_create':True}"/>
                        </group>
                        <notebook>
                            <page string="Detail">
                                <field name="target_line_ids" nolabel="1">
                                    <list editable="bottom">
                                        <field name="type" required="1"/>
                                        <field name="target_type" required="1"/>
                                        <field name="category_id" required="1" options="{'no_open':True,'no_create':True}"/>
                                        <field name="target" required="1"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="type" required="1"/>
                                                <field name="target" required="1"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_date" readonly="1"/>
                                        <field name="create_uid" readonly="1" options="{'no_open':True,'no_create':True}"/>
                                    </group>
                                    <group>
                                        <field name="write_date" readonly="1"/>
                                        <field name="write_uid" readonly="1" options="{'no_open':True,'no_create':True}"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_target_sales_people_filter" model="ir.ui.view">
            <field name="name">tw.target.sales.people.filter</field>
            <field name="model">tw.target.sales.people</field>
            <field name="arch" type="xml">
                <search string="Search Target Sales People">
                    <field name="company_id" string="Branch"/>
                </search>
            </field>
        </record>

        <record id="action_tw_target_sales_people" model="ir.actions.act_window">
            <field name="name">Target Sales People</field>
            <field name="res_model">tw.target.sales.people</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>