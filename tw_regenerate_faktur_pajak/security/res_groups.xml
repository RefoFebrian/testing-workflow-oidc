            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan_line"/>
            <field name="name">tw_regenerate_faktur_pajak_line delete</field>
            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_regenerate_faktur_pajak_read')),
                (4, ref('group_tw_regenerate_faktur_pajak_update')),
                (4, ref('group_tw_regenerate_faktur_pajak_delete')),
            ]"/>
        </record>
    </data>

</odoo>
