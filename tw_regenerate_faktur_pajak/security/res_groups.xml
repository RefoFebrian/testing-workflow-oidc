<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- TW Regenerate Faktur Pajak -->
        <!-- READ  -->
        <record id="group_tw_regenerate_faktur_pajak_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Regenerate Faktur Pajak Read</field>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan"/>
            <field name="name">tw_regenerate_faktur_pajak read</field>
            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan_line"/>
            <field name="name">tw_regenerate_faktur_pajak_line read</field>
            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- UPDATE  -->
        <record id="group_tw_regenerate_faktur_pajak_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Regenerate Faktur Pajak Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_regenerate_faktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan"/>
