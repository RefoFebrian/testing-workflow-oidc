            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan_line"/>
            <field name="name">tw_regenerate_faktur_pajak_line update</field>
            <field name="group_id" ref="group_tw_regenerate_faktur_pajak_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- DELETE  -->
        <record id="group_tw_regenerate_faktur_pajak_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Regenerate Faktur Pajak Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_regenerate_faktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_regenerate_faktur_pajak_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_regenerate_faktur_pajak_gabungan"/>
