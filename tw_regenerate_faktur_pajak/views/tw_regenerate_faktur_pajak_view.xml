<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- List View -->
    <record id="tw_regenerate_faktur_pajak_list_view" model="ir.ui.view">
      <field name="name">tw.regenerate.faktur.pajak.gabungan.list</field>
      <field name="model">tw.regenerate.faktur.pajak.gabungan</field>
      <field name="priority">2</field>
      <field name="arch" type="xml">
        <list string="Regenerate Faktur Pajak">
          <field name="name"/>
          <field name="date"/>
          <field name="model_id"/>
          <field name="state"/>
        </list>
      </field>
    </record>

    <!-- Search View -->
    <record id="tw_regenerate_faktur_pajak_search_view" model="ir.ui.view">
      <field name="name">tw.regenerate.faktur.pajak.gabungan.search</field>
      <field name="model">tw.regenerate.faktur.pajak.gabungan</field>
      <field name="arch" type="xml">
        <search string="Search Regenerate Faktur Pajak">
          <field name="name"/>
          <field name="date"/>
          <field name="model_id"/>
          <field name="state"/>
        </search>
      </field>
    </record>

    <!-- Form View -->
    <record id="tw_regenerate_faktur_pajak_form_view" model="ir.ui.view">
      <field name="name">tw.regenerate.faktur.pajak.gabungan.form</field>
      <field name="model">tw.regenerate.faktur.pajak.gabungan</field>
      <field name="arch" type="xml">
        <form string="Regenerate Faktur Pajak">

          <header>
            <button name="action_post" groups="tw_regenerate_faktur_pajak.group_tw_regenerate_faktur_pajak_button_post" invisible="state != 'draft'" string="Post" class="oe_highlight" type="object"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,post"/>
          </header>

          <sheet>
            <div class="oe_title">
              <h1>
                Regenerate Faktur Pajak
                <field name="name" readonly="1"/>
              </h1>
            </div>
            <group>
              <group col="4">
                <field name="model_id" options="{'no_create': True, 'no_open': True}" required="1" readonly="state != 'draft'"/>
                <field name="date" readonly="1"/>
              </group>
            </group>

            <notebook>
              <page string="Transaction Details">
                <field name="regenerate_line" readonly="state != 'draft'">
                  <list editable="top" edit="false" create="false">
                    <field name="name"/>
                    <field name="model_id" column_invisible="True"/>
                    <field name="untaxed_amount"/>
                    <field name="tax_amount"/>
                    <field name="amount_total"/>
                    <field name="partner_id"/>
                    <field name="date"/>
                    <field name="transaction_id" column_invisible="True"/>
                  </list>
                </field>
              </page>
              <page string="Audit Trail">
                <group>
                  <group>
                    <field name="create_uid" readonly="1"/>
                    <field name="create_date" readonly="1"/>
                    <field name="confirm_uid" readonly="1"/>
                    <field name="confirm_date" readonly="1"/>
                  </group>
                  <group>
                    <field name="write_uid" readonly="1"/>
                    <field name="write_date" readonly="1"/>
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <!-- Action -->
    <record model="ir.actions.act_window" id="tw_regenerate_faktur_pajak_action">
      <field name="name">Regenerate Faktur Pajak</field>
      <field name="res_model">tw.regenerate.faktur.pajak.gabungan</field>
      <field name="view_mode">list,form</field>
    </record>

  </data>
</odoo>
