<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <!-- RFA -->

        <record id="group_tw_part_sales_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Request Approval Part Sales</field>
        </record>

        <record id="access_tw_part_sales_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_part_sales.model_tw_part_sales"/>
            <field name="name">tw_part_sales_rfa</field>
            <field name="group_id" ref="group_tw_part_sales_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="access_sale_order_option_rfa" model="ir.model.access">
            <field name="model_id" ref="sale_management.model_sale_order_option"/>
            <field name="name">sale_order_option_rfa</field>
            <field name="group_id" ref="group_tw_part_sales_rfa"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- Approve -->

        <record id="group_tw_part_sales_approve" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Approve Part Sales</field>
        </record>

        <record id="access_tw_part_sales_approve" model="ir.model.access">
            <field name="model_id" ref="tw_part_sales.model_tw_part_sales"/>
            <field name="name">tw_part_sales_approve</field>
            <field name="group_id" ref="group_tw_part_sales_approve"/>
            <field name="perm_write">1</field>
        </record>

        <record id="access_sale_order_option_approve" model="ir.model.access">
            <field name="model_id" ref="sale_management.model_sale_order_option"/>
            <field name="name">sale_order_option_approve</field>
            <field name="group_id" ref="group_tw_part_sales_approve"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <!-- Cancel Approval -->

        <record id="group_tw_part_sales_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Approval Part Sales</field>
        </record>

        <record id="access_tw_part_sales_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_part_sales.model_tw_part_sales"/>
            <field name="name">tw_part_sales_cancel_approval</field>
            <field name="group_id" ref="group_tw_part_sales_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        <record id="access_sale_order_option_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="sale_management.model_sale_order_option"/>
            <field name="name">sale_order_option_cancel_approval</field>
            <field name="group_id" ref="group_tw_part_sales_cancel_approval"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        
        <!-- Reject Approval -->

        <record id="group_tw_part_sales_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Part Sales</field>
        </record>

        <record id="access_tw_part_sales_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_part_sales.model_tw_part_sales"/>
            <field name="name">tw_part_sales_reject_approval</field>
            <field name="group_id" ref="group_tw_part_sales_reject_approval"/>
            <field name="perm_write">1</field>
        </record>

        <record id="access_sale_order_option_reject_approval" model="ir.model.access">
            <field name="model_id" ref="sale_management.model_sale_order_option"/>
            <field name="name">sale_order_option_reject_approval</field>
            <field name="group_id" ref="group_tw_part_sales_reject_approval"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_part_sales_rfa')),
                (4, ref('group_tw_part_sales_approve')),
                (4, ref('group_tw_part_sales_cancel_approval')),
                (4, ref('group_tw_part_sales_reject_approval')),
            ]" />
        </record>
    </data>


</odoo>
