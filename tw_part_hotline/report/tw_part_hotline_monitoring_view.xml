<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_part_hotline_monitoring_view" model="ir.ui.view">
            <field name="name">tw.part.hotline.monitoring.view</field>
            <field name="model">tw.part.hotline.monitoring.wizard</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Monitoring Hotline">
                    <header>
                        <h1>Monitoring Hotline</h1>
                        <p></p>
                    </header>
                    <div class="col-xm-12">
                        <label for="company_ids" string="Branch"/>
                        <div>
                            <field name="company_ids" options="{'no_create':True,'no_open':True}" required="1" widget="many2many_tags" style="width:50%"/>
                        </div>
                        <label for="options" string="Options"/>
                        <div>
                            <field name="options" required="1" style="width:50%"/>
                        </div>
                        <label for="start_date" string="Periode" invisible="options != 'periode'"/>
                        <div>
                            <field name="start_date" class="oe_inline" invisible="options != 'periode'" required="options == 'periode'"/>
                            <span invisible="options != 'periode'">-</span>
                            <field name="end_date" class="oe_inline" invisible="options != 'periode'" required="options == 'periode'"/>
                        </div>
                        <label for="no_hotline" string="No Hotline" invisible="options != 'hotline'"/>
                        <div>
                            <field name="no_hotline" invisible="options != 'hotline'" required="options == 'hotline'" style="width:50%"/>
                        </div>
                        <button name="action_search" type="object" string="Search" class="btn btn-default oe_highlight"/>
                        <button name="action_xls" type="object" string="Download Xls" invisible="is_report != True"/>
                        <button name="action_csv" type="object" string="Download Csv" invisible="is_report != True"/>
                    </div>
                    <field name="is_report" invisible="1"/>
                    <hr/>

                    <field name="create_date" invisible="1"/>
                    <group invisible="create_date == False or is_report != False">
                        <p>"Data tidak ada !"</p>
                    </group>
                    <group invisible="is_report == False">
                        <field name="detail_ids" nolabel="1" readonly="1">
                            <list>
                                <field name="name"/>
                                <field name="tgl_hotline"/>
                                <field name="lot_id" options="{'no_open':True,'no_create':True}"/>
                                <field name="chassis_number"/>
                                <field name="no_pol"/>
                                <field name="customer_id" options="{'no_open':True,'no_create':True}"/>
                                <field name="customer_name" string="Pembawa"/>
                                <field name="mobile"/>
                                <field name="is_po"/>
                                <field name="po_date"/>
                                <field name="umur"/>
                                <field name="is_wo"/>
                            </list>
                            <form>
                                <sheet>
                                    <group>
                                        <group>
                                            <field name="name"/>
                                            <field name="tgl_hotline"/>
                                            <field name="lot_id" options="{'no_open':True,'no_create':True}"/>
                                            <field name="chassis_number"/>
                                            <field name="no_pol"/>
                                        </group>
                                        <group>
                                            <field name="customer_id" options="{'no_open':True,'no_create':True}"/>
                                            <field name="customer_name" string="Pembawa"/>
                                            <field name="mobile"/>
                                        </group>
                                        <group>
                                            <field name="is_po"/>
                                            <field name="po_date"/>
                                            <field name="umur"/>
                                            <field name="is_wo"/>
                                        </group>
                                    </group>
                                    <notebook>
                                        <page string="Detail">
                                            <field name="line_ids" editable="top">
                                                <list>
                                                    <field name="product_id"/>
                                                    <field name="name"/>
                                                    <field name="qty" sum="Total"/>
                                                    <field name="qty_po" sum="Total"/>
                                                    <field name="qty_reserved" sum="Total"/>
                                                    <field name="no_po"/>
                                                    <field name="no_wo"/>
                                                    <field name="no_ps"/>
                                                </list>
                                                <form>
                                                    <sheet>
                                                        <group>
                                                            <field name="product_id" options="{'no_open':True,'no_create':True}"/>
                                                            <field name="name"/>
                                                            <field name="qty"/>
                                                            <field name="qty_po"/>
                                                            <field name="qty_reserved"/>
                                                            <field name="no_po"/>
                                                            <field name="no_wo"/>
                                                            <field name="no_ps"/>
                                                        </group>
                                                    </sheet>
                                                </form>
                                            </field>
                                        </page>
                                        <page string="Alokasi DP">
                                            <field name="dp_ids">
                                                <list>
                                                    <field name="name"/>
                                                    <field name="amount_alokasi" sum="Total"/>
                                                </list>
                                                <form>
                                                    <sheet>
                                                        <group>
                                                            <field name="name"/>
                                                            <field name="amount_alokasi"/>
                                                        </group>
                                                    </sheet>
                                                </form>
                                            </field>
                                        </page>
                                    </notebook>
                                </sheet>
                            </form>
                        </field>
                    </group>
                </form>
            </field>
        </record>

        <record id="tw_part_hotline_monitoring_wizard" model="ir.actions.act_window">
            <field name="name">Part Hotline Monitoring</field>
            <field name="res_model">tw.part.hotline.monitoring.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

    </data>
</odoo>
