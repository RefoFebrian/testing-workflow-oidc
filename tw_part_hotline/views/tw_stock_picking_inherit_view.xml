<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tw_stock_picking_inherit_hotline_form_view" model="ir.ui.view">
        <field name="name">tw.stock.picking.inherit.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_picking_move_tree']" position="before">
                <button name="action_view_part_hotline" icon="fa-wrench" string="Hotline" type="object" invisible="not part_hotline_id"/>
            </xpath>
        </field>
    </record>
</odoo>
