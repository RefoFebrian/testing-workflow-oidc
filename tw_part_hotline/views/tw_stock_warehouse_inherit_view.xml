<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tw_stock_warehouse_inherit_form_view" model="ir.ui.view">
        <field name="name">tw.stock.warehouse.inherit.form</field>
        <field name="model">stock.warehouse</field>
        <field name="inherit_id" ref="stock.view_warehouse"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='in_type_id']" position="after">
                <field name="in_hotline_type_id" string="Type Picking In Hotline"/>
            </xpath>
        </field>
    </record>
</odoo>
