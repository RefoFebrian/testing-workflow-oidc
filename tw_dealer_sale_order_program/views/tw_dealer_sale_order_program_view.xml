<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_dealer_order_program_inherit_view_form" model="ir.ui.view">
			<field name="name">tw.dealer.order.program.inherit.view.form</field>
			<field name="model">tw.dealer.sale.order</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_order_view_form" />
			<field name="priority">100</field>
			<field name="arch" type="xml">

				<group name="amount_discount" position="inside">
					<field name="amount_subsidy" readonly="1" />
					<field name="amount_subsidy_md" readonly="1" />
					<field name="amount_subsidy_finco" readonly="1" />
					<field name="amount_subsidy_dealer" readonly="1" />
				</group>

				<xpath expr="//field[@name='summary_discount_ids']/list//field[@name='discount_regular']" position="after">
					<field name="amount_subsidy" readonly="1" optional="hide"/>
					<field name="amount_subsidy_dealer" readonly="1" optional="hide"/>
					<field name="amount_subsidy_md" readonly="1" optional="hide"/>
					<field name="amount_subsidy_finco" readonly="1" optional="hide"/>
				</xpath>

				<xpath expr="//field[@name='summary_discount_ids']/form//field[@name='discount_regular']" position="after">
					<field name="amount_subsidy" readonly="1"/>
					<field name="amount_subsidy_dealer" readonly="1"/>
					<field name="amount_subsidy_md" readonly="1"/>
					<field name="amount_subsidy_finco" readonly="1"/>
				</xpath>

			</field>
		</record>

		<record id="tw_dealer_order_line_program_inherit_view_form" model="ir.ui.view">
			<field name="name">tw.dealer.order.line.program.inherit.view.form</field>
			<field name="model">tw.dealer.sale.order.line</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sale_order_line_view_form" />
			<field name="priority">100</field>
			<field name="arch" type="xml">

				<field name="analytic_line_ids" position="after">
					<field name="available_sales_program_ids" widget="many2many_tags" invisible="1"/>
				</field>

				<xpath expr="//page[@name='page_lines']" position="after">
					<page string="Discount Line" name="dso_line_program">
						<field name="sales_program_ids" readonly="parent.state != 'draft'">
							<list editable="bottom">
								<field name="sales_program_id" required="1" domain="[('id', 'in', parent.available_sales_program_ids)]" options="{'no_create': True, 'no_open': True}"/>
								<field name="dp_type" optional="hide" readonly="1" />
								<field name="subsidy_type" optional="hide" readonly="1" />
								<field name="amount_md" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_ahm" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_finco" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_dealer" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_others" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_diff_md" optional="hide" readonly="1" force_save="1"/>
								<field name="amount_diff_finco" optional="hide" readonly="1" force_save="1"/>
								<field name="discount_amount" readonly="1" force_save="1"/>
								<field name="discount_customer" required="1" readonly="subsidy_type == 'fix'" force_save="1"/>
							</list>
							<form>
								<group>
									<group>
										<field name="sales_program_id" />
										<field name="dp_type" />
									</group>
									<group>
										<field name="amount_md" />
										<field name="amount_ahm" />
										<field name="amount_finco" />
										<field name="amount_dealer" />
										<field name="amount_others" />
										<field name="amount_diff_md" />
										<field name="amount_diff_finco" />
										<field name="discount_amount" />
										<field name="discount_customer" />
									</group>
								</group>
							</form>
						</field>
					</page>
				</xpath>
			</field>
		</record>

		<record id="tw_dealer_sale_order_report_wizard_inherit_view" model="ir.ui.view">
			<field name="name">tw.dealer.sale.order.report.wizard.inherit.view.form</field>
			<field name="model">tw.dealer.sale.order</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sale_order_report_wizard_view" />
			<field name="arch" type="xml">
				<xpath expr="//div[@name='print_report_invoice_dso']" position="before">
					<div style="display: inline-block; margin-right: 8px;">
						<button name="action_print_report_subsidi_leasing_wizard" invisible="state not in ('sale','done') or finco_id == False" type="object" string="Print Subsidi Leasing" class="oe_highlight"/>
					</div>
				</xpath>
			</field>
		</record>

		<record id="tw_dealer_sale_order_subsidi_leasing_wizard_view" model="ir.ui.view">
			<field name="name">tw.dealer.sale.order.subsidi.leasing.wizard</field>
			<field name="model">tw.dealer.sale.order</field>
			<field name="arch" type="xml">
				<form string="Subsidi Leasing">
					<group>
						<field name="for_reason_payment"/>
					</group>
					<footer>
						<button name="action_print_report_subsidi_leasing" string="Print" type="object" class="oe_highlight"/>
						<button string="Close" special="cancel" class="btn-secondary"/>
					</footer>
				</form>
			</field>
		</record>

	</data>
</odoo>
