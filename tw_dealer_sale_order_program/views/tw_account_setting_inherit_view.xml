<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_settings_dso_discount_inherit_view" model="ir.ui.view">
            <field name="name">tw.account.settings.dso.discount.inherit.view</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view" />
            <field name="arch" type="xml">
                <field name="account_dso_discount_regular_id" position="after">
                    <field name="account_dso_discount_quotation_id" domain="[('account_type', '=', 'expense')]" options="{'no_quick_create': True}" />
                    <field name="account_dso_remaining_subsidy_id" domain="[('account_type', '=', 'expense')]" options="{'no_quick_create': True}" />
                    <field name="journal_dso_subsidy_finco_id" options="{'no_quick_create': True}" />
                    <field name="journal_dso_subsidy_md_id" options="{'no_quick_create': True}" />
                </field>
            </field>
        </record>
    </data>
</odoo>
