<odoo>
    <data>
    <!-- Departement -->  
    <record id="tw_department_inherit_list_view" model="ir.ui.view">
        <field name="name">hr.department.inherit.list</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.view_department_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">1</attribute>
                <attribute name="edit">0</attribute>
            </xpath>

            <field name="manager_id" position="attributes">
                <attribute name="string">Department Head</attribute>
            </field>

            <field name="manager_id" position="after">
                <field name="code"/>
            </field>

             <!-- Hilangin -->
            <field name="parent_id" position="attributes">
                  <attribute name="invisible">1</attribute>   
            </field> 
        </field>
    </record>

    <record id="tw_department_inherit_kanban_view" model="ir.ui.view">
        <field name="name">hr.department.kanban.inherit</field>
        <field name="model">hr.department</field>
        <field name="inherit_id" ref="hr.hr_department_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="edit">0</attribute>
            </xpath>
        </field>
    </record>

    <record id='tw_department_form_view' model='ir.ui.view'>
              <field name='name'>tw.department.form</field>
              <field name='model'>hr.department</field>
              <field name="inherit_id" ref="hr.view_department_form"/>
              <field name="arch" type="xml">
                    <group>
                    </group>

                    <!-- No Open/Create -->
                    <field name="manager_id" position="attributes">
                        <attribute name="options">{'no_open':True,'no_create':True}</attribute>
                        <attribute name="string">Department Head</attribute>
                        <attribute name="domain">[('id','!=',1)]</attribute>
                    </field>

                    <field name="manager_id" position="after">
                        <field name="code"/>
                    </field>

                    <!--hilangin bawaan -->

                    <field name="parent_id" position="attributes">
                        <attribute name="invisible">1</attribute>
                    </field>
                </field>
    </record>

    <record model="ir.actions.act_window" id="tw_department_action">
          <field name="name">Department</field>
          <field name="res_model">hr.department</field>
          <field name="view_mode">list,form</field>
    </record>
    
    </data>
</odoo>