<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
	    <!-- TW Upload Supplier Payment Groups -->	
        	
        <record id="group_tw_upload_supplier_payment_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Upload Supplier Payment Read</field>
        </record> 

		<record id="access_tw_upload_supplier_payment_read" model="ir.model.access">
    		<field name="model_id" ref="model_tw_upload_supplier_payment"/>
      		<field name="name">tw_upload_supplier_payment read</field> 
      		<field name="group_id" ref="group_tw_upload_supplier_payment_read"/>  
      		<field name="perm_read">1</field> 
		</record>
		
		<record id="group_tw_upload_supplier_payment_update" model="res.groups">
	    	<field name="category_id" ref="tw_base.tw_backoffice"/>
	      	<field name="name">TW Upload Supplier Payment Update</field>
		</record>

		<record id="access_tw_upload_supplier_payment_update" model="ir.model.access">
    		<field name="model_id" ref="model_tw_upload_supplier_payment"/>
      		<field name="name">tw_upload_supplier_payment update</field> 
      		<field name="group_id" ref="group_tw_upload_supplier_payment_update"/>  
      		<field name="perm_write">1</field> 
      		<field name="perm_create">1</field> 
		</record>
		
		<record id="group_tw_upload_supplier_payment_delete" model="res.groups">
	    	<field name="category_id" ref="tw_base.tw_backoffice"/>
	      	<field name="name">TW Upload Supplier Payment Delete</field>
		</record>

		<record id="access_tw_upload_supplier_payment_delete" model="ir.model.access">
    		<field name="model_id" ref="model_tw_upload_supplier_payment"/>
      		<field name="name">tw_upload_supplier_payment delete</field> 
      		<field name="group_id" ref="group_tw_upload_supplier_payment_delete"/>  
      		<field name="perm_unlink">1</field> 
		</record>

    </data>
    
    <data noupdate="1">
		<record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_upload_supplier_payment_read')),
				(4,ref('group_tw_upload_supplier_payment_update')),
				(4,ref('group_tw_upload_supplier_payment_delete')),
			]"/> 
		</record>
	</data>
</odoo>