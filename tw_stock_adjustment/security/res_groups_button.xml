<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_stock_adjustment_confirm" model="res.groups">
            <field name="name">TW Button Confirm Stock Adjustment</field>
            <field name="category_id" ref="tw_base.tw_role" />
        </record>
        <record id="access_tw_stock_adjustment_confirm" model="ir.model.access">
            <field name="name">tw_stock_adjustment_confirm</field>
            <field name="model_id" ref="tw_stock_adjustment.model_tw_stock_adjustment"/>
            <field name="group_id" ref="group_tw_stock_adjustment_confirm"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
        </record>
            
        <record id="group_tw_stock_adjustment_validate" model="res.groups">
            <field name="name">TW Button Validate Stock Adjustment</field>
            <field name="category_id" ref="tw_base.tw_role" />
        </record>
        <record id="access_tw_stock_adjustment_validate" model="ir.model.access">
            <field name="name">tw_stock_adjustment_validate</field>
            <field name="model_id" ref="tw_stock_adjustment.model_tw_stock_adjustment"/>
            <field name="group_id" ref="group_tw_stock_adjustment_validate"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
        </record>
            
        <record id="group_tw_stock_adjustment_cancel" model="res.groups">
            <field name="name">TW Button Cancel Stock Adjustment</field>
            <field name="category_id" ref="tw_base.tw_role" />
        </record>
        <record id="access_tw_stock_adjustment_cancel" model="ir.model.access">
            <field name="name">tw_stock_adjustment_cancel</field>
            <field name="model_id" ref="tw_stock_adjustment.model_tw_stock_adjustment"/>
            <field name="group_id" ref="group_tw_stock_adjustment_cancel"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
        </record>
            
        <record id="group_tw_stock_adjustment_set_to_draft" model="res.groups">
            <field name="name">TW Button Set to Draft Stock Adjustment</field>
            <field name="category_id" ref="tw_base.tw_role" />
        </record>
        <record id="access_tw_stock_adjustment_set_to_draft" model="ir.model.access">
            <field name="name">tw_stock_adjustment_set_to_draft</field>
            <field name="model_id" ref="tw_stock_adjustment.model_tw_stock_adjustment"/>
            <field name="group_id" ref="group_tw_stock_adjustment_set_to_draft"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_stock_adjustment_confirm')),
                (4,ref('group_tw_stock_adjustment_validate')),
                (4,ref('group_tw_stock_adjustment_cancel')),
                (4,ref('group_tw_stock_adjustment_set_to_draft')),
            ]"/>
        </record>
    </data>
    

</odoo>
