<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_vehicle_document_outstanding_view_search" model="ir.ui.view">
            <field name="name">tw.tw.vehicle.document.outstanding.search</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Engine Number"/>
                    <field name="chassis_number"/>
                    <field name="partner_id"/>
                    <field name="customer_stnk_id"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="state"/>
                    <field name="cddb_state"/>
                    <field name="is_hold_cdb"/>
                    <filter string="Paid" name="state_paid" domain="[('state', '=', 'paid')]" />
                    <filter string="Customer Not Set" name="customer_not_set" domain="[('partner_id', '=', False)]" />
                    <filter string="Customer STNK Not Set" name="customer_stnk_not_set" domain="[('customer_stnk_id', '=', False)]" />
                    <filter string="Hold" name="hold_cdb" domain="[('is_hold_cdb', '=', True)]" />
                    <filter string="Outstanding" name="outstanding_cdb" domain="[('is_hold_cdb', '=', False)]" />
                    <filter string="Branch" name="group_branch" context="{'group_by': 'company_id'}" />
                    <filter string="Customer" name="group_customer" context="{'group_by': 'partner_id'}" />
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}" />
                </search>
            </field>
        </record>

        <record id="tw_vehicle_document_outstanding_view_list" model="ir.ui.view">
            <field name="name">tw.tw.vehicle.document.outstanding.list</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <list create="false" edit="false" delete="false">
                    <field name="name" string="Engine Number"/>
                    <field name="chassis_number"/>
                    <field name="partner_id"/>
                    <field name="customer_stnk_id"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="state"/>
                    <field name="cddb_state"/>
                    <button name="action_edit_udstk" type="object" title="Edit UDSTK" icon="fa-edit" invisible="cddb_state != 'draft' or is_hold_cdb"/>
                    <button name="action_edit_customer" type="object" title="Customer Database" icon="fa-user" invisible="cddb_state != 'udstk'"/>
                    <button name="action_hold_cdb" type="object" string="Hold" class="oe_highlight btn-danger" invisible="cddb_state != 'draft' or is_hold_cdb" groups="tw_vehicle_document.group_vehicle_document_receive_button_hold_cdb"/>
                    <button name="action_unhold_cdb" type="object" string="Process" class="oe_highlight" invisible="cddb_state != 'draft' or not is_hold_cdb" groups="tw_vehicle_document.group_vehicle_document_receive_button_unhold_cdb"/>
                </list>
            </field>
        </record>
        
        <record id="tw_vehicle_document_outstanding_action" model="ir.actions.act_window">
            <field name="name">Outstanding Permohonan Faktur</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock.lot</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_vehicle_document_outstanding_view_list"/>
            <field name="search_view_id" ref="tw_vehicle_document_outstanding_view_search"/>
            <field name="context">{'search_default_outstanding_cdb':1}</field>
            <field name="domain">[('vehicle_document_request_id', '=', False), ('state', '=', 'paid'), ('cddb_state', '!=', 'cddb')]</field>
        </record>

    </data>
</odoo>
