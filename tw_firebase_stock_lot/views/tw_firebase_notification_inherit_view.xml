<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_firebase_notification_stock_lot_view_inherit_form" model="ir.ui.view">
            <field name="name">tw.firebase.notification.stock.lot.view.inherit.form</field>
            <field name="model">tw.firebase.notification</field>
            <field name="inherit_id" ref="tw_firebase.tw_firebase_notification_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='customer_name']" position="after">
                    <field name="lot_id" readonly='state != "draft"'/>
                </xpath>
            </field>
        </record>

        <record id="tw_firebase_notification_stock_lot_view_inherit_search" model="ir.ui.view">
            <field name="name">tw.firebase.notification.stock.lot.view.inherit.search</field>
            <field name="model">tw.firebase.notification</field>
            <field name="inherit_id" ref="tw_firebase.tw_firebase_notification_view_search" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='customer_name']" position="after">
                    <field name="lot_id" readonly='state != "draft"'/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>