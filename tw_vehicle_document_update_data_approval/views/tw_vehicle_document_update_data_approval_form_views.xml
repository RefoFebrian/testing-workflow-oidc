<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="tw_vehicle_document_update_approval_form_view" model="ir.ui.view">
      <field name="name">tw.vehicle.document.update.approval.form</field>
      <field name="model">tw.vehicle.document.update.data</field>
      <field name="inherit_id" ref="tw_vehicle_document_update_data.tw_vehicle_document_update_data_form_view" />
      <field name="arch" type="xml">
        <field name="state" position="replace">
          <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,confirm"/>
        </field>  
        <button name="action_confirm" position="replace">
          <button name="action_request_approval"
            invisible="state != 'draft'" string="RFA" type="object"
            class="oe_highlight" groups="tw_vehicle_document_update_data.group_button_action_request"/>
          <button name="action_approval" invisible="state != 'waiting_for_approval'"
            string="Approve" type="object" class="oe_highlight"/>
          <button name="action_reject_or_cancel" invisible="state != 'waiting_for_approval'"
            string="Reject" type="object"
            context="{'window_title': 'Reject'}"/>
          <button name="action_confirm" invisible="state != 'approved'"
            data-hotkey="q" string="Confirm" type="object" class="oe_highlight"
            context="{'validate_analytic': True}" groups="tw_vehicle_document_update_data.group_button_action_confirm"/>
          <button name="action_reject_or_cancel" invisible="state not in ('waiting_for_approval', 'approved')"
            string="Cancel Approval" type="object" context="{'window_title': 'Cancel'}" groups="tw_vehicle_document_update_data.group_button_action_cancel"/>
        </button>

        <xpath expr="//page[@name='audit_trail']" position="before">
          <page string="Approval">
            <field name="approval_ids" readonly="True" />
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>