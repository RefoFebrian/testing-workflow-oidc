<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="view_company_form_inherit_doodool" model="ir.ui.view">
        <field name="name">res.company.form.inherit.doodool</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='general_info']" position="inside">
                <group string="Doodool API Settings">
                    <field name="is_allow_lead"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

