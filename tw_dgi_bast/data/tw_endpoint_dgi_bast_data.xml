<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        =============================================================
        DGI BAST Endpoint Configurations

        Endpoint untuk sync BAST (Surat Jalan / Batch Transfer Out)
        dari DGI API. Satu endpoint per API Config
        (HSO, ASP, DAM, DAW, NPM, SINSEN, WAHANA)

        target_model: stock.picking.batch (Batch Transfers)
        =============================================================
        -->

        <!-- ==================== HSO ==================== -->
        <record id="tw_endpoint_dgi_bast_hso" model="tw.endpoint.configuration">
            <field name="code">dgi_bast</field>
            <field name="version">1</field>
            <field name="url_path">bast/read</field>
            <field name="method">post</field>
            <field name="config_id" ref="tw_dgi.tw_api_config_dgi_hso"/>
            <field name="mode">read</field>
            <field name="target_model_id" ref="stock_picking_batch.model_stock_picking_batch"/>
            <field name="dgi_division_id" ref="tw_dgi.tw_selection_division_dgi_h1"/>
        </record>

