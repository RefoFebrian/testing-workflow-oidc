<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        
        <record id="group_tw_button_form_deal_lead" model="res.groups">
            <field name="category_id" ref="tw_module_category_lead"/>
            <field name="name">TW Button Form Deal Lead</field>
        </record>

        <record id="group_tw_button_form_propose_lead" model="res.groups">
            <field name="category_id" ref="tw_module_category_lead"/>
            <field name="name">TW Button Data Confirmation Lead</field>
        </record>

        <record id="group_tw_button_revision" model="res.groups">
            <field name="category_id" ref="tw_module_category_lead"/>
            <field name="name">TW Button Revision</field>
        </record>

        <record id="group_tw_button_update_otr" model="res.groups">
            <field name="category_id" ref="tw_module_category_lead"/>
            <field name="name">TW Button Update OTR</field>
        </record>
    
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_button_form_deal_lead')),
                (4,ref('group_tw_button_form_propose_lead')),
                (4,ref('group_tw_button_revision')),
                (4,ref('group_tw_button_update_otr')),
                ]" />
        </record>
    </data>

</odoo>
