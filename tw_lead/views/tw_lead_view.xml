<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_lead_view_filter" model="ir.ui.view">
            <field name="name">tw.lead.view.filter</field>
            <field name="model">tw.lead</field>
            <field name="priority" eval="15"/>
            <field name="arch" type="xml">
                <search string="Search Leads">
                    <field name="name" string="Lead" filter_domain="['|', ('name', 'ilike', self), ('partner_id', 'child_of', self)]"/>
                    <field name="identification_number" string="Nomor KTP"/>
                    <field name="customer_name" string="Nama Customer"/>
                    <field name="mobile" string="Nomor Handphone"/>
                    <field name="partner_id" operator="child_of"/>
                    <field name="company_id" operator="child_of"/>
                    <field name="sales_id" string="Salesperson"/>
                    <field name="product_id" string="Product" filter_domain="[('product_id', 'ilike', self)]"/>
                    <!-- We only allow to search on the following sale order line fields (product, name) because the other fields, such as price, quantity, ...
                        will not be searched as often, and if they need to be searched it's usually in the context of products
                        and then they can be searched from the page listing the sale order lines related to a product (from the product itself).
                    -->
                    <!-- <filter string="Quotation" domain="[('state', '=', 'draft')]" name="quotation_filter"/> -->

                    <group expand="0" string="Group By">
                        <filter string="Salesperson" name="salesperson" domain="[]" context="{'group_by': 'sales_id'}" />
                        <filter string="Branch" name="company_id" domain="[]" context="{'group_by': 'company_id'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_lead_crm_lead_list_view" model="ir.ui.view">
            <field name="name">tw.lead.crm.lead.list.view</field>
            <field name="model">tw.lead</field>
            <field name="arch" type="xml">
                <list string="Leads" sample="1">
                    <field name="company_id" optional="show"/>
                    <field name="name" string="No Buku Tamu"/>
                    <field name="customer_name" string="Nama Customer" optional="show"/>
                    <field name="mobile" string="No HP" optional="show"/>
                    <field name="sales_id" string="Sales Person" optional="show"/>
                    <field name="create_date" optional="show"/>
                    <field name="state" widget="badge" decoration-info="state == 'open'" decoration-warning="state == 'dealt'" decoration-success="state == 'approved'" decoration-danger="state == 'reject'"/>

                    <field name="partner_id" optional="hide"/>
                    <field name="identification_number" optional="hide"/>
                    <field name="identification_family_number" optional="hide"/>
                    <field name="user_company_ids" column_invisible="True"/>
                    <field name="date_deadline" column_invisible="True"/>
                    <field name="contact_name" optional="hide"/>
                    <field name="partner_name" optional="hide"/>
                    <field name="email_from" optional="hide"/>
                    <field name="phone" optional="hide" class="o_force_ltr"/>
                    <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                    <field name="city" optional="hide"/>
                    <field name="state_id" optional="hide"/>
                    <field name="country_id" optional="hide" options="{'no_open': True, 'no_create': True}"/>
                    <!-- Explicit domain due to multi edit -> real company domain would be complicated -->
                    <field name="user_id" optional="hide" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                    <field name="tag_ids" optional="hide" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    <field name="priority" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="tw_lead_crm_lead_form_view" model="ir.ui.view">
            <field name="name">tw.lead.crm.lead.showroom.form.view</field>
            <field name="model">tw.lead</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_show_deal_form" type="object" invisible="state not in ('open', 'reject') or interest != 'hot'" string="Deal" class="oe_highlight" groups="tw_lead.group_tw_button_form_deal_lead" />
                        <button name="action_propose" type="object" invisible="state not in 'dealt'" string="Data Confirmation" class="oe_highlight" groups="tw_lead.group_tw_button_form_propose_lead" />
                        <button name="action_propose" type="object" invisible="state not in 'reject'" string="Revision" class="oe_highlight" groups="tw_lead.group_tw_button_revision" />
                        <button name="action_update_otr" type="object" string="Update OTR" invisible="state not in ('proposed', 'dealt')" groups="tw_lead.group_tw_button_update_otr"/>

                        <field name="state" widget="statusbar" statusbar_visible="open,dealt,proposed,receipt,approved" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box"/>
                        <div class="oe_title mb32">
                            <label for="name" class="oe_edit_only"/>
                            <h2>
                                <h1 invisible="name">
                                    <span>New Leads</span>
                                </h1>
                                <h1 invisible="not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </h2>
                            <h1>
                                <field name="customer_name" required="1" placeholder="Nama Customer" readonly="state != 'open'"/>
                            </h1>
                        </div>
                        <group>
                            <field name="last_state_date" invisible="1" />
                            <field name="last_state" invisible="1" />
                            <group name="leads_info">
                                <field name="company_id" required="1" readonly="state != 'open'" options="{'no_create': True, 'no_open': True}" />
                                <field name="interest_id" required="1" readonly="state != 'open'" options="{'no_create': True, 'no_open': True}" />
                                <field name="interest" invisible="1" />
                                <field name="product_category_ids" widget="many2many_tags" invisible="1" />
                                <field name="product_id" required="interest in ('medium','hot')" readonly="state != 'open'" options="{'no_create': True, 'no_open': True}" context="{'list_view_ref': 'tw_product.tw_product_list_view'}" />
                                <field name="partner_id" invisible="1" />
                                <field name="customer_grade_id" invisible="1" />
                                <field name="unit_availability_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="unit_availability" invisible="1" />
                            </group>
                            <group name="salesperson">
                                <field name="date" readonly="1"/>
                                <field name="sales_id" readonly="state != 'open'" required="1" options="{'no_open': True, 'no_create': True}" domain="[('company_id', '=', company_id),('job_id.sales_force_id.value','in',('salesman','sales_counter','sales_partner','sales_koordinator','soh','sales_operation_head'))]"/>
                                <field name="sales_coordinator_id" readonly="state != 'open'" options="{'no_create': True, 'no_open': True}"/>
                                <label for="data_source_id" string="Sumber Data"/>
                                <div class="d-flex align-items-center gap-1 w-auto">
                                    <field name="data_source_char" invisible="1"/>
                                    <field name="data_source_id" string="Sumber Data" readonly="1" force_save="1" class="flex-grow-0" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="version_display" readonly="1" nolabel="1" class="flex-grow-0 flex-shrink-0" invisible="data_source_char != 'apps'"/>
                                </div>
                            </group>
                            <group name="customer_info" string="Customer Info">
                                <field name="identification_number" string="Nomor KTP" readonly="state != 'open'" required="interest == 'hot'" />
                                <field name="identification_family_number" string="Nomor KK" readonly="state != 'open'" />
                                <label for="birthplace" string="Tempat / Tgl Lahir" />
                                <div class="d-flex">
                                    <field name="birthplace" readonly="state != 'open'" required="interest == 'hot'" style="width: 150px;"/>
                                    <span class="m-1">/</span>
                                    <field name="birthdate" readonly="state != 'open'" required="interest == 'hot'" style="width: 150px;"/>
                                </div>
                                <field name="gender_id" readonly="state != 'open'" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="religion_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="mobile" readonly="state != 'open'" required="1" />
                                <label for="whatsapp" string="Whatsapp" />
                                <div class="d-flex justify-content-between">
                                    <field name="is_same_with_mobile" readonly="state != 'open'" required="1" help="This is a helpful description"/>
                                    <field name="whatsapp" readonly="state != 'open'" required="interest == 'hot'"/>
                                </div>
                                <field name="phone" readonly="state != 'open'"/>
                                <field name="email" readonly="state != 'open'"/>
                            </group>
                            <group name="customer_info2" string="">
                                <field name="blood_type_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="hobby_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="education_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="occupation_id" readonly="state != 'open'" required="interest == 'hot'" options="{'no_open': True, 'no_create': True}" />
                                <field name="marital_status_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="housing_tenure_id" readonly="state != 'open'" required="interest == 'hot'" options="{'no_open': True, 'no_create': True}" />
                                <field name="mobile_plan_status_id" readonly="state != 'open'" required="interest == 'hot'" options="{'no_open': True, 'no_create': True}" />
                                <field name="expense_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                                <field name="income_id" readonly="state != 'open'" options="{'no_open': True, 'no_create': True}" />
                            </group>
                            <group name="customer_address" string="Alamat Sesuai KTP">
                                <field name="street" placeholder="Street..." required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="street2" placeholder="Street2..." readonly="state != 'open'"/>
                                <label for="rt" string="RT/RW"/>
                                <div>
                                    <field name="rt" placeholder="RT" style="width: 25%" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                    <field name="rw" placeholder="RW" style="width: 25%" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                </div>
                                <field name="state_id" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="city_id" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="district_id" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="sub_district_id" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="zip" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="country_id" invisible="1"/>
                            </group>
                            <group name="customer_address2" string="Alamat Domisili/Survei">
                                <field name="is_same_ktp" readonly="state != 'open'"/>
                                <field name="street_domicile" string="Street" placeholder="Street..." required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="street2_domicile" string="Street2" placeholder="Street2..." readonly="state != 'open'"/>
                                <label for="rt_domicile" string="RT/RW"/>
                                <div>
                                    <field name="rt_domicile" placeholder="RT" style="width: 25%" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                    <field name="rw_domicile" placeholder="RW" style="width: 25%" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                </div>
                                <field name="state_domicile_id" string="Provinsi" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="city_domicile_id" string="Kota" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="district_domicile_id" string="Kecamatan" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="sub_district_domicile_id" string="Kelurahan" options="{'no_open': True,'no_create': True}" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                                <field name="zip_domicile" string="Zip" required="interest in ('medium','hot')" readonly="state != 'open'"/>
                            </group>
                            <group name="motorcycle_info" string="Motorcycle and Usage">
                                <field name="unit_operator_id" readonly="state != 'open'" required="interest != 'cold'" options="{'no_open': True, 'no_create': True}" />
                                <field name="unit_usage_id" readonly="state != 'open'" required="interest != 'cold'" options="{'no_open': True, 'no_create': True}" />
                                <field name="current_motorcycle" readonly="state != 'open'" required="interest != 'cold'" options="{'no_open': True, 'no_create': True}" />
                                <field name="motor_brand_id" readonly="state != 'open'" required="interest != 'cold'" options="{'no_open': True, 'no_create': True}" />
                                <field name="motor_type_id" readonly="state != 'open'" required="interest != 'cold'" options="{'no_open': True, 'no_create': True}" />
                            </group>
                            <group name="credit_proposal" string="Credit Proposal">
                                <field name="payment_type_id" readonly="state != 'open'" required="interest != 'cold'" options="{'no_create': True, 'no_open': True}" />
                                <field name="payment_type" invisible="1" />
                                <field name="finco_id" readonly="state != 'open'" required="payment_type == 'Credit'" invisible="payment_type != 'Credit'" options="{'no_create': True, 'no_open': True}" />
                                <field name="down_payment" readonly="state != 'open'" required="payment_type == 'Credit'" invisible="payment_type != 'Credit'" />
                                <field name="down_payment_date" readonly="state != 'open'" required="down_payment != False" invisible="payment_type != 'Credit'" />
                                <field name="tenor" readonly="state != 'open'" required="payment_type == 'Credit'" invisible="payment_type != 'Credit'" />
                                <field name="installment" readonly="state != 'open'" required="payment_type == 'Credit'" invisible="payment_type != 'Credit'" />
                                <field name="price_otr" readonly="1" force_save="1"/>
                                <field name="discount" readonly="state not in ('open','dealt')"/>
                            </group>
                            <group name="ownership" string="Ownership">
                                <field name="motor_ownership_id" readonly="state != 'open'" required="interest == 'hot'" options="{'no_create': True, 'no_open': True}" />
                                <field name="motor_ownership" invisible="1" />
                                <field name="partner_stnk_id" invisible="motor_ownership != 'other'" required="motor_ownership == 'other'" context="{
                                            'form_view_ref': 'tw_partner.tw_partner_contact_form_view',
                                            'default_is_customer':1,
                                            'default_company_id': company_id,
                                            'no_create': True,
                                            'no_open': True
                                        }" />
                            </group>
                            <group>
                                <field name="note" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="lead_addresses" string="Addresses">
                                <field name="address_ids" readonly="state != 'open'">
                                    <list>
                                        <field name="lead_id" invisible="1" optional="hide" />
                                        <field name="name" optional="show" />
                                        <field name="rt" optional="hide" />
                                        <field name="rw" optional="hide" />
                                        <field name="street" optional="show" />
                                        <field name="street2" optional="hide" />
                                        <field name="zip" optional="show" />
                                        <field name="address_type_id" optional="show" />
                                        <field name="sub_district_id" optional="hide" />
                                        <field name="district_id" optional="hide" />
                                        <field name="city_id" optional="hide" />
                                        <field name="state_id" string="Provinsi" optional="show" />
                                        <field name="country_id" optional="hide" />
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <group name="address_type">
                                                    <field name="address_type_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                                                    <field name="name" required="1"/>
                                                    <field name="address_type" invisible="1"/>
                                                    <field name="is_same_ktp" invisible="address_type == 'ktp'"/>
                                                </group>
                                                <group name="address_info">
                                                    <field name="street" placeholder="Street..." required="address_type_id"/>
                                                    <field name="street2" placeholder="Street 2..."/>
                                                    <label for="rt" string="RT/RW"/>
                                                    <div>
                                                        <field name="rt" placeholder="001" class="o_address_city" />
                                                        <field name="rw" placeholder="002" class="o_address_city" />
                                                    </div>
                                                    <field name="state_id" options="{'no_open': True, 'no_create': True}" required="address_type_id"/>
                                                    <field name="city_id" options="{'no_open': True, 'no_create': True}" required="address_type_id"/>
                                                    <field name="district_id" options="{'no_open': True, 'no_create': True}" required="address_type_id"/>
                                                    <field name="sub_district_id" options="{'no_open': True, 'no_create': True}" required="address_type_id"/>
                                                    <field name="zip"/>
                                                    <field name="country_id" readonly="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page name="lead_documents" string="Document">
                                <field name="document_ids" readonly="state not in ('open','dealt')">
                                    <list string="Documents" editable="bottom">
                                        <field name="name" />
                                        <field name="document_type_id" required="1" />
                                        <field name="lead_id" optional="hide" />
                                        <field name="document_filename" />
                                        <field name="document_file" required="1" widget="binary" filename="document_filename"/>
                                        <field name="document_show" />
                                        <field name="upload_date" />
                                    </list>
                                </field>
                            </page>
                            <page name="other_information" string="Other Information">
                                <group name="credit_documents" string="Credit Proposal Docs" invisible="payment_type == 'Cash'">
                                    <field name="finco_po" readonly="state != 'open'"/>
                                    <field name="finco_pic" readonly="state != 'open'"/>
                                    <field name="finco_identify" readonly="state != 'open'"/>
                                    <field name="finco_po_create" readonly="state != 'open'"/>
                                    <field name="finco_po_sent" readonly="state != 'open'"/>
                                </group>
                                <group name="social_media" string="Social Media">
                                    <field name="facebook" readonly="state != 'open'"/>
                                    <field name="youtube" readonly="state != 'open'"/>
                                    <field name="tiktok" readonly="state != 'open'"/>
                                    <field name="instagram" readonly="state != 'open'"/>
                                    <field name="twitter" readonly="state != 'open'"/>
                                </group>
                                <group name="other_info" string="Other Info">
                                </group>
                            </page>
                            <page name="lead_logs" string="Log">
                                <field name="log_ids" readonly="1">
                                    <list string="Log" edit="0" delete="0">
                                        <field name="name" />
                                        <field name="date" />
                                        <field name="lead_id" optional="hide"/>
                                        <field name="category_id" />
                                    </list>
                                </field>
                            </page>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_date" readonly="1"/>
                                        <field name="create_uid" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_date" readonly="1"/>
                                        <field name="write_uid" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter reload_on_post="True"/>
                </form>
            </field>
        </record>

        <record id="view_tw_lead_deal_form" model="ir.ui.view">
            <field name="name">view.tw.lead.deal.form</field>
            <field name="model">tw.lead</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Deal">
                    <header>
                        <h2>Deal Confirmation</h2>
                        <p>Please fill in all required fields</p>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="company_id" invisible="1" />
                                <field name="md_id" invisible="1" />
                                <field name="down_payment" invisible="1" />
                                <label for="birthplace" string="Tempat / Tgl Lahir" />
                                <div class="d-flex justify-content-between">
                                    <field name="birthplace" required="1" />
                                    <span class="m-1">/</span>
                                    <field name="birthdate" required="1" />
                                </div>
                                <field name="identification_number" string="Nomor KTP" required="1" />
                                <field name="identification_family_number" string="Nomor KK" required="1" />
                                <field name="mobile" required="1" />
                                <label for="whatsapp" string="Whatsapp" />
                                <div class="d-flex justify-content-between">
                                    <field name="is_same_with_mobile" required="1" />
                                    <field name="whatsapp" required="1" />
                                </div>
                                <field name="motor_ownership_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="motor_ownership" invisible="1" />
                                <field name="partner_stnk_id" invisible="motor_ownership != 'other' or not motor_ownership" required="motor_ownership == 'other'" context="{
                                            'form_view_ref': 'tw_partner.tw_partner_contact_form_view',
                                            'default_is_customer':1,
                                            'default_company_id': company_id,
                                            'no_create': True,
                                            'no_open': True
                                        }" />

                                <field name="product_category_ids" widget="many2many_tags" invisible="1" />
                                <field name="product_id" required="1" options="{'no_open':True,'no_create':True}" context="{ 'list_view_ref': 'tw_product.tw_product_list_view' }" />
                                <field name="payment_type_id" required="1" options="{'no_open':True,'no_create':True}" />
                                <field name="payment_type" invisible="1" />
                                <field name="finco_id" options="{'no_open':True,'no_create':True}" invisible="payment_type != 'Credit'" required="payment_type == 'Credit'" />
                                <field name="due_date" invisible="payment_type != 'Credit'"/>
                                <field name="price_otr" readonly="1" force_save="1"/>
                                <field name="discount"/>
                                <field name="tenor" style="width : 25%%" invisible="payment_type != 'Credit'" required="payment_type == 'Credit'" />
                                <field name="installment" invisible="payment_type != 'Credit'" required="payment_type == 'Credit'" />
                            </group>
                            <group>
                                <field name="religion_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="blood_type_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="hobby_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="education_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="occupation_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="marital_status_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="housing_tenure_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="unit_operator_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="unit_usage_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="current_motorcycle" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="motor_brand_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="mobile_plan_status_id" required="1" options="{'no_open': True, 'no_create': True}" />
                                <field name="motor_type_id" options="{'no_open': True, 'no_create': True}" />
                            </group>
                            <group>
                                <field name="note" string="Note/Reason" required="1"/>
                            </group>
                        </group>
                        <footer>
                            <button name="action_deal" string="Deal" type="object" class="oe_highlight"/>
                            <button string="Cancel" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_lead_action_window" model="ir.actions.act_window">
            <field name="name">Leads</field>
            <field name="res_model">tw.lead</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_lead_view_filter"/>
            <field name="context">{'default_division': 'Unit', 'default_type': 'lead'}</field>
