        </record>

        <record id="access_tw_faktur_pajak_out_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_out_line"/>
            <field name="name">tw_faktur_pajak_out_line read</field>
            <field name="group_id" ref="group_tw_faktur_pajak_core_tax_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_upload_core_tax_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_upload_core_tax"/>
            <field name="name">tw_upload_core_tax read</field>
            <field name="group_id" ref="group_tw_faktur_pajak_core_tax_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_e_faktur_coretax_pajak_wizard_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_e_faktur_coretax_pajak_wizard"/>
