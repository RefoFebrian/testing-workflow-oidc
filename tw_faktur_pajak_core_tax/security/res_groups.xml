        <record id="group_tw_faktur_pajak_core_tax_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Core Tax Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_faktur_pajak_core_tax_read'))]"/>
        </record>

        <record id="access_tw_faktur_pajak_out_line_delete" model="ir.model.access">
