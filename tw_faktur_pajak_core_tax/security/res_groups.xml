    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_faktur_pajak_core_tax_read')),
                (4, ref('group_tw_faktur_pajak_core_tax_update')),
                (4, ref('group_tw_faktur_pajak_core_tax_delete')),
            ]"/>
        </record>
