<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_tw_report_performance_expedition" model="ir.ui.view">
            <field name="name">Report Performance Expedition</field>
            <field name="model">tw.report.performance.expedition</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report Performance Expedition">
                    <group>
                        <group>
                            <field name="company_id" required="1"/>
                            <label for="start_date" string="Tanggal"/>
                            <div class="o_row">
                                <field name="start_date" widget="date" class="oe_inline" required="1"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                <field name="end_date" widget="date" class="oe_inline" required="1"/>
                            </div>
                        </group>
                        <group>
                            <field name="division" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Export Excel" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_performance_expedition_wizard" model="ir.actions.act_window">
            <field name="name">Laporan Performance Ekspedisi</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.report.performance.expedition</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>