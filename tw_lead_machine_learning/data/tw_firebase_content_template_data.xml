<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="firebase_content_template_reassign_crm_notification" model="tw.firebase.content.template">
            <field name="name">Reassign CRM Notification</field>
            <field name="content" type="html">
                <p>
                    <p>Haloo,<br/> Buku Tamu %no_leads% telah dilakukan Re-Assign Sales Person dari <span style="color: #ff0000;">%sales_sebelum% kepada %sales_sesudah%</span> Karena tidak dilakukan FU dalam 1 hari pada konsumen ini :</p>
                        <table border="0" width="100%" cellspacing="0" cellpadding="0">
                            <tbody>
                                <tr>
                                    <td style="width: 35%;">Nama Customer</td>
                                    <td style="width: 5%;">:</td>
                                    <td style="width: 60%;">%prospek_name% </td>
                                </tr>
                                <tr>
                                    <td style="width: 35%;">No HP</td>
                                    <td style="width: 5%;">:</td>
                                    <td style="width: 60%;">%prospek_mobile%</td>
                                </tr>
                                <tr>
                                    <td style="width: 35%;">Janji Follow up</td>
                                    <td style="width: 5%;">:</td>
                                    <td style="width: 60%;">%prospek_followup_date%</td>
                                </tr>
                                <tr>
                                    <td style="width: 35%;">Folowup By</td>
                                    <td style="width: 5%;">:</td>
                                    <td style="width: 60%;">%prospek_followup_by%</td>
                                </tr>
                                <tr>
                                    <td style="width: 35%;">Minat</td>
                                    <td style="width: 5%;">:</td>
                                    <td style="width: 60%;">%prospek_minat%</td>
                                </tr>
                            </tbody>
                        </table>
                    <p>
                        <br/>
                            %additional_msg%
                        <br/>
                    </p>
                    <br/><br/> Terimakasih, <br/><br/><p>HondaKita</p>
                </p>
            </field>
        </record>
    
    </data>
</odoo>