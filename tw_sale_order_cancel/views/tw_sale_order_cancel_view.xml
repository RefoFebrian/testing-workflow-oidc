<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        
        <!-- Sale Order Cancel Views -->
        
        <record model="ir.ui.view" id="sale_order_cancel_list_view">
            <field name="name">tw.sale.order.cancel.list</field>
            <field name="model">tw.sale.order.cancel</field>
            <field name="arch" type="xml">
                <list string="Sale Order Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="sale_order_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        
        <record id="view_sale_order_cancel_search" model="ir.ui.view">
            <field name="name">tw.sale.order.cancel.search</field>
            <field name="model">tw.sale.order.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Sale Order Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="sale_order_id"/>
                    <field name="division"/>
                    <field name="state"/>
                    <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="Waiting for Approval" name="waiting_for_approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_branch" context="{'group_by':'company_id'}"/>
                        <filter string="Division" name="group_by_division" context="{'group_by':'division'}"/>
                        <filter string="State" name="group_by_state" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <record model="ir.ui.view" id="inherit_sale_order_cancel_form_view">
            <field name="name">tw.sale.order.cancel.form</field>
            <field name="model">tw.sale.order.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_sale_order" type="object"
                            class="oe_stat_button" icon="fa-shopping-cart"
                            invisible="not sale_order_id">
                        <field name="sale_order_id" widget="statinfo" string="Sale Order"/>
                    </button>
                </xpath>
                <!-- Make division readonly when set from context -->
                <field name="division" position="attributes">
                    <attribute name="readonly">context.get('default_division') != False</attribute>
                </field>
                <field name="transaction_name" position="after">
                    <field name="allow_cancel_so_with_payment" invisible="1"/>
                    <field name="paid_sale_order_ids" invisible="1"/>
                    <field name="sale_order_id" required="1" readonly="state != 'draft'"
                           options="{'no_create':True,'no_open':True}"
                           domain="[('company_id','=',company_id),('division','=',division),('state','in',['sale','done']),('id','not in',paid_sale_order_ids)]"/>
                </field>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_sale_order_cancel.group_tw_sale_order_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_sale_order_cancel.group_tw_sale_order_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_sale_order_cancel.group_tw_sale_order_cancel_approval_confirm</attribute>
                </xpath>
            </field>
        </record>
        
        <!-- ============================================================ -->
        <!-- Action for Unit (Showroom) -->
        <!-- ============================================================ -->
        
        <record model="ir.actions.act_window" id="sale_order_cancel_unit_action">
            <field name="name">Sale Order Cancel</field>
            <field name="res_model">tw.sale.order.cancel</field>
            <field name="search_view_id" ref="view_sale_order_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('tw_sale.model_tw_sale_order'),
            'default_model_type': 'tw.sale.order',
            'default_division': 'Unit',
            'search_default_division': 'Unit',
            }
            "/>
            <field name="domain">[('division','=','Unit')]</field>
        </record>
        
        <record id="sale_order_cancel_unit_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="sale_order_cancel_list_view"/>
            <field name="act_window_id" ref="sale_order_cancel_unit_action"/>
        </record>
        
        <record id="sale_order_cancel_unit_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_sale_order_cancel_form_view"/>
            <field name="act_window_id" ref="sale_order_cancel_unit_action"/>
        </record>
        
        <!-- ============================================================ -->
        <!-- Action for Sparepart (Workshop) -->
        <!-- ============================================================ -->
        
        <record model="ir.actions.act_window" id="sale_order_cancel_sparepart_action">
            <field name="name">Sale Order Cancel</field>
            <field name="res_model">tw.sale.order.cancel</field>
            <field name="search_view_id" ref="view_sale_order_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('tw_sale.model_tw_sale_order'),
            'default_model_type': 'tw.sale.order',
            'default_division': 'Sparepart',
            'search_default_division': 'Sparepart',
            }
            "/>
            <field name="domain">[('division','=','Sparepart')]</field>
        </record>
        
        <record id="sale_order_cancel_sparepart_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="sale_order_cancel_list_view"/>
            <field name="act_window_id" ref="sale_order_cancel_sparepart_action"/>
        </record>
        
        <record id="sale_order_cancel_sparepart_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_sale_order_cancel_form_view"/>
            <field name="act_window_id" ref="sale_order_cancel_sparepart_action"/>
        </record>
        
	</data>
</odoo>