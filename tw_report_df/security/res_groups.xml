<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_report_control_df_read" model="res.groups">
            <field name="name">Tw Laporan Control DF Read</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>

        <record id="access_tw_report_control_df_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_control_df"/>
            <field name="name">tw.report_control_df read</field>
            <field name="group_id" ref="group_tw_report_control_df_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_report_control_df_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Control DF update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_report_control_df_read'))]"/>
        </record>

        <record id="access_tw_report_control_df_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_control_df"/>
            <field name="name">tw.report_control_df update</field>
            <field name="group_id" ref="group_tw_report_control_df_update"/>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="group_tw_report_control_df_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Control DF delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_report_control_df_read'))]"/>
        </record>

        <record id="access_tw_report_control_df_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_control_df"/>
            <field name="name">tw.report_control_df delete</field>
            <field name="group_id" ref="group_tw_report_control_df_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_report_control_df_read')),
                (4, ref('group_tw_report_control_df_update')),
                (4, ref('group_tw_report_control_df_delete')),
            ]"/>
        </record>
    </data>

    

</odoo>
