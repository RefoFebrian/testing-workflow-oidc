<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <!-- TW Collecting Voucher Group -->
        <record id="tw_collecting_voucher_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Collecting Voucher Read</field>
        </record>

        <record id="tw_collecting_voucher_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_voucher" />
            <field name="name">tw_collecting_voucher read</field>
            <field name="group_id" ref="tw_collecting_voucher_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_collecting_voucher_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Collecting Voucher Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_collecting_voucher_group_read'))]" />
        </record>

        <record id="tw_collecting_voucher_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_voucher" />
            <field name="name">tw_collecting_voucher update</field>
            <field name="group_id" ref="tw_collecting_voucher_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_collecting_voucher_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Collecting Voucher Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_collecting_voucher_group_read'))]" />
        </record>

        <record id="tw_collecting_voucher_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_collecting_voucher" />
            <field name="name">tw_collecting_voucher delete</field>
            <field name="group_id" ref="tw_collecting_voucher_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids"
                eval="[
                (4,ref('tw_collecting_voucher_group_read')),
                (4,ref('tw_collecting_voucher_group_update')),
                (4,ref('tw_collecting_voucher_group_delete')),
                ]" />
        </record>
    </data>


</odoo>