<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_profit_before_tax_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_profit_before_tax.tw_module_category_profit_before_tax" />
            <field name="name">TW Profit Before Tax RFA</field>
        </record>

        <record id="access_tw_profit_before_tax_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="model_tw_profit_before_tax" />
            <field name="name">access_tw_profit_before_tax rfa</field>
            <field name="group_id" ref="group_tw_profit_before_tax_approval_rfa" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_profit_before_tax_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_profit_before_tax.tw_module_category_profit_before_tax" />
            <field name="name">TW Profit Before Tax Cancel</field>
        </record>

        <record id="access_tw_profit_before_tax_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_profit_before_tax" />
            <field name="name">access_tw_profit_before_tax cancel</field>
            <field name="group_id" ref="group_tw_profit_before_tax_approval_cancel" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_profit_before_tax_approval_rfa')),
                (4, ref('group_tw_profit_before_tax_approval_cancel')),
            ]" />
        </record>
    </data>

</odoo>
