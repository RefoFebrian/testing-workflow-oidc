<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_partner_list_simple" model="ir.ui.view">
            <field name="name">res.partner.list.simple</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list>
                    <field name="complete_name"/>
                    <field name="phone"/>
                    <field name="email"/>
                </list>
            </field>
        </record>

        <record id="view_tw_report_return_pembelian_form" model="ir.ui.view">
            <field name="name">tw.report.return.pembelian.form</field>
            <field name="model">tw.report.return.pembelian</field>
            <field name="arch" type="xml">
                <form string="Laporan Return Pembelian">
                    <group>
                        <group>
                            <field name="division"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <label for="start_date" string="Date"/>
                            <div class="o_row">
                                <field name="start_date"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                <field name="end_date"/>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="Branches">
                            <field name="company_ids"/>
                        </page>
                        <page string="Suppliers/Customer">
                            <field name="partner_ids" context="{'list_view_ref': 'tw_report_payment.view_partner_list_simple', 'list_view_ref': 'tw_report_payment.view_partner_list_simple'}"/>
                        </page>
                    </notebook>

                    <footer>
                        <button name="excel_report" string="Export Excel" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tw_report_return_pembelian" model="ir.actions.act_window">
            <field name="name">Laporan Return Pembelian</field>
            <field name="res_model">tw.report.return.pembelian</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>
