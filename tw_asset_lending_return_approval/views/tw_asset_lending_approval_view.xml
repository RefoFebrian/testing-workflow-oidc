<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>  
    	
		<record id="tw_asset_lending_approval_form_view" model="ir.ui.view">
            <field name="name">tw.asset.lending.approval.form</field>
            <field name="model">tw.asset.lending</field>
            <field name="inherit_id" ref="tw_asset_lending_return.tw_asset_lending_view_form"/>
            <field name="arch" type="xml">

				<field name="state" position="replace">
					<field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,open,partially_returned,done"/>
				</field>

				<button name="action_confirm" position="replace">
					<button name="action_request_approval" invisible="state != 'draft'" string="RFA" type="object" class="oe_highlight" groups="tw_asset_lending_return_approval.group_tw_asset_lending_return_approval_request"/>
					<button name="action_approval" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight" />
					<button name="action_reject_or_cancel" invisible="state != 'waiting_for_approval'" string="Reject" type="object" context="{'window_title': 'Reject'}"/>
					<button name="action_confirm" invisible="state != 'approved'" data-hotkey="q" string="Confirm" type="object" class="oe_highlight" groups="tw_asset_lending_return_approval.group_tw_asset_lending_return_approval_confirm"/>
					<button name="action_print_asset_lending" string="Print" type="object" invisible="state not in ('waiting_for_approval', 'approved')" groups="tw_asset_lending_return.tw_rent_aset_group_read"/>
					<button name="action_reject_or_cancel" invisible="state not in ('waiting_for_approval', 'approved')" string="Cancel Approval" type="object" context="{'window_title': 'Cancel'}" groups="tw_asset_lending_return_approval.group_tw_asset_lending_return_approval_cancel"/>
				</button>

				<xpath expr="//page[@name='detail_asset']" position="after">
					<page string="Approval">
						<field name="approval_ids" readonly="True">
						</field>
					</page>
				</xpath>
			</field>
		</record>
		<record id="inherit_tw_asset_lending_search_view" model="ir.ui.view">
			<field name="name">tw.asset.lending.search.inherit</field>
			<field name="model">tw.asset.lending</field>
			<field name="inherit_id" ref="tw_asset_lending_return.tw_asset_lending_search_view"/>
			<field name="arch" type="xml">
				<xpath expr="//search" position="inside">
					<filter name="waiting_for_approval" string="Waiting for Approval" domain="[('state', '=', 'waiting_for_approval')]"/>
					<filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
				</xpath>
			</field>
		</record>
		
 	</data>
</odoo>