        <!-- Paper Format -->
        <record id="paperformat_asset_lending_return_print" model="report.paperformat">
            <field name="name">Peminjaman Aset</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">10</field>
            <field name="dpi">90</field>
        </record>

        <!-- Report Action -->
        <record id="action_report_asset_lending_return_print" model="ir.actions.report">
            <field name="name">Print Peminjaman</field>
            <field name="model">tw.asset.lending</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_asset_lending_return_approval.print_lending</field>
            <field name="report_file">tw_asset_lending_return_approval.print_lending</field>
            <field name="print_report_name">'Form Peminjaman Aset - %s' % object.name</field>
            <field name="paperformat_id" ref="paperformat_asset_lending_return_print"/>
        </record>

