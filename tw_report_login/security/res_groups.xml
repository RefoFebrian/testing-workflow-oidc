<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_report_login_read" model="res.groups">
            <field name="name">Tw Laporan Login Read</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>

        <record id="access_tw_report_login_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_login"/>
            <field name="name">tw.report_login read</field>
            <field name="group_id" ref="group_tw_report_login_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_report_login_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Login update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_report_login_read'))]"/>
        </record>

        <record id="access_tw_report_login_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_login"/>
            <field name="name">tw.report_login update</field>
            <field name="group_id" ref="group_tw_report_login_update"/>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="group_tw_report_login_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Login delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_report_login_read'))]"/>
        </record>

        <record id="access_tw_report_login_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_report_login"/>
            <field name="name">tw.report_login delete</field>
            <field name="group_id" ref="group_tw_report_login_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_report_login_read')),
                (4, ref('group_tw_report_login_update')),
                (4, ref('group_tw_report_login_delete')),
            ]"/>
        </record>
    </data>
    

</odoo>
