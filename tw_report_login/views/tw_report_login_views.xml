<odoo>
  <data>
   <record id="tw_report_login_view" model="ir.ui.view">
      <field name="name">Print Laporan Login</field>
      <field name="model">tw.report.login</field>
      <field name="type">form</field>
      <field name="arch" type="xml">
            <form string="Laporan Login">
                <group>
                  <group>
                    <field name="company_id" options="{'no_create': True,'no_open': True}"/>
                  </group>
                  <group>
                    <label for="start_date" string="Date"/>
                    <div>
                      <field name="start_date" class="oe_inline"/> - <field name="end_date" class="oe_inline"/>
                    </div>
                  </group>
                </group>
                <notebook colspan="5">
                <page string="Employee">
              <field name="resource_ids" colspan="4" nolabel="1"/>
                </page>
              </notebook>
                  <footer>
                      <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/> Or
                      <button string="Cancel" class="oe_link" special="cancel" />
                  </footer>
                
            </form>
        </field>
      </record>

      <record id="tw_report_login_action_wizard" model="ir.actions.act_window">
      <field name="name">Laporan Login</field>
      <field name="type">ir.actions.act_window</field>
      <field name="res_model">tw.report.login</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      </record>

      <menuitem name="Laporan Login" id="tw_report_login_menuitem"  parent="tw_menu.submenu_tw_showroom_report" sequence="4"  action="tw_report_login_action_wizard" groups="tw_report_login.group_tw_report_login_read"/>	
  </data>
</odoo>
