        </record> 

        <record id="access_stock_return_picking_line_cancel_delete" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking_line"/>
            <field name="name">stock_return_picking_line cancel delete</field>
            <field name="group_id" ref="group_tw_mutation_order_cancel_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record> 
        
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_mutation_order_cancel_read')),
                (4, ref('group_tw_mutation_order_cancel_update')),
                (4, ref('group_tw_mutation_order_cancel_delete')),
            ]"/>
        </record>
    </data>
</odoo>
