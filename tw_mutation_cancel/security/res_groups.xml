            <field name="perm_write">1</field>
        </record> 

        <record id="access_stock_return_picking_line_cancel_update" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking_line"/>
            <field name="name">stock_return_picking_line cancel update</field>
            <field name="group_id" ref="group_tw_mutation_order_cancel_update"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_mutation_order_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Mutation Order Cancel Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_mutation_order_cancel_read'))]"/>
        </record>
        
        <record id="access_tw_mutation_order_cancel_delete" model="ir.model.access">
            <field name="model_id" ref="tw_mutation_cancel.model_tw_mutation_order_cancel"/>
