<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Mutation Order Cancel -->
        <record id="group_tw_mutation_order_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Mutation Order Cancel Read</field>
        </record>
        
        <record id="access_tw_mutation_order_cancel_read" model="ir.model.access">
            <field name="model_id" ref="tw_mutation_cancel.model_tw_mutation_order_cancel"/>
            <field name="name">tw_mutation_order_cancel read</field>
            <field name="group_id" ref="group_tw_mutation_order_cancel_read"/>
            <field name="perm_read">1</field>
        </record> 

        <record id="access_stock_return_picking_line_cancel_read" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking_line"/>
            <field name="name">stock_return_picking_line cancel read</field>
            <field name="group_id" ref="group_tw_mutation_order_cancel_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_mutation_order_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Mutation Order Cancel Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_mutation_order_cancel_read'))]"/>
        </record>
        
        <record id="access_tw_mutation_order_cancel_update" model="ir.model.access">
            <field name="model_id" ref="tw_mutation_cancel.model_tw_mutation_order_cancel"/>
