<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- TW API Group Read -->

        <record id="tw_api_configuration_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW API Configuration Read</field>
        </record>

        <record id="tw_api_configuration_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_configuration" />
            <field name="name">tw_api_configuration read</field>
            <field name="group_id" ref="tw_api_configuration_group_read" />
            <field name="perm_read">1</field>
        </record>
        <record id="tw_endpoint_configuration_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_endpoint_configuration" />
            <field name="name">tw_endpoint_configuration read</field>
            <field name="group_id" ref="tw_api_configuration_group_read" />
            <field name="perm_read">1</field>
        </record>
        <record id="tw_api_configuration_selection_access_read" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection" />
            <field name="name">tw_api_configuration_selection read</field>
            <field name="group_id" ref="tw_api_configuration_group_read" />
            <field name="perm_read">1</field>
        </record>
        
        <record id="tw_api_configuration_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW API Configuration Update</field>
        </record>

        <record id="tw_api_configuration_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_configuration" />
            <field name="name">tw_api_configuration update</field>
            <field name="group_id" ref="tw_api_configuration_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="tw_endpoint_configuration_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_endpoint_configuration" />
            <field name="name">tw_endpoint_configuration update</field>
            <field name="group_id" ref="tw_api_configuration_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_api_configuration_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW API Configuration Delete</field>
        </record>

        <record id="tw_api_configuration_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_configuration" />
            <field name="name">tw_api_configuration delete</field>
            <field name="group_id" ref="tw_api_configuration_group_delete" />
            <field name="perm_unlink">1</field>
        </record>
        <record id="tw_endpoint_configuration_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_endpoint_configuration" />
            <field name="name">tw_endpoint_configuration delete</field>
            <field name="group_id" ref="tw_api_configuration_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        
        <!-- Api LOG -->

        <record id="group_tw_api_log_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW API Log Read</field>
        </record> 
        
        <record id="access_tw_api_log_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_log"/>
            <field name="name">tw_api_log read</field> 
            <field name="group_id" ref="group_tw_api_log_read"/>  
            <field name="perm_read">1</field> 
        </record> 
        <record id="access_tw_api_log_selection_read" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection"/>
            <field name="name">tw_api_log_selection read</field> 
            <field name="group_id" ref="group_tw_api_log_read"/>  
            <field name="perm_read">1</field> 
        </record> 
        <record id="access_tw_api_log_detail_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_log_detail"/>
            <field name="name">tw_api_log_detail read</field> 
            <field name="group_id" ref="group_tw_api_log_read"/>  
            <field name="perm_read">1</field> 
        </record> 
        <record id="access_tw_api_log_user_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_users"/>
            <field name="name">tw_api_log_user read</field> 
            <field name="group_id" ref="group_tw_api_log_read"/>  
            <field name="perm_read">1</field> 
        </record> 
        <record id="access_tw_api_log_model_read" model="ir.model.access">
            <field name="model_id" ref="base.model_ir_model"/>
            <field name="name">tw_api_log_model read</field> 
            <field name="group_id" ref="group_tw_api_log_read"/>  
            <field name="perm_read">1</field> 
        </record>
        
        <record id="group_tw_api_log_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW API Log Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_api_log_read'))]"/>                             
        </record>
        
        <record id="access_tw_api_log_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_log"/>
            <field name="name">tw_api_log update</field> 
            <field name="group_id" ref="group_tw_api_log_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      

        <record id="group_tw_api_log_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW API Log Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_api_log_read'))]"/>                             
        </record>
                        
        <record id="access_tw_api_log_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_log"/>
            <field name="name">tw_api_log delete</field> 
            <field name="group_id" ref="group_tw_api_log_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>
        
        <!-- Api Type -->

        <record id="group_tw_api_type_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW API Type Read</field> 
        </record> 
        <record id="access_tw_api_type_selection_read" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection"/>
            <field name="name">tw_api_type_selection read</field> 
            <field name="group_id" ref="group_tw_api_type_read"/>  
            <field name="perm_read">1</field> 
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

    </data>
    
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_api_configuration_group_read')),
                (4,ref('tw_api_configuration_group_update')),
                (4,ref('tw_api_configuration_group_delete')),
                (4,ref('group_tw_api_log_read')),
                (4,ref('group_tw_api_log_update')),
                (4,ref('group_tw_api_log_delete')),
                ]" />
        </record>
    </data>
</odoo>
