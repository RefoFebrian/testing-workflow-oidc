<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">  
        <!-- TW Quality Checking -->
        <record id="group_tw_quality_checking_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Quality Checking Read</field>
        </record> 
        
        <record id="access_tw_quality_checking_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking"/>
            <field name="name">tw_quality_checking read</field>
            <field name="group_id" ref="group_tw_quality_checking_read"/>
            <field name="perm_read">1</field>
        </record> 

        <record id="access_tw_quality_checking_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking_line"/>
            <field name="name">tw_quality_checking_line read</field>
            <field name="group_id" ref="group_tw_quality_checking_read"/>
            <field name="perm_read">1</field>
        </record> 
                
        <record id="group_tw_quality_checking_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Quality Checking Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_quality_checking_read'))]"/>
        </record>
                        
        <record id="access_tw_quality_checking_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking"/>
            <field name="name">tw_quality_checking update</field>
            <field name="group_id" ref="group_tw_quality_checking_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>  
            
        <record id="access_tw_quality_checking_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking_line"/>
            <field name="name">tw_quality_checking_line update</field>
            <field name="group_id" ref="group_tw_quality_checking_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>      

        <record id="group_tw_quality_checking_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Quality Checking Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_quality_checking_read'))]"/>
        </record>
                        
        <record id="access_tw_quality_checking_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking"/>
            <field name="name">tw_quality_checking delete</field>
            <field name="group_id" ref="group_tw_quality_checking_delete"/>
            <field name="perm_unlink">1</field>
        </record>
        
        <record id="access_tw_quality_checking_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_quality_checking_line"/>
            <field name="name">tw_quality_checking_line delete</field>
            <field name="group_id" ref="group_tw_quality_checking_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <!-- TW Master Cardboard Dimensions -->
        <record id="group_tw_cardboard_dimensions_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Cardboard Dimensions Read</field>
        </record> 

        <record id="access_tw_cardboard_dimensions_read" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection"/>
            <field name="name">tw_cardboard_dimensions read</field>
            <field name="group_id" ref="group_tw_cardboard_dimensions_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_cardboard_dimensions_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Cardboard Dimensions Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cardboard_dimensions_read'))]"/>
        </record>

        <record id="access_tw_cardboard_dimensions_update" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection"/>
            <field name="name">tw_cardboard_dimensions update</field>
            <field name="group_id" ref="group_tw_cardboard_dimensions_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_cardboard_dimensions_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Cardboard Dimensions Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_cardboard_dimensions_read'))]"/>
        </record>

        <record id="access_tw_cardboard_dimensions_delete" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection"/>
            <field name="name">tw_cardboard_dimensions delete</field>
            <field name="group_id" ref="group_tw_cardboard_dimensions_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_quality_checking_read')),
                (4,ref('group_tw_quality_checking_update')),
                (4,ref('group_tw_quality_checking_delete')),
                (4,ref('group_tw_cardboard_dimensions_read')),
                (4,ref('group_tw_cardboard_dimensions_update')),
                (4,ref('group_tw_cardboard_dimensions_delete')),
            ]" />
        </record>
    </data>
</odoo>