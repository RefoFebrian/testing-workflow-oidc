<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="cartoon_pdf_report">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <!-- Header -->
                            <div class="row">
                                <div class="col-12 text-center">
                                    <h2><strong>CARTOON</strong></h2>
                                </div>
                            </div>

                            <!-- Info Header -->
                            <div class="row mt-4">
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td width="40%"><strong>No. Transaksi</strong></td>
                                            <td width="5%">:</td>
                                            <td><span t-field="o.name"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Branch</strong></td>
                                            <td>:</td>
                                            <td><span t-field="o.company_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Stock Picking</strong></td>
                                            <td>:</td>
                                            <td>
                                                <t t-foreach="o.stockcard_ids" t-as="picking">
                                                    <span t-esc="picking.name"/>
                                                    <t t-if="not picking_last">, </t>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Jumlah Cetak</strong></td>
                                            <td>:</td>
                                            <td><span t-field="o.print_counter"/></td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-6">
                                    <table class="table table-sm table-borderless">
                                        <tr>
                                            <td width="40%"><strong>Tanggal</strong></td>
                                            <td width="5%">:</td>
                                            <td><span t-field="o.date" t-options="{'widget': 'date'}"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Dimensi Kardus</strong></td>
                                            <td>:</td>
                                            <td><span t-field="o.cardboard_id.name"/></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Berat Kardus</strong></td>
                                            <td>:</td>
                                            <td><span t-field="o.weight_box"/> Kg</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Jumlah Kardus</strong></td>
                                            <td>:</td>
                                            <td><span t-field="o.number_of_boxes"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Detail Table -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h5><strong>Detail Sparepart</strong></h5>
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr style="background-color: #f5f5f5;">
                                                <th class="text-center" width="5%">No</th>
                                                <th>Source Document</th>
                                                <th>Kode Produk</th>
                                                <th class="text-center" width="10%">Qty</th>
                                                <th class="text-center" width="10%">Qty Supply</th>
                                                <th class="text-end" width="12%">Berat (gram)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-set="no" t-value="0"/>
                                            <t t-set="total_qty" t-value="0"/>
                                            <t t-set="total_qty_supply" t-value="0"/>
                                            <t t-set="total_weight" t-value="0"/>
                                            <t t-foreach="o.quality_checking_ids" t-as="line">
                                                <t t-set="no" t-value="no + 1"/>
                                                <t t-set="total_qty" t-value="total_qty + line.quantity"/>
                                                <t t-set="total_qty_supply" t-value="total_qty_supply + line.qty_supply"/>
                                                <t t-set="total_weight" t-value="total_weight + line.weight"/>
                                                <tr>
                                                    <td class="text-center"><t t-esc="no"/></td>
                                                    <td><span t-field="line.picking_id.name"/></td>
                                                    <td><span t-field="line.product_id.default_code"/> - <span t-field="line.product_id.name"/></td>
                                                    <td class="text-center"><span t-field="line.quantity"/></td>
                                                    <td class="text-center"><span t-field="line.qty_supply"/></td>
                                                    <td class="text-end"><span t-field="line.weight" t-options="{'widget': 'float', 'precision': 2}"/></td>
                                                </tr>
                                            </t>
                                        </tbody>
                                        <tfoot>
                                            <tr style="background-color: #f5f5f5; font-weight: bold;">
                                                <td colspan="3" class="text-end"><strong>Total</strong></td>
                                                <td class="text-center"><t t-esc="total_qty"/></td>
                                                <td class="text-center"><t t-esc="total_qty_supply"/></td>
                                                <td class="text-end"><t t-esc="'%.2f' % total_weight"/></td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>

                            <!-- Footer Signature -->
                            <div class="row mt-5">
                                <div class="col-4 text-center">
                                    <p>Dibuat oleh,</p>
                                    <br/><br/><br/>
                                    <p>____________________</p>
                                    <p><span t-field="o.create_uid.name"/></p>
                                </div>
                                <div class="col-4 text-center">
                                    <p>Diperiksa oleh,</p>
                                    <br/><br/><br/>
                                    <p>____________________</p>
                                </div>
                                <div class="col-4 text-center">
                                    <p>Disetujui oleh,</p>
                                    <br/><br/><br/>
                                    <p>____________________</p>
                                </div>
                            </div>

                            <!-- Print Info -->
                            <div class="row mt-4">
                                <div class="col-12 text-end" style="font-size: 10px; color: #888;">
                                    <p>Dicetak pada: &#160;<span t-esc="time_date(o.date)"/> oleh <span t-esc="print_user()"/></p>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
