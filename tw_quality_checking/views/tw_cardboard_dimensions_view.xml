<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_cardboard_dimensions_list" model="ir.ui.view">
            <field name="name">tw.cardboard.dimensions.list</field>
            <field name="model">tw.selection</field>
            <field name="arch" type="xml">
                <list string="Master Dimensi Kardus" create="1" delete="0" editable="top">
                    <field name="name" required="1"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="action_tw_cardboard_dimensions" model="ir.actions.act_window">
            <field name="name">Master Dimensi Kardus</field>
            <field name="res_model">tw.selection</field>
            <field name="view_mode">list</field>
            <field name="domain">[('type','=','CardboardDimensions')]</field>
            <field name="context">{'default_type': 'CardboardDimensions'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Tidak ada Master Dimensi Kardus ditemukan. Mari buat baru!
                </p>
            </field>
        </record>

        <record id="tw_cardboard_dimensions_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tw_cardboard_dimensions_list"/>
            <field name="act_window_id" ref="action_tw_cardboard_dimensions"/>
        </record>
    </data>
</odoo>