<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <!-- Wizard View -->
        <record id="tw_import_bank_mutasi_wizard_view" model="ir.ui.view">
            <field name="name">tw.import.bank.mutasi.wizard</field>
            <field name="model">tw.import.bank.mutasi</field>
            <field name="arch" type="xml">
                <form>
                	<sheet>
                        <group>
                            <field name="company_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="format" required="1" readonly="format == 'update'"/>
                            <field name="data_file" required="1"/>
                            <label for="action_download_format_file" string="Contoh File" style="font-weight: bold"/>
                            <div>
                                <button name="action_download_format_file" type="object" class="btn btn-outline-secondary btn-sm">
                                    <i class="fa fa-download me-1" title="Download"/>
                                    Download Template Excel
                                </button>
                            </div>
                            <field name="account_id" invisible="format == 'update'" required="format != 'update'" options="{'no_create': True, 'no_open': True}" domain="[('account_type','in',('asset_cash', 'asset_current')), ('company_ids','=',company_id)]"/>
                            <field name="journal_id" invisible="format == 'update'" options="{'no_create': True, 'no_open': True}"/>
                            <field name="saldo_akhir" invisible="format == 'update'" required="format != 'update'"/>
                        </group>
                        <footer>
                            <button name="action_import" string="Import" type="object" class="oe_highlight"/>
                            or 
                            <button string="Cancel" class="oe_link" special="cancel"/>
                        </footer>
	                </sheet>
	            </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_import_bank_mutasi_action" model="ir.actions.server">
            <field name="name">Import Bank Mutasi</field>
            <field name="model_id" ref="tw_bank_reconcile.model_tw_import_bank_mutasi"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.import.bank.mutasi'].action_import_bank_mutasi_tree()
            </field>
        </record>

        <record id="tw_import_bank_mutasi_update_action" model="ir.actions.server">
            <field name="name">Import Bank Mutasi (Update)</field>
            <field name="model_id" ref="tw_bank_reconcile.model_tw_import_bank_mutasi"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.import.bank.mutasi'].action_import_bank_mutasi_tree('update')
            </field>
        </record>
	     
	</data>
</odoo>