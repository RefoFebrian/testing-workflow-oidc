<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">

		<!-- Reconcile Bank Mutasi Button -->
		<record id="group_tw_bank_mutasi_button_reconcile" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reconcile Bank Mutasi</field>
        </record>
        <record id="access_tw_bank_mutasi_button_reconcile" model="ir.model.access">
            <field name="model_id" ref="model_tw_bank_mutasi"/>
            <field name="name">tw_bank_mutasi_button_reconcile update</field>
            <field name="group_id" ref="group_tw_bank_mutasi_button_reconcile"/>
            <field name="perm_write">1</field>
        </record>
		
        <!-- Confirm Bank Reconcile Button -->
		<record id="group_tw_bank_reconcile_button_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Bank Reconcile</field>
        </record>
        <record id="access_tw_bank_reconcile_button_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_bank_reconcile"/>
            <field name="name">tw_bank_reconcile_button_confirm update</field>
            <field name="group_id" ref="group_tw_bank_reconcile_button_confirm"/>
            <field name="perm_write">1</field>
        </record>

	</data>
    <data>
		<record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_bank_mutasi_button_reconcile')),
                (4,ref('group_tw_bank_reconcile_button_confirm')),
            ]"/>
        </record>
    </data>
</odoo>