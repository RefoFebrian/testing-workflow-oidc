<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <record id="tw_dealer_sale_order_branch_setting_form_view" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.branch.setting.inherit.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_dealer_sale_order.tw_account_settings_dso_inherit_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='dso_journal_cancel']" position="inside">
                    <field name="journal_dealer_sale_order_cancel_id" options="{'no_create': True}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>