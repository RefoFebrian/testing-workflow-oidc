<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_settings_dso_direct_gift_inherit_view" model="ir.ui.view">
            <field name="name">tw.account.settings.dso.direct.gift.inherit.view</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_dealer_sale_order.tw_account_settings_dso_inherit_view" />
            <field name="arch" type="xml">
                <group name="account_discounts" position="after">
                    <group name="journal_direct_gift">
                        <h3 class="o_stat_info" colspan="2" style="margin-top:20px;">
                            <span class="text-success">Program Direct Gift</span>
                        </h3>
                        <field name="journal_dso_direct_gift_md_id" domain="[('type', '=', 'sale')]" options="{'no_quick_create': True}" />
                        <field name="journal_direct_gift_finco_id" domain="[('type', '=', 'sale')]" options="{'no_quick_create': True}" />
                    </group>
                </group>
            </field>
        </record>
    </data>
</odoo>