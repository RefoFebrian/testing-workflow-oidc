<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_report_qr_code_unit_wizard" model="ir.ui.view">
			<field name="name">tw.report.qr.code.unit.wizard</field>
			<field name="model">tw.report.qr.code.unit</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string="Report Generate QR Code">
					<group>
                        <field name="state" required="1"/>
                        <field name="options" required="1"/>
                        <label for="start_date" string="Periode"/>
                        <div>
                            <field name="start_date" required="1" placeholder="Start Date" class="oe_inline" /> - <field name="end_date" required="1" placeholder="End Date" class="oe_inline"/>
                        </div>
                    </group>
	                <footer>
	                    <button name="generate_data" string="Export Report" type="object" class="oe_highlight"/>
	                    <button string="Cancel" special="cancel" class="btn btn-default"/>
	                </footer>
				</form>
			</field>
		</record>

		<record id="action_tw_report_qr_code_unit_wizard" model="ir.actions.act_window">
			<field name="name">Laporan Generate QR Code</field> 
			<field name="res_model">tw.report.qr.code.unit</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="view_tw_report_qr_code_unit_wizard"/>
			<field name="target">new</field>
		</record>
    </data>
</odoo>
