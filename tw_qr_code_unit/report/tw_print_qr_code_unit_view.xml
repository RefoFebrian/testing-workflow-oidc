<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_qr_code_unit" model="report.paperformat">
            <field name="name">Surat Jalan Stock Picking</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="css_margins" eval="True"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <record id="qr_code_unit_report" model="ir.actions.report">
            <field name="name">QR Code Unit</field>
            <field name="model">tw.print.generate.qr.code</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_qr_code_unit.tw_print_qr_code_unit_template</field>
            <field name="print_report_name">'Print_QR_Code_Unit_%s.pdf' % (object.origin)</field>
            <field name="paperformat_id" ref="paperformat_qr_code_unit"/>
        </record>
    </data>
</odoo>