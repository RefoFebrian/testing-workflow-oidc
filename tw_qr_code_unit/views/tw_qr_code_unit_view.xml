<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_qr_code_unit_list_view" model="ir.ui.view">
            <field name="name">tw.qr.code.unit.list</field>
            <field name="model">tw.qr.code.unit</field>
            <field name="arch" type="xml">
                <list string="QR Code Unit" create="0" edit="0" delete="0" duplicate="0">
                    <field name="name" widget="CopyClipboardChar"/>
					<field name="lot_id"/>
					<field name="company_id"/>
					<field name="create_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_qr_code_unit_form_view" model="ir.ui.view">
            <field name="name">tw.qr.code.unit.form</field>
            <field name="model">tw.qr.code.unit</field>
            <field name="arch" type="xml">
                <form string="QR Code Unit" create="0" edit="0" delete="0" duplicate="0">
                    <header>
                        <button name="action_generate_qr_code" string="Generate QR Code" type="object" class="oe_highlight" groups="tw_qr_code_unit.group_tw_qr_code_unit_button_generate_qr_code"/>
                        <field name="state" widget="statusbar" statusbar_visible="New,Printed,Linked" />
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="lot_id"/>
                            </group>
                            <group>
                                <field name="company_id"/>
                            </group>
                        </group>
                        <notebook>   
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"></field>
                                        <field name="create_date" readonly="1"></field>
                                        <field name="printed_uid" readonly="1"></field>
                                        <field name="printed_date" readonly="1"></field>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>		                 
		                </notebook>	
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_qr_code_unit_search_view" model="ir.ui.view">
            <field name="name">tw.qr.code.unit.search</field>
            <field name="model">tw.qr.code.unit</field>
            <field name="arch" type="xml">
                <search string="Search QR Code Unit">
                    <field name="name"/>
                    <field name="lot_id"/>
                    <filter name="state_new" string="State New" domain="[('state','=','New')]"/>
                    <filter name="state_printed" string="State Printed" domain="[('state','=','Printed')]"/>
                    <filter name="state_linked" string="State Linked" domain="[('state','=','Linked')]"/>
                </search>
            </field>
        </record>

        <record id="tw_qr_code_unit_action" model="ir.actions.act_window">
            <field name="name">QR Code Unit</field>
            <field name="res_model">tw.qr.code.unit</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_state_printed': 1}</field>
        </record>
    </data>
</odoo>