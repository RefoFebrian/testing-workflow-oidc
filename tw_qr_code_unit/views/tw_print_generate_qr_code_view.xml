<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_reprint_generate_qr_code_wizard_view" model="ir.ui.view">
			<field name="name">tw.print.generate.qr.code.wizard</field>
			<field name="model">tw.print.generate.qr.code</field>
			<field name="arch" type="xml">
				<form>
					<group>
						<field name="description" required="1"/>
					</group>
					<footer>
						<button name="action_print_barcode_label" string="Print" type="object" class="oe_highlight"/>
						<button string="Close" class="oe_link" special="cancel" />
					</footer>
				</form>
			</field>
		</record>

        <record id="tw_print_generate_qr_code_list_view" model="ir.ui.view">
            <field name="name">tw.print.generate.qr.code.list</field>
            <field name="model">tw.print.generate.qr.code</field>
            <field name="arch" type="xml">
                <list string="Print Generate QR Code" duplicate="0">
                    <field name="name"/>
					<field name="company_id"/>
                    <field name="date"/>
					<field name="print_count"/>
                    <field name="print_to"/>
                    <field name="description"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_print_generate_qr_code_form_view" model="ir.ui.view">
            <field name="name">tw.print.generate.qr.code.form</field>
            <field name="model">tw.print.generate.qr.code</field>
            <field name="arch" type="xml">
                <form string="Print Generate QR Code" duplicate="0">
                    <header>
                        <button name="action_listing_qr_code" string="Listing QR Code" type="object" class="oe_highlight" invisible="is_generate == True"/>
                        <button name="action_print_barcode_label" string="Print QR Code" type="object" class="oe_highlight" invisible="is_generate == False or state == 'done'"/>
                        <button name="action_reprint_barcode_label" invisible="state != 'done'" string="Re-Print QR Code" type="object" class="oe_highlight"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="name" readonly="1"/>	
                            </h1>
                        </div>
                        <group col="4" colspan="4">
                            <field name="company_id" options="{'no_create': True,'no_open':True}" readonly="1"/>
                            <field name="is_generate" invisible="1"/>
                            <field name="date" readonly="1"/>
                            <field name="print_count" required="1" readonly="state == 'done' or is_generate == True"/>
                            <field name="print_to" readonly="1"/>
                            <field name="description" readonly="1"/>
                        </group>
                        <notebook>   
                            <page string="List QR Code">
                                <field name="qr_code_ids" readonly="state == 'done'">
                                    <list string="Print QR Code" editable="bottom" create="0" edit="0" delete="0">
                                        <field name="name"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"></field>
                                        <field name="create_date" readonly="1"></field>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>		                 
		                </notebook>	
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_print_generate_qr_code_search_view" model="ir.ui.view">
            <field name="name">tw.print.generate.qr.code.search</field>
            <field name="model">tw.print.generate.qr.code</field>
            <field name="arch" type="xml">
                <search string="Search Print Generate QR Code">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="description"/>
					<field name="print_count"/>
					<field name="company_id"/>
                    <filter name="state_draft" string="State Draft" domain="[('state','=','draft')]"/>
                    <filter name="state_done" string="State Done" domain="[('state','=','done')]"/>
                    <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
                    <filter name="group_by_date" string="Group By Date" context="{'group_by':'date'}"/>
                </search>
            </field>
        </record>

        <record id="tw_print_generate_qr_code_action" model="ir.actions.act_window">
            <field name="name">Print Generate QR Code</field>
            <field name="res_model">tw.print.generate.qr.code</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>