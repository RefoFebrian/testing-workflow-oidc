<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_b2b_file_ps_report_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.file.ps.report.form</field>
            <field name="model">tw.b2b.file.ps.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report B2B File PS">
                    <group col="2" colspan="2">
                        <group>
                            <field name="state" required="1"/>
                            <label for="start_date" string="Period"/>
                            <div>
                                <field name="start_date" class="oe_inline" required="1"/>
                                -
                                <field name="end_date" class="oe_inline" required="1"/>
                            </div>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_b2b_file_ps_report_action" model="ir.actions.act_window">
            <field name="name">Laporan B2B File PS</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.b2b.file.ps.report</field>
            <field name="view_id" ref="tw_b2b_file_ps_report_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>