<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- TW Laporan PSL -->
        <record id="tw_b2b_file_psl_report_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW B2B File PSL Report Read</field>
        </record>

        <record id="tw_b2b_file_psl_report_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_b2b_file_psl_report" />
            <field name="name">tw_b2b_file_psl_report read</field>
            <field name="group_id" ref="tw_b2b_file_psl_report_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_b2b_file_psl_report_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW B2B File PSL Report Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_b2b_file_psl_report_group_read'))]" /> 
        </record>

        <record id="tw_b2b_file_psl_report_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_b2b_file_psl_report" />
            <field name="name">tw_b2b_file_psl_report update</field>
            <field name="group_id" ref="tw_b2b_file_psl_report_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
    <!-- TW Laporan PS -->
        <record id="tw_b2b_file_ps_report_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW B2B File PS Report Read</field>
        </record>

        <record id="tw_b2b_file_ps_report_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_b2b_file_ps_report" />
            <field name="name">tw_b2b_file_ps_report read</field>
            <field name="group_id" ref="tw_b2b_file_ps_report_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_b2b_file_ps_report_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW B2B File PS Report Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_b2b_file_ps_report_group_read'))]" /> 
        </record>

        <record id="tw_b2b_file_ps_report_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_b2b_file_ps_report" />
            <field name="name">tw_b2b_file_ps_report update</field>
            <field name="group_id" ref="tw_b2b_file_ps_report_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_b2b_file_psl_report_group_read')),
   	            (4,ref('tw_b2b_file_psl_report_group_update')),
                (4,ref('tw_b2b_file_ps_report_group_read')),
                (4,ref('tw_b2b_file_ps_report_group_update'))     
            ]" />
        </record>
    </data>
</odoo>