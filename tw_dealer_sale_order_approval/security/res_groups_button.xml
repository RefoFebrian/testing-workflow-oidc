<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_dealer_sale_order_rfa" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order" />
            <field name="name">TW Button Request Approval Dealer Sales Order</field>
        </record>
        <record id="access_tw_dealer_sale_order_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_dealer_sale_order.model_tw_dealer_sale_order"/>
            <field name="name">tw_dealer_sale_order_rfa</field>
            <field name="group_id" ref="group_tw_dealer_sale_order_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_dealer_sale_order_cancel_button" model="res.groups">
            <field name="name">TW Button Cancel Dealer Sales Order</field>
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
        </record>
        <record id="access_tw_dealer_sale_order_cancel_button" model="ir.model.access">
                <field name="model_id" ref="tw_dealer_sale_order.model_tw_dealer_sale_order"/>
                <field name="name">tw_dealer_sale_order_cancel_button update</field>
                <field name="group_id" ref="group_tw_dealer_sale_order_cancel_button"/>
                <field name="perm_write">1</field>
        </record>

        
        <record id="group_tw_dealer_sale_order_reject_button" model="res.groups">
            <field name="name">TW Button Reject Dealer Sales Order</field>
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
        </record>
        <record id="access_tw_dealer_sale_order_reject_button" model="ir.model.access">
                <field name="model_id" ref="tw_dealer_sale_order.model_tw_dealer_sale_order"/>
                <field name="name">tw_dealer_sale_order_reject_button update</field>
                <field name="group_id" ref="group_tw_dealer_sale_order_reject_button"/>
                <field name="perm_write">1</field>
        </record>


        <record id="group_tw_dealer_sale_order_approve_button" model="res.groups">
            <field name="name">TW Button Approve Dealer Sales Order</field>
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
        </record>
        <record id="access_tw_dealer_sale_order_approve_button" model="ir.model.access">
                <field name="model_id" ref="tw_dealer_sale_order.model_tw_dealer_sale_order"/>
                <field name="name">tw_dealer_sale_order_cancel_button update</field>
                <field name="group_id" ref="group_tw_dealer_sale_order_cancel_button"/>
                <field name="perm_write">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_dealer_sale_order_rfa')),
                (4, ref('group_tw_dealer_sale_order_cancel_button')),
                (4, ref('group_tw_dealer_sale_order_reject_button')),
                (4, ref('group_tw_dealer_sale_order_approve_button')),
            ]" />
        </record>
    </data>

</odoo>
