<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">    
        <record id="tw_branch_setting_rules" model="ir.rule">
            <field name="name">tw.branch.setting rule</field>
            <field name="model_id" ref="model_tw_branch_setting"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        <record id="tw_branch_setting_rules_admin" model="ir.rule">
            <field name="name">tw.branch.setting rule admin</field>
            <field name="model_id" ref="model_tw_branch_setting"/>
            <field name="groups" eval="[Command.set([ref('base.group_erp_manager')])]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
 	</data>
 </odoo>