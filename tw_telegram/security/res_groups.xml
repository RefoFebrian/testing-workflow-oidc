<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Telegram Configuration -->
        <record id="group_tw_telegram_configuration_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Telegram Configuration Read</field>
        </record>

        <record id="access_tw_telegram_configuration_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_telegram_configuration"/>
            <field name="name">tw_telegram_configuration read</field>
            <field name="group_id" ref="group_tw_telegram_configuration_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_telegram_configuration_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Telegram Configuration Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_telegram_configuration_read'))]"/>
        </record>

        <record id="access_tw_telegram_configuration_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_telegram_configuration"/>
            <field name="name">tw_telegram_configuration update</field>
            <field name="group_id" ref="group_tw_telegram_configuration_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_telegram_configuration_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Telegram Configuration Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_telegram_configuration_read'))]"/>
        </record>

        <record id="access_tw_telegram_configuration_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_telegram_configuration"/>
            <field name="name">tw_telegram_configuration delete</field>
            <field name="group_id" ref="group_tw_telegram_configuration_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
               	(4, ref('group_tw_telegram_configuration_read')),
                (4, ref('group_tw_telegram_configuration_update')),
                (4, ref('group_tw_telegram_configuration_delete')),
				]"/>
        </record>
    </data>
</odoo>