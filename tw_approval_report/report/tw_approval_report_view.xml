<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_approval_matrix_report_view_form" model="ir.ui.view">
            <field name="name">tw.approval.matrix.report.form</field>
            <field name="model">tw.approval.matrix.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Laporan Matrix Approval">
                    <group>
                        <field name="matrix_type" required="1" />
                        <field name="report_type" required="1" />
                        <field name="approval_config_ids" string="Config"
                            invisible="matrix_type != 'biaya'"
                            required="matrix_type == 'biaya'"
                            options="{'no_create': True, 'no_open': True}" widget="many2many_tags" />
                        <field name="product_template_ids" string="Product"
                            invisible="matrix_type != 'discount'"
                            required="matrix_type == 'discount'"
                            options="{'no_create': True, 'no_open': True}" widget="many2many_tags" />
                    </group>
                    <notebook colspan="5">
                        <page string="Dealer">
                            <field name="company_ids" colspan="4" nolabel="1"
                                options="{'no_create': True, 'no_open': True}">
                                <list editable="bottom">
                                    <field name="code" />
                                    <field name="name" string="Dealer" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="excel_report" string="Export Report" type="object"
                            class="oe_highlight" />
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="tw_approval_matrix_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Matrix Approval</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.approval.matrix.report</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_approval_matrix_report_view_form" />
            <field name="target">new</field>
        </record>

    </data>
</odoo>