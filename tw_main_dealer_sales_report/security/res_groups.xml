<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_main_dealer_sales_report_read" model="res.groups">
	    	<field name="category_id" ref="tw_base.tw_role"/>
	      	<field name="name">TW Laporan Main Dealer Sales Read</field>
		</record>

		<record id="access_tw_main_dealer_sales_report_read" model="ir.model.access">
    		<field name="model_id" ref="model_tw_main_dealer_sales_report"/>
      		<field name="name">tw_main_dealer_sales_report read</field> 
      		<field name="group_id" ref="group_tw_main_dealer_sales_report_read"/>  
      		<field name="perm_read">1</field> 
		</record>
    
        <record id="group_tw_main_dealer_sales_report_update" model="res.groups">
	    	<field name="category_id" ref="tw_base.tw_role"/>
	      	<field name="name">TW Laporan Main Dealer Sales Update</field>
		</record>

		<record id="access_tw_main_dealer_sales_report_update" model="ir.model.access">
    		<field name="model_id" ref="model_tw_main_dealer_sales_report"/>
      		<field name="name">tw_main_dealer_sales_report update</field> 
      		<field name="group_id" ref="group_tw_main_dealer_sales_report_update"/>  
      		<field name="perm_create">1</field> 
      		<field name="perm_write">1</field> 
		</record>

        <!-- SYSTEM ADMIN -->
	 	<record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_main_dealer_sales_report_read')),
				(4,ref('group_tw_main_dealer_sales_report_update')),
			]"/> 
		</record>
    </data>
    

</odoo>
