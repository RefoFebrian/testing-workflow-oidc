<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_stock_lot_account_form_view" model="ir.ui.view">
            <field name="name">tw.stock.lot.account.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock_account.view_production_lot_form_stock_account" />
            <field name="arch" type="xml">
                <field name="standard_price" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <field name="avg_cost" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>
                <field name="standard_price" position="attributes">
                    <attribute name="invisible">1</attribute>
                </field>
                <field name="company_currency_id" position="before">
                    <field name="factur_number" readonly="1"/>
                    <field name="supplier_invoice_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="stnk_invoice_price" widget="monetary" options="{'currency_field': 'company_currency_id'}" readonly="1"/>
                </field>
                <field name="company_currency_id" position="after">
                    <field name="stock_valuation" invisible="1"/>
                    <field name="cogs" widget="monetary" options="{'currency_field': 'company_currency_id'}" readonly="1"/>
                    <field name="initial_cogs" widget="monetary" options="{'currency_field': 'company_currency_id'}" readonly="1"/>
                </field>
                <field name="total_value" position="attributes">
                    <attribute name="string">Current Total Value</attribute>
                </field>
            </field>
        </record>
    </data>
</odoo>