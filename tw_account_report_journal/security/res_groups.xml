<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Account Report Journal -->
        <record id="group_account_laporan_journal" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Journal</field>
        </record>

        <record id="access_account_laporan_journal" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_report_journal"/>
            <field name="name">tw.account.laporan.journal access</field>
            <field name="group_id" ref="group_account_laporan_journal"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_account_report_journal_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_report_journal"/>
            <field name="name">tw.account.report.journal read access</field>
            <field name="group_id" ref="group_account_laporan_journal"/>
            <field name="perm_read">1</field>
        </record>
    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_account_laporan_journal')),
            ]"/>
        </record>
    </data>
</odoo>
