<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <!-- Wizard View -->
        <record id="tw_upload_sp_digital_wizard_view" model="ir.ui.view">
            <field name="name">tw.upload.sp.digital.wizard</field>
            <field name="model">tw.upload.sp.digital</field>
            <field name="arch" type="xml">
                <form>
                	<sheet>
						<group colspan="4" col="4" invisible="state_x == 'get'">
                            <group colspan="2">
								<field name="file" filename="filename" string="Upload File"/>
                            </group>
                            <group colspan="2">
                                <label for="action_download_format_file" string="Contoh File"/>
                                <div>                   
                                    <button name="action_download_format_file" type="object" class="oe_highlight" icon="fa-download" string="Download Contoh"/>
                                </div>
                            </group>
                        </group>
		                <field invisible="1" name="state_x"/>
		                <newline/>    
		                <group col="4" fill="0" invisible="state_x != 'get'">
		                    <separator colspan="4" string="Generate SP Digital Master Success ..." invisible="state_x == 'choose'"/>
		                </group>
		                <footer>
		                    <button name="action_import" invisible="state_x == 'get'" required="1" string="Import" type="object" class="oe_highlight"/>
		                    <button string="Cancel" invisible="state_x == 'get'" class="oe_link" special="cancel" />
		                </footer>
	                </sheet>
	            </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_upload_sp_digital_action" model="ir.actions.server">
            <field name="name">Upload SP Digital</field>
            <field name="model_id" ref="tw_sp_digital.model_tw_upload_sp_digital"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.upload.sp.digital'].action_upload_sp_digital_tree()
            </field>
        </record>
        
        <record id="tw_upload_sp_digital_target_action" model="ir.actions.server">
            <field name="name">Upload SP Digital Master</field>
            <field name="model_id" ref="tw_sp_digital.model_tw_upload_sp_digital"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.upload.sp.digital'].action_upload_sp_digital_tree('target')
            </field>
        </record>
	     
	</data>
</odoo>