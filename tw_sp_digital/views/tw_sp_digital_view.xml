<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_sp_digital_list_view" model="ir.ui.view">
            <field name="name">tw.sp.digital.list</field>
            <field name="model">tw.sp.digital</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Sp Digital" create="0" edit="0">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="employee_id"/>
                    <field name="sp_level"/>
                    <field name="date"/>
                    <field name="state" widget="badge"/>
                    <field name="total_approval" widget="progressbar" invisible="state != 'rfa'"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_sp_digital_form_view" model="ir.ui.view">
            <field name="name">tw.sp.digital.form</field>
            <field name="model">tw.sp.digital</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Sp Digital" create="0" edit="0">
                    <header>
                        <button name="action_rfa" string="Request Deviasi" invisible="state != 'open'" class="oe_highlight" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_rfa"/>
                        <button name="action_approve" string="Approve" invisible="state != 'rfa'" class="oe_highlight" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_approve"/>
                        <button name="action_reject" string="Reject" invisible="state != 'rfa'" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_reject"/>
                        <button name="action_confirm" string="Confirm SP" invisible="state != 'open'" class="oe_highlight" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_confirm"/>
                        <button name="action_received" string="Konfirmasi terima SP" invisible="state != 'confirmed'" class="oe_highlight" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_done"/>
                        <button name="action_sp_digital_save_document_file" string="Perbaharui Dokumen SP" type="object"/>
                        <button name="action_send_to_draft" string="Send to draft" invisible="state not in ('open', 'rfa', 'deviasi')" class="oe_highlight" type="object" groups="tw_sp_digital.group_tw_sp_digital_button_draft"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,open,rfa,deviasi,confirmed,done"/>
					</header>
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="name" readonly="1" invisible="create_date == False"/>
                            </h1>
                            <field name="total_approval" widget="percentpie" readonly="1" invisible="state != 'rfa'"/>
                            <h4 colspan="4" invisible="alasan_reject == False">
                                <p>Alasan Reject Deviasi : </p>
                            </h4>
                            <field name="alasan_reject" nolabel="1" readonly="1" style="color:red;" invisible="alasan_reject == False"/>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" readonly="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="employee_id" required="1" readonly="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="job_title" readonly="1"/>
                                <field name="sp_level" required="1" readonly="1"/>
                                <field name="amount_denda" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1" force_save="1"/>
                                <field name="month" readonly="1"/>
                                <field name="year" readonly="1"/>
                                <div>
                                    <br/>
                                    <span class="alert alert-info" role="status" modifiers="{}" invisible="state == 'draft'">
                                        Download PDF : 
                                        <button name="action_sp_digital_document" string=" Disini" style="margin-bottom: 3px" class="oe_stat_button" icon="fa-print" type="object"/>
                                    </span>
                                </div>
                                <field name="filename_sp" invisible="1"/>
                                <field name="file_sp" filename="filename_sp" readonly="1" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="line_ids" string="Detail">
                                <field name="line_ids" readonly="1">
                                    <list editable="bottom">
                                        <field name="name" readonly="1"/>
                                        <field name="type" required="1"/>
                                        <field name="sp_level" required="1"/>
                                        <field name="date" readonly="1" force_save="1"/>
                                        <field name="state" invisible="1"/>
                                        <field name="employee_id" invisible="1" force_save="1"/>
                                        <field name="sp_digital_id" invisible="1"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group colspan="4" col="4">
                                                <field name="name" readonly="1"/>
                                                <field name="type" required="1"/>
                                                <field name="sp_level" required="1"/>
                                                <field name="date" readonly="1" force_save="1"/>
                                                <field name="keterangan" readonly="1"/>
                                                <field name="state" invisible="1" force_save="1"/>
                                                <field name="sp_digital_id" invisible="1"/>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page name="approval_ids" string="Approval">
                                <field name="approval_ids" readonly="1">
                                    <list colors="red:state == 'rejected';">
                                        <field name="group_id" readonly="1"/>
                                        <field name="approver_id" readonly="1"/>
                                        <field name="tanggal" readonly="1"/>
                                        <field name="state" readonly="1" widget="badge" decoration-success="state == 'approved'" decoration-info="state == 'open'" decoration-danger="state == 'rejected'"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group> 
                                                <group>
                                                    <field name="group_id" readonly="1"/>
                                                    <field name="approver_id" readonly="1"/>
                                                </group>
                                                <group>
                                                    <field name="tanggal" readonly="1"/>
                                                    <field name="state" readonly="1"/>
                                                    <field name="reason" readonly="1" invisible="reason == False"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                            <page string="Audit Trail" invisible="create_uid == False">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="request_uid" readonly="1" invisible="request_uid == False"/>
                                        <field name="request_date" readonly="1" invisible="request_date == False"/>
                                        <field name="reject_uid" readonly="1" invisible="reject_uid == False"/>
                                        <field name="reject_date" readonly="1" invisible="reject_date == False"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1" invisible="confirm_uid == False"/>
                                        <field name="confirm_date" readonly="1" invisible="confirm_date == False"/>
                                        <field name="done_uid" readonly="1" invisible="done_uid == False"/>
                                        <field name="done_date" readonly="1" invisible="done_date == False"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                        <field name="is_auto_confirm" invisible="1"/>
                        <div class="alert alert-warning" role="status" invisible="is_auto_confirm == False">
                            This SP is auto confirmed due late confirmation
                        </div>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_sp_digital_search_view" model="ir.ui.view">
            <field name="name">tw.sp.digital.search</field>
            <field name="model">tw.sp.digital</field>
            <field name="arch" type="xml">
                <search string="Sp Digital">
                    <field name="employee_id" select="True"/>
                    <field name="company_id" select="True"/>
                    <field name="name" select="True"/>
                    <field name="date" select="True"/>
                    <filter name="request_for_approval_state" string="Request Approval" domain="[('state', '=', 'rfa')]"/>
                    <filter name="this_month" string="This month" domain="[('date','&gt;=',context_today().strftime('%%Y-%%m-01 00:00:00'))]"/>
                    <filter name="active_state" string="Active SP" domain="[('state', 'in', ('confirmed','done')),('date','&gt;=',context_today().strftime('%%Y-%%m-01 00:00:00'))]"/>
                    <filter name="confirmed_state" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="done_state" string="Done" domain="[('state', '=', 'done')]"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="Date" domain="[]" name="group_by_date" context="{'group_by': 'date'}"/>
                        <filter string="Employee" domain="[]" name="group_by_employee_id" context="{'group_by': 'employee_id'}"/>
                        <filter string="SP Level" domain="[]" name="group_by_sp_level" context="{'group_by': 'sp_level'}"/>
                        <filter string="State" domain="[]" name="group_by_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_sp_digital_action" model="ir.actions.server">
            <field name="name">SP Digital</field>
            <field name="model_id" ref="tw_sp_digital.model_tw_sp_digital"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.sp.digital'].action_sp_digital_tree()
            </field>
        </record>
        
    </data>
</odoo>