<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="tw_stock_document_view_list" model="ir.ui.view">
        <field name="name">tw.stock.document.list</field>
        <field name="model">tw.stock.document</field>
        <field name="arch" type="xml">
            <list string="Stock Documents" create="0" edit="0" delete="0">
                <field name="company_id"/>
                <field name="lot_id"/>
                <field name="product_id" optional="show"/>
                <field name="type"/>
                <field name="document_number"/>
                <field name="state" widget="badge" decoration-success="state == 'stock'" decoration-warning="state == 'intransit'" decoration-info="state == 'customer'"/>
                <field name="location_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="tw_stock_document_view_form" model="ir.ui.view">
        <field name="name">tw.stock.document.form</field>
        <field name="model">tw.stock.document</field>
        <field name="arch" type="xml">
            <form string="Stock Document" create="0" edit="0" delete="0">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="stock,intransit,customer"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_view_moves"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-exchange"
                            invisible="move_count == 0">
                            <field name="move_count" widget="statinfo" string="Moves"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Document Information">
                            <field name="lot_id" required="1"/>
                            <field name="product_id"/>
                            <field name="type" required="1"/>
                            <field name="document_number"/>
                        </group>
                        <group string="Location">
                            <field name="company_id" required="1"/>
                            <field name="location_id" domain="[('document_type', '=', 'vehicle_registration' if type == 'stnk' else 'vehicle_ownership')]"/>
                        </group>
                    </group>
                    <group string="Audit Trail" groups="base.group_no_one">
                        <field name="last_update_date"/>
                        <field name="last_update_uid"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="tw_stock_document_view_search" model="ir.ui.view">
        <field name="name">tw.stock.document.search</field>
        <field name="model">tw.stock.document</field>
        <field name="arch" type="xml">
            <search string="Stock Documents">
                <field name="lot_id"/>
                <field name="document_number"/>
                <field name="location_id"/>
                <separator/>
                <filter name="filter_stnk" string="STNK" domain="[('type', '=', 'stnk')]"/>
                <filter name="filter_bpkb" string="BPKB" domain="[('type', '=', 'bpkb')]"/>
                <separator/>
                <filter name="filter_stock" string="Stock" domain="[('state', '=', 'stock')]"/>
                <filter name="filter_intransit" string="In Transit" domain="[('state', '=', 'intransit')]"/>
                <filter name="filter_customer" string="Customer" domain="[('state', '=', 'customer')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="groupby_type" string="Type" context="{'group_by': 'type'}"/>
                    <filter name="groupby_state" string="State" context="{'group_by': 'state'}"/>
                    <filter name="groupby_location" string="Location" context="{'group_by': 'location_id'}"/>
                    <filter name="groupby_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="tw_stock_document_action" model="ir.actions.act_window">
        <field name="name">Stock Documents</field>
        <field name="res_model">tw.stock.document</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="tw_stock_document_view_search"/>
        <field name="context">{'search_default_filter_stock': 1, 'search_default_groupby_type': 1, 'create': False, 'edit': False, 'delete': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No stock documents found
            </p>
            <p>
                Stock documents are created automatically when receiving STNK/BPKB.
            </p>
        </field>
    </record>

</odoo>
