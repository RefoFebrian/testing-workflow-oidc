<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_register_kwitansi_view_list" model="ir.ui.view">
            <field name="name">tw.register.kwitansi.line.list</field>
            <field name="model">tw.register.kwitansi.line</field>
            <field name="priority">2</field>
            <field name="arch" type="xml">
                <list string="Register Kwitansi" create="0" delete="0">
                    <field name="name" />
                    <field name="company_id" />
                    <field name="payment_id" />
                    <field name="state" />
                </list>
            </field>
        </record>

        <record id="tw_register_kwitansi_line_view_search" model="ir.ui.view">
            <field name="name">tw.register.kwitansi.line.search</field>
            <field name="model">tw.register.kwitansi.line</field>
            <field name="arch" type="xml">
                <search string="Search Register Kwitansi">
                    <field name='name' />
                    <field name='company_id' />
                    <field name='payment_id' />

                    <filter name="filter_printed" string="Printed" domain="[('state', '=', 'printed')]" />
                    <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]" />
                    <filter name="filter_draft" string="Open" domain="[('state', '=', 'open')]" />
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_branch" icon="terp-go-month" domain="[]"
                            context="{'group_by':'company_id'}" />
                        <filter name="group_by_state" string="State" context="{'group_by': 'state'}" />
                        <filter name="group_by_payment" string="Payment No." context="{'group_by': 'payment_id'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_register_kwitansi_view_form" model="ir.ui.view">
            <field name="name">tw.register.kwitansi.form</field>
            <field name="model">tw.register.kwitansi.line</field>
            <field name="arch" type="xml">
                <form string="Register Kwitansi" create="0" edit="0" delete="0">
                    <sheet>
                        <!-- <div class="oe_button_box" name="button_box">
                            <button name="action_view_transaction" string="Transaction" icon="fa-pencil-square-o" class="oe_stat_button" type="object" invisible="not transaction_id"/>
                        </div> -->
                        <group col="4">
                            <field name="name" />
                            <field name="company_id" />
                            <field name="payment_id" />
                            <field name="reason" />
                            <field name="state" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.actions.act_window" id="tw_register_kwitansi_action">
            <field name="name">Register Kwitansi</field>
            <field name="res_model">tw.register.kwitansi.line</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>