<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_laporan_kwitansi_wizard_form_view" model="ir.ui.view">
            <field name="name">tw.laporan.kwitansi.wizard.form</field>
            <field name="model">tw.laporan.kwitansi.wizard</field>
            <field name="arch" type="xml">
                <form string="Laporan Kwitansi" create="false" delete="false" edit="false">
                    <group col="4" colspan="4">
						<field name="state" required="1"/>
                        <label for="start_date" string="Date"/> 
                        <div>
                            <field name="start_date" required="1" class="oe_inline"/> - <field name="end_date" required="1" class="oe_inline"/>
                        </div>
                    </group>
                    <notebook colspan="5">
                        <page string="Branches">
							<field name="company_ids" colspan="4" nolabel="1">
								<list>
                                    <field name="name"/>
                                    <field name="partner_id"></field>
                                  
                                </list>
                            </field>
						</page>
                    </notebook>
                    
                    <footer>
                        <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight" close="true"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="action_laporan_kwitansi" model="ir.actions.act_window">
            <field name="name">Laporan Kwitansi</field>
            <field name="res_model">tw.laporan.kwitansi.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_laporan_kwitansi_wizard_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>