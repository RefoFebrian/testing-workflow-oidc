<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Checklist Tool Button -->
        <record id="group_button_rfa_checklist_tool" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Checklist Tool RFA</field>
            <field name="implied_ids" eval="[(4, ref('tw_checklist_tool.group_checklist_tool_read'))]"/>
        </record>
        <record id="group_button_approved_checklist_tool" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Checklist Tool Approve</field>
            <field name="implied_ids" eval="[(4, ref('tw_checklist_tool.group_checklist_tool_read'))]"/>
        </record>
        <record id="group_button_reject_checklist_tool" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Checklist Tool Reject</field>
            <field name="implied_ids" eval="[(4, ref('tw_checklist_tool.group_checklist_tool_read'))]"/>
        </record>

        <!-- Admin Group -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_button_rfa_checklist_tool')),
                (4, ref('group_button_approved_checklist_tool')),
                (4, ref('group_button_reject_checklist_tool')),
            ]"/>
        </record>

    </data>
</odoo>