<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <!-- List View -->
        <record id="registration_document_handover_cancel_list_view" model="ir.ui.view">
            <field name="name">tw.registration.document.handover.cancel.list</field>
            <field name="model">tw.registration.document.handover.cancel</field>
            <field name="arch" type="xml">
                <list string="Cancel Penyerahan STNK">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="document_registration_handover_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_registration_document_handover_cancel_search" model="ir.ui.view">
            <field name="name">tw.registration.document.handover.cancel.search</field>
            <field name="model">tw.registration.document.handover.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Cancel Penyerahan STNK">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="document_registration_handover_id"/>
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="waiting_for_approval" string="Waiting For Approval" domain="[('state','=','waiting_for_approval')]"/>
                    <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                    <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_state" string="Status" context="{'group_by':'state'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by':'date'}"/>
                        <filter name="group_by_company" string="Branch" context="{'group_by':'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form View (Inherited) -->
        <record model="ir.ui.view" id="inherit_registration_document_handover_cancel_form_view">
            <field name="name">tw.registration.document.handover.cancel.form</field>
            <field name="model">tw.registration.document.handover.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <field name="transaction_name" position="after">
                    <field name="document_registration_handover_id" required="1" readonly="state != 'draft'" options="{'no_create':True,'no_open':True}" domain="[('company_id','=',company_id),('state','=','done')]" invisible="context.get('default_model_type') != 'tw.registration.document.handover.cancel'"/>
                </field>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_vehicle_document_handover_cancel.group_tw_registration_document_handover_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_vehicle_document_handover_cancel.group_tw_registration_document_handover_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_vehicle_document_handover_cancel.group_tw_registration_document_handover_cancel_approval_confirm</attribute>
                </xpath>
            </field>
        </record>

        <!-- Action -->
        <record id="registration_document_handover_cancel_unit_action" model="ir.actions.act_window">
            <field name="name">Cancel Penyerahan STNK</field>
            <field name="res_model">tw.registration.document.handover.cancel</field>
            <field name="search_view_id" ref="view_registration_document_handover_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('tw_vehicle_document_handover_cancel.model_tw_registration_document_handover_cancel'),
            'default_model_type': 'tw.registration.document.handover.cancel',
            'default_division': 'Unit',
            'readonly_division': True,
            'search_default_draft': True,
            'search_default_waiting_for_approval': True,
            'search_default_approved':True,
            }
            "/>
            <field name="domain">[('division','=','Unit'),'|',('document_registration_handover_id','!=',False),('model_id.model','=','tw.registration.document.handover.cancel')]</field>
        </record>

        <record id="registration_document_handover_cancel_unit_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="registration_document_handover_cancel_list_view"/>
            <field name="act_window_id" ref="registration_document_handover_cancel_unit_action"/>
        </record>

        <record id="registration_document_handover_cancel_unit_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_registration_document_handover_cancel_form_view"/>
            <field name="act_window_id" ref="registration_document_handover_cancel_unit_action"/>
        </record>
    </data>
</odoo>
