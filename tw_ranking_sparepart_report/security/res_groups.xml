<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Laporan Ranking Sparepart Group -->
        <record id="group_tw_ranking_sparepart_laporan" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Laporan Ranking Sparepart</field>
        </record>
        <record id="access_tw_ranking_sparepart_laporan" model="ir.model.access">
            <field name="model_id" ref="model_tw_ranking_sparepart_report"/>
            <field name="name">tw_ranking_sparepart_laporan</field>
            <field name="group_id" ref="group_tw_ranking_sparepart_laporan"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_ranking_sparepart_laporan')),
            ]"/>
        </record>
    </data>
</odoo>