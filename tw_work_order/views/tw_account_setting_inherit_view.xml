<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Inheritted on other module  -->
    <record id="tw_account_setting_account_journal_wo_pricelist_form_view" model="ir.ui.view">
        <field name="name">tw.account.setting.account.journal.wo.pricelist</field>
        <field name="model">tw.account.setting</field>
        <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='work_order_container']" position="inside">
                <group name="group_work_order">
                    <h3 class="o_stat_info" colspan="2" style="margin-top:0px;">
                        <span class="text-success">Work Order</span>
                    </h3>
                    <field name="wo_reg_journal_id" options="{'no_create': True}"/>
                    <field name="wo_customer_payment_journal_id" options="{'no_create': True}"/>
                </group>
                <group name="work_order_cancel">
                    <h3 class="o_stat_info" colspan="2" style="margin-top:0px;">
                        <span class="text-success">Journal Cancel</span>
                    </h3>
                </group>
            </xpath>
        </field>
    </record>
</odoo>