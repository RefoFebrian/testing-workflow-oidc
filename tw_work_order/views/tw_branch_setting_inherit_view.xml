<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="tw_branch_setting_account_journal_wo_pricelist_form_view" model="ir.ui.view">
        <field name="name">tw.branch.setting.account.journal.wo.pricelist</field>
        <field name="model">tw.branch.setting</field>
        <field name="inherit_id" ref="tw_pricelist_branch.tw_pricelist_branch_setting_inherit_form_view"/>
        <field name="arch" type="xml">
            <field name="pricelist_purchase_sparepart_id" position="after">
                <field name="pricelist_service_id" required="branch_category in ('H23','H123')" options="{'no_quick_create': True}"/>
            </field>
        </field>
    </record>
</odoo>