<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record model="ir.ui.view" id="product_attribute_value_code_form_view">
            <field name="name">tw.stock.lot.form.word_order</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form" />
            <field name="arch" type="xml">
                <xpath expr='//page[@name="description"]' position='after'>
                    <page string="Work Order">
                        <field name="work_order_ids" nolabel="1" colspan="4" readonly="1">
                            <list string="Work Order">
                                <field name="name" />
                                <!-- TODO: Field di bawah ini tidak ada pada stock.lot -->
                                <!-- <field name="date" /> -->
                                <!-- <field name="type" /> -->
                                <!-- <field name="km" /> -->
                                <!-- <field name="plate_number" /> -->
                            </list>
                        </field>
                    </page>
                    <page string="Audit Trail">
                        <group>
                            <group>
                                <field name="create_uid" readonly="1"></field>
                                <field name="create_date" readonly="1"></field>
                            </group>
                            <group>
                                <field name="write_uid" readonly="1"></field>
                                <field name="write_date" readonly="1"></field>
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>


    </data>
</odoo>   