<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="tw_firebase_content_template_view_list" model="ir.ui.view">
            <field name="name">tw.firebase.content.template.list</field>
            <field name="model">tw.firebase.content.template</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Firebase content template">
                    <field name="name" />
                </list>
            </field>
        </record>
        <!-- form view -->
        <record id="tw_firebase_content_template_view_form" model="ir.ui.view">
            <field name="name">tw.firebase.content.template.form</field>
            <field name="model">tw.firebase.content.template</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Firebase content template">
                    <header>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!--button type="object" name="action_view_detail" class="oe_stat_button" icon="fa-pencil-square-o"-->
                                <!--field name="detail_count" widget="statinfo" string="Detail(s)"/-->
                                <!--field name="detail_ids" invisible="1"/-->
                            <!--/button-->
                        </div>
                        <group>
                            <field name="name" />
                            <field name="content" />
                        </group>
                        <notebook>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="tw_firebase_content_template_view_search" model="ir.ui.view">
            <field name="name">tw.firebase.content.template.search</field>
            <field name="model">tw.firebase.content.template</field>
            <field name="arch" type="xml">
                <search string="Firebase content template">

                    <filter string="Name" name="filter_by_name" domain="[('name','=','')]" />
                    <filter string="Content" name="filter_by_content" domain="[('content','=','')]" />
                    <field name="name" select="True"/>
                    <field name="content" select="True"/>
                    <group string="Group By..">
                    </group>
                </search>
            </field>
        </record>
        <!-- action window -->
        <record id="tw_firebase_content_template_action" model="ir.actions.act_window">
            <field name="name">Firebase content template</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.firebase.content.template</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname":1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                Click to add a new Firebase content template
                </p><p>
                Click the Create button to add a new Firebase content template
                </p>
            </field>
        </record>
    </data>
</odoo>