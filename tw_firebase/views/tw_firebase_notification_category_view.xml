<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list view -->
        <record id="tw_firebase_notification_category_view_list" model="ir.ui.view">
            <field name="name">tw.firebase.notification.category.list</field>
            <field name="model">tw.firebase.notification.category</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Firebase notification category">
                    <field name="name" />
                    <field name="title" />
                    <field name="jenis_reminder" />
                    <field name="content_template_id" />
                    <field name="sumber_data" />
                    <field name="max_jam" />
                    <field name="job_id" />
                    <field name="active" />
                </list>
            </field>
        </record>
        <!-- form view -->
        <record id="tw_firebase_notification_category_view_form" model="ir.ui.view">
            <field name="name">tw.firebase.notification.category.form</field>
            <field name="model">tw.firebase.notification.category</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="Firebase notification category">
                    <header>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <!--button type="object" name="action_view_detail" class="oe_stat_button" icon="fa-pencil-square-o"-->
                                <!--field name="detail_count" widget="statinfo" string="Detail(s)"/-->
                                <!--field name="detail_ids" invisible="1"/-->
                            <!--/button-->
                        </div>
                        <group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="title" required="1"/>
                                <field name="content_template_id" required="1"/>
                            </group>
                            <group>
                                <field name="jenis_reminder" required="1"/>
                                <field name="sumber_data" required="1"/>
                                <field name="max_jam"/>
                                <field name="job_id"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- search -->
        <record id="tw_firebase_notification_category_view_search" model="ir.ui.view">
            <field name="name">tw.firebase.notification.category.search</field>
            <field name="model">tw.firebase.notification.category</field>
            <field name="arch" type="xml">
                <search string="Firebase notification category">
                    <filter string="Name" name="filter_by_name" domain="[('name','=','')]"/>
                    <filter string="Jenis reminder" name="filter_by_jenis_reminder" domain="[('jenis_reminder','=','')]"/>
                    <filter string="Sumber data" name="filter_by_sumber_data" domain="[('sumber_data','=','')]" />
                    <filter string="Max hari" name="filter_by_max_jam" domain="[('max_jam','=','')]" />
                    <filter string="Inactive" name="active" domain="[('active','=',False)]" />
                    <field name="sumber_data" select="True"/>
                    <field name="content_template_id" options="{'no_open':True,'no_create':True}"/>
                    <field name="max_jam" select="True"/>
                    <field name="job_id" select="True"/>
                    <field name="name" />
                    <field name="jenis_reminder" />
                    <group string="Group By..">
                        <filter string="Job" domain="[]" name="group_by_job_id" context="{'group_by':'job_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!-- action window -->
        <record id="tw_firebase_notification_category_action" model="ir.actions.act_window">
            <field name="name">Firebase notification category</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.firebase.notification.category</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_fieldname":1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                Click to add a new Firebase notification category
                </p><p>
                Click the Create button to add a new Firebase notification category
                </p>
            </field>
        </record>

        
    </data>
</odoo>