      <record id="firebase_content_template_tomorrow_followup_reminder" model="tw.firebase.content.template">
        <field name="name">Tomorrow Followup Reminder</field>
        <field name="content" type="html">
            <p>
               <p> <b>Hi, %penerima% </b> <br /> Jadwal Follow Up konsumen besok ada %jumlah_followup% :</p>
                  <table border="0" width="100%" cellspacing="0" cellpadding="0">
                    <tbody>
                      <tr>
                        <td style="width: 30%;white-space:nowrap; overflow: hidden; text-overflow: ellipsis;">%customers%</td>
                        <td style="width: 40%;text-align:left">%dates% </td>
                        <td style="width: 30%;text-align:left">%followup_by% </td>
                      </tr>
                    </tbody>
                  </table>
                    <p> <b>Jangan lupa untuk di Follow Up.</b> </p>
                    <br /> <br /> Terimakasih, <br /><br /><p>HondaKita</p>
                </p>
          </field>
      </record>

