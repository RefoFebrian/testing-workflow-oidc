      <record id="firebase_content_template_sp_notification_confirmed_employee_reminder" model="tw.firebase.content.template">
        <field name="name">SP Notification Employee</field>
        <field name="content" type="html">
          <p>
            Kepada Yth. %name%,<br/>
            anda telah mendapatkan surat peringatan (SP %sp_level%).<br/>
            Silahkan konfirmasi lakukan konfirmasi melalui Aplikasi doodool atau Situs Web Tunas Honda.<br/>
            Atas Perhatian anda kami ucapkan terimakasih. Salam Satu Hati.
          </p>
        </field>
      </record>

      <record id="firebase_content_template_notification_approval_pbt" model="tw.firebase.content.template">
        <field name="name">Approval Input Sisa Margin</field>
        <field name="content" type="html">
          <p>
            Kepada Yth. <strong>%name%</strong>,<br/>
            Anda diharapkan untuk melakukan approval dan pengecekan terhadap Sisa Margin yang sudah diupload oleh cabang berikut:<br/>
            %branch%
            <br />
            Jika tidak upload sisa margin dan status belum approved maka <strong>insentif tidak dapat dihitung</strong>,
            jika master sisa margin belum aktif maka <strong>tidak bisa buka DO di doodolan.</strong><br /><br />
            Atas Perhatian anda kami ucapkan terimakasih.<br />Salam Satu Hati.
          </p>
        </field>
      </record>

      <record id="firebase_content_template_notification_reminder_input_pbt_to_soh" model="tw.firebase.content.template">
        <field name="name">Reminder Input Sisa Margin</field>
        <field name="content" type="html">
          <p>
            Kepada Yth. <strong>%name%</strong>,<br/>
            Anda diharapkan untuk segera upload Sisa Margin untuk bulan ini!<br />
            Untuk melakukan download format Sisa Margin silakan buka menu <strong>PBT > Download Input Sisa Margin</strong><br />
            Untuk melakukan upload Sisa Margin silakan buka menu <strong>PBT > Upload Input Sisa Margin</strong>
            Jika tidak upload sisa margin dan status belum approved maka <strong>insentif tidak dapat dihitung</strong>,
            jika master sisa margin belum aktif maka <strong>tidak bisa buka DO di doodolan.</strong><br /><br />
            Atas Perhatian anda kami ucapkan terimakasih.<br />
            Salam Satu Hati.
            
          </p>
        </field>
      </record>

