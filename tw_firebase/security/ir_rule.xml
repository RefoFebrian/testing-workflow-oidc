<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
		<record id="tw_firebase_notification_rule" model="ir.rule">
			<field name="name">tw.firebase.notification rule</field>
			<field name="model_id" ref="model_tw_firebase_notification"/>
			<field name="domain_force">[('company_id', 'in', company_ids)]</field>
		</record>

		<record id="tw_firebase_message_rule" model="ir.rule">
			<field name="name">tw.firebase.message rule</field>
			<field name="model_id" ref="model_tw_firebase_message"/>
			<field name="domain_force">[('company_id', 'in', company_ids)]</field>
		</record>
	</data>
</odoo>