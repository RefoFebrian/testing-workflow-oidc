<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- TW Firebase User Group Read -->

        <record id="tw_firebase_user_group_read" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase User Read</field>
        </record>

        <record id="tw_firebase_user_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_user" />
            <field name="name">tw_firebase_user read</field>
            <field name="group_id" ref="tw_firebase_user_group_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- TW Firebase User Group Update -->

        <record id="tw_firebase_user_group_update" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase User Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_firebase_user_group_read'))]" />
        </record>

        <record id="tw_firebase_user_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_user" />
            <field name="name">tw_firebase_user update</field>
            <field name="group_id" ref="tw_firebase_user_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- TW Firebase User Group Delete -->

        <record id="tw_firebase_user_group_delete" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase User Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_firebase_user_group_read'))]" />
        </record>

        <record id="tw_firebase_user_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_user" />
            <field name="name">tw_firebase_user delete</field>
            <field name="group_id" ref="tw_firebase_user_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_firebase_user_group_read')),
                (4,ref('tw_firebase_user_group_update')),
                (4,ref('tw_firebase_user_group_delete')),
                ]" />
        </record>
    </data>
</odoo>