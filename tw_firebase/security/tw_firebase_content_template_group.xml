<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- TW Firebase Template Konten Group Read -->

        <record id="tw_firebase_content_template_group_read" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase Template Konten Read</field>
        </record>

        <record id="tw_firebase_content_template_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_content_template" />
            <field name="name">tw_firebase_content_template read</field>
            <field name="group_id" ref="tw_firebase_content_template_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_firebase_notification_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_notification" />
            <field name="name">tw_firebase_notification read</field>
            <field name="group_id" ref="tw_firebase_content_template_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_firebase_message_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_message" />
            <field name="name">tw_firebase_message read</field>
            <field name="group_id" ref="tw_firebase_content_template_group_read" />
            <field name="perm_read">1</field>
        </record>

        <!-- TW Firebase Template Konten Group Update -->

        <record id="tw_firebase_content_template_group_update" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase Template Konten Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_firebase_content_template_group_read'))]" />
        </record>

        <record id="tw_firebase_content_template_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_content_template" />
            <field name="name">tw_firebase_content_template update</field>
            <field name="group_id" ref="tw_firebase_content_template_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_firebase_notification_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_notification" />
            <field name="name">tw_firebase_notification update</field>
            <field name="group_id" ref="tw_firebase_content_template_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_firebase_message_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_message" />
            <field name="name">tw_firebase_message update</field>
            <field name="group_id" ref="tw_firebase_content_template_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- TW Firebase Template Konten Group Delete -->

        <record id="tw_firebase_content_template_group_delete" model="res.groups">
            <field name="category_id" ref="tw_firebase.tw_module_category_firebase" />
            <field name="name">TW Firebase Template Konten Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_firebase_content_template_group_read'))]" />
        </record>

        <record id="tw_firebase_content_template_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_content_template" />
            <field name="name">tw_firebase_content_template delete</field>
            <field name="group_id" ref="tw_firebase_content_template_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_firebase_notification_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_notification" />
            <field name="name">tw_firebase_notification delete</field>
            <field name="group_id" ref="tw_firebase_content_template_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_firebase_message_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_firebase_message" />
            <field name="name">tw_firebase_message delete</field>
            <field name="group_id" ref="tw_firebase_content_template_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_firebase_content_template_group_read')),
                (4,ref('tw_firebase_content_template_group_update')),
                (4,ref('tw_firebase_content_template_group_delete')),
                ]" />
        </record>
    </data>
</odoo>