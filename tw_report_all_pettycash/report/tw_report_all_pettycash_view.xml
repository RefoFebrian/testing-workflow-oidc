<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_tw_report_all_pettycash" model="ir.ui.view">
            <field name="name">Report All Petty Cash</field>
            <field name="model">tw.report.all.pettycash</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report All Petty Cash">
                    <group>
                        <group>
                            <field name="option"/>
                            <field name="state_pettycash_in" invisible="option != 'pettycash_in'"/>
                            <field name="state_pettycash_out" invisible="option != 'pettycash_out'"/>
                            <field name="division"/>
                            <field name="journal_bt_id" invisible="option != 'bank_transfer'"/>
                        </group>
                        <group>
                            <field name="journal_id" invisible="option not in ('pettycash_out','pettycash_in')"/>
                            <field name="pettycash_id" invisible="option != 'pettycash_in'"/>
                            <field name="state_reimburse" invisible="option != 'reimbursed'"/>
                            <field name="state_bank_transfer" invisible="option != 'bank_transfer'"/>
                            <label for="start_date" string="Tanggal"/>
                            <div class="o_row">
                                <field name="start_date" widget="date" class="oe_inline"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                <field name="end_date" widget="date" class="oe_inline"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branch">
                            <field name="company_ids"/>
                        </page>
                    </notebook>
                    <footer>
                        <button name="excel_report" string="Export" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_all_petty_cash_wizard" model="ir.actions.act_window">
            <field name="name">Laporan All Petty Cash</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.report.all.pettycash</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>