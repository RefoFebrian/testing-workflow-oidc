<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_stock_lot_partner_cdb_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.stock.lot.partner.cdb.inherit.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='main_group']" position="after">
                    <group name="cdb_partner_group" string="CDB">
                        <field name="cdb_partner_id" string="CDB" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>