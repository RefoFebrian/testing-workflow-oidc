<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_tw_partner_cdb_form" model="ir.ui.view">
            <field name="name">tw.partner.cdb.form</field>
            <field name="model">tw.partner.cdb</field>
            <field name="arch" type="xml">
                <form string="Form CDB">
                    <sheet>
                        <div>
                            <div id="cdb_header" style="width: 50%; display: inline-block;">
                                <label for="name" class="oe_edit_only"/>
                                <h1 style="margin-top: 0%;">
                                    <field name="name" required="1" placeholder="Nama Customer" widget="no_special_char"/>
                                </h1>
                                <label for="identification_number" string="No KTP" class="oe_edit_only" invisible="customer_code_id.value != 'I'"/>
                                <field name="identification_number" invisible="customer_code_id.value not in ['I','G']" required="customer_code_id.value in ['I','G']"/>
                            </div>
                        </div>
                        <group name="data_nosin">
                            <group>
                                <field name="company_id" required="1" string="Branch"/>
                                <field name="product_id" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="lot_ids" required="1" widget="many2many_tags" options="{'no_open': True, 'no_create': True}" readonly="1" string="No Mesin"/>
                            </group>
                        </group>
                        <group name="data_customer" string="Data Customer">
                            <group name="general_data_customer_1">
                                <field name="partner_id" context="{'form_view_ref': 'tw_partner.tw_partner_contact_form_view'}" readonly="1"/>
                                <label for="birthplace" string="Tempat/Tgl Lahir" />
                                <div>
                                    <field name="birthplace" placeholder="Tempat Kelahiran" required="1" style="margin-right:5px;" />
                                    <field name="birthdate" placeholder="Tanggal Lahir" required="1" />
                                </div>
                                <field name="gender_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="customer_code_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="identification_family_number"/>
                                <field name="hobby_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="ethnic_group" required="1"/>
                                <field name="blood_type_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="religion_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="education_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="occupation_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="job_position"/>
                                <field name="responsible"/>
                                <field name="responsible_occupation_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="expense_id" string="Pengeluaran" required="1" options="{'no_open': True, 'no_create': True}"/>
                            </group>
                            <group name="general_data_customer_2">
                                <field name="mobile_plan_status_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="housing_tenure_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="unit_operator_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="unit_usage_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="motor_brand_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="motor_type_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="customer_traits"/>
                                <field name="customer_type_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="is_branch" invisible="1"/>
                                <field name="is_customer" invisible="1"/>
                            </group>
                            <group string="Address">
                                <label for="street" string="Street Address" class="o_edit_only"/>
                                <div>
                                    <field name="street" placeholder="Street..." required="1" widget="no_special_char"/>
                                    <field name="street2" placeholder="Street 2..." widget="no_special_char"/>
                                </div>
                                <label for="rt" string="RT/RW" />
                                <div>
                                    <field name="rt" placeholder="RT" style="width: 25%" required="1" />
                                    <field name="rw" placeholder="RW" style="width: 25%" required="1" />
                                </div>
                                <label for="state_id" string="Provinsi"/>
                                <div class="d-flex">
                                    <field name="state_id" class="oe_no_button" placeholder="Provinsi" options="{'no_open': True,'no_create': True}" nolabel="1" context="{'country_id': country_id, 'default_country_id': country_id}" required="1" on_change="1" can_create="True" can_write="True" />
                                    <field name="state_text" nolabel="1" placeholder="Provinsi" required="1"/>
                                </div>
                                <label for="city_id" string="Kota/Kabupaten"/>
                                <div class="d-flex">
                                    <field name="city_id" placeholder="Kota/Kabupaten" nolabel="1" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" />
                                    <field name="city_text" nolabel="1" placeholder="Kota/Kabupaten" required="1"/>
                                </div>
                                <label for="district_id" string="Kecamatan"/>
                                <div class="d-flex">
                                    <field name="district_id" placeholder="Kecamatan" nolabel="1" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" />
                                    <field name="district_text" nolabel="1" placeholder="Kecamatan" required="1"/>
                                </div>
                                <label for="sub_district_id" string="Kelurahan" />
                                <div class="d-flex">
                                    <field name="sub_district_id" placeholder="Kelurahan" string="Kelurahan" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" />
                                    <field name="sub_district_text" nolabel="1" placeholder="Kelurahan" required="1"/>
                                </div>
                                <field name="zip_code" placeholder="Kode Pos" required="1" on_change="1" />
                            </group>
                            <group string="Address Domicile">
                                <field name="same_address" widget="boolean_button" force_save="1"/>
                                <label for="street_domicile" string="Street Address" class="o_edit_only"/>
                                <div>
                                    <field name="street_domicile" placeholder="Street..." required="1" force_save="1" widget="no_special_char"/>
                                    <field name="street2_domicile" placeholder="Street 2..." force_save="1" widget="no_special_char"/>
                                </div>
                                <label for="rt_domicile" string="RT/RW" />
                                <div>
                                    <field name="rt_domicile" placeholder="RT" style="width: 25%" required="1" force_save="1"/>
                                    <field name="rw_domicile" placeholder="RW" style="width: 25%" required="1" force_save="1"/>
                                </div>
                                <field name="state_domicile_id" class="oe_no_button" placeholder="Provinsi" options="{'no_open': True,'no_create': True}" string="Provinsi" context="{'country_id': country_domicile_id, 'default_country_id': country_domicile_id}" required="1" can_create="True" can_write="True" force_save="1"/>
                                <field name="city_domicile_id" placeholder="Kota/Kabupaten" string="Kota/Kabupaten" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" force_save="1"/>
                                <label for="district_domicile_id" string="Kecamatan"/>
                                <div>
                                    <field name="district_domicile_id" placeholder="Kecamatan" string="Kecamatan" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" force_save="1" />
                                </div>
                                <label for="sub_district_domicile_id" string="Kelurahan" />
                                <div>
                                    <field name="sub_district_domicile_id" placeholder="Kelurahan" string="Kelurahan" options="{'no_open': True,'no_create': True}" required="1" can_create="True" can_write="True" force_save="1"/>
                                </div>
                                <field name="zip_code_domicile" placeholder="Kode Pos" string="Kode Pos" required="1" force_save="1"/>
                            </group>
                            <group name="customer_contact" string="Kontak">
                                <field name="mobile" required="1"/>
                                <field name="whatsapp"/>
                                <field name="phone"/>
                                <field name="email"/>
                                <field name="can_contacted" widget="radio"/>
                            </group>
                            <group name="customer_sales_info" string="Penjualan">
                                <field name="employee_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="sales_channel_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="payment_type_id" required="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="finco_id" invisible="payment_type_id.value != '2'" required="payment_type_id.value == '2'" options="{'no_open': True, 'no_create': True}"/>
                                <field name="downpayment" invisible="payment_type_id.value != '2'" required="payment_type_id.value == '2'"/>
                                <field name="tenor" invisible="payment_type_id.value != '2'" required="payment_type_id.value == '2'"/>
                                <field name="installments" invisible="payment_type_id.value != '2'" required="payment_type_id.value == '2'"/>
                            </group>
                            <group name="status_cdb" string="Status">
                                <field name="is_ro_honda"/>
                                <field name="is_ro_dealer"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_tw_partner_cdb_list" model="ir.ui.view">
            <field name="name">tw.partner.cdb.list</field>
            <field name="model">tw.partner.cdb</field>
            <field name="arch" type="xml">
                <list string="Partner CDB" create="false" edit="false" delete="false">
                    <field name="company_id" string="Branch"/>
                    <field name="name"/>
                    <field name="cddb_code"/>
                    <field name="identification_number"/>
                    <field name="date"/>
                    <field name="lot_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_tw_partner_cdb_search" model="ir.ui.view">
            <field name="name">tw.partner.cdb.search</field>
            <field name="model">tw.partner.cdb</field>
            <field name="arch" type="xml">
                <search string="Search CDB">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="cddb_code"/>
                    <field name="date"/>
                    <field name="identification_number"/>
                    <field name="lot_ids"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_dealer" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_name" string="Name" context="{'group_by': 'name'}"/>
                        <filter name="group_by_date" string="Tanggal" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_tw_partner_cdb" model="ir.actions.act_window">
            <field name="name">CDB</field>
            <field name="res_model">tw.partner.cdb</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': False, 'edit': False}</field>
            <field name="search_view_id" ref="view_tw_partner_cdb_search"/>
            <field name="view_id" ref="view_tw_partner_cdb_list"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first CDB
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <!-- <menuitem id="menu_tw_partner_cdb_root" name="Partner CDB" sequence="10"/>
        <menuitem id="menu_tw_partner_cdb" name="Partner CDB" parent="menu_tw_partner_cdb_root" action="action_tw_partner_cdb"/> -->
    </data>
</odoo>