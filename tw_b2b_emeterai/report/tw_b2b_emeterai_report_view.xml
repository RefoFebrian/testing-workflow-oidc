<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

        <!-- Wizard View -->
        <record id="tw_b2b_emeterai_report_wizard_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.report.wizard</field>
            <field name="model">tw.b2b.emeterai.report</field>
            <field name="arch" type="xml">
                <form string="Laporan Penggunaan e-Meterai">
                	<sheet>
                        <group invisible="state_x == 'get'">
                            <label for="start_date" string="Date" invisible="state_x == 'get'"/>
                            <div>
                                <field name="start_date" required="1" class="oe_inline"/> - <field name="end_date" required="1" class="oe_inline"/>
                            </div>
                        </group>
                        <notebook invisible="state_x == 'get'">
                            <page string="Branchs">
                                <field name="company_ids" colspan="4" options="{'no_create': True, 'no_open': True}" nolabel="1"/>
                            </page>
                        </notebook>
		                <field invisible="1" name="state_x"/>
		                <newline/>
		                <group col="4" fill="0" invisible="state_x != 'get'">
		                    <separator colspan="4" string="Generate B2B e-Meterai Report Success. Click link below to download ..." invisible="state_x == 'choose'"/>
                            <field name="name" invisible="1" width="100"/>
	                        <field name="data_x" nolabel="1" readonly="0" width="100" filename="name" invisible="state_x == 'choose'"/>
		                </group>
		                <footer>
		                    <button name="action_export" invisible="state_x == 'get'" required="1" string="Export Data" type="object" class="oe_highlight"/>
		                    <button string="Cancel" invisible="state_x == 'get'" class="btn btn-default" special="cancel" />
		                </footer>
	                </sheet>
	            </form>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_b2b_emeterai_report_action" model="ir.actions.server">
            <field name="name">Laporan Penggunaan e-Meterai</field>
            <field name="model_id" ref="tw_b2b_emeterai.model_tw_b2b_emeterai_report"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.b2b.emeterai.report'].action_b2b_emeterai_report_tree()
            </field>
        </record>
	     
	</data>
</odoo>