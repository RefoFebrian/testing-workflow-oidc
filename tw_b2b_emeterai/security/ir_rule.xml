<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">

		<record id="tw_b2b_emeterai_rule" model="ir.rule">
			<field name="name">tw.b2b.emeterai rule</field>
			<field name="model_id" ref="model_tw_b2b_emeterai"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('tw_b2b_emeterai.group_tw_b2b_emeterai_read'))]"/>
		</record>
		
		<record id="tw_b2b_emeterai_master_coordinate_rule" model="ir.rule">
			<field name="name">tw.b2b.emeterai.master.coordinate rule</field>
			<field name="model_id" ref="model_tw_b2b_emeterai_master_coordinate"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('tw_b2b_emeterai.group_tw_b2b_emeterai_master_coordinate_read'))]"/>
		</record>
		
		<record id="tw_b2b_emeterai_master_quota_rule" model="ir.rule">
			<field name="name">tw.b2b.emeterai.master.quota rule</field>
			<field name="model_id" ref="model_tw_b2b_emeterai_master_quota"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('tw_b2b_emeterai.group_tw_b2b_emeterai_master_quota_read'))]"/>
		</record>

	</data>
</odoo>