<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_b2b_emeterai_master_coordinate_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.coordinate.list</field>
            <field name="model">tw.b2b.emeterai.master.coordinate</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Master Koordinat e-Meterai" default_order="id desc">
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="amount_limit"/>
                    <field name="list_coordinate"/>
                    <field name="report_id"/>
                    <field name="model_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_b2b_emeterai_master_coordinate_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.coordinate.form</field>
            <field name="model">tw.b2b.emeterai.master.coordinate</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Master Koordinat e-Meterai">
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="name" readonly="1" invisible="create_date == False"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="report_id" required="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="model_id" required="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="amount_limit" required="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1" force_save="1"/>
                                <field name="list_coordinate" placeholder="e.g. 154, 203, 201, 246" required="1"/>
                                <span style="font-size: 10px; font-weight: bold; color: black;">
                                    <i>
                                    * Silakan input koordinat posisi e-Meterai untuk report yang dipilih, urutan koordinat untuk parameter visLLX, visLLY, visURX, visURY<br/>
                                    ** Panduan pengisian parameter tersebut melalui website berikut </i><b><a href="https://perurica.github.io/pdfviewer" target="_blank">https://perurica.github.io/pdfviewer</a></b>
                                </span>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail" invisible="create_uid == False">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_b2b_emeterai_master_coordinate_search_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.coordinate.search</field>
            <field name="model">tw.b2b.emeterai.master.coordinate</field>
            <field name="arch" type="xml">
                <search string="Master Koordinat e-Meterai">
                    <field name="company_id" select="True"/>
                    <field name="name" select="True"/>
                    <field name="list_coordinate" select="True"/>
                    <field name="report_id" select="True"/>
                    <field name="model_id" select="True"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="Report" domain="[]" name="group_by_report_id" context="{'group_by': 'report_id'}"/>
                        <filter string="Model" domain="[]" name="group_by_model_id" context="{'group_by': 'model_id'}"/>
                        <filter string="Date" domain="[]" name="group_by_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_b2b_emeterai_master_coordinate_action" model="ir.actions.server">
            <field name="name">Master Koordinat e-Meterai</field>
            <field name="model_id" ref="tw_b2b_emeterai.model_tw_b2b_emeterai_master_coordinate"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.b2b.emeterai.master.coordinate'].action_b2b_emeterai_master_coordinate_tree()
            </field>
        </record>
        
    </data>
</odoo>