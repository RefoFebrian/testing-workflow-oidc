<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_b2b_emeterai_master_quota_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.quota.list</field>
            <field name="model">tw.b2b.emeterai.master.quota</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="Master Kuota e-Meterai" default_order="id desc">
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="quota"/>
                    <field name="total_usage"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_b2b_emeterai_master_quota_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.quota.form</field>
            <field name="model">tw.b2b.emeterai.master.quota</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Master Kuota e-Meterai">
                    <header>
                        <button name="action_reset_total_usage_stamp_emeterai" string="Reset Total Penggunaan" invisible="total_usage &lt; 1" class="oe_highlight" type="object" groups="tw_b2b_emeterai.group_tw_b2b_emeterai_master_quota_button_reset_usage_stamp"/>
					</header>
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="name" readonly="1" invisible="create_date == False"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="quota" required="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1" force_save="1"/>
                                <field name="total_usage" readonly="1" force_save="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail" invisible="create_uid == False">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_b2b_emeterai_master_quota_search_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.master.quota.search</field>
            <field name="model">tw.b2b.emeterai.master.quota</field>
            <field name="arch" type="xml">
                <search string="Master Kuota e-Meterai">
                    <field name="company_id" select="True"/>
                    <field name="name" select="True"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="Date" domain="[]" name="group_by_date" context="{'group_by': 'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_b2b_emeterai_master_quota_action" model="ir.actions.server">
            <field name="name">Master Kuota e-Meterai</field>
            <field name="model_id" ref="tw_b2b_emeterai.model_tw_b2b_emeterai_master_quota"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.b2b.emeterai.master.quota'].action_b2b_emeterai_master_quota_tree()
            </field>
        </record>
        
    </data>
</odoo>