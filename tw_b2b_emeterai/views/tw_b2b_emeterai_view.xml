<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_b2b_emeterai_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.list</field>
            <field name="model">tw.b2b.emeterai</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="B2B e-Meterai" create="0" default_order="id desc">
                    <field name="company_id"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="report_id"/>
                    <field name="model_id"/>
                    <field name="transaction_id"/>
                    <field name="transaction_name"/>
                    <field name="amount"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_b2b_emeterai_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.form</field>
            <field name="model">tw.b2b.emeterai</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="B2B e-Meterai" create="0">
                    <header>
                        <button name="action_process_stamp_emeterai" string="Process Stamp" invisible="state != 'draft'" class="oe_highlight" type="object"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,process,stamp"/>
					</header>
                    <sheet>
                        <div class="oe_title">                      
                            <h1>
                                <field name="name" readonly="1" invisible="create_date == False"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1" readonly="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="report_id" readonly="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="stamped_file_id" invisible="stamped_file_id == False" readonly="1"/>
                                <field name="stamped_serial_number" invisible="stamped_serial_number == False" readonly="1"/>
                                <field name="stamped_status" invisible="stamped_status == False" readonly="1"/>
                                <field name="stamped_filename" invisible="1"/>
                                <field name="stamped_response" invisible="1"/>
                                <field name="stamped_note" invisible="stamped_note == False" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1" force_save="1"/>
                                <field name="model_id" readonly="1" options="{'no_open': True, 'no_create_edit': True}"/>
                                <field name="transaction_id" readonly="1"/>
                                <field name="transaction_name" readonly="1"/>
                                <field name="amount" readonly="1"/>
                                <div>
                                    <br/>
                                    <span class="alert alert-info" role="status" modifiers="{}" invisible="state == 'draft'">
                                        Download PDF :
                                    </span>
                                    <br/>
                                    <br/>
                                    <span>
                                        <field name="file" invisible="stamped_filename == False" readonly="1" widget="pdf_viewer" style="width: 100%; height: 50%;" filename="stamped_filename"/>
                                    </span>
                                    <span>
                                        <field name="download_file" invisible="stamped_filename == False" readonly="1" filename="stamped_filename"/>
                                    </span>
                                </div>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail" invisible="create_uid == False">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_b2b_emeterai_search_view" model="ir.ui.view">
            <field name="name">tw.b2b.emeterai.search</field>
            <field name="model">tw.b2b.emeterai</field>
            <field name="arch" type="xml">
                <search string="B2B e-Meterai">
                    <field name="company_id" select="True"/>
                    <field name="name" select="True"/>
                    <field name="report_id" select="True"/>
                    <field name="model_id" select="True"/>
                    <field name="transaction_id" select="True"/>
                    <field name="transaction_name" select="True"/>
                    <filter name="draft_state" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="process_state" string="Process" domain="[('state','=','process')]"/>
                    <filter name="stamp_state" string="Stamp" domain="[('state','=','stamp')]"/>
                    <filter name="error_state" string="Error" domain="[('state','=','error')]"/>
                    <group string="Group By..">
                        <filter string="Branch" domain="[]" name="group_by_company_id" context="{'group_by': 'company_id'}"/>
                        <filter string="Report" domain="[]" name="group_by_report_id" context="{'group_by': 'report_id'}"/>
                        <filter string="Model" domain="[]" name="group_by_model_id" context="{'group_by': 'model_id'}"/>
                        <filter string="State" domain="[]" name="group_by_state" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_b2b_emeterai_action" model="ir.actions.server">
            <field name="name">B2B e-Meterai</field>
            <field name="model_id" ref="tw_b2b_emeterai.model_tw_b2b_emeterai"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.b2b.emeterai'].action_b2b_emeterai_tree()
            </field>
        </record>
        
    </data>
</odoo>