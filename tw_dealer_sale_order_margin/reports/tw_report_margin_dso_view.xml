<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_report_net_margin_dso_wizard" model="ir.ui.view">
            <field name="name">tw.report.net.margin.dso.wizard</field>
            <field name="model">tw.report.net.margin.dso</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Laporan Sisa Margin DSO">
                    <group invisible="state_x == 'get'">
                        <group>
                            <field name="start_date"
                                   widget="daterange"
                                   options="{'end_date_field': 'end_date'}"
                                   required="1" />
                            <field name="end_date" invisible="1" />
                            <field name="employee_ids" widget="many2many_tags" style="width: 47%%;" options="{'no_show':True, 'no_create':True, 'no_open':True}" />
                        </group>
                    </group>
                    <notebook invisible="state_x == 'get'">
                        <page string="Branches">
                            <field name="company_ids" colspan="4" nolabel="1" options="{'no_show':True,'no_create':True,'no_open':True}">
                                <list create="1" delete="1" editable="bottom" edit="0">
                                    <field name="code" />
                                    <field name="name" />
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <field invisible="1" name="state_x" />
                    <newline />
                    <group col="4" fill="0" invisible="state_x != 'get'">
                        <separator colspan="4" string="Excel Export Generated. Click link below to download ..." invisible="state_x == 'choose'" />
                        <field name="file" width="100" invisible="state_x == 'choose'" />
                        <field name="data_x" nolabel="1" readonly="0" width="100" filename="file" invisible="state_x == 'choose'" />
                    </group>
                    <footer>
                        <button name="excel_report" string="Export Data" type="object" class="oe_highlight" invisible="state_x == 'get'" />
                        <!-- <label string=" or " invisible="state_x == 'get'"> -->
                        <button string="Cancel" special="cancel" class="btn btn-default" invisible="state_x == 'get'" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_report_net_margin_dso_wizard" model="ir.actions.act_window">
            <field name="name">Laporan Sisa Margin DSO</field>
            <field name="res_model">tw.report.net.margin.dso</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_report_net_margin_dso_wizard" />
            <field name="target">new</field>
        </record>

        
    </data>
</odoo>