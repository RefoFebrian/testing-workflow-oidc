<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_tw_vehicle_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Vehicle Read</field>
        </record> 
        
        <record id="access_tw_vehicle_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle"/>
            <field name="name">tw_vehicle read</field> 
            <field name="group_id" ref="group_tw_vehicle_read"/>  
            <field name="perm_read">1</field> 
        </record> 
                
        <record id="group_tw_vehicle_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Vehicle Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_read'))]"/>                             
        </record>
                        
        <record id="access_tw_vehicle_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle"/>
            <field name="name">tw_vehicle update</field> 
            <field name="group_id" ref="group_tw_vehicle_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      

        <record id="group_tw_vehicle_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Vehicle Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_read'))]"/>                             
        </record>
                        
        <record id="access_tw_vehicle_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle"/>
            <field name="name">tw_vehicle delete</field> 
            <field name="group_id" ref="group_tw_vehicle_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_vehicle_read')),
                (4,ref('group_tw_vehicle_update')),
                (4,ref('group_tw_vehicle_delete')),
                ]" />
        </record>         
    </data>
</odoo>