<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_tw_boom_process_escalation" model="ir.cron">
            <field name="name">BOOM: Process Task Escalation</field>
            <field name="model_id" ref="tw_boom.model_tw_boom_task"/>
            <field name="state">code</field>
            <field name="code">model.action_process_escalation()</field>
            <field name="active" eval="False"/>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + relativedelta(days=1)).strftime('%Y-%m-%d 01:00:00')"/>
        </record>
    </data>
</odoo>
