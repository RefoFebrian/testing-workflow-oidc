<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- ============================================================ -->
        <!-- List View                                                     -->
        <!-- ============================================================ -->
        <record id="tw_api_log_partition_list_view" model="ir.ui.view">
            <field name="name">tw.api.log.partition.list</field>
            <field name="model">tw.api.log.partition</field>
            <field name="arch" type="xml">
                <list string="API Log Partitions"
                      create="false" edit="false"
                      decoration-muted="is_default == True">
                    <field name="partition_type"/>
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="row_count"/>
                    <field name="size_mb"/>
                    <field name="is_default"/>
                    <button name="action_detach_and_drop"
                            type="object"
                            string="Drop"
                            class="btn btn-danger"
                            icon="fa-trash"
                            confirm="This will permanently delete all data in this partition. Are you sure?"
                            invisible="is_default == True"/>
                </list>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Form View                                                     -->
        <!-- ============================================================ -->
        <record id="tw_api_log_partition_form_view" model="ir.ui.view">
            <field name="name">tw.api.log.partition.form</field>
            <field name="model">tw.api.log.partition</field>
            <field name="arch" type="xml">
                <form string="API Log Partition" create="false" edit="false">
                    <header>
                        <button name="action_detach_and_drop"
                                type="object"
                                string="Detach &amp; Drop Partition"
                                class="btn btn-danger"
                                confirm="This will permanently delete all data in this partition. Are you sure?"
                                invisible="is_default == True"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="partition_type"/>
                                <field name="name"/>
                                <field name="is_default"/>
                            </group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="row_count"/>
                                <field name="size_mb"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Search View                                                   -->
        <!-- ============================================================ -->
        <record id="tw_api_log_partition_search_view" model="ir.ui.view">
            <field name="name">tw.api.log.partition.search</field>
            <field name="model">tw.api.log.partition</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="partition_type"/>
                    <filter string="Header Partitions" name="filter_header" domain="[('partition_type', '=', 'header')]"/>
                    <filter string="Detail Partitions" name="filter_detail" domain="[('partition_type', '=', 'detail')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Type" name="group_by_type" context="{'group_by':'partition_type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ============================================================ -->
        <!-- Action & Menu                                                 -->
        <!-- ============================================================ -->
        <record id="tw_api_log_partition_action" model="ir.actions.act_window">
            <field name="name">API Log Partitions</field>
            <field name="res_model">tw.api.log.partition</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_group_by_type': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No partition data loaded yet.
                </p>
                <p>
                    Click "Sync Partitions" to discover existing partitions.
                </p>
            </field>
        </record>

        <record id="tw_api_log_partition_action_server_sync" model="ir.actions.server">
            <field name="name">Sync Partitions</field>
            <field name="model_id" ref="model_tw_api_log_partition"/>
            <field name="binding_model_id" ref="model_tw_api_log_partition"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">model.action_sync_partitions()</field>
        </record>

        <record id="tw_api_log_partition_action_server_ensure" model="ir.actions.server">
            <field name="name">Create Future Partitions</field>
            <field name="model_id" ref="model_tw_api_log_partition"/>
            <field name="binding_model_id" ref="model_tw_api_log_partition"/>
            <field name="binding_view_types">list</field>
            <field name="state">code</field>
            <field name="code">model.action_ensure_future_partitions()</field>
        </record>

    </data>
</odoo>
