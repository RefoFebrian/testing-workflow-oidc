<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_asset_adjustment_approval_request" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Request Approval Asset Adjustment</field>
        </record>

        <record id="access_tw_asset_adjustment_approval_request" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment"/>
            <field name="name">tw_asset_adjustment_approval_request update</field>
            <field name="group_id" ref="group_tw_asset_adjustment_approval_request"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_asset_adjustment_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Cancel Asset Adjustment</field>
        </record>
        <record id="access_tw_asset_adjustment_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment"/>
            <field name="name">tw_asset_adjustment_approval_cancel update</field>
            <field name="group_id" ref="group_tw_asset_adjustment_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_asset_adjustment_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Reject Asset Adjustment</field>
        </record>
        <record id="access_tw_asset_adjustment_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment"/>
            <field name="name">tw_asset_adjustment_approval_reject update</field>
            <field name="group_id" ref="group_tw_asset_adjustment_approval_reject"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_asset_adjustment_approval_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Button Confirm Asset Adjustment</field>
        </record>
        <record id="access_tw_asset_adjustment_approval_confirm" model="ir.model.access">
            <field name="model_id" ref="tw_asset_adjustment.model_tw_asset_adjustment"/>
            <field name="name">tw_asset_adjustment_approval_confirm update</field>
            <field name="group_id" ref="group_tw_asset_adjustment_approval_confirm"/>
            <field name="perm_write">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_asset_adjustment_approval_cancel')),
                (4,ref('group_tw_asset_adjustment_approval_reject')),
                (4,ref('group_tw_asset_adjustment_approval_request')),
                (4,ref('group_tw_asset_adjustment_approval_confirm')),
            ]">
			</field>
		</record>
	</data>

</odoo>
