<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_vehicle_birojasa_billing_lot_form" model="ir.ui.view">
            <field name="name">tw.vehicle.birojasa_billing.lot.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id"
                ref="tw_vehicle_document_receipt.view_vehicle_document_receipt_lot_form" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='document_receipt']" position="after">  
                    <group name="birojasa_billing" string="Tagihan Birojasa">
                        <group>
                            <field name="birojasa_billing_id" string="Tagihan Birojasa"
                                readonly="1" />
                            <field name="birojasa_billing_date"
                                string="Tanggal Tagihan Birojasa" readonly="1" />
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>