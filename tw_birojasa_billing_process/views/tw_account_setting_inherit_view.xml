<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_settings_birojasa_inherit_view" model="ir.ui.view">
            <field name="name">tw.account.settings.birojasa.inherit.view</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//page[@name='page_4']" position="after">
                    <page string="Document Handling" name="tagihan_birojasa">
                        <group>
                            <group string="Tagihan Biro Jasa" name="tagihan_birojasa">
                                <field name="journal_birojasa_bbn_id" options="{ 'no_open': True, 'no_create': True }"/>
                            </group>
                            <group string="Journal Cancel" name="birojasa_journal_cancel"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>