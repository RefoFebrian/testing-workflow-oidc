<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_birojasa_billing_view_search" model="ir.ui.view">
            <field name="name">tw.birojasa.billing.process.search</field>
            <field name="model">tw.birojasa.billing.process</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>

		            <field name="biro_jasa_id"/>
		            <field name="state"/>
					<field name="billing_line_ids" string="Engine No" filter_domain="[('billing_line_ids.name', 'ilike', self)]"/>
					<field name="billing_line_ids" string="Product" filter_domain="[('billing_line_ids.product_id', 'ilike', self)]"/>
					<field name="billing_line_ids" string="City" filter_domain="[('billing_line_ids.city_id', 'ilike', self)]"/>
					<field name="billing_line_ids" string="Customer STNK" filter_domain="[('billing_line_ids.customer_stnk_id', 'ilike', self)]"/>
					<field name="billing_line_ids" string="No Notice" filter_domain="[('billing_line_ids.notice_number', 'ilike', self)]"/>
					<filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
					<filter name="done" string="Done" domain="[('state','=','done')]"/>
					<filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]"/>
					<filter name="group_by_state" string="Group by State" context="{'group_by':'state'}"/>
					<filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
					<filter name="group_by_division" string="Group by Division" context="{'group_by':'division'}"/>
                </search>
            </field>
        </record>

        <record id="tw_birojasa_billing_view_list" model="ir.ui.view">
            <field name="name">tw.birojasa.billing.process.list</field>
            <field name="model">tw.birojasa.billing.process</field>
            <field name="arch" type="xml">
                <list default_order="id desc">
                    <field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>
					<field name="biro_jasa_id"/>
					<field name="type"/>
					<field name="document_number"/>
					<field name="approval_correction_amount"/>
					<field name="tax_ids" widget="many2many_tags"/>
					<field name="date"/>
		            <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_birojasa_billing_view_form" model="ir.ui.view">
            <field name="name">tw.birojasa.billing.process.form</field>
            <field name="model">tw.birojasa.billing.process</field>
            <field name="arch" type="xml">
                <form>
                    <header>
						<button name="action_confirm" data-hotkey="c" invisible="state != 'draft'" string="Confirm" type="object" class="oe_highlight" groups="tw_birojasa_billing_process.group_birojasa_billing_button_confirm"/>
						<button name="action_cancel" data-hotkey="z" invisible="state != 'draft'" string="Cancel" type="object" groups="tw_birojasa_billing_process.group_birojasa_billing_button_cancel"/>
                        <button name="action_print_out_birojasa" invisible="state not in ('confirmed', 'done')" string="Print" type="object" class="oe_highlight" groups="tw_birojasa_billing_process.group_birojasa_billing_button_print"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
	           		</header>
                    <sheet>
						<div class="oe_button_box" name="button_box">
							<button 
								name="action_view_invoice" 
								type="object" 
								class="oe_stat_button" 
								icon="fa-file-invoice" 
								invisible="not invoice_id">
								<field name="invoice_id" widget="statinfo" string="Bills"/>
							</button>
                        </div>
                        <div class="oe_title">
                            <span class="o_form_label">Tagihan Birojasa</span>
			        		<h1>
				 				<field name="name" class="oe_inline" invisible="not name" readonly="1"/>
                                <span invisible="name">Draft</span>
			 				</h1>
			        	</div>
                        <group>
							<group>
								<field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" required="1"/>
                                <field name="available_biro_jasa_ids" invisible="1"/>
                                <field name="biro_jasa_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" required="1"/>
                                <field name="type" readonly="state != 'draft'" required="1"/>
                                <field name="description" readonly="state != 'draft'"/>
                                <field name="document_number" readonly="state != 'draft'"/>
                                <field name="document_copy" readonly="state != 'draft'"/>
                                <field name="tax_ids" readonly="state != 'draft'" options="{'no_create': True,'no_open': True}" widget="many2many_tags"/>
								<div colspan="2" col="2" style="margin-bottom: 30px;">
									<p>(*) <span style="font-style: italic;color: red">PPN &amp; PPH harus sama seperti di kwitansi. Yuk di cek lagi biar tidak keliru! :D</span></p>
								</div>
							</group>
						    <group>
	                    		<field name="currency_id" invisible="1" />
	                    		<field name="division" readonly="1" />
                                <field name="date" readonly="1"/>
								<field name="document_date" readonly="state != 'draft'" required="1"/>
								<field name="approval_correction_amount" readonly="1"/>
	                    	</group>
						</group>
                        <notebook>
		                    <page string="Engine Line">
		                        <field name="billing_line_ids" readonly="state != 'draft'">
		                            <list editable="bottom">
                                		<field name="lot_id" required="1" options="{'no_create': True,'no_open': True}" width="200"/>
                                		<field name="product_id" options="{'no_create': True,'no_open': True}" width="150"/>
                                		<field name="city_id" options="{'no_create': True,'no_open': True}" width="150"/>
                                		<field name="customer_stnk_id" options="{'no_create': True,'no_open': True}" width="200"/>
                                        <field name="notice_number" required="1" string="No Notice" width="120"/>
                                        <field name="notice_date" required="1" string="Tgl JTP Notice" width="120"/>
                                        <field name="service_amount" string="Jasa" width="100"/>
                                        <field name="estimation_amount" string="Total Estimasi" width="120"/>
                                        <field name="progressive_tax_amount" string="Pajak Progresif" width="100"/>
                                        <field name="amount_total" string="Total Tagihan" width="120"/>
                                        <field name="correction_amount" string="Koreksi" width="100"/>
						             </list>
		                        </field>
								<group>
									<group>
									  <field name="notes" nolabel="1" placeholder="Notes ..." colspan="2"/>
									</group>
									<group>
										<group class="oe_subtotal_footer" colspan="2">
											<field name="estimation_amount" string="Total Estimasi"/>
											<field name="correction_amount" string="Koreksi"/>
											<field name="progressive_tax_amount" string="Total Progresif"/>
											<field name="tax_totals"
													widget="account-tax-totals-field"
													nolabel="1"
													readonly="1"/>
										</group>
									</group>
								</group>
								<div class="clearfix"/>
		                    </page>
							<page name="document" string="Document">
								<group>
									<group>
										<field name="document_filename" invisible="1"/>
										<field name="document_file" filename="document_filename"/>
									</group>
								</group>
							</page>
							<page name="invoicing" string="Invoicing">
								<group>
									<group>
										<field name="invoice_method" readonly="1"/>
										<field name="invoiced" readonly="1"/>
										<field name="invoice_id" readonly="1"/>
									</group>
								</group>
							</page>
                            <page name="audit_trail" string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
										<field name="confirm_uid" readonly="1"/>
										<field name="confirm_date" readonly="1"/>
									</group>
									<group>
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
										<field name="cancel_uid" readonly="1"/>
										<field name="cancel_date" readonly="1"/>
									</group>
								</group>
							</page>
		                </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_birojasa_billing_action" model="ir.actions.act_window">
            <field name="name">Tagihan Birojasa</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.birojasa.billing.process</field>
            <field name="view_mode">list,form</field>
			<field name="context">{"search_default_draft": 1}</field>
        </record>

    </data>
</odoo>
