<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="view_tw_so_bakso_stnk_wizard" model="ir.ui.view">
            <field name="name">tw.so.bakso.stnk.wizard</field>
            <field name="model">tw.vehicle.document.bakso.registration</field>
            <field name="arch" type="xml">
                <form string="Berita Acara SO">
                    <sheet>
                        <group>
                            <field name="opname_id" readonly="1" options="{'no_open':True,'no_create':True}"/>
                            <field name="note_bakso"/>
                        </group>
                        <footer>
                            <button name="action_submit_bakso" string="Print" type="object" class="btn-primary"/>
                            <button string="Close" class="oe_link" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>