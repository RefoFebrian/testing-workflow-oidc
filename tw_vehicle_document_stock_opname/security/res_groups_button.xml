<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Stock Opname STNK Buttons -->
        <record id="group_so_reg_generate_stock" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname STNK Generate Stock</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_reg_posted" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname STNK Post</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_reg_print_validasi" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname STNK Print Validasi</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_reg_print_bakso" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname STNK Print Bakso</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_reg_download_excel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname Download Excel STNK</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>

        <!-- Stock Opname BPKB Buttons -->
        <record id="group_so_generate_stock" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname BPKB Generate Stock</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_posted" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname BPKB Post</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_print_validasi" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
