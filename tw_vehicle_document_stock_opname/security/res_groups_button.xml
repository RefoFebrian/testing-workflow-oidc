            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_print_bakso" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname BPKB Print Bakso</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>
        <record id="group_so_download_excel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Vehicle Document Stock Opname Download Excel BPKB</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_stock_opname_read'))]"/>
        </record>

        <!-- Admin Group -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_so_reg_generate_stock')),
                (4, ref('group_so_reg_posted')),
                (4, ref('group_so_reg_print_validasi')),
                (4, ref('group_so_reg_print_bakso')),
                (4, ref('group_so_reg_download_excel')),
                (4, ref('group_so_generate_stock')),
                (4, ref('group_so_posted')),
                (4, ref('group_so_print_validasi')),
                (4, ref('group_so_print_bakso')),
                (4, ref('group_so_download_excel')),
            ]"/>
        </record>

    </data>
