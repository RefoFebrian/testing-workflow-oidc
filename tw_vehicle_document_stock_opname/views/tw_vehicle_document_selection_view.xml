        <!-- Master List View -->
        <record id="action_tw_ceklis_fisik_stnk_list_view" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_selection.tw_selection_master_list_view"/>
