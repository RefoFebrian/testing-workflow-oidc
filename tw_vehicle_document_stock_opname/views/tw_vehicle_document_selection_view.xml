<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Action Selection -->
        <record id="action_tw_ceklis_fisik_stnk" model="ir.actions.act_window">
            <field name="name">Ceklis Fisik STNK</field>
            <field name="res_model">tw.selection</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('type', '=', 'CekFisikStnk')]</field>
            <field name="context">{'default_type': 'CekFisikStnk','search_default_active': True}</field>
        </record>

        <record id="action_tw_ceklis_fisik_bpkb" model="ir.actions.act_window">
            <field name="name">Ceklis Fisik BPKB</field>
