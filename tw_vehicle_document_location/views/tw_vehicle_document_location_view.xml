<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_vehicle_document_location_view_search" model="ir.ui.view">
            <field name="name">tw.vehicle.document.location.search</field>
            <field name="model">tw.vehicle.document.location</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" string="Location Name"/>
                    <field name="company_id"/>
                    <field name="address"/>
                    <field name="type" string="Location Type"/>
                    <separator/>
                    <filter name="active" string="Active" domain="[('active','=',True)]"/>
                    <filter name="inactive" string="Inactive" domain="[('active','=',False)]"/>
                    <separator/>
                    <filter name="internal_location" string="Internal Location" domain="[('type','=','internal')]"/>
                    <filter name="transit_location" string="Transit Location" domain="[('type','=','transit')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
                        <filter name="group_by_type" string="Location Type" context="{'group_by':'type'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="tw_vehicle_document_location_view_list" model="ir.ui.view">
            <field name="name">tw.vehicle.document.location.list</field>
            <field name="model">tw.vehicle.document.location</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="description"/>
                    <field name="address"/>
                    <field name="city_id"/>
                    <field name="type"/>
                </list>
            </field>
        </record>


        <record id="tw_vehicle_document_location_view_form" model="ir.ui.view">
            <field name="name">tw.vehicle.document.location.form</field>
            <field name="model">tw.vehicle.document.location</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" class="oe_inline" placeholder="Location Name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" required="1"/>
                                <field name="description" required="1"/>
                                <field name="type" required="1"/>
                            </group>
                            <group>
                                <field name="address"/>
                                <field name="city_id"/>
                                <field name="active" widget="boolean_toggle"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_vehicle_registration_location_action" model="ir.actions.act_window">
            <field name="name">Lokasi STNK</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.vehicle.document.location</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_document_type':'vehicle_registration','search_default_active':True}</field>
            <field name="domain">[('document_type','=','vehicle_registration')]</field>
        </record>
        <record id="tw_vehicle_ownership_location_action" model="ir.actions.act_window">
            <field name="name">Lokasi BPKB</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.vehicle.document.location</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'default_document_type':'vehicle_ownership','search_default_active':True}</field>
            <field name="domain">[('document_type','=','vehicle_ownership')]</field>
        </record>

    </data>
</odoo>