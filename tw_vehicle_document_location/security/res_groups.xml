<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Vehicle Document Location Groups -->
        <record id="group_vehicle_document_location_read" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW STNK BPKB Location Read</field>
        </record>

        <record id="access_tw_vehicle_document_location_read" model="ir.model.access">
            <field name="name">tw_vehicle_document_location_read</field>
            <field name="model_id" ref="model_tw_vehicle_document_location"/>
            <field name="group_id" ref="tw_vehicle_document_location.group_vehicle_document_location_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="access_tw_vehicle_document_location_res_company_read" model="ir.model.access">
            <field name="name">res_company_read</field>
            <field name="model_id" ref="base.model_res_company"/>
            <field name="group_id" ref="tw_vehicle_document_location.group_vehicle_document_location_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="group_vehicle_document_location_update" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW STNK BPKB Location Update</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_location_read'))]"/>
        </record>

        <record id="access_tw_vehicle_document_location_update" model="ir.model.access">
            <field name="name">tw_vehicle_document_location_update</field>
            <field name="model_id" ref="model_tw_vehicle_document_location"/>
            <field name="group_id" ref="tw_vehicle_document_location.group_vehicle_document_location_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="group_vehicle_document_location_delete" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW STNK BPKB Location Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_document_location_read'))]"/>
        </record>

        <record id="access_tw_vehicle_document_location_delete" model="ir.model.access">
            <field name="name">tw_vehicle_document_location_delete</field>
            <field name="model_id" ref="model_tw_vehicle_document_location"/>
            <field name="group_id" ref="tw_vehicle_document_location.group_vehicle_document_location_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_vehicle_document_location_read')),
                (4,ref('group_vehicle_document_location_update')),
                (4,ref('group_vehicle_document_location_delete')),
            ]"/>
        </record>
    </data>
</odoo>
