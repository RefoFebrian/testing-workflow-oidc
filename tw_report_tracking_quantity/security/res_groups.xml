<odoo>
    <data noupdate="1">

        <record id="group_report_tracking_quantity_showroom" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Tracking Quantity Showroom</field>
        </record>

        <record id="access_tw_report_tracking_quantity_group_showroom" model="ir.model.access">
            <field name="name">tw.report.payment.group</field>
            <field name="model_id" ref="model_tw_report_tracking_quantity"/>
            <field name="group_id" ref="group_report_tracking_quantity_showroom"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="group_report_tracking_quantity_workshop" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Tracking Quantity Workshop</field>
        </record>

        <record id="access_tw_report_tracking_quantity_group_workshop" model="ir.model.access">
            <field name="name">tw.report.payment.group</field>
            <field name="model_id" ref="model_tw_report_tracking_quantity"/>
            <field name="group_id" ref="group_report_tracking_quantity_workshop"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_report_tracking_quantity_showroom')), (4, ref('group_report_tracking_quantity_workshop'))]"/>
        </record>

    </data>
</odoo>