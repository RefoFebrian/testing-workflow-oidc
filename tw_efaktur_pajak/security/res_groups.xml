<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- TW Generate eFaktur Pajak -->
        <!-- READ -->
        <record id="group_tw_efaktur_pajak_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Generate eFaktur Pajak Read</field>
        </record>

        <record id="access_tw_efaktur_pajak_wizard_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_efaktur_pajak_wizard"/>
            <field name="name">tw_efaktur_pajak_wizard read</field>
            <field name="group_id" ref="group_tw_efaktur_pajak_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- UPDATE -->
        <record id="group_tw_efaktur_pajak_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Generate eFaktur Pajak Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_efaktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_efaktur_pajak_wizard_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_efaktur_pajak_wizard"/>
            <field name="name">tw_efaktur_pajak_wizard update</field>
            <field name="group_id" ref="group_tw_efaktur_pajak_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- DELETE -->
        <record id="group_tw_efaktur_pajak_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Generate eFaktur Pajak Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_efaktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_efaktur_pajak_wizard_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_efaktur_pajak_wizard"/>
            <field name="name">tw_efaktur_pajak_wizard delete</field>
            <field name="group_id" ref="group_tw_efaktur_pajak_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <!-- System Admin gets all groups -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_efaktur_pajak_read')),
                (4, ref('group_tw_efaktur_pajak_update')),
                (4, ref('group_tw_efaktur_pajak_delete')),
            ]"/>
        </record>
    </data>

</odoo>
