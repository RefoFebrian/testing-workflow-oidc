<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Proses STNK -->
        <record id="group_tw_vehicle_registration_process_read" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Proses STNK Read</field>
        </record>
        
        <!-- Main Model Access -->
        <record id="access_tw_vehicle_registration_process_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process"/>
            <field name="name">tw_vehicle_registration_process read</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Line Model Access -->
        <record id="access_tw_vehicle_registration_process_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process_line"/>
            <field name="name">tw_vehicle_registration_process_line read</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Related Models Access -->
        <record id="access_stock_lot_read" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_lot"/>
            <field name="name">stock.lot.vehicle.registration</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_company_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_company"/>
            <field name="name">res.company.vehicle.registration</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_partner_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="name">res.partner.vehicle.registration</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_res_users_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_users"/>
            <field name="name">res.users.vehicle.registration</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Update Group -->
        <record id="group_tw_vehicle_registration_process_update" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Proses STNK Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_registration_process_read'))]"/>
        </record>
        
        <record id="access_tw_vehicle_registration_process_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process"/>
            <field name="name">tw_vehicle_registration_process update</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_vehicle_registration_process_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process_line"/>
            <field name="name">tw_vehicle_registration_process_line update</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Delete Group -->
        <record id="group_tw_vehicle_registration_process_delete" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Proses STNK Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_vehicle_registration_process_read'))]"/>
        </record>
        
        <record id="access_tw_vehicle_registration_process_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process"/>
            <field name="name">tw_vehicle_registration_process delete</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_vehicle_registration_process_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_vehicle_registration_process_line"/>
            <field name="name">tw_vehicle_registration_process_line delete</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_delete"/>
            <field name="perm_unlink">1</field>
        </record>
        <!-- Change Biro Jasa -->
        <record id="group_tw_vehicle_registration_process_change_biro_jasa" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Proses STNK Change Biro Jasa</field>
        </record>
        
        <!-- Main Model Access -->
        <record id="access_tw_vehicle_registration_process_change_biro_jasa" model="ir.model.access">
            <field name="model_id" ref="model_tw_change_birojasa_wizard"/>
            <field name="name">tw_change_birojasa_wizard change biro jasa</field>
            <field name="group_id" ref="group_tw_vehicle_registration_process_change_biro_jasa"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
            (4,ref('group_tw_vehicle_registration_process_read')),
            (4,ref('group_tw_vehicle_registration_process_update')),
            (4,ref('group_tw_vehicle_registration_process_delete')),
            (4,ref('group_tw_vehicle_registration_process_change_biro_jasa')),
            ]"/>
        </record>
    </data>
</odoo>
