<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="tw_vehicle_registration_process_view_list" model="ir.ui.view">
      <field name="name">tw.vehicle.registration.process.list</field>
      <field name="model">tw.vehicle.registration.process</field>
      <field name="arch" type="xml">
        <list>
          <field name="name" />
          <field name="company_id" />
          <field name="division" />

          <field name="biro_jasa_id" />
          <field name="date" />
          <field name="state" />
        </list>
      </field>
    </record>

    <record id="tw_vehicle_registration_process_view_form" model="ir.ui.view">
      <field name="name">tw.vehicle.registration.process.form</field>
      <field name="model">tw.vehicle.registration.process</field>
      <field name="arch" type="xml">
        <form>
          <header>
            <button name="action_confirm" data-hotkey="c" invisible="state != 'draft'" string="Post" type="object" class="oe_highlight" groups="tw_vehicle_registration_process.group_vehicle_registration_process_button_post" />
            <button name="action_print_out_registration" invisible="state != 'done'" string="Print" type="object" class="oe_highlight" groups="tw_vehicle_registration_process.group_vehicle_registration_process_button_print_out_registration"/>
            <field name="state" widget="statusbar" statusbar_visible="draft,done" />
          </header>
          <sheet>
            <div class="oe_button_box" name="button_box">
              <button name="action_view_change_biro_jasa_journals" type="object" class="oe_stat_button" icon="fa-book" invisible="not old_biro_jasa_id or state != 'done' or change_biro_jasa_journal_count == 0">
                <field name="change_biro_jasa_journal_count" widget="statinfo" string="Journal Ganti BiJas"/>
              </button>
            </div>
            <div class="oe_title">
              <span class="o_form_label">Proses STNK</span>
              <h1>
                <field name="name" class="oe_inline" invisible="not name" />
                <span invisible="name">Draft</span>
              </h1>
            </div>
            <div class="alert alert-info mb-2 mt-2" role="alert" invisible="not old_biro_jasa_id or old_biro_jasa_id == biro_jasa_id">
                Info: Pergantian Biro Jasa dari <field name="old_biro_jasa_id" readonly="1" class="oe_inline fw-bold" options="{'no_open': True}"/>
 menjadi <field name="biro_jasa_id" readonly="1" class="oe_inline fw-bold" options="{'no_open': True}"/>
. Jurnal Accrue BBN dan data Serial Number akan otomatis diperbarui ketika Posted.
          </div>
          <group>
            <group>
              <field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" />
              <field name="company_id" invisible="1" />
              <div>
                <label for="biro_jasa_id">Biro Jasa</label>
                <field name="available_biro_jasa_ids" invisible="1"/>
                <field name="old_biro_jasa_id" invisible="1"/>
                <field name="biro_jasa_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" class="oe_inline ms-1"/>
                <button name="action_change_biro_jasa" invisible="not biro_jasa_id or state != 'draft'" string="Change Biro Jasa" title="Change Biro Jasa" type="object" class="oe_inline btn-link" icon="fa-exchange"/>
              </div>
            </group>
            <group>
              <field name="division" readonly="1" />
              <field name="date" readonly="1" />
              <field name="available_lot_ids" invisible="1" />
            </group>
          </group>
          <notebook>
            <page string="Engine Line">
              <field name="registration_process_line_ids" readonly="state != 'draft'">
                <list editable="bottom" create="false" edit="false">
                  <field name="lot_id" required="1" options="{'no_create': True,'no_open': True}" domain="[('id', 'in', parent.available_lot_ids)]" width="200" string="Engine No"/>
                  <field name="chassis_number" width="150"/>
                  <field name="customer_stnk_id" width="150"/>
                  <field name="doc_number" width="120"/>
                  <field name="vehicle_document_request_date" string="Tanggal Permohonan Faktur" width="150"/>
                  <field name="vehicle_document_receive_date" string="Tanggal Penerimaan Faktur" width="150"/>
                  <field name="state" readonly="1" decoration-danger="state == 'cancel'" decoration-warning="state == 'draft'" decoration-success="state == 'done'" width="100" />
                </list>
              </field>
            </page>
            <page string="Audit Trail" name="audit_trail">
              <group>
                <group>
                  <field name="create_uid" readonly="1" />
                  <field name="create_date" readonly="1" />
                  <field name="confirm_uid" readonly="1" />
                  <field name="confirm_date" readonly="1" />
                </group>
                <group>
                  <field name="write_uid" readonly="1" />
                  <field name="write_date" readonly="1" />
                  <field name="cancel_uid" readonly="1" />
                  <field name="cancel_date" readonly="1" />
                </group>
              </group>
            </page>
          </notebook>
        </sheet>
        <chatter>
          <field name="message_ids"/>
          <field name="activity_ids"/>
        </chatter>
      </form>
    </field>
  </record>

  <record id="tw_vehicle_registration_process_view_search" model="ir.ui.view">
    <field name="name">tw.vehicle.registration.process.search</field>
    <field name="model">tw.vehicle.registration.process</field>
    <field name="arch" type="xml">
      <search>
        <field name="name" />
        <field name="company_id" />
        <field name="division" />
        <field name="biro_jasa_id" />
        <field name="state" />
        <field name="registration_process_line_ids" string="Engine Number" filter_domain="[('registration_process_line_ids.name', 'ilike', self)]"/>
        <field name="registration_process_line_ids" string="Chassis Number" filter_domain="[('registration_process_line_ids.chassis_number', 'ilike', self)]"/>
        <field name="registration_process_line_ids" string="Customer STNK" filter_domain="[('registration_process_line_ids.customer_stnk_id', 'ilike', self)]"/>
        <field name="registration_process_line_ids" string="No Faktur STNK" filter_domain="[('registration_process_line_ids.doc_number', 'ilike', self)]"/>
        <filter name="draft" string="Draft" domain="[('state','=','draft')]" />
        <filter name="done" string="Done" domain="[('state','=','done')]" />
        <filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]" />
        <filter name="group_by_state" string="Group by State" context="{'group_by':'state'}" />
        <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}" />
        <filter name="group_by_division" string="Group by Division" context="{'group_by':'division'}" />
      </search>
    </field>
  </record>

  <record id="tw_vehicle_registration_process_action" model="ir.actions.act_window">
    <field name="name">Proses STNK</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">tw.vehicle.registration.process</field>
    <field name="view_mode">list,form</field>
    <field name="context">{"search_default_draft": 1}</field>
  </record>

</data>
</odoo>