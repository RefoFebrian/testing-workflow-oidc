<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tw_change_birojasa_wizard_form" model="ir.ui.view">
        <field name="name">tw.change.birojasa.wizard.form</field>
        <field name="model">tw.change.birojasa.wizard</field>
        <field name="arch" type="xml">
            <form string="Change Biro Jasa">
                <div class="alert alert-warning mb-0" role="alert">
                    <strong>⚠ Perhatian!</strong>
                    <p class="mb-1 mt-1">
                        Tindakan ini akan mengganti Biro Jasa pada semua Serial Number yang terdaftar pada proses STNK ini.
                    </p>
                    <p class="mb-0">
                        Jurnal <strong>Accrue BBN lama</strong> akan dibalik secara otomatis, dan jurnal
                        <strong>Accrue BBN baru</strong> akan dibuat atas Biro Jasa yang baru dipilih.
                    </p>
                </div>
                <group col="4">
                        <field name="available_biro_jasa_ids" invisible="1"/>
                        <field name="old_biro_jasa_id" options="{'no_create': True,'no_open': True}"/>
                        <field name="new_biro_jasa_id" domain="[('id', 'in', available_biro_jasa_ids),('id', '!=', old_biro_jasa_id)]" options="{'no_create': True,'no_open': True}" />
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary" confirm="Apakah anda yakin ingin mengubah Biro Jasa?"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


</odoo>
