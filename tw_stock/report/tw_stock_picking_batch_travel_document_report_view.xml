<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_batch_travel_document_stock_picking_batch" model="report.paperformat">
            <field name="name">Surat Jalan Stock Picking Batch</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="css_margins" eval="True"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <record id="batch_travel_document_stock_picking_batch_report" model="ir.actions.report">
            <field name="name">Surat Jalan Stock Picking Batch</field>
            <field name="model">stock.picking.batch</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_stock.batch_travel_document_template</field>
            <field name="print_report_name">'Print_Surat_Jalan_Batch_%s.pdf' % (object.name)</field>
            <field name="paperformat_id" ref="tw_web.tw_report_paperformat_a3"/>
        </record>
    </data>
</odoo>
