<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data> 
        
        <record id="tw_stock_picking_type_tree_inherit" model="ir.ui.view">
            <field name="name">tw.stock.picking.type.tree.inherit</field>
            <field name="model">stock.picking.type</field>
            <field name="inherit_id" ref="stock.view_picking_type_tree"/>
            <field name="arch" type="xml">
                <field name="company_id" position="after">
                    <field name="company_id"/>
                    <field name="division"/>
                </field>
            </field>
        </record>
        
        <record id="tw_stock_picking_type_form_inherit" model="ir.ui.view">
            <field name="name">tw.stock.picking.type.form.inherit</field>
            <field name="model">stock.picking.type</field>
            <field name="inherit_id" ref="stock.view_picking_type_form"/>
            <field name="arch" type="xml">
                <field name="code" position="after">
                    <field name="division"/>
                </field>
                <field name="company_id" position="after">
                    <field name="company_id" placeholder="e.g. Name/Code Dealer" options="{'no_open': True,'no_create': True}" force_save="1"/>
                </field>
                <xpath expr="//field[@name='sequence_id']" position="after">
                    <field name="batch_sequence_code"/>
                </xpath>
                <xpath expr="//field[@name='auto_batch']" position="before">
                    <field name="is_create_batch_next_step"/>
                    <field name="is_create_batch_backorder"/>
                    <field name="is_auto_create_batch_line"/>
                    <field name="is_validate_batch_line"/>
                    <field name="is_need_location"/>
                    <field name="default_qty"/>
                </xpath>
            </field>
        </record>

        <record id="tw_stock_picking_type_filter_inherit" model="ir.ui.view">
            <field name="name">tw.stock.picking.type.filter.inherit</field>
            <field name="model">stock.picking.type</field>
            <field name="inherit_id" ref="stock.view_pickingtype_filter" />
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="company_id"/>
                    <field name="division"/>
                </field>
            </field>
        </record>
        
    </data>
</odoo>