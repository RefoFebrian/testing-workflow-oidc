<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_stock_move_line_mobile_form_inherit" model="ir.ui.view">
            <field name="name">stock.move.line.mobile.form</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_move_line_form"/>
            <field name="priority">1000</field>
            <field name="arch" type="xml">
                <xpath expr="//form" position="attributes">
                    <attribute name="create">0</attribute>
                    <attribute name="edit">0</attribute>
                </xpath>
                <field name="product_id" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <xpath expr="//form/sheet/group/group/field[@name='location_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </xpath>
                <xpath expr="//form/sheet/group/group/field[@name='location_dest_id']" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </xpath>
                <field name="product_uom_id" position="attributes">
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                </field>
                <xpath expr="//field[@name='create_uid']" position="replace">
                </xpath>
            </field>
        </record>

        <record id="tw_stock_move_line_operation_inherit_view_tree" model="ir.ui.view">
            <field name="name">tw.stock.move.line.inherit.list</field>
            <field name="model">stock.move.line</field>
            <field name="inherit_id" ref="stock.view_stock_move_line_operation_tree" />
            <field name="arch" type="xml">

                <field name="lot_name" position="after">
                    <field name="categ_tracking" column_invisible="1"/>
                    <field name="chassis_number" string="Nomor Rangka" required="parent.use_create_lots and categ_tracking == 'serial_chassis' and parent.show_lots_text" column_invisible="not parent.use_create_lots or parent.has_tracking != 'serial' or parent.has_chassis_tracking != 'serial_chassis'" groups="stock.group_production_lot" force_save="1" />
                    <field name="production_year" required="parent.use_create_lots" string="Tahun Produksi" groups="stock.group_production_lot" column_invisible="not parent.use_create_lots or parent.has_tracking != 'serial'" force_save="1"/>
                    <field name="is_rfs" required="parent.use_create_lots" string="Ready for Sale?" groups="stock.group_production_lot" force_save="1"/>
                </field>

                <field name="lot_id" position="replace">
                    <field name="domain_lot_ids" column_invisible="1"/>
                    <field name="lot_id" string="Lot/Serial Number" groups="stock.group_production_lot" column_invisible="not parent.use_existing_lots or parent.has_tracking != 'serial' or not parent.show_lots_m2o" required="parent.use_existing_lots and parent.show_lots_m2o" domain="[('id', 'in', domain_lot_ids)]" readonly="picking_id.division == 'Sparepart'" options="{'no_create': True, 'no_open': True}" context="{
                            'active_picking_id': picking_id,
                            'default_product_id': parent.product_id,
                        }"/>
                </field>

                <field name="lot_name" position="replace">
                    <field name="lot_name" required="parent.use_create_lots" string="Nomor Mesin" groups="stock.group_production_lot" column_invisible="not parent.use_create_lots or parent.has_tracking != 'serial'" force_save="1" />
                </field>

                <xpath expr="//field[@name='product_uom_id'][2]" position="attributes">
                    <attribute name="optional">hide</attribute>
                </xpath>


                <xpath expr="//field[@name='location_dest_id'][2]" position="attributes">
                    <attribute name="string">Destination Location</attribute>
                    <attribute name="options">{'no_create': True,'no_open': True}</attribute>
                </xpath>

                <xpath expr="//field[@name='location_dest_id'][2]" position="before">
                    <field name="location_id" string="Source Location" column_invisible="parent.picking_code == 'incoming'" domain="[('id','in', parent.available_location_ids)]" options="{'no_create': True, 'no_open': True}" />
                </xpath>

                <field name="owner_id" position="attributes">
                    <attribute name="column_invisible">True</attribute>
                </field>

                <field name="quant_id" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                    <attribute name="optional">hide</attribute>
                </field>

                <xpath expr="//field[@name='result_package_id'][2]" position="attributes">
                    <attribute name="domain">[('picking_id', '=', parent.picking_id), ('product_id', '=', parent.product_id)]</attribute>
                    <attribute name="column_invisible">parent.has_tracking == 'serial' and parent.division != 'Sparepart'</attribute>
                    <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
                    <attribute name="readonly">1</attribute>
                    <attribute name="force_save">1</attribute>
                </xpath>

                <xpath expr="//field[@name='product_uom_id'][2]" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>