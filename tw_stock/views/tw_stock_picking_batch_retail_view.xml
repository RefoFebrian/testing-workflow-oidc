<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_stock_picking_batch_retail_list" model="ir.ui.view">
            <field name="name">stock.picking.batch.retail.list</field>
            <field name="model">stock.picking.batch</field>
            <field name="arch" type="xml">
                <list string="Stock Batch Transfer" multi_edit="1" sample="1" class="oe_stock_picking_batch" duplicate="0">
                    <field name="name" decoration-bf="1"/>
                    <field name="division" optional="show" readonly="1"/>
                    <field name="date" optional="show" readonly="1"/>
                    <field name="location_id" optional="show" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="description"/>
                    <field name="scheduled_date" readonly="1"/>
                    <field name="picking_type_id" readonly="1" options="{'no_create': True,'no_open': True}"/>
                    <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state in ('draft', 'in_progress')" decoration-danger="state == 'cancel'"/>
                    <field name="activity_exception_decoration" widget="activity_exception"/>
                </list>
            </field>
        </record>

        <record id="tw_stock_picking_batch_retail_form" model="ir.ui.view">
            <field name="name">stock.picking.batch.retail.form</field>
            <field name="model">stock.picking.batch</field>
            <field name="arch" type="xml">
                <form string="Stock Batch Transfer" duplicate="0">
                    <field name="type" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="show_check_availability" invisible="1"/>
                    <field name="show_allocation" invisible="1"/>
                    <field name="picking_type_code" invisible="1"/>
                    <field name="is_wave" invisible="1"/>
                    <field name="show_lots_text" invisible="1"/>
                    <header>
                        <button name="action_confirm" invisible="state != 'draft'" string="Confirm" type="object" class="oe_highlight" groups="tw_stock.group_tw_stock_picking_batch_button_confirm_read"/>
                        <button name="action_set_draft" invisible="state != 'cancel'" string="Set to Draft" type="object" class="oe_highlight" groups="tw_stock.group_tw_stock_picking_batch_button_set_draft_read"/>
                        <button name="action_done" string="Validate" type="object" class="oe_highlight" invisible="state != 'in_progress'" groups="tw_stock.group_tw_stock_picking_batch_button_validate_read"/>
                        <button name="action_cancel" string="Cancel" type="object" invisible="state != 'in_progress'" groups="tw_stock.group_tw_stock_picking_batch_button_cancel_read"/>
                        <button name="action_print_travel_document" string="Print Surat Jalan" type="object" invisible="state != 'done' and picking_type_id.code != 'outgoing'" data-hotkey="o" groups="tw_stock.group_tw_stock_travel_document"/>
                        <button name="action_batch_bastk_report" string="Print BASTK" type="object" invisible="state != 'done' and picking_type_id.code != 'outgoing'" groups="tw_stock.group_button_tw_stock_bastk"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_reception_report" string="Allocation" type="object" class="oe_stat_button" icon="fa-list" invisible="not show_allocation" groups="stock.group_reception_report"/>
                            <button name="action_view_pickings" string="View Pickings" type="object" class="oe_stat_button" icon="fa-list" invisible="not picking_ids"/>
                            <button name="action_view_next_batch" string="View Next Batch" type="object" class="oe_stat_button" icon="fa-truck" invisible="not batch_next_id"/>
                            <button name="action_view_backorder_batch" string="View Backorder Batch" type="object" class="oe_stat_button" icon="fa-share" invisible="not batch_backorder_id"/>
                        </div>
                        <div class="oe_title">
                            <h1>
                                <field name="name" class="oe_inline"/>
                            </h1>
                        </div>
                        <group>
                            <group id="batch_delivery_data">
                                <field name="company_id" groups="base.group_multi_company" string="Branch" readonly="state != 'draft'" force_save="1" options="{'no_create': True,'no_open': True}"/>
                                <field name="picking_type_id" required="1" readonly="state != 'draft'" options="{'no_create': True,'no_open': True}" domain="[('company_id', '=', company_id)]" />
                                <field name="source_picking_ids" widget="many2many_tags" domain="[
                                        ('state','in',['assigned','confirmed','waiting']), ('batch_id','=',False), ('division','=',division), ('picking_type_id','=',picking_type_id), ('company_id','=',company_id)
                                    ]" readonly="state != 'draft'" required="1" options="{'no_create': True,'no_open': True}" />
                                <field name="use_create_lots" invisible="1"/>
                                <field name="description" readonly="state != 'draft'"/>
                            </group>
                            <group name="detail">
                                <field name="division" placeholder="e.g. Division" required="1" readonly="context.get('is_readonly', state != 'draft')" force_save="1"/>
                                <field name="date" readonly="1" force_save="1"/>
                            </group>
                            <field name="properties" nolabel="1" columns="2" hideAddButton="1"/>
                            <field name="is_validate_batch_line" invisible="1"/>
                            <field name="is_need_location" invisible="1"/>
                            <field name="default_qty" invisible="1"/>
                        </group>
                        <notebook>
                            <page string="Batch Lines" invisible="is_validate_batch_line == True and state != 'draft'">
                                <label for="batch_line_ids" string="Unit" invisible="division == 'Sparepart'"/>
                                <field name="batch_line_ids" readonly="state != 'draft'">
                                    <list string="Batch Lines" editable="bottom">
                                        <field name="division" column_invisible="1"/>
                                        <field name="product_domain_ids" column_invisible="1"/>
                                        <field name="product_id" options="{'no_open': True, 'no_create': True}" required="1" domain="[('id','in',product_domain_ids)]"/>
                                        <field name="move_id" options="{'no_open': True, 'no_create': True}" readonly="1" force_save="1" optional="hide"/>
                                        <field name="lot_ids" column_invisible="1"/>
                                        <field name="lot_id" required="parent.division == 'Unit' and not parent.use_create_lots" column_invisible="parent.use_create_lots" options="{'no_open': True, 'no_create': True}" domain="[('id','in',lot_ids)]" />
                                        <field name="categ_tracking" column_invisible="1"/>
                                        <field name="lot_name" required="parent.division == 'Unit' and parent.use_create_lots" column_invisible="not parent.use_create_lots" />
                                        <field name="chassis_number" required="parent.division == 'Unit' and parent.use_create_lots and categ_tracking == 'serial_chassis'" column_invisible="not parent.use_create_lots" />
                                        <field name="production_year" required="parent.division == 'Unit' and parent.use_create_lots" column_invisible="not parent.use_create_lots" />
                                        <field name="location_id" readonly="1" force_save="1" column_invisible="parent.use_create_lots" options="{'no_open': True, 'no_create': True}" />
                                        <field name="location_dest_id" required="parent.division == 'Unit' and parent.use_create_lots" column_invisible="not parent.use_create_lots" options="{'no_open': True, 'no_create': True}" domain="[('usage','=','internal'),('company_id','=',parent.company_id)]" />
                                        <field name="is_rfs"/>
                                        <field name="quantity" string="Qty" sum="Total Quantity" required="1" readonly="parent.division == 'Unit'" force_save="1"/>
                                        <field name="product_uom_qty" string="Qty Seharusnya" readonly="1" force_save="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Pick/Pack Line" invisible="not is_validate_batch_line or state != 'in_progress'">
                                <field name="batch_line_ids" readonly="state != 'in_progress'">
                                    <list string="Batch Lines" editable="bottom">
                                        <field name="division" column_invisible="1"/>
                                        <field name="product_domain_ids" column_invisible="1"/>
                                        <field name="product_id" options="{'no_open': True, 'no_create': True}" required="1" domain="[('id','in',product_domain_ids)]"/>
                                        <field name="move_id" options="{'no_open': True, 'no_create': True}" readonly="1" force_save="1" optional="hide"/>
                                        <field name="lot_ids" column_invisible="1"/>
                                        <field name="lot_id" 
                                            required="parent.division == 'Unit' and not parent.use_create_lots" 
                                            column_invisible="parent.use_create_lots"
                                            options="{'no_open': True, 'no_create': True}" 
                                            domain="[('id','in',lot_ids)]"
                                        />
                                        <field name="location_id" 
                                            required="1"
                                            column_invisible="not parent.is_need_location"
                                            options="{'no_open': True, 'no_create': True}" 
                                        />
                                        <field name="quantity" string="Qty" sum="Total Quantity" required="1" readonly="parent.division == 'Unit'" force_save="1"/>
                                        <field name="product_uom_qty" string="Qty Seharusnya" readonly="1" force_save="1"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Detailed Operations" name="page_detailed_operations" invisible="state == 'draft'">
                                <field name="move_line_ids" context="{'list_view_ref': 'stock_picking_batch.view_move_line_tree'}" readonly="state not in ['draft', 'in_progress']" />
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_create': True,'no_open': True}"></field>
                                        <field name="create_date" readonly="1"></field>
                                        <field name="validate_uid" readonly="1" options="{'no_create': True,'no_open': True}"></field>
                                        <field name="validate_date" readonly="1"></field>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" options="{'no_create': True,'no_open': True}"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

