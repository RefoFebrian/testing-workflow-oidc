<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_faktur_pajak_out_list_view" model="ir.ui.view">
            <field name="name">tw.faktur.pajak.out.list</field>
            <field name="model">tw.faktur.pajak.out</field>
            <field name="arch" type="xml">
                <list string="Faktur Pajak" create="0" delete="0">
					<field name="company_id"/>
                    <field name="name"/>
                    <field name="transaction_id"/>
                    <field name="model_id"/>
                    <field name="is_combined_tax"/>
                    <field name="date"/>
                    <field name="partner_id"/>
                    <field name="untaxed_amount"/>
                    <field name="tax_amount"/>
                    <field name="amount_total"/>
                    <field name="release_date"/>
                    <field name="year"/>
           			<field name="state" widget="badge" decoration-success="state == 'close'" decoration-info="state in ('open', 'print')" decoration-danger="state == 'cancel'"/>
                </list>
            </field>
     	</record>

        <record id="tw_faktur_pajak_out_form_view" model="ir.ui.view">
            <field name="name">tw.faktur.pajak.out.form</field>
            <field name="model">tw.faktur.pajak.out</field>
            <field name="arch" type="xml">
                <form string="Faktur Pajak" create="0" edit="0" delete="0">
					<header>
						<field name="state" widget="statusbar" statusbar_visible="open,close,print"/>
	           		</header>
					<sheet>
						<div class="oe_title">
							<h1>
								<field name="name" readonly="1" force_save="1"/>
							</h1>
						</div>
	                   	<group>
	                   		<group>
			           			<field name="model_id" options="{'no_open':True,'no_create_edit':True}"/>
			           			<field name="is_combined_tax"/>
			           			<field name="partner_id" options="{'no_open':True,'no_create_edit':True}"/>
			                    <field name="release_date"/>
			                    <field name="year"/>
			                    <field name="ref"/>
                                <field name="company_id" options="{'no_open':True,'no_create_edit':True}"/>
	                   		</group>
	                   		<group>
			                    <field name="printed_count"/>
								<field name="date"/>
			                    <field name="untaxed_amount"/>
			                    <field name="tax_amount"/>
			                    <field name="amount_total"/>
							</group>
	           			</group>
						<notebook> 
							<page string="Audit Trail" name="audit_trail">
								<group>
									<group>
										<field name="create_uid" options="{'no_open':True,'no_create_edit':True}" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
									</group>
									<group>
										<field name="write_uid" options="{'no_open':True,'no_create_edit':True}" readonly="1"></field>
										<field name="write_date" readonly="1"></field>
									</group>
								</group>
							</page>
					  </notebook>
           			</sheet>
                </form>
			</field>
      	</record>

		<record id="tw_faktur_pajak_out_search_view" model="ir.ui.view">
            <field name="name">tw.faktur.pajak.out.search</field>
            <field name="model">tw.faktur.pajak.out</field>
            <field name="arch" type="xml">
                <search string="Faktur Pajak">
                	<field name="name"/>
        			<field name="partner_id"/>
        			<field name="model_id"/>
        			<field name="transaction_id"/>
                    <field name="company_id"/>
                    <field name="year"/>
					<filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
					<filter name="close" string="Close" domain="[('state','=','close')]"/>
					<filter name="print" string="Print" domain="[('state','=','print')]"/>
					<filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Form" name="form" domain="[]" context="{'group_by':'model_id'}"/>
						<filter string="Tanggal" name="date" domain="[]" context="{'group_by':'date'}"/>
						<filter string="Partner" name="partner" domain="[]" context="{'group_by':'partner_id'}"/>
                        <filter string="Branch" name="branch" domain="[]" context="{'group_by':'company_id'}"/>
						<filter string="State" name="state" domain="[]" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>
		
		<record id="tw_faktur_pajak_out_action" model="ir.actions.act_window">
		    <field name="name">Faktur Pajak</field>
			<field name="res_model">tw.faktur.pajak.out</field>
		    <field name="view_mode">list,form</field>
		</record>
    </data>
</odoo>