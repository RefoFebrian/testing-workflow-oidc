<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_faktur_pajak_multi_company_rule" model="ir.rule">
            <field name="name">TW Faktur Pajak Multi-Company</field>
            <field name="model_id" ref="model_tw_faktur_pajak"/>
            <field name="domain_force">[('company_id', 'child_of', company_ids)]</field>
        </record>
        <record id="tw_faktur_pajak_out_multi_company_rule" model="ir.rule">
            <field name="name">TW Faktur Pajak Out Multi-Company</field>
            <field name="model_id" ref="model_tw_faktur_pajak_out"/>
            <field name="domain_force">['|', ('company_id', 'child_of', company_ids), ('faktur_pajak_id.company_id', 'child_of', company_ids)]</field>
        </record>
    </data>
</odoo>
