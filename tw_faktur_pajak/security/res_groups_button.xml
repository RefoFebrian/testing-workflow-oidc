<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Post Faktur Pajak -->
        <record id="group_tw_faktur_pajak_button_post" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Post Faktur Pajak</field>
        </record>

        <record id="access_tw_faktur_pajak_button_post" model="ir.model.access">
            <field name="model_id" ref="tw_faktur_pajak.model_tw_faktur_pajak"/>
            <field name="name">tw_faktur_pajak_button_post update</field>
            <field name="group_id" ref="group_tw_faktur_pajak_button_post"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_faktur_pajak_button_post')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>