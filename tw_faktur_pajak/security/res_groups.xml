<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- TW Faktur Pajak -->
        <!-- READ  -->
        <record id="group_tw_faktur_pajak_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Read</field>
        </record>

        <record id="access_tw_faktur_pajak_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak"/>
            <field name="name">tw_faktur_pajak read</field>
            <field name="group_id" ref="group_tw_faktur_pajak_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_faktur_pajak_out_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_out"/>
            <field name="name">tw_faktur_pajak_out read</field>
            <field name="group_id" ref="group_tw_faktur_pajak_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- UPDATE  -->
        <record id="group_tw_faktur_pajak_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_faktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_faktur_pajak_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak"/>
            <field name="name">tw_faktur_pajak update</field> 
            <field name="group_id" ref="group_tw_faktur_pajak_update"/>
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

        <record id="access_tw_faktur_pajak_out_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_out"/>
            <field name="name">tw_faktur_pajak_out update</field> 
            <field name="group_id" ref="group_tw_faktur_pajak_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- DELETE  -->
        <record id="group_tw_faktur_pajak_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_faktur_pajak_read'))]"/>
        </record>

        <record id="access_tw_faktur_pajak_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak"/>
            <field name="name">tw_faktur_pajak delete</field>
            <field name="group_id" ref="group_tw_faktur_pajak_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_faktur_pajak_out_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_out"/>
            <field name="name">tw_faktur_pajak_out delete</field>
            <field name="group_id" ref="group_tw_faktur_pajak_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_faktur_pajak_read')),
                (4, ref('group_tw_faktur_pajak_update')),
                (4, ref('group_tw_faktur_pajak_delete')),
            ]"/>
        </record>
    </data>

</odoo>
