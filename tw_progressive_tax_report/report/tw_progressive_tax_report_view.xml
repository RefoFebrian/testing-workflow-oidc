<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_progressive_tax_report_view_form" model="ir.ui.view">
            <field name="name">tw.progressive.tax.report.view.form</field>
            <field name="model">tw.progressive.tax.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report Pajak Progressive">
                    <group>
                        <group>
                            <label for="start_date" string="Periode"/>
                            <div>
                                <field name="start_date" placeholder="Start date" class="oe_inline"/>
                                <field name="end_date" placeholder="End date" class="oe_inline"/>
                            </div>
                        </group>
                        <group>
                            <field name="state" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branch">
                            <field name="company_ids" colspan="4" nolabel="1" required="1" />
                        </page>
                    </notebook>
                    <footer>
                        <button name="excel_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                    
                </form>
            </field>
        </record>

        <record id="action_tw_progressive_tax_report" model="ir.actions.act_window">
            <field name="name">Laporan Pajak Progressive</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.progressive.tax.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
         
    </data>
</odoo>