<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- teds Lead Group Read -->
        <record id="module_category_config" model="ir.module.category">
            <field name="name">DB Config</field>
            <field name="sequence">60</field>
        </record>

        <record id="tw_db_config_group_read" model="res.groups">
            <field name="category_id" ref="module_category_config" />
            <field name="name">TW DB Config Read</field>
        </record>

        <record id="tw_db_config_access_read" model="ir.model.access">
            <field name="name">tw_db_config read</field>
            <field name="model_id" ref="model_tw_db_config" />
            <field name="group_id" ref="tw_db_config_group_read" />
            <field name="perm_read">1</field>
        </record>
        
        <record id="tw_db_config_group_update" model="res.groups">
            <field name="category_id" ref="module_category_config" />
            <field name="name">TW DB Config Update</field>
        </record>

        <record id="tw_db_config_access_update" model="ir.model.access">
            <field name="name">tw_db_config update</field>
            <field name="model_id" ref="model_tw_db_config" />
            <field name="group_id" ref="tw_db_config_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_db_config_group_delete" model="res.groups">
            <field name="category_id" ref="module_category_config" />
            <field name="name">TW DB Config Delete</field>
        </record>

        <record id="tw_db_config_access_delete" model="ir.model.access">
            <field name="name">tw_db_config delete</field>
            <field name="model_id" ref="model_tw_db_config" />
            <field name="group_id" ref="tw_db_config_group_delete" />
            <field name="perm_unlink">1</field>
        </record>


    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
               	(4, ref('tw_db_config_group_read')),
                (4, ref('tw_db_config_group_update')),
                (4, ref('tw_db_config_group_delete')),
				]"/>
        </record>
    </data>
</odoo>