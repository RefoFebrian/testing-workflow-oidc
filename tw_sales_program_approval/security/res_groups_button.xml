<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_tw_sales_program_rfa" model="res.groups">
            <field name="name">TW Button Request Approval Sales Program</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>
        <record id="access_tw_sales_program_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="name">tw_sales_program_rfa</field>
            <field name="group_id" ref="group_tw_sales_program_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_sales_program_cancel_button" model="res.groups">
            <field name="name">TW Button Cancel Sales Program</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>
        <record id="access_tw_sales_program_cancel_button" model="ir.model.access">
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="name">tw_sales_program_cancel_button update</field>
            <field name="group_id" ref="group_tw_sales_program_cancel_button"/>
            <field name="perm_write">1</field>
        </record>

        
        <record id="group_tw_sales_program_reject_button" model="res.groups">
            <field name="name">TW Button Reject Sales Program</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>
        <record id="access_tw_sales_program_reject_button" model="ir.model.access">
            <field name="model_id" ref="tw_sales_program.model_tw_sales_program"/>
            <field name="name">tw_sales_program_reject_button update</field>
            <field name="group_id" ref="group_tw_sales_program_reject_button"/>
            <field name="perm_write">1</field>
        </record>


    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_sales_program_rfa')),
                (4, ref('group_tw_sales_program_cancel_button')),
                (4, ref('group_tw_sales_program_reject_button')),
            ]" />
        </record>
    </data>
</odoo>
