<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_service_package_view_form" model="ir.ui.view">
            <field name="name">tw.service.package.form</field>
            <field name="model">tw.service.package</field>
            <field name="arch" type="xml">
                <form string="Paket Service">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="area_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="active"/>
                                <field name="is_priority"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Detail Paket">
                                <field name="line_ids">
                                    <list editable="bottom" delete="0" decoration-muted="active == False">
                                        <field name="division" required="1"/>
                                        <field name="product_id" required="1" domain="[('sale_ok', '=', True),('division','=',division)]"/>
                                        <field name="quantity" required="1"/>
                                        <field name="discount"/>
                                        <field name="active" widget="boolean_toggle" readonly="1" force_save="1" invisible="1" nolabel="1"/>
                                        <field name="create_uid" optional="hide" readonly="1"/>
                                        <field name="create_date" optional="hide" readonly="1"/>
                                        <field name="write_uid" optional="hide" readonly="1"/>
                                        <field name="write_date" optional="hide" readonly="1"/>
                                        <button name="toggle_active" type="object" string="Nonaktifkan" class="btn-secondary" invisible="active == False" confirm="Apakah Anda yakin ingin menonaktifkan baris ini?"/>
                                        <button name="toggle_active" type="object" string="Aktifkan" class="btn-primary" invisible="active == True"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" string="Created By"/>
                                        <field name="create_date" readonly="1" string="Created On"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" string="Last Update By"/>
                                        <field name="write_date" readonly="1" string="Last Update On"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_service_package_view_list" model="ir.ui.view">
            <field name="name">tw.service.package.list</field>
            <field name="model">tw.service.package</field>
            <field name="arch" type="xml">
                <list string="Paket Service">
                    <field name="company_id"/>
                    <field name="area_id"/>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="active"/>
                    <field name="is_priority"/>
                </list>
            </field>
        </record>

        <record id="tw_service_package_view_search" model="ir.ui.view">
            <field name="name">tw.service.package.search</field>
            <field name="model">tw.service.package</field>
            <field name="arch" type="xml">
                <search string="Cari Paket Service">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="area_id"/>
                    <field name="active"/>
                    <field name="is_priority"/>
                    <filter name="filter_active" string="Aktif" domain="[('active', '=', True)]"/>
                    <filter name="filter_inactive" string="Non-aktif" domain="[('active', '=', False)]"/>
                    <filter name="filter_priority" string="Prioritas" domain="[('is_priority', '=', True)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_company" domain="[]" context="{'group_by': 'company_id'}"/>
                        <filter string="Area" name="group_by_area" domain="[]" context="{'group_by': 'area_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="tw_service_package_action" model="ir.actions.act_window">
            <field name="name">Service Package</field>
            <field name="res_model">tw.service.package</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Buat Paket Service baru
                </p>
            </field>
        </record>
    </data>
</odoo>
