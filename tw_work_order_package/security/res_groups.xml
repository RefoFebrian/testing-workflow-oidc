<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- TW Service Package -->
        <record id="tw_service_package_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Service Package Read</field>
        </record>

        <record id="tw_service_package_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package" />
            <field name="name">tw_service_package read</field>
            <field name="group_id" ref="tw_service_package_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_service_package_line_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package_line" />
            <field name="name">tw_service_package_line read</field>
            <field name="group_id" ref="tw_service_package_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_service_package_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Service Package Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_service_package_group_read'))]" />
        </record>

        <record id="tw_service_package_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package" />
            <field name="name">tw_service_package update</field>
            <field name="group_id" ref="tw_service_package_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_service_package_line_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package_line" />
            <field name="name">tw_service_package_line update</field>
            <field name="group_id" ref="tw_service_package_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_service_package_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Service Package Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_service_package_group_read'))]" />
        </record>

        <record id="tw_service_package_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package" />
            <field name="name">tw_service_package delete</field>
            <field name="group_id" ref="tw_service_package_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="tw_service_package_line_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_package_line" />
            <field name="name">tw_service_package_line delete</field>
            <field name="group_id" ref="tw_service_package_group_delete" />
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_service_package_group_read')),
                (4,ref('tw_service_package_group_update')),
                (4,ref('tw_service_package_group_delete')),
            ]" />
        </record>
    </data>
</odoo>