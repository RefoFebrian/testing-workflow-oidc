<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_stock_distribution_update_date_view_wizard" model="ir.ui.view">
		    <field name="name">tw.stock.distribution.update.date.view.wizard</field>
		    <field name="model">tw.stock.distribution</field>
		    <field name="arch" type="xml">
		        <form>
                    <group>
                        <field name="start_date" string="Start Date" required="1"/>
                        <field name="end_date" string="End Date" required="1"/>
                    </group>
                    <footer>
                        <button name="action_confirm_update_date" type="object" string="Confirm" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
		        </form>
		    </field>
        </record>
	</data>
</odoo>