    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_stock_distribution_showroom_read')),
                (4, ref('group_tw_stock_distribution_showroom_update')),
                (4, ref('group_tw_stock_distribution_showroom_delete')),
                (4, ref('group_tw_stock_distribution_workshop_read')),
                (4, ref('group_tw_stock_distribution_workshop_update')),
