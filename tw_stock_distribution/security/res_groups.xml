<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- TW Stock Distribution Showroom -->
        <!-- READ  -->
        <record id="group_tw_stock_distribution_showroom_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Stock Distribution Showroom Read</field>
        </record>

        <record id="access_tw_stock_distribution_showroom_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_distribution"/>
            <field name="name">tw_stock_distribution_showroom read</field>
            <field name="group_id" ref="group_tw_stock_distribution_showroom_read"/>
