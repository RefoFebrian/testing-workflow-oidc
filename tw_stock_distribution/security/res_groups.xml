            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Stock Distribution Showroom Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_stock_distribution_showroom_read'))]"/>
        </record>

        <record id="access_tw_stock_distribution_showroom_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_distribution"/>
            <field name="name">tw_stock_distribution_showroom delete</field>
            <field name="group_id" ref="group_tw_stock_distribution_showroom_delete"/>
