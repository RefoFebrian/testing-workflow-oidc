<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Process Stock Inbound -->
		<record id="group_button_process_stock_inbound" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Process Stock Inbound</field>
        </record>
        
        <record id="access_button_mark_process_stock_inbound" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_inbound"/>
            <field name="name">tw_stock_inbound_button_process update</field>
            <field name="group_id" ref="group_button_process_stock_inbound"/>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_button_process_stock_inbound')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>