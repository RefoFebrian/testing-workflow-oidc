<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_dealer_sale_order_pelunasan_leasing_bank_wizard_view" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.pelunasan.leasing.bank.wizard</field>
            <field name="model">tw.dealer.sale.order</field>
            <field name="arch" type="xml">
                <form string="Pelunasan Leasing">
                    <group>
                        <field name="company_id" invisible="True"/>
                        <field name="journal_id" required="True" domain="[('company_id','=',company_id)]" options="{'no_create': True,'no_open':True}"/>
                    </group>
                    <footer>
                        <button name="action_print_report_pelunasan_leasing" string="Print" type="object" class="oe_highlight"/>
                        <button string="Close" special="cancel" class="btn-secondary"/>
		            </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>