<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_dealer_sale_order_surat_kuasa_wizard_view" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.surat.kuasa.wizard</field>
            <field name="model">tw.dealer.sale.order</field>
            <field name="arch" type="xml">
                <form string="Surat Kuasa">
                    <group>
                        <field name="power_of_attorney_type" required="True"/>
                    </group>
                    <footer>
                        <button name="action_print_report_surat_kuasa" string="Print" type="object" class="oe_highlight"/>
                        <button string="Close" special="cancel" class="btn-secondary"/>
		            </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>