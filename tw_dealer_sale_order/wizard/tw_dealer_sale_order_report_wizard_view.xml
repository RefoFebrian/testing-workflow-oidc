<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_dealer_sale_order_report_wizard_view" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.report.wizard</field>
            <field name="model">tw.dealer.sale.order</field>
            <field name="arch" type="xml">
                <form string="SO" create="false" edit="false">
                    <div style="display: inline-block; margin-right: 8px;" name="print_report_dp_po">
                        <button name="action_print_report_dp_po" invisible="state not in ('sale','done')" type="object" string="Print DP PO" class="oe_highlight"/>
                    </div>

                    <div style="display: inline-block; margin-right: 8px;" name="pelunasan_leasing_bank_wizard_view">
                        <button name="action_pelunasan_leasing_bank_wizard_view" invisible="state not in ('sale','done')" type="object" string="Print Pelunasan Leasing" class="oe_highlight"/>
                    </div>

                    <div style="display: inline-block; margin-right: 8px;" name="print_report_serah_bpkb">
                        <button name="action_print_report_serah_bpkb" invisible="state not in ('sale','done')" type="object" string="Print Serah BPKB" class="oe_highlight"/>
                    </div>

                    <div style="display: inline-block; margin-right: 8px;" name="print_report_invoice_dso">
                        <button name="action_print_report_invoice_dso" invisible="state not in ('sale','done')" type="object" string="Print Invoice DSO" class="oe_highlight"/>
                    </div>

                    <div style="display: inline-block; margin-right: 8px;" name="print_report_surat_kuasa">
                        <button name="action_surat_kuasa_wizard_view" invisible="state not in ('sale','done')" type="object" string="Print Surat Kuasa" class="oe_highlight"/>
                    </div>

                    <div style="display: inline-block; margin-right: 8px;" name="print_report_cod_settlement">
                        <button name="action_cod_settlement_wizard_view" invisible="is_cod != True and state not in ('sale','done')" type="object" string="Print Pelunasan COD" class="oe_highlight"/>
                    </div>

                    <field name="state" invisible="1"/>
                    <footer>
                        <button string="Close" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>