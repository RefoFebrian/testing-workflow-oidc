<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_stock_lot_dealer_sale_order_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.stock.lot.dealer.sale.order.inherit.form</field>
            <field name="model">stock.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='main_group']" position="after">
                    <group>
                        <group name="dealer_sale_order_group" string="Sales Information">
                            <field name="sales_order_reserved_id" readonly="1" options="{'no_create': True}"/>
                            <field name="customer_reserved_id" readonly="1" options="{'no_create': True}"/>
                            <field name="payment_type_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                            <field name="dealer_sale_order_id" readonly="1" options="{'no_create': True}"/>
                            <field name="partner_id" readonly="1" options="{'no_create': True}"/>
                        </group>
                        <group name="dealer_sale_order_group2" string="">
                            <field name="do_date" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="downpayment" readonly="1"/>
                        </group>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>