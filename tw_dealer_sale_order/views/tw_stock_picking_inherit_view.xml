<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_stock_picking_dso_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.stock.picking.dealer.sale.order.inherit.form</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <!-- Hide the cancel button if this delivery comes from an active Dealer Sale Order -->
                <xpath expr="//header/button[@name='action_cancel']" position="attributes">
                    <attribute name="invisible">state not in ('assigned', 'confirmed', 'draft', 'waiting') or dealer_sale_order_id != False</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
