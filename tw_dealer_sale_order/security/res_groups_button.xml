<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Button Groups -->
        <record id="group_tw_dealer_sale_order_confirm" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
            <field name="name">TW Button Dealer Sale Order Confirm</field>
        </record>

        <record id="access_tw_dealer_sale_order_stock_wh_orderpoint_read" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_warehouse_orderpoint" />
            <field name="name">access_tw_dealer_sale_order_stock_wh_orderpoint read</field>
            <field name="group_id" ref="group_tw_dealer_sale_order_confirm"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_dealer_sale_order_confirm_edit_user_read" model="ir.model.access">
            <field name="model_id" ref="base.model_res_users" />
            <field name="name">access_tw_dealer_sale_order_confirm_edit_user read</field>
            <field name="group_id" ref="group_tw_dealer_sale_order_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_dealer_sale_order_cancel" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
            <field name="name">TW Button Dealer Sale Order Cancel</field>
        </record>

        <record id="access_tw_dealer_sale_order_stock_wh_orderpoint_cancel" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_warehouse_orderpoint"/>
            <field name="name">access_tw_dealer_sale_order_stock_wh_orderpoint cancel</field>
            <field name="group_id" ref="group_tw_dealer_sale_order_cancel"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_dealer_sale_order_view_picking" model="res.groups">
            <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
            <field name="name">TW Button Dealer Sale Order View Picking</field>
        </record>
        
        <record id="group_tw_dealer_sale_order_view_invoice" model="res.groups">
           <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
           <field name="name">TW Button Dealer Sale Order View Invoice</field> 
        </record>

        <record id="group_tw_dealer_sale_order_view_journal_entry" model="res.groups">
           <field name="category_id" ref="tw_dealer_sale_order.tw_module_category_dealer_sale_order"/>
           <field name="name">TW Button Dealer Sale Order View Journal Entry</field> 
        </record>
        
    </data>

    <data>
        <!-- Add all button groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_dealer_sale_order_confirm')),
                (4, ref('group_tw_dealer_sale_order_cancel')),
                (4, ref('group_tw_dealer_sale_order_view_picking')),
                (4, ref('group_tw_dealer_sale_order_view_invoice')),
                (4, ref('group_tw_dealer_sale_order_view_journal_entry')),
            ]" />
        </record>
    </data>
</odoo>
