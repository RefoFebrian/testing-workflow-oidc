<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_dso_data_consumen_report_wizard_view" model="ir.ui.view">
            <field name="name">tw.dso.data.consumen.report.wizard</field>
            <field name="model">tw.dealer.sale.order.data.consumen.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form create="0" edit="0" delete="0">
                    <group>
                        <label for="start_date" string="Periode"/>
                        <div>
                            <field name="start_date"
                                    widget="daterange"
                                    options="{'end_date_field': 'end_date'}"
                                    required="1" />
                            <field name="end_date" invisible="1" />
                        </div>
                    </group>
                    <notebook>
                        <page string="Companies">
                            <field name="company_ids" colspan="4" nolabel="1"/>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="tw_dso_data_consumen_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Data Konsumen</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.dealer.sale.order.data.consumen.report</field>
            <field name="view_id" ref="tw_dso_data_consumen_report_wizard_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>