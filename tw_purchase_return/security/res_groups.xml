<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Purchase Return -->
        <record id="group_tw_purchase_return_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Purchase Return Read</field>
        </record>
        
        <record id="access_tw_purchase_return_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return"/>
            <field name="name">tw_purchase_return read</field>
            <field name="group_id" ref="group_tw_purchase_return_read"/>
            <field name="perm_read">1</field>
        </record> 

        <record id="access_tw_purchase_return_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return_line"/>
            <field name="name">tw_purchase_return_line read</field>
            <field name="group_id" ref="group_tw_purchase_return_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_purchase_return_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Purchase Return Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_purchase_return_read'))]"/>
        </record>
        
        <record id="access_tw_purchase_return_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return"/>
            <field name="name">tw_purchase_return update</field>
            <field name="group_id" ref="group_tw_purchase_return_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record> 

        <record id="access_tw_purchase_return_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return_line"/>
            <field name="name">tw_purchase_return_line update</field> 
            <field name="group_id" ref="group_tw_purchase_return_update"/>  
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_purchase_return_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Purchase Return Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_purchase_return_read'))]"/>
        </record>
        
        <record id="access_tw_purchase_return_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return"/>
            <field name="name">tw_purchase_return delete</field>
            <field name="group_id" ref="group_tw_purchase_return_delete"/>
            <field name="perm_unlink">1</field>
        </record> 

        <record id="access_tw_purchase_return_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return_line"/>
            <field name="name">tw_purchase_return_line delete</field>
            <field name="group_id" ref="group_tw_purchase_return_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_return_read')),
                (4, ref('group_tw_purchase_return_update')),
                (4, ref('group_tw_purchase_return_delete'))
            ]"/>
        </record>
    </data>
</odoo>
