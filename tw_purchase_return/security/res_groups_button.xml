<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_purchase_return_create_invoice" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Create Invoice</field>
        </record>
             
        <record id="access_tw_purchase_return_create_invoice_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_create_invoice read</field> 
            <field name="group_id" ref="group_tw_purchase_return_create_invoice"/>  
            <field name="perm_read">1</field> 
        </record>   

        <record id="group_tw_purchase_return_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Confirm</field>
        </record>
             
        <record id="access_tw_purchase_return_confirm_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_confirm read</field> 
            <field name="group_id" ref="group_tw_purchase_return_confirm"/>  
            <field name="perm_read">1</field> 
        </record>  
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_return_create_invoice')),
                (4, ref('group_tw_purchase_return_confirm')),
            ]"/>
        </record>
    </data>

</odoo>
