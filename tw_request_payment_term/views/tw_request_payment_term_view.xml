<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record model="ir.ui.view" id="tw_request_payment_term_list_view">
      <field name="name">tw.request.payment.term.list.view</field>
      <field name="model">tw.request.payment.term</field>
      <field name="arch" type="xml">
        <list>
          <field name="company_id" string="Branch"/>
          <field name="division"/>
          <field name="date"/>
          <field name="partner_id"/>
          <field name="name" string="Reference"/>
          <field name="payment_term_id" string="Current Payment Term"/>
          <field name="trans_type" string="Type"/>
          <field name="state"/>
        </list>
      </field>
    </record>
    <record id="tw_request_payment_term_form_view" model="ir.ui.view">
      <field name="name">tw.request.payment.term.form_view</field>
      <field name="model">tw.request.payment.term</field>
      <field name="arch" type="xml">
        <form string="Payment Term Entries">
          <header>
              <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'" groups='tw_request_payment_term.group_request_payment_term_confirm_button'/>
              <field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>
          </header>
          <sheet>
            <div class="oe_title">
                <h1 invisible="name"><span>Draft</span></h1>
                <h1 invisible="not name"><field name="name" readonly="1"/></h1>
            </div>
            <group>
              <group>
                  <field name="company_id" string="Branch" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                  <field name="partner_id" required="1" options="{'no_create': True, 'no_open': True}" readonly="state != 'draft'"/>
                  <field name="trans_type" required="1" readonly="state != 'draft'"/>
                  <field name="current_payment_term_id" readonly="1"/>
                  <field name="payment_term_id" string="New Payment Term" required="1" readonly="state != 'draft'"/>
              </group>
              <group>
                  <field name="division" required="1" readonly="state != 'draft'"/>
                  <field name="date" readonly="1"/>
              </group>
            </group>
            <notebook>
            <page string="Audit Trail" name="audit_trail">
              <group>
                <group string="Stage">
                  <label for="create_uid" string="Created by"/>
                  <div>
                    <field name="create_uid" readonly="1" class="oe_inline"/>
                    <field name="create_date" string="on" readonly="1" class="oe_inline" style="margin-left: 20px;"/>
                  </div>
                  <label for="confirm_uid" string="Confirmed by"/>
                  <div>
                      <field name="confirm_uid" readonly="1" class="oe_inline"/>
                      <field name="confirm_date" string="on" readonly="1" class="oe_inline" style="margin-left: 20px;"/>
                  </div>
                </group>
                <group string="Last Updated">
                  <label for="write_uid" string="Last Updated by"/>
                  <div>
                    <field name="write_uid" readonly="1" class="oe_inline"/>
                    <field name="write_date" string="on" readonly="1" class="oe_inline" style="margin-left: 20px;"/>
                  </div>
                </group>
              </group>
            </page>
          </notebook>
          </sheet>
        </form>
      </field>
    </record>
    <record model="ir.actions.act_window" id="tw_request_payment_term_act_window">
      <field name="name">Request Payment Term</field>
      <field name="res_model">tw.request.payment.term</field>
      <field name="view_mode">list,form</field>
      <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
              Create your first Payment Request
          </p>
      </field>      
    </record>
  </data>
</odoo>
