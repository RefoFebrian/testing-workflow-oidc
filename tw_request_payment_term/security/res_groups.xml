<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- RPT Read Group -->
        <record id="group_tw_request_payment_term_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Request Payment Term Read</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- RPT Update Group -->
        <record id="group_tw_request_payment_term_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Request Payment Term Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_request_payment_term_read'))]"/>
        </record>

        <!-- RPT Delete Group -->
        <record id="group_tw_request_payment_term_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Request Payment Term Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_request_payment_term_read'))]"/>
        </record>

    </data>
    
    <!-- Add all Request Payment Term groups to System Admin in one go for better performance -->
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_request_payment_term_read')),
                (4, ref('group_tw_request_payment_term_update')),
                (4, ref('group_tw_request_payment_term_delete'))
            ]"/>
        </record>
    </data>
</odoo>
