<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <template id="dg_print_validasi">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <div class="page" style="font-family: Arial, Helvetica, sans-serif;">
                        <div class="oe_structure"/>
                        <div class="col-xs-12" style="margin-bottom:10px;">
                            <table style="font-size:10px; width:100%; line-height:1.6; border-collapse: collapse; border:1px solid black;">
                                <tr>
                                    <th colspan="4"
                                        style="font-size:12px; text-align:left; padding:5px; border:1px solid black; font-weight:bold;">
                                        <span t-esc="doc.name or '-'"/>
                                    </th>
                                </tr>
                                <tr>
                                    <th style="width:15%; padding:4px; border:1px solid black; font-weight:bold;">
                                        Branch
                                    </th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.company_id.display_name or '-'"/>
                                    </td>
                                    <th style="width:15%; padding:4px; border:1px solid black; font-weight:bold;">PDI
                                    </th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.pdi_id.name or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="padding:4px; border:1px solid black; font-weight:bold;">Division</th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.division or '-'"/>
                                    </td>
                                    <th style="padding:4px; border:1px solid black; font-weight:bold;">ADH</th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.adh_id.name or '-'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <th style="padding:4px; border:1px solid black; font-weight:bold;">Tanggal SO</th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.date.strftime('%d-%m-%Y') if doc.date else '-'" />
                                    </td>
                                    <th style="padding:4px; border:1px solid black; font-weight:bold;">SOH</th>
                                    <td style="padding:4px; border:1px solid black;">: &#160;<span t-esc="doc.soh_id.name or '-'"/>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div class="col-xs-12" style="margin-top:10px;">
                            <p style="font-weight:bold; margin-bottom:5px;">Data Stock Direct Gift</p>
                            <table style="font-size:9px; width:100%; border-collapse: collapse; border:1px solid black;">
                                <thead style="background-color:#f2f2f2;">
                                    <tr>
                                        <th style="padding:3px; text-align:center; border:1px solid black;">No</th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Nama Barang
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Aging</th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Harga Satuan
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Qty Sistem
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Amount Total
                                            Sistem
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Qty Fisik
                                            Baik
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Qty Fisik
                                            Rusak
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Total Qty
                                            Fisik
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Amount Total
                                            Fisik
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Selisih Qty
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Selisih
                                            Amount
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Saldo
                                            Logbook
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.detail_ids" t-as="detail" t-index="detail_index">
                                        <tr style="page-break-inside: avoid;">
                                            <td style="padding:3px; text-align:center; border:1px solid black;">
                                                <span t-esc="detail_index + 1"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.product_id.display_name or '-'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.aging or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.unit_price or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.qty or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.amount or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.qty_physical_good or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.qty_physical_broken or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.qty_physical_total or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="detail.amount_total or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.diff_qty or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.diff_amount or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="detail.balance_log_book or '0'"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot style="font-weight:bold;">
                                    <tr>
                                        <td colspan="4"
                                            style="padding:3px; text-align:left; border:1px solid black;">Total
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.qty for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.amount for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.qty_physical_good for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.qty_physical_broken for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.qty_physical_total for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(detail.amount_total for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;">
                                            <span t-esc="sum(detail.diff_qty for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;">
                                            <span t-esc="sum(detail.diff_amount for detail in doc.detail_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;">
                                            <span t-esc="sum(detail.balance_log_book for detail in doc.detail_ids)"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="col-xs-12" style="margin-top:10px;">
                            <p style="font-weight:bold; margin-bottom:5px;">Fisik Tidak Tercatat Sistem</p>
                            <table style="font-size:9px; width:100%; border-collapse: collapse; border:1px solid black;">
                                <thead style="background-color:#f2f2f2;">
                                    <tr>
                                        <th style="padding:3px; text-align:center; border:1px solid black;">No</th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Nama Barang
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Qty Fisik
                                            Baik
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Qty Fisik
                                            Rusak
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Total Qty
                                            Fisik
                                        </th>
                                        <th style="padding:3px; text-align:left; border:1px solid black;">Saldo
                                            Logbook
                                        </th>
                                    </tr>

                                </thead>
                                <tbody>
                                    <t t-foreach="doc.other_dg_ids" t-as="other" t-index="other_index">
                                        <tr style="page-break-inside: avoid;">
                                            <td style="padding:3px; text-align:center; border:1px solid black;">
                                                <span t-esc="other_index + 1"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="other.product_name or '-'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="other.qty_physical_good or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="other.qty_physical_broken or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;" class="text-end">
                                                <span t-esc="other.qty_physical_total or '0'"/>
                                            </td>
                                            <td style="padding:3px; border:1px solid black;">
                                                <span t-esc="other.balance_log_book or '0'"/>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>

                                <tfoot style="font-weight:bold;">
                                    <tr>
                                        <td colspan="2"
                                            style="padding:3px; text-align:left; border:1px solid black;">Total
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(other.qty_physical_good for other in doc.other_dg_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(other.qty_physical_broken for other in doc.other_dg_ids)"/>
                                        </td>
                                        <td style="padding:3px; border:1px solid black;" class="text-end">
                                            <span t-esc="sum(other.qty_physical_total for other in doc.other_dg_ids)"/>
                                        </td>

                                        <td style="padding:3px; border:1px solid black;">
                                            <span t-esc="sum(other.balance_log_book for other in doc.other_dg_ids)"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="col-xs-12" style="margin-top: 20px;">
                            <table style="font-size:10px; width:100%; text-align:center; border-collapse: collapse; border:1px solid black;">
                                <thead>
                                    <tr>
                                        <th style="text-align: center; border:1px solid black;">PIC SO</th>
                                        <th colspan="2" style="text-align: center; border:1px solid black;">
                                            MENGETAHUI
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr style="height: 80px;">
                                        <td style="border:1px solid black;"></td>
                                        <td style="border:1px solid black;"></td>
                                        <td style="border:1px solid black;"></td>
                                    </tr>
                                    <tr>
                                        <td style="width:33.3%; border:1px solid black;">
                                            <span t-esc="doc.adh_id.name or '-'"/>
                                            <br/>
                                            ADH
                                        </td>
                                        <td style="width:33.3%; border:1px solid black;">
                                            <span t-esc="doc.pdi_id.name or '-'"/>
                                            <br/>
                                            PDI
                                        </td>
                                        <td style="width:33.3%; border:1px solid black;">
                                            <span t-esc="doc.soh_id.name or '-'"/>
                                            <br/>
                                            SOH
                                        </td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" style="text-align:left; border:none; font-size:9px;">
                                            <span t-esc="user.name or '-'"/>,
                                            <span t-esc="get_local_time()"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="oe_structure"/>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>