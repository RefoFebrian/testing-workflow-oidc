<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Direct Gift Buttons -->
        <record id="group_so_dg_button_generate_stock" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Direct Gift Generate Stock</field>
            <field name="implied_ids" eval="[(4, ref('group_stock_opname_direct_gift_showroom_read'))]"/>
        </record>
        <record id="group_so_dg_button_posted" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Direct Gift Post</field>
            <field name="implied_ids" eval="[(4, ref('group_stock_opname_direct_gift_showroom_read'))]"/>
        </record>
        <record id="group_so_dg_button_print_validasi" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Direct Gift Print Validasi</field>
            <field name="implied_ids" eval="[(4, ref('group_stock_opname_direct_gift_showroom_read'))]"/>
        </record>
        <record id="group_so_dg_button_print_bakso" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Direct Gift Print Bakso</field>
            <field name="implied_ids" eval="[(4, ref('group_stock_opname_direct_gift_showroom_read'))]"/>
        </record>
        <record id="group_so_dg_button_download_excel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button - Direct Gift Download Excel</field>
            <field name="implied_ids" eval="[(4, ref('group_stock_opname_direct_gift_showroom_read'))]"/>
        </record>

        <!-- Admin Group -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_so_dg_button_generate_stock')),
                (4, ref('group_so_dg_button_posted')),
                (4, ref('group_so_dg_button_print_validasi')),
                (4, ref('group_so_dg_button_print_bakso')),
                (4, ref('group_so_dg_button_download_excel')),
            ]"/>
        </record>

    </data>
</odoo>