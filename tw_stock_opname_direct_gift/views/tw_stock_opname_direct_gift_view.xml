<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <!-- Showroom -->
        <record id="view_tw_stock_opname_direct_gift_list" model="ir.ui.view">
            <field name="name">tw.stock.opname.direct.gift.list</field>
            <field name="model">tw.stock.opname.direct.gift</field>
            <field name="arch" type="xml">
                <list string="Stock Opname Direct Gift">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="generate_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_tw_stock_opname_direct_gift_form" model="ir.ui.view">
            <field name="name">tw.stock.opname.direct.gift.form</field>
            <field name="model">tw.stock.opname.direct.gift</field>
            <field name="arch" type="xml">
                <form string="Stock Opname Direct Gift">
                    <header>
                        <button name="action_generate_stock" string="Generate Stock" class="oe_highlight" type="object" invisible="not create_date or generate_date" groups="tw_stock_opname_direct_gift.group_so_dg_button_generate_stock"/>

                        <button name="action_post" string="Post" class="oe_highlight" type="object" confirm="Harap pastikan kembali data direct gift tidak tercatat sistem! Untuk Direct Gift yang tidak tercatat dalam sistem wajib diisi pada kolom Direct Gift Tidak Tercatat Sistem." invisible="state != 'open' or not generate_date"
                        groups="tw_stock_opname_direct_gift.group_so_dg_button_posted"/>

                        <button name="action_print_validasi" string="Print Validasi" class="oe_highlight" type="object" invisible="state != 'posted'" groups="tw_stock_opname_direct_gift.group_so_dg_button_print_validasi"/>

                        <button name="action_bakso" string="Berita Acara SO" type="object" invisible="state != 'posted'" groups="tw_stock_opname_direct_gift.group_so_dg_button_print_bakso"/>

                        <button name="action_download_excel_direct_gift" type="object" string="Download Excel" invisible="state != 'posted'" groups="tw_stock_opname_direct_gift.group_so_dg_button_download_excel"/>

                        <field name="state" widget="statusbar" statusbar_visible="draft,open,posted"/>
                    </header>

                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_open': True, 'no_create': True}" required="1" readonly="state != 'draft'"/>
                                <field name="create_date" invisible="1"/>
                                <field name="pdi_id" required="1" options="{'no_open': True, 'no_create': True}" readonly="state not in ('draft','open')"/>
                                <field name="adh_id" required="1" options="{'no_open': True, 'no_create': True}" readonly="state not in ('draft','open')"/>
                                <field name="soh_id" required="1" options="{'no_open': True, 'no_create': True}" readonly="state not in ('draft','open')"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="is_pilot" readonly="1" invisible="1"/>
                                <field name="division" required="1" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="DG Stock">
                                <field name="detail_ids" nolabel="1" readonly="state == 'posted'">
                                    <list create="false" delete="false" editable="top">
                                        <field name="product_id" options="{'no_open':True,'no_create':True}"
                                               readonly="1" width="180"/>
                                        <field name="name" readonly="1" width="120"/>
                                        <field name="aging" readonly="1"/>
                                        <field name="unit_price" readonly="1" width="120"/>
                                        <field name="qty" readonly="1" sum="Total"/>
                                        <field name="amount" readonly="1" sum="Total" width="160"/>
                                        <field name="qty_physical_good" required="1" sum="Total" width="100"/>
                                        <field name="qty_physical_broken" required="1" sum="Total" width="110"/>
                                        <field name="qty_physical_total" required="1" sum="Total" width="110"/>
                                        <field name="amount_total" readonly="1" sum="Total" width="140"/>
                                        <field name="diff_qty" readonly="1" sum="Total" width="100"/>
                                        <field name="diff_amount" readonly="1" sum="Total" width="110"/>
                                        <field name="balance_log_book" required="1" sum="Total" width="110"/>
                                    </list>
                                </field>
                            </page>
                            <page string="DG Tidak Tercatat Sistem">
                                <field name="other_dg_ids" readonly="state == 'posted'">
                                    <list editable="top">
                                        <field name="product_name" required="1"/>
                                        <field name="qty_physical_good" required="1" sum="Total" width="120"/>
                                        <field name="qty_physical_broken" required="1" sum="Total" width="120"/>
                                        <field name="qty_physical_total" readonly="1" sum="Total" width="120"/>
                                        <field name="balance_log_book" required="1" sum="Total" width="120"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Lampiran" invisible="is_pilot == False" >
                                <field name="attachment_ids" nolabel="1" readonly="state != 'draft'"/>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="post_uid" readonly="1" invisible="not post_uid"/>
                                        <field name="post_date" readonly="1" invisible="not post_date"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="generate_date" readonly="1" invisible="not generate_date"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tw_stock_opname_direct_gift_search" model="ir.ui.view">
            <field name="name">tw.stock.opname.direct.gift.search</field>
            <field name="model">tw.stock.opname.direct.gift</field>
            <field name="arch" type="xml">
                <search string="Stock Opname Direct Gift">
                    <field name="name"/>
                    <field name="company_id" string="Branch"/>
                    <field name="date"/>
                    <field name="pdi_id"/>
                    <field name="adh_id"/>
                    <field name="soh_id"/>
                    <field name="detail_ids" string="DG Stock Product" filter_domain="[('detail_ids','ilike',self)]"/>
                    <field name="other_dg_ids" string="DG Tidak Tercatat Sistem Nama Product" filter_domain="[('other_dg_ids','ilike',self)]"/>
                    <field name="date"/>
                    <field name="state"/>
                    <separator/>
                    <filter name="state_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="state_open" string="Open" domain="[('state', '=', 'open')]"/>
                    <filter name="state_posted" string="Posted" domain="[('state', '=', 'posted')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_by_date" string="Tanggal SO" context="{'group_by': 'date'}"/>
                        <filter name="group_by_name" string="Name" context="{'group_by': 'name'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tw_stock_opname_direct_gift" model="ir.actions.act_window">
            <field name="name">Direct Gift</field>
            <field name="res_model">tw.stock.opname.direct.gift</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_state_draft': '1', 'search_default_state_open':'1'}</field>
            <field name="search_view_id" ref="view_tw_stock_opname_direct_gift_search"/>
        </record>

    </data>
</odoo>