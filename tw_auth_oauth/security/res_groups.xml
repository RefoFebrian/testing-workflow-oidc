<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        
        <!-- Laporan SSO Tunas -->	
        <record id="group_tw_auth_oauth_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan SSO Tunas Read</field>
        </record> 
        
        <record id="access_tw_auth_oauth_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_auth_oauth_report"/>
            <field name="name">tw_auth_oauth read</field> 
            <field name="group_id" ref="group_tw_auth_oauth_read"/>  
            <field name="perm_read">1</field> 
        </record> 

                                
        <record id="group_tw_auth_oauth_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan SSO Tunas Update</field>
			<field name="implied_ids" eval="[(4, ref('group_tw_auth_oauth_read'))]"/>            	            	
        </record>
                        
        <record id="access_tw_auth_oauth_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_auth_oauth_report"/>
            <field name="name">tw_auth_oauth update</field> 
            <field name="group_id" ref="group_tw_auth_oauth_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      
        
        <record id="access_tw_auth_oauth_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_auth_oauth_report"/>
            <field name="name">tw_auth_oauth delete</field> 
            <field name="group_id" ref="group_tw_auth_oauth_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>                   
        
        <record id="group_tw_auth_oauth_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan SSO Tunas Delete</field>
			<field name="implied_ids" eval="[(4, ref('group_tw_auth_oauth_read'))]"/>            	            	
        </record>
                        
        <record id="access_tw_auth_oauth_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_auth_oauth_report"/>
            <field name="name">tw_auth_oauth delete</field> 
            <field name="group_id" ref="group_tw_auth_oauth_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>      
        
    </data>

    
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_auth_oauth_read')),
                (4, ref('group_tw_auth_oauth_update')),
                (4, ref('group_tw_auth_oauth_delete')),
            ]" />
        </record>
    </data>
    

</odoo>
