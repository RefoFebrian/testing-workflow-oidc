<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">    
        <record id="group_approval_delegation_request" model="res.groups">
            <field name="name">TW Button Approval Delegation Request</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
        
        <record id="group_approval_delegation_approve" model="res.groups">
            <field name="name">TW Button Approval Delegation Approve</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
        
        <record id="group_approval_delegation_reject" model="res.groups">
            <field name="name">TW Button Approval Delegation Reject</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
        
        <record id="group_approval_delegation_cancel" model="res.groups">
            <field name="name">TW Button Approval Delegation Cancel</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>

        <record id="group_approval_delegation_confirm" model="res.groups">
            <field name="name">TW Button Approval Delegation Confirm</field>
            <field name="category_id" ref="base.module_category_hidden"/>
        </record>
    
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_approval_delegation_request')),
                (4, ref('group_approval_delegation_approve')),
                (4, ref('group_approval_delegation_reject')),
                (4, ref('group_approval_delegation_cancel')),
                (4, ref('group_approval_delegation_confirm')),
            ]"/>
        </record>
    </data>

</odoo>
