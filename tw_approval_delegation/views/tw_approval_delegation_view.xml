<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_approval_delegation_list" model="ir.ui.view">
            <field name="name">tw.approval.delegation.list</field>
            <field name="model">tw.approval.delegation</field>
            <field name="arch" type="xml">
                <list default_order="id desc">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="company_id"/>
                    <field name="employee_id"/>
                    <field name="delegate_employee_id"/>
                    <field name="group_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="is_active"/>
                    <field name="is_added"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_tw_approval_delegation_form" model="ir.ui.view">
            <field name="name">tw.approval.delegation.form</field>
            <field name="model">tw.approval.delegation</field>
            <field name="arch" type="xml">
                <form string="Approval Delegation">
                    <header>
                        <button name="action_request_approval" string="Request Approval" type="object" class="btn-primary" invisible="state != 'draft'" groups="tw_approval_delegation.group_approval_delegation_request"/>
                        <button name="action_approval" string="Approve" type="object" class="btn-primary" invisible="state != 'waiting_for_approval'"/>
                        <button name="action_reject" string="Reject" type="object" class="btn-secondary" invisible="state != 'waiting_for_approval'"/>
                        <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'approved'" groups="tw_approval_delegation.group_approval_delegation_confirm"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" invisible="state not in ('draft', 'waiting_for_approval', 'approved', 'confirmed')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,confirmed,done,cancel"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1 invisible="name"><span>Draft</span></h1>
                            <h1 invisible="not name"><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_open': True, 'no_create': True}" readonly="state != 'draft'"/>
                                <field name="employee_id" options="{'no_open': True, 'no_create': True}" readonly="state != 'draft'" domain="[('company_id', '=', company_id)]"/>
                                <field name="delegate_employee_id" options="{'no_open': True, 'no_create': True}" readonly="state != 'draft'" domain="[('company_id', '=', company_id), ('user_id', '!=', False), ('id', '!=', employee_id)]"/>
                                <field name="reason" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="division" required="1" readonly="state != 'draft'"/>
                                <field name="date" readonly="1" force_save="1"/>
                                <field name="start_date" readonly="state != 'draft'"/>
                                <field name="end_date" readonly="state != 'draft'"/>
                                <field name="approval_state" readonly="1"/>
                                <field name="group_id" readonly="1" force_save="1" options="{'no_open': True, 'no_create': True}"/>
                                <field name="is_active" readonly="1" force_save="1" invisible="1"/>
                                <field name="is_added" readonly="1" force_save="1" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Approval Lines">
                                <field name="approval_ids" readonly="1">
                                    <list create="0" edit="0" delete="0">
                                        <field name="group_id"/>
                                        <field name="company_id" optional="show"/>
                                        <field name="division" optional="show"/>
                                        <field name="limit"/>
                                        <field name="value" optional="show"/>
                                        <field name="state"/>
                                        <field name="reason"/>
                                        <field name="approver_id" optional="show"/>
                                        <field name="transaction_no" optional="hide"/>
                                        <field name="create_date" string="Tanggal" widget="date"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="rfa_uid" readonly="1"/>
                                        <field name="rfa_date" readonly="1"/>
                                        <field name="approved_uid" readonly="1"/>
                                        <field name="approved_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                        <field name="completed_uid" readonly="1"/>
                                        <field name="completed_date" readonly="1"/>
                                        <field name="cancel_uid" readonly="1"/>
                                        <field name="cancel_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_tw_approval_delegation_search" model="ir.ui.view">
            <field name="name">tw.approval.delegation.search</field>
            <field name="model">tw.approval.delegation</field>
            <field name="arch" type="xml">
                <search string="Approval Delegation">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="employee_id"/>
                    <field name="delegate_employee_id"/>
                    <field name="group_id"/>
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                    <filter name="filter_waiting" string="Waiting Approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                    <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                    <filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                    <filter name="filter_active" string="Active" domain="[('is_active', '=', True)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_branch" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="group_state" string="State" context="{'group_by': 'state'}"/>
                        <filter name="group_start_date" string="Start Date" context="{'group_by': 'start_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tw_approval_delegation" model="ir.actions.act_window">
            <field name="name">Approval Delegation</field>
            <field name="res_model">tw.approval.delegation</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tw_approval_delegation_search"/>
            <field name="context">{'default_division': 'Umum'}</field>
        </record>
    </data>
</odoo>
