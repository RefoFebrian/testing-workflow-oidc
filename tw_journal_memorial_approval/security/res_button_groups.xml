<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- RFA Payment -->
		
        <record id="group_tw_journal_memorial_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Request Approval Journal Memorial</field>
        </record>

        <record id="access_tw_journal_memorial_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_journal_memorial.model_tw_journal_memorial"/>
            <field name="name">tw_journal_memorial RFA</field>
            <field name="group_id" ref="group_tw_journal_memorial_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_journal_memorial_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Cancel Journal Memorial</field>
        </record>
        <record id="access_tw_journal_memorial_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_journal_memorial.model_tw_journal_memorial"/>
            <field name="name">tw_journal_memorial Cancel Approval</field>
            <field name="group_id" ref="group_tw_journal_memorial_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>  
        
                
        <record id="group_tw_journal_memorial_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">TW Button Reject Journal Memorial</field>
        </record>
        <record id="access_tw_journal_memorial_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_journal_memorial.model_tw_journal_memorial"/>
            <field name="name">tw_journal_memorial Reject Approval</field>
            <field name="group_id" ref="group_tw_journal_memorial_reject_approval"/>
            <field name="perm_write">1</field>
        </record> 

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_journal_memorial_rfa')),
                (4, ref('group_tw_journal_memorial_cancel_approval')),
                (4, ref('group_tw_journal_memorial_reject_approval')),
            ]"/>
        </record>
    </data>

</odoo>
