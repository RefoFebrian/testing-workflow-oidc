        <!-- Master Sales Program Subsidi Barang Group Read -->
        <record id="group_tw_sale_report_undelivered_all" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Sale Order Undelivered</field>
        </record>
        <record id="access_tw_sale_report_undelivered_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_sale_report_undelivered"/>
