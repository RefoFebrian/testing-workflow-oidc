<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_report_branch_grading_form" model="ir.ui.view">
        <field name="name">tw.report.branch.grading.form</field>
        <field name="model">tw.report.branch.grading</field>
        <field name="arch" type="xml">
            <form string="Report Branch Grading">
                <group col="4">
                    <field name="options" required="1"/>
                    <field name="division" invisible="options == 'Unit'"/>
                    <field name="status" invisible="options == 'current'"/>
                    <label for="start_date" string="Tanggal" invisible="options == 'current'"/>
                    <div class="o_row" invisible="options == 'current'">
                        <field name="start_date" widget="date" nolabel="1"/>
                        <span class="mx-2">-</span>
                        <field name="end_date" widget="date" nolabel="1"/>
                    </div>
                </group>
                <notebook>
                    <page string="Branches">
                        <field name="company_ids" nolabel="1">
                            <list>
                                <field name="code" string="Code" optional="show"/>
                                <field name="name" string="Name"/>
                                <field name="branch_type_id" string="Branch Type" optional="show"/>
                            </list>
                        </field>
                    </page>
                    <page string="Customer">
                        <field name="partner_ids" nolabel="1">
                            <list>
                                <field name="name" string="Name"/>
                                <field name="phone" string="Phone" optional="show"/>
                                <field name="email" string="Email" optional="show"/>
                            </list>
                        </field>
                    </page>
                    <page string="Account">
                        <field name="account_ids" nolabel="1">
                            <list>
                                <field name="code" string="Code"/>
                                <field name="name" string="Name"/>
                                <field name="account_type" string="Internal Type" optional="show"/>
                                <field name="currency_id" string="Company Currency" optional="show"/>
                            </list>
                        </field>
                    </page>
                    <page string="Journal">
                        <field name="journal_ids" nolabel="1">
                            <list>
                                <field name="code" string="Code"/>
                                <field name="name" string="Journal Name"/>
                                <field name="type" string="Type" optional="show"/>
                                <field name="partner_id" string="User" optional="show"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_print_report" string="Export Report" type="object" class="oe_highlight"/>
                    <span class="mx-2">or .</span>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_server_tw_report_branch_grading" model="ir.actions.server">
        <field name="name">Laporan Branch Grading</field>
        <field name="model_id" ref="model_tw_report_branch_grading"/>
        <field name="state">code</field>
        <field name="code">action = model.action_tw_report_branch_grading_wizard()</field>
    </record>
</odoo>
