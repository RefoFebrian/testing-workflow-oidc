<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="paperformat_tw_payment_kwitansi" model="report.paperformat">
            <field name="name">Paper Format Kwitansi</field>
            <field name="default" eval="True"/>
            <field name="format">custom</field>
            <field name="page_height">200</field>
            <field name="page_width">297</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">6</field>
            <field name="margin_right">6</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">25</field>
            <field name="dpi">90</field>
        </record>
        
        <record id="action_report_tw_payment_kwitansi" model="ir.actions.report">
            <field name="name">TW Payment Kwitansi</field>
            <field name="model">tw.account.payment</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_payment.report_tw_account_payment_kwitansi</field>
            <field name="report_file">tw_payment.report_tw_account_payment_kwitansi</field>
            <field name="paperformat_id" ref="tw_payment.paperformat_tw_payment_kwitansi"/>
            <field name="print_report_name">'Customer_Payment_Kwitansi_%s.pdf' % (object.name)</field>
        </record>
        
    </data>
</odoo>
