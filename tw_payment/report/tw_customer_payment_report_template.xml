<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_tw_customer_payment_document">
        <t t-call="tw_web.teto_report_layout">
            <t t-call="tw_web.teto_report_styles_base" />

            <t t-set="o" t-value="o.with_context(lang=lang)"/>
            <t t-set="values" t-value="o._get_payment_receipt_report_values()"/>

            <div class="page">
                <div class="oe_structure">

                    <div class="row">
                        <div class="col-12 text-center bold font-lg">KWITANSI</div>
                    </div>

                    <div class="row">
                        <div class="col-5 offset-7">
                            <t t-esc="o.company_id.name" />, <t t-esc="print_address(o.company_id.partner_id)" />
                        </div>
                    </div>

                    <div class="row mt-5">
                        <div class="col-12">
                            <table class="table-borderless">
                                <tr>
                                    <td width="17%">No Kwitansi</td>
                                    <td>:</td>
                                    <td width="43%"><t t-esc="o.name"/></td>
                                    <td width="17%">No Form</td>
                                    <td>:</td>
                                    <td width="20%"></td>
                                </tr>
                                <tr>
                                    <td>Sudah terima dari</td>
                                    <td>:</td>
                                    <td colspan="4"><t t-esc="o.partner_id.name"/></td>
                                </tr>
                                <tr>
                                    <td>Banyaknya uang</td>
                                    <td>:</td>
                                    <td colspan="4" class="text-end"><t t-esc="'{:.2f}'.format(o.amount)"/></td>
                                </tr>
                                <tr>
                                    <td>Terbilang</td>
                                    <td>:</td>
                                    <td colspan="4" class="text-end"><t t-esc="terbilang(o.amount)"/></td>
                                </tr>
                                <tr>
                                    <td>Untuk pembayaran</td>
                                    <td>:</td>
                                    <td colspan="4"><t t-esc="o.memo"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <div class="row mt-5">
                        <div class="col-6">
                            <t t-esc="o.company_id.state_id.name"/>, <t t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''"/>
                        </div>
                    </div>
                    <br /><br /><br />
                    <div class="row">
                        <div class="col-6">
                            <t t-esc="user.name"/>, <t t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-12">
                            Putih:Konsumen; Kuning:Finance; Hijau:Accounting; Biru:Finance Company (Leasing); Merah:Kasir
                        </div>
                    </div>

                </div>
            </div>
        </t>
    </template>

    <template id="report_tw_customer_payment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang or o.company_id.partner_id.lang"/>
                <t t-call="tw_payment.report_tw_customer_payment_document" t-lang="lang"/>
            </t>
        </t>
    </template>
    
</odoo>
