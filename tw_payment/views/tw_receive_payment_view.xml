<odoo>
  <data>
    <!-- Receive payment from Partner (Previously known as Hutang Lain or Cash Receive) -->
    
    <record id="tw_account_payment_receive_payment_list_view" model="ir.ui.view">
        <field name="name">tw.account.payment.receive.payment.list</field>
        <field name="model">tw.account.payment</field>
        <field name="arch" type="xml">
            <list string="Payment" default_order="id desc">
                <field name="name"/>
                <field name="date"/>
                <field name="company_id"/>
                <field name="division"/>
                <field name="partner_id"/>
                <field name="state" widget="badge" decoration-info="state in ('draft','cancel','rejected')" decoration-warning="state not in ('draft','canceled','rejected','paid')" decoration-success="state == 'paid'"/>
            </list>
        </field>
    </record>
    
    <record id="tw_account_payment_receive_payment_form_view" model="ir.ui.view">
        <field name="name">account.payment.receive.payment.form</field>
        <field name="model">tw.account.payment</field>
        <field name="arch" type="xml">
            <form string="Pay">
                <header>
                    <button name="action_print_kwitansi" string="Print Kwitansi" type="object" invisible="state != 'paid' or type == 'supplier_payment'" data-hotkey="k"/>
                    <button name="action_validate" string="Validate" type="object" class="oe_highlight" invisible="state not in ('draft','in_process') or move_id" data-hotkey="q" groups="tw_payment.group_tw_receive_payment_validate_button"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid"/>
                </header>
                <div class="alert alert-warning mb-0" role="alert" invisible="not duplicate_payment_ids or state!='draft'">
                    <span>This payment has the same partner, amount and date as </span>
                    <field name="duplicate_payment_ids" widget="x2many_buttons" string="Duplicated Payments"/>
                </div>
                <sheet>
                    <!-- Invisible fields -->
                    <field name="id" invisible="1"/>
                    <field name="type" invisible="1"/>
                    <field name="is_sent" invisible="1"/>
                    <field name="need_cancel_request" invisible="1"/>
                    <field name="is_reconciled" invisible="1"/>
                    <field name="is_matched" invisible="1"/>
                    <field name="payment_method_code" invisible="1"/>
                    <field name="show_partner_bank_account" invisible="1"/>
                    <field name="require_partner_bank_account" invisible="1"/>
                    <field name="available_payment_method_line_ids" invisible="1"/>
                    <field name="available_account_ids" invisible="1"/>
                    <field name="available_partner_bank_ids" invisible="1"/>
                    <field name="country_code" invisible="1"/>
                    <field name="partner_type" invisible="1"/>
                    <field name="reconciled_invoices_type" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <field name="paired_internal_transfer_payment_id" invisible="1"/>
                    <field name="available_journal_ids" invisible="1"/>
                    <field name="currency_id" invisible="1"/>

                    <div class="oe_button_box" name="button_box">
                        <!-- Journal Entry  button -->
                        <button name="button_open_journal_entry" type="object" class="oe_stat_button" icon="fa-bars" invisible="not move_id" groups="account.group_account_user,account.group_account_readonly">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Journal Entry</span>
                            </div>
                        </button>
                    </div>

                    <widget name="web_ribbon" text="Invoicing App Legacy"
                            bg_color="text-bg-info"
                            invisible="state != 'invoicing_legacy'"
                            tooltip="This payment has been generated through the Invoicing app, before installing Accounting. It has been disabled by the 'Invoicing Switch Threshold Date' setting so that it does not impact your accounting."/>

                    <div class="oe_title">
                        <h1 invisible="not name"><field name="name" readonly="1"/></h1>
                    </div>

                    <group name="main_group">
                        <group name="group1">
                            <field name="company_id" options="{'no_create': True, 'no_open': True}" required="1" readonly="state != 'draft' or id"/>
                            <field name="payment_type" widget="radio" options="{'horizontal': True}" invisible="1"/>
                            <field name="partner_id" context="{'default_is_company': True}" string="Partner" options="{'no_quick_create': True}" required="1" readonly="state != 'draft'"/>
                            <field name="journal_id" domain="[('id', 'in', available_journal_ids)]" readonly="state != 'draft'" options="{'no_create': True, 'no_open': True}"/>
                            <label for="amount"/>
                            <div name="amount_div" class="o_row">
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="currency_id" options="{'no_create': True, 'no_open': True}" required="1" readonly="1" groups="base.group_multi_currency"/>
                            </div>
                        </group>
                        <group name="group2">
                            <field name="division" options="{'no_create': True, 'no_open': True}" required="1" readonly="state != 'draft'"/>
                            <field name="date" readonly="1"/>
                            <field name="memo" string="Memo" readonly="state != 'draft'"/>
                            <field name="is_receipt_printed" string="Cetak Kwitansi" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <!-- To be used in localizations requiring to add a page -->
                        <notebook name="payment_notebook" colspan="2"/>
                    </group>
                    <notebook>
                        <page name="receive_detail" string="Receive Detail">
                            <field name="line_cr_ids" readonly="state != 'draft'">
                                <list string="Receive Detail" editable="bottom">                                   
                                    <field name="account_id" options="{'no_open':True,'no_create':True}" domain="[('account_type','=','liability_payable'),('id','in',parent.available_account_ids), ('company_ids', 'parent_of', company_id)]" />
                                    <field name="name" required="True"/>
                                    <field name="amount" required="True" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Journal Items" invisible="state != 'paid'">
                            <field name="move_ids" readonly="1" />
                        </page>
                        <page name="audit_trail" string="Audit Trail">
                            <field name="move_id" readonly="1" invisible="not move_id"/>
                            <br/>
                            <group>
                                <group>
                                    <field name="create_uid" readonly="1" options="{'no_open': True, 'no_create': True}"></field>
                                    <field name="create_date" readonly="1"></field>
                                </group>
                                <group>							
                                    <field name="write_uid" readonly="1" options="{'no_open': True, 'no_create': True}"></field>
                                    <field name="write_date" readonly="1"></field>
                                </group>
                                <group>
                                    <field name="confirm_uid" readonly="1" options="{'no_open': True, 'no_create': True}" invisible="not confirm_uid"></field>
                                    <field name="confirm_date" readonly="1" invisible="not confirm_date"></field>
                                </group>
                                <group>							
                                    <field name="validate_uid" readonly="1" options="{'no_open': True, 'no_create': True}" invisible="not validate_uid"></field>
                                    <field name="validate_date" readonly="1" invisible="not validate_date"></field>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="o_attachment_preview"/>
                <chatter/>
            </form>
        </field>
    </record>


    <record id="tw_account_payment_receive_payment_action" model="ir.actions.act_window">
        <field name="name">Hutang Lain</field>
        <field name="res_model">tw.account.payment</field>
        <field name="view_mode">list,kanban,form,graph,activity</field>
        <field name="view_ids" eval="[(5, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('tw_payment.tw_account_payment_receive_payment_list_view')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('tw_payment.tw_account_payment_receive_payment_form_view')})
        ]"/>
        <field name="domain">[('type', '=', 'receive_payment')]</field>
        <field name="search_view_id" ref="tw_account_payment_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a payment
            </p><p>
                Payments are used to register liquidity movements. You can process those payments by your own means or by using installed facilities.
            </p>
        </field>
    </record>

    <record id="tw_payment.tw_account_payment_receive_payment_action" model="ir.actions.act_window">
        <field name="context" eval="
            {
                'default_type': 'receive_payment',
                'default_payment_type': 'inbound',
                'default_partner_type': 'customer',
                'search_default_inbound_filter': 1,
                'search_default_draft': 1,
                'default_move_journal_types': ('bank', 'cash'),
                'display_account_trust': True,
                'action_id': ref('tw_payment.tw_account_payment_receive_payment_action'),
            }
            " />
    </record>

  </data>
</odoo>
