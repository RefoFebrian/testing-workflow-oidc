<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_workshop_claim_type_list" model="ir.ui.view">
            <field name="name">tw.workshop.claim.type.list</field>
            <field name="model">tw.selection</field>
            <field name="arch" type="xml">
                <list string="Workshop claim type" create="1" delete="0" editable="top">
                    <field name="sequence" widget="handle"/>
                    <field name="name" required="1" string="claim type"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <record id="tw_workshop_claim_type_search_view" model="ir.ui.view">
            <field name="name">tw.workshop.claim.type.search</field>
            <field name="model">tw.selection</field>
            <field name="arch" type="xml">
                <search string="Search Workshop Claim Type">
                    <field name="name" string="Workshop Claim Type Name"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Workshop Claim Type Name" name="group_by_name" domain="[]" context="{'group_by': 'name'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="action_tw_workshop_claim_type" model="ir.actions.act_window">
            <field name="name">Workshop claim type</field>
            <field name="res_model">tw.selection</field>
            <field name="view_mode">list</field>
            <field name="search_view_id" ref="tw_workshop_claim_type_search_view"/>
            <field name="domain">[('type','=','WorkOrderClaimType')]</field>
            <field name="context">{'default_type': 'WorkshopClaimType'}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Workshop claim type found. Let's create one!
                </p>
            </field>
        </record>

        <record id="tw_workshop_claim_type_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_tw_workshop_claim_type_list"/>
            <field name="act_window_id" ref="action_tw_workshop_claim_type"/>
        </record>
    </data>
</odoo>