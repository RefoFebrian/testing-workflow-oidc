<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Form Access -->
        <record id="group_tw_res_users_form_read" model="res.groups">
			<field name="category_id" ref="tw_base.tw_role" />
			<field name="name">TW Res Users Form Read</field>
		</record>
    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_res_users_form_read')),
            ]" />
        </record>

        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_res_users_form_read')),
            ]" />
        </record>
    </data>
</odoo>
