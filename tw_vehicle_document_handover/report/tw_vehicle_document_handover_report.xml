<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="paperformat_vehicle_document_handover" model="report.paperformat">
            <field name="name">Vehicle Document Handover Report</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">15</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="css_margins" eval="True"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_print_out_registration_handover" model="ir.actions.report">
            <field name="name">Print Out Registration Handover</field>
            <field name="model">tw.vehicle.registration.handover</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_vehicle_document_handover.reg_handover_report</field>
            <field name="report_file">tw_vehicle_document_handover.reg_handover_report</field>
            <field name="print_report_name">'Penyerahan STNK - %s' % (object.name)</field>
            <field name="paperformat_id" ref="paperformat_vehicle_document_handover"/>
        </record>

        <record id="action_print_out_ownership_handover_customer" model="ir.actions.report">
            <field name="name">Print Out Ownership Handover Customer</field>
            <field name="model">tw.vehicle.ownership.handover</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_vehicle_document_handover.own_handover_report</field>
            <field name="report_file">tw_vehicle_document_handover.own_handover_report</field>
            <field name="print_report_name">'Penyerahan BPKB Personal - %s' % (object.name)</field>
            <field name="paperformat_id" ref="paperformat_vehicle_document_handover"/>
        </record>

        <record id="action_print_out_ownership_handover_company" model="ir.actions.report">
            <field name="name">Print Out Ownership Handover Company</field>
            <field name="model">tw.vehicle.ownership.handover</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_vehicle_document_handover.own_handover_report_company</field>
            <field name="report_file">tw_vehicle_document_handover.own_handover_report_company</field>
            <field name="print_report_name">'Penyerahan BPKB - %s' % (object.name)</field>
            <field name="paperformat_id" ref="paperformat_vehicle_document_handover"/>
        </record>

    </data>
</odoo>