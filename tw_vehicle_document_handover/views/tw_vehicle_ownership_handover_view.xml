<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_vehicle_ownership_handover_view_search" model="ir.ui.view">
            <field name="name">tw.vehicle.ownership.handover.search</field>
            <field name="model">tw.vehicle.ownership.handover</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="partner_id"/>
                    <field name="receiver"/>
                    <field name="state"/>
                    <field name="ownership_handover_line_ids" string="Engine Number" filter_domain="[('ownership_handover_line_ids.name', 'ilike', self)]"/>
                    <field name="ownership_handover_line_ids" string="Customer STNK" filter_domain="[('ownership_handover_line_ids.customer_stnk_id', 'ilike', self)]"/>
                    <field name="ownership_handover_line_ids" string="Nomor BPKB" filter_domain="[('ownership_handover_line_ids.bpkb_number', 'ilike', self)]"/>
                    <field name="ownership_handover_line_ids" string="Nomor Urut BPKB" filter_domain="[('ownership_handover_line_ids.bpkb_order_number', 'ilike', self)]"/>
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="done" string="Done" domain="[('state','=','done')]"/>
                    <filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]"/>
                    <filter name="group_by_state" string="Group by State" context="{'group_by':'state'}"/>
                    <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
                    <filter name="group_by_division" string="Group by Division" context="{'group_by':'division'}"/>
                </search>
            </field>
        </record>

        <record id="tw_vehicle_ownership_handover_view_list" model="ir.ui.view">
            <field name="name">tw.vehicle.ownership.handover.list</field>
            <field name="model">tw.vehicle.ownership.handover</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="partner_id"/>
                    <field name="receiver"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_vehicle_ownership_handover_view_form" model="ir.ui.view">
            <field name="name">tw.vehicle.ownership.handover.form</field>
            <field name="model">tw.vehicle.ownership.handover</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" data-hotkey="c" invisible="state != 'draft'" string="Post" type="object" class="oe_highlight" groups="tw_vehicle_document_handover.group_vehicle_ownership_handover_button_post"/>
                        <button name="action_print_out_ownership_handover_customer" invisible="state != 'done'" string="Print User" type="object" class="oe_highlight" groups="tw_vehicle_document_handover.group_vehicle_ownership_handover_button_print_customer"/>
                        <button name="action_print_out_ownership_handover_company" invisible="partner_type != 'finco' or state != 'done'" string="Print Leasing" type="object" class="oe_highlight" groups="tw_vehicle_document_handover.group_vehicle_ownership_handover_button_print_company"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <span class="o_form_label">Penyerahan BPKB</span>
                            <h1>
                                <field name="name" class="oe_inline" invisible="not name"/>
                                <span invisible="name">Draft</span>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
                                <field name="partner_type" readonly="state != 'draft'"/>
                                <field name="allowed_partner_ids" widget="many2many_tags" invisible="1"/>
                                <field name="partner_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" domain="[('id', 'in', allowed_partner_ids)]"/>
                                <field name="receiver" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="division" readonly="1"/>
                                <field name="date" readonly="1"/>
                                <field name="ownership_handover_date" readonly="state != 'draft'"/>
                                <field name="print_count" string="Cetak Ke" readonly="1"/>
                                <field name="note" readonly="state != 'draft'"/>
                                <field name="count_printed" readonly="1"/>
                                <field name="available_lot_ids" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Engine Line">
                                <field name="ownership_handover_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom" string="Engine Line">
                                        <field name="lot_id" required="1" options="{'no_create': True,'no_open': True}" domain="[('id', 'in', parent.available_lot_ids)]" width="200" string="Engine Number"/>
                                        <field name="customer_stnk_id" readonly="1" force_save="1" width="300"/>
                                        <field name="bpkb_number" readonly="1" force_save="1" width="150"/>
                                        <field name="bpkb_order_number" readonly="1" force_save="1" width="150"/>
                                        <field name="ownership_handover_date" force_save="1" width="150" required="1"/>
                                        <field name="state" readonly="1" decoration-danger="state == 'cancel'" decoration-warning="state == 'draft'" decoration-success="state == 'done'" width="100" />
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="cancel_uid" readonly="1"/>
                                        <field name="cancel_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_vehicle_ownership_handover_action" model="ir.actions.act_window">
            <field name="name">Penyerahan BPKB</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.vehicle.ownership.handover</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_draft": 1}</field>
        </record>
    </data>
</odoo>