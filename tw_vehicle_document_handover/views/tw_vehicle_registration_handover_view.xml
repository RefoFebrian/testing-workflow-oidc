<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_vehicle_registration_handover_view_search" model="ir.ui.view">
            <field name="name">tw.vehicle.registration.handover.search</field>
            <field name="model">tw.vehicle.registration.handover</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="partner_id"/>
                    <field name="receiver"/>
                    <field name="state"/>
                    <field name="registration_handover_line_ids" string="Engine Number" filter_domain="[('registration_handover_line_ids.name', 'ilike', self)]"/>
                    <field name="registration_handover_line_ids" string="Customer STNK" filter_domain="[('registration_handover_line_ids.customer_stnk_id', 'ilike', self)]"/>
                    <field name="registration_handover_line_ids" string="No Notice" filter_domain="[('registration_handover_line_ids.notice_number', 'ilike', self)]"/>
                    <field name="registration_handover_line_ids" string="No STNK" filter_domain="[('registration_handover_line_ids.stnk_number', 'ilike', self)]"/>
                    <field name="registration_handover_line_ids" string="No Plate" filter_domain="[('registration_handover_line_ids.plate_number', 'ilike', self)]"/>
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="done" string="Done" domain="[('state','=','done')]"/>
                    <filter name="cancelled" string="Cancelled" domain="[('state','=','cancel')]"/>
                    <filter name="group_by_state" string="Group by State" context="{'group_by':'state'}"/>
                    <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}"/>
                    <filter name="group_by_division" string="Group by Division" context="{'group_by':'division'}"/>
                </search>
            </field>
        </record>

        <record id="tw_vehicle_registration_handover_view_list" model="ir.ui.view">
            <field name="name">tw.vehicle.registration.handover.list</field>
            <field name="model">tw.vehicle.registration.handover</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="partner_id"/>
                    <field name="receiver"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_vehicle_registration_handover_view_form" model="ir.ui.view">
            <field name="name">tw.vehicle.registration.handover.form</field>
            <field name="model">tw.vehicle.registration.handover</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_confirm" data-hotkey="c" invisible="state != 'draft'" string="Post" type="object" class="oe_highlight" groups="tw_vehicle_document_handover.group_vehicle_stnk_handover_button_post"/>
                        <button name="action_print_out_registration_handover" invisible="state != 'done'" string="Print" type="object" class="oe_highlight" groups="tw_vehicle_document_handover.group_vehicle_stnk_handover_button_print"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <span class="o_form_label">Penyerahan STNK</span>
                            <h1>
                                <field name="name" class="oe_inline" invisible="not name"/>
                                <span invisible="name">Draft</span>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
                                <field name="partner_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
                                <field name="receiver" readonly="state != 'draft'"/>
                            </group>
                            <group>
                                <field name="division" readonly="1"/>
                                <field name="date" readonly="1"/>
                                <field name="note" readonly="state != 'draft'"/>
                                <field name="available_lot_ids" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Engine Line">
                                <field name="registration_handover_line_ids" readonly="state != 'draft'">
                                    <list editable="bottom" string="Engine Line">
                                        <field name="vehicle_registration_handover" column_invisible="1"/>
                                        <field name="notice_handover" column_invisible="1"/>
                                        <field name="plate_handover" column_invisible="1"/>
                                        <field name="lot_id" required="1" options="{'no_create': True,'no_open': True}" domain="[('id', 'in', parent.available_lot_ids)]" width="200" string="Engine Number"/>
                                        <field name="customer_stnk_id" readonly="1" force_save="1" width="300"/>
                                        <field name="notice_number" readonly="1" force_save="1" width="150"/>
                                        <field name="stnk_number" readonly="1" force_save="1" width="150"/>
                                        <field name="plate_number" readonly="1" force_save="1" width="150"/>
                                        <field name="notice_handover_date" readonly="notice_handover" force_save="1" width="150"/>
                                        <field name="stnk_handover_date" readonly="vehicle_registration_handover" force_save="1" width="150"/>
                                        <field name="plate_handover_date" readonly="plate_handover" force_save="1" width="150"/>
                                        <field name="state" readonly="1" decoration-danger="state == 'cancel'"
                                                    decoration-warning="state == 'draft'"
                                                    decoration-success="state == 'done'"
                                                    width="100"
                                        />
                                    </list>
                                </field>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                        <field name="confirm_uid" readonly="1"/>
                                        <field name="confirm_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                        <field name="cancel_uid" readonly="1"/>
                                        <field name="cancel_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_vehicle_registration_handover_action" model="ir.actions.act_window">
            <field name="name">Penyerahan STNK</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.vehicle.registration.handover</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"search_default_draft": 1}</field>
        </record>
    </data>
</odoo>