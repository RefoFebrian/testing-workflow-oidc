<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_mrp_mrp_bom_form_view" model="ir.ui.view">
            <field name="name">tw.mrp.mrp.bom.form.view</field>
            <field name="model">mrp.bom</field>
            <field name="inherit_id" ref="mrp.mrp_bom_form_view" />
            <field name="priority">16</field>
            <field name="arch" type="xml">
                <!-- Filter Product to show Division = Unit for Bundling only -->
                <field name="product_tmpl_id" position="attributes">
                    <attribute name="invisible">type == 'normal'</attribute>
                    <attribute name="domain">type == 'normal' and [('division', '=', 'Unit')] or []</attribute>
                </field>
                <field name="product_tmpl_id" position="after">
                    <field name="product_tmpl_id" string="Product To" invisible="type != 'normal'" domain="[('division', '=', 'Unit')]"/>
                </field>
                
                <!-- Filter Product Variant to show Division = Unit for Bundling -->
                <!-- Also filter by product_tmpl_id to only show variants of selected product -->
                <field name="product_id" position="attributes">
                    <attribute name="domain">type == 'normal' and [('division', '=', 'Unit'), ('product_tmpl_id', '=', product_tmpl_id)] or [('product_tmpl_id', '=', product_tmpl_id)]</attribute>
                    <attribute name="required">type != 'normal'</attribute>
                </field>
                
                <xpath expr="//page[@name='components']/field[@name='bom_line_ids']/list/field[@name='product_id']" position="attributes">
                    <attribute name="string">Product From</attribute>
                </xpath>
            </field>
        </record>

        <record id="tw_mrp_inherit_bundling_action" model="ir.actions.act_window">
            <field name="name">Bundling</field>
            <field name="res_model">mrp.bom</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('type', '=', 'normal')]"/>
            <field name="context" eval="{
                'default_type': 'normal',
			}"/>
        </record>
    </data>
</odoo>
