<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_bundling_production_report_form" model="ir.ui.view">
        <field name="name">tw.bundling.production.report.form</field>
        <field name="model">tw.bundling.production.report</field>
        <field name="arch" type="xml">
            <form string="Bundling Production Report">
                <group col="4">
                    <field name="state_filter" required="1"/>
                    <field name="division_filter" required="1"/>
                    <label for="start_date" string="Date Range"/>
                    <div class="o_row">
                        <field name="start_date" widget="date" nolabel="1"/>
                        <span class="mx-2">-</span>
                        <field name="end_date" widget="date" nolabel="1"/>
                    </div>
                </group>
                <notebook>
                    <page string="Branches">
                        <field name="company_ids" nolabel="1">
                            <list>
                                <field name="code" string="Code" optional="show"/>
                                <field name="name" string="Name"/>
                                <field name="branch_type_id" string="Branch Type" optional="show"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_print_excel" string="Export Excel" type="object" class="oe_highlight"/>
                    <span class="mx-2">or</span>
                    <button string="Cancel" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tw_bundling_production_report" model="ir.actions.act_window">
        <field name="name">Bundling Production Report</field>
        <field name="res_model">tw.bundling.production.report</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
