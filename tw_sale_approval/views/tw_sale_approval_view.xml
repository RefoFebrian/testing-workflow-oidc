<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>  
    	
		<record id="tw_sale_order_approval_form_view" model="ir.ui.view">
            <field name="name">tw.sale.order.approval.form</field>
            <field name="model">tw.sale.order</field>
            <field name="inherit_id" ref="tw_sale.tw_sale_order_form_view"/>
            <field name="arch" type="xml">
				<button name="action_confirm" position="replace">
					<button name="action_request_approval" invisible="state != 'draft'" string="RFA" type="object" class="oe_highlight" groups="tw_sale_approval.group_tw_sale_order_approval_rfa"/>
					<button name="action_approval" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight"/>
					<button name="action_confirm" invisible="state != 'approved'" data-hotkey="q" string="Confirm" type="object" class="oe_highlight" context="{'validate_analytic': True}" groups="tw_sale_approval.group_tw_sale_order_confirm" />
					<button name="action_reject_or_cancel" invisible="state != 'waiting_for_approval'" string="Reject" type="object" context="{'window_title': 'Reject'}"/>
					<button name="action_reject_or_cancel" invisible="state not in ('waiting_for_approval','approved')" string="Cancel Approval" type="object" groups="tw_sale_approval.group_tw_sale_order_approval_cancel" context="{'window_title': 'Cancel'}"/>
				</button>

				<xpath expr="//page[@name='other_information']" position="after">
					<page string="Approval">
						<field name="approval_ids" readonly="True">
						</field>
					</page>
				</xpath>
			</field>
		</record>
		
 	</data>
</odoo>