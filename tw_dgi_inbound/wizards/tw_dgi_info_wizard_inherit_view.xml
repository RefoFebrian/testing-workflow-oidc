<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_dgi_info_wizard_form_inherit_inbound" model="ir.ui.view">
        <field name="name">tw.dgi.info.wizard.form.inherit.inbound</field>
        <field name="model">tw.dgi.info.wizard</field>
        <field name="inherit_id" ref="tw_dgi.view_tw_dgi_info_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='dgi_reference_group']" position="inside">
                <field name="md_reference_po" invisible="not md_reference_po"/>
                <field name="md_reference_sl" invisible="not md_reference_sl"/>
            </xpath>
        </field>
    </record>
</odoo>
