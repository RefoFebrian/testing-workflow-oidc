<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        =============================================================
        DGI UINB (Unit Inbound) Endpoint Configurations

        Endpoint untuk sync PO Unit dari DGI API
        Satu endpoint per API Config (HSO, ASP, DAM, DAW, NPM, SINSEN, WAHANA)
        =============================================================
        -->

        <!-- ==================== HSO ==================== -->
        <record id="tw_endpoint_dgi_uinb_hso" model="tw.endpoint.configuration">
            <field name="code">dgi_uinb</field>
            <field name="version">1</field>
            <field name="url_path">uinb/read</field>
            <field name="method">post</field>
            <field name="config_id" ref="tw_dgi.tw_api_config_dgi_hso"/>
            <field name="mode">read</field>
            <field name="target_model_id" ref="purchase.model_purchase_order"/>
            <field name="dgi_division_id" ref="tw_dgi.tw_selection_division_dgi_h1"/>
        </record>

