<odoo>
    <data>

        <record id="tw_purchase_discount_inherit_view_form" model="ir.ui.view">
            <field name="name">tw.purchase.order.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form" />
            <field name="arch" type="xml">

                <field name="product_id" position="after">
                    <field name="is_discount" invisible="1" optional="hide" />
                </field>

                <xpath expr="//page[@name='products']/group/group[1]" position="after">
                    <group>
                        
                        <field name="discount_ids" nolabel="1" class="discount_footer"
                               domain="[('is_discount', '=', True)]"
                               groups="tw_purchase_discount.group_tw_purchase_discount_showroom">
                            <list delete="false" editable="bottom" create="false">
                                <field name="name" readonly="1" />
                                <field name="discount_amount" />
                                <field name="price_unit" invisible="1" />
                                <field name="product_id" invisible="1" />
                                <field name="product_qty" invisible="1" />
                                <field name="product_uom" invisible="1" />
                                <field name="taxes_id" invisible="1" />
                                <field name="is_discount" invisible="1" />
                            </list>
                        </field>
                    </group>
                    <group />
                </xpath>
                
            </field>
        </record>

    </data>
</odoo>
