<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_purchase_discount_showroom" model="res.groups">
            <field name="name">TW Purchase Discount Showroom</field>
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order" />
        </record>

        <record id="access_tw_purchase_order_discount_showroom_read" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order" />
            <field name="name">tw_purchase_order_discount_showroom read</field>
            <field name="group_id" ref="group_tw_purchase_discount_showroom" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_purchase_order_line_discount_showroom_read" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order_line" />
            <field name="name">tw_purchase_order_line_discount_showroom read</field>
            <field name="group_id" ref="group_tw_purchase_discount_showroom" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_purchase_order_line_discount_showroom_update" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order_line" />
            <field name="name">tw_purchase_order_line_discount_showroom update</field>
            <field name="group_id" ref="group_tw_purchase_discount_showroom" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_purchase_discount_workshop" model="res.groups">
            <field name="name">TW Purchase Discount Workshop</field>
            <field name="category_id" ref="tw_purchase_order.tw_module_category_purchase_order" />
        </record>

        <record id="access_tw_purchase_order_discount_workshop_read" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order" />
            <field name="name">tw_purchase_order_discount_workshop read</field>
            <field name="group_id" ref="group_tw_purchase_discount_workshop" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_purchase_order_line_discount_workshop_read" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order_line" />
            <field name="name">tw_purchase_order_line_discount_workshop read</field>
            <field name="group_id" ref="group_tw_purchase_discount_workshop" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_purchase_order_line_discount_workshop_update" model="ir.model.access">
            <field name="model_id" ref="purchase.model_purchase_order_line" />
            <field name="name">tw_purchase_order_line_discount_workshop update</field>
            <field name="group_id" ref="group_tw_purchase_discount_workshop" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_discount_showroom')),
                (4, ref('group_tw_purchase_discount_workshop')),
            ]"/>
        </record>
    </data>
</odoo>