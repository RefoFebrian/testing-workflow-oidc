<odoo>
    <data>
        <record id="tw_asset_disposal_account_setting_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.asset.disposal.account.setting.inherit.view.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='journal_disposal_asset_id']" position="after">
                    <field name="journal_disposal_asset_hl_id" options="{'no_create': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
