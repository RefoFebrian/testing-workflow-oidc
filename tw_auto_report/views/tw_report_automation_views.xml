<odoo>
  <data>
    <record model="ir.ui.view" id="tw_report_automation_list_view">
      <field name="name">tw_report_automation list view</field>
      <field name="model">tw.report.automation</field>
      <field name="arch" type="xml">
        <list>
          <field name="name"/>
          <field name="directory"/>
          <field name="model"/>
        </list>
      </field>
    </record>

    <record id="tw_report_automation_form_view" model="ir.ui.view">
      <field name="name">tw_report_automation.form.view</field>
      <field name="model">tw.report.automation</field>
      <field name="arch" type="xml">
        <form string="Report Automation">
          <header>
            <button name="action_generate_report" string="Run Manually" type="object" class="btn-primary" invisible="not is_admin" groups="tw_auto_report.group_button_tw_auto_report_run_manually"/>
            <button name="action_confirmed" string="Confirm" type="object" class="btn-primary" invisible="state == 'confirmed'" groups="tw_auto_report.group_button_tw_auto_report_confirmed"/>
            <button name="action_draft" string="Set To Draft" type="object" class="btn-primary" invisible="state == 'draft'" groups="tw_auto_report.group_button_tw_auto_report_draft"/>
            <field name="state" widget="statusbar"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="is_admin" invisible="1"/>
                <field name="name" required="1" readonly="state == 'confirmed'"/>
                <field name="config_id" required="1" readonly="state == 'confirmed'"/>
                <field name="directory" required="1" readonly="state == 'confirmed'"/>
                <field name="ext" required="1" readonly="state == 'confirmed'"/>
              </group>
              <group>
                <field name="model_id" readonly="1"/>
                <field name="model" readonly="1"/>
                <field name="parameter" readonly="1"/>
                <field name="method" readonly="1"/>
              </group>
            </group>
            <notebook>
              <page name="report_files" string="Report Files">
                <field name="report_ids">
                  <list create="0" delete="0">
                    <field name="name"/>
                    <field name="full_path"/>
                    <field name="create_date"/>
                    <field name="create_uid"/>
                    <button name="action_download" string="Download" type="object" class="btn-secondary" icon="fa-download"/>
                  </list>
                </field>
              </page>
              <page name="audit_trail" string="Audit Trail">
                <group>
                  <group>
                    <field name="create_date"/>
                    <field name="create_uid"/>
                  </group>
                  <group>
                    <field name="write_date"/>
                    <field name="write_uid"/>
                  </group>
                </group>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record model="ir.actions.act_window" id="tw_report_automation_action_window">
      <field name="name">Report Automation</field>
      <field name="res_model">tw.report.automation</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="tw_report_automation_menuitem" sequence="10" action="tw_report_automation_action_window" groups="tw_auto_report.group_auto_report_read" parent="tw_menu.submenu_tw_report"/>

  </data>
</odoo>
