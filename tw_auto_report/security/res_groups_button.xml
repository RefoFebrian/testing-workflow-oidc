            <field name="name">TW Button Auto Report Run Manually</field>
            <field name="model_access" eval="[
                (4, ref('tw_auto_report.access_auto_report_read')),
                (4, ref('tw_auto_report.access_auto_report_file_read')),
                (4, ref('tw_auto_report.access_auto_report_update')),
                (4, ref('tw_auto_report.access_auto_report_file_update'))
            ]" />
        </record>

        <record id="group_button_tw_auto_report_confirmed" model="res.groups">
            <field name="category_id" ref="tw_auto_report.tw_auto_report_category" />
            <field name="name">TW Button Auto Report Confirmed</field>
            <field name="model_access" eval="[
                (4, ref('tw_auto_report.access_auto_report_read')),
                (4, ref('tw_auto_report.access_auto_report_file_read')),
                (4, ref('tw_auto_report.access_auto_report_update')),
                (4, ref('tw_auto_report.access_auto_report_file_update'))
            ]" />
        </record>
        
        <record id="group_button_tw_auto_report_draft" model="res.groups">
            <field name="category_id" ref="tw_auto_report.tw_auto_report_category" />
            <field name="name">TW Button Auto Report Draft</field>
            <field name="model_access" eval="[
                (4, ref('tw_auto_report.access_auto_report_read')),
                (4, ref('tw_auto_report.access_auto_report_file_read')),
                (4, ref('tw_auto_report.access_auto_report_update')),
                (4, ref('tw_auto_report.access_auto_report_file_update'))
            ]" />
        </record>

    </data>

    <data>
    
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
            (4,ref('group_button_tw_auto_report_run_manually')),
            (4,ref('group_button_tw_auto_report_confirmed')),
            (4,ref('group_button_tw_auto_report_draft')),
            ]"/>
        </record>
    
    </data>
    

</odoo>
