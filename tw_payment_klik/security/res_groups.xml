<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Payment Klik Wizard Access Group -->
        <record id="group_tw_laporan_payment_klik_wizard" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Payment Klik</field>
        </record>

        <record id="group_tw_laporan_payment_klik_bank_wizard" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Laporan Payment Klik Bank</field>
        </record>

        <record id="group_tw_verification_payment_klik" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Verification Payment Klik</field>
        </record>

        <record id="group_tw_approval_payment_klik" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Approval Payment Klik</field>
        </record>

        <record id="group_tw_process_payment_klik" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Process Payment Klik</field>
        </record>

        <!-- Add groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_laporan_payment_klik_wizard')),
                (4, ref('group_tw_laporan_payment_klik_bank_wizard')),
                (4, ref('group_tw_verification_payment_klik')),
                (4, ref('group_tw_approval_payment_klik')),
                (4, ref('group_tw_process_payment_klik')),
            ]"/>
        </record>
    </data>
</odoo>