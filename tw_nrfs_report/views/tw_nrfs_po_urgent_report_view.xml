<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_nrfs_po_urgent_form_view" model="ir.ui.view">
            <field name="name">tw.nrfs.po.urgent.report.form</field>
            <field name="model">tw.nrfs.po.urgent.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Laporan PO NRFS">
                    <group col="2" colspan="2">
                        <label for="start_date" string="Period"/>
                            <div>
                                <field name="start_date" class="oe_inline" required="1"/>
                                -
                                <field name="end_date" class="oe_inline" required="1"/>
                            </div>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="tw_nrfs_po_urgent_report_action" model="ir.actions.act_window">
            <field name="name">Laporan PO NRFS</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.nrfs.po.urgent.report</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_nrfs_po_urgent_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>