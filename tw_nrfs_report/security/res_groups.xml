<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

    <!-- TW Laporan NRFS LKUAT -->
        <record id="tw_nrfs_lkuat_laporan_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan NRFS LKUAT Read</field>
        </record>

        <record id="tw_nrfs_lkuat_laporan_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_lkuat_report" />
            <field name="name">tw_nrfs_lkuat_laporan read</field>
            <field name="group_id" ref="tw_nrfs_lkuat_laporan_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_nrfs_lkuat_laporan_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan NRFS LKUAT Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_nrfs_lkuat_laporan_group_read'))]" /> 
        </record>

        <record id="tw_nrfs_lkuat_laporan_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_lkuat_report" />
            <field name="name">tw_nrfs_lkuat_laporan update</field>
            <field name="group_id" ref="tw_nrfs_lkuat_laporan_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    <!-- TW Laporan PO Urgent Read -->
        <record id="tw_nrfs_po_urgent_laporan_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan PO Urgent Read</field>
        </record>

        <record id="tw_nrfs_po_urgent_laporan_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_po_urgent_report" />
            <field name="name">tw_nrfs_po_urgent_laporan read</field>
            <field name="group_id" ref="tw_nrfs_po_urgent_laporan_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_nrfs_po_urgent_laporan_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan PO Urgent Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_nrfs_po_urgent_laporan_group_read'))]" /> 
        </record>

        <record id="tw_nrfs_po_urgent_laporan_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_po_urgent_report" />
            <field name="name">tw_nrfs_po_urgent_laporan update</field>
            <field name="group_id" ref="tw_nrfs_po_urgent_laporan_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    <!-- TW Laporan NRFS Sparepart Read -->
        <record id="tw_nrfs_sparepart_laporan_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan NRFS Sparepart Read</field>
        </record>

        <record id="tw_nrfs_sparepart_laporan_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_sparepart_report" />
            <field name="name">tw_nrfs_sparepart_laporan read</field>
            <field name="group_id" ref="tw_nrfs_sparepart_laporan_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_nrfs_sparepart_laporan_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Laporan NRFS Sparepart Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_nrfs_sparepart_laporan_group_read'))]" /> 
        </record>

        <record id="tw_nrfs_sparepart_laporan_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_nrfs_sparepart_report" />
            <field name="name">tw_nrfs_sparepart_laporan update</field>
            <field name="group_id" ref="tw_nrfs_sparepart_laporan_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_nrfs_lkuat_laporan_group_read')),
   	            (4,ref('tw_nrfs_lkuat_laporan_group_update')),
                (4,ref('tw_nrfs_po_urgent_laporan_group_read')),
   	            (4,ref('tw_nrfs_po_urgent_laporan_group_update')),
                (4,ref('tw_nrfs_sparepart_laporan_group_read')),
   	            (4,ref('tw_nrfs_sparepart_laporan_group_update'))
            ]" />
        </record>
    </data>
</odoo>