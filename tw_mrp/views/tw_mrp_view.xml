<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_mrp_inherit_form_view" model="ir.ui.view">
            <field name="name">mrp.inherit.form</field>
            <field name="model">mrp.bom</field>
            <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
            <field name="arch" type="xml">
               <xpath expr="//sheet" position="before">
                    <header>
                        <button name="action_copy" string="Copy" type="object" class="oe_highlight" groups="tw_mrp.group_extras_button_copy"/>
                    </header>
               </xpath>

               <field name="product_qty" position="attributes">
                    <attribute name="readonly">True</attribute>
               </field>

               <field name="product_tmpl_id" position="attributes">
                    <attribute name="options">{'no_create': True}</attribute>
               </field>

               <field name="product_id" position="attributes">
                    <attribute name="options">{'no_create': True}</attribute>
               </field>
               
               <field name="company_id" position="attributes">
                    <attribute name="readonly">True</attribute>
               </field>

               <field name="type" position="attributes">
                    <attribute name="widget"></attribute>
                    <attribute name="readonly">True</attribute>
               </field>

               <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="attributes">
                    <attribute name="options">{'no_create': True}</attribute>
               </xpath>

               <page name="miscellaneous" position="after">
                    <page string="Audit Trail" name="audit_trail">
                        <group>
                            <group>
                                <field name="create_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="create_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="write_uid" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                <field name="write_date" readonly="1"/>
                            </group>
                        </group>
                    </page>
                </page>
            
            </field>
        </record>
        
    
    </data>
</odoo>
