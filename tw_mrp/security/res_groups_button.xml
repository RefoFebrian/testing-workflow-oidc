<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Extras Button -->
        <record id="group_extras_button_copy" model="res.groups">
            <field name="category_id" ref="tw_mrp.tw_module_category_mrp"/>
            <field name="name">TW Button - Extras Copy</field>
        </record>

        <!-- Extras Wizard Access -->
        <record id="access_tw_mrp_copy_wizard_read" model="ir.model.access">
            <field name="name">tw_mrp_copy_wizard read</field>
            <field name="model_id" ref="model_tw_mrp_copy_wizard"/>
            <field name="group_id" ref="group_extras_button_copy"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="access_tw_mrp_copy_wizard_update" model="ir.model.access">
            <field name="name">tw_mrp_copy_wizard update</field>
            <field name="model_id" ref="model_tw_mrp_copy_wizard"/>
            <field name="group_id" ref="group_extras_button_copy"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>
        <record id="access_tw_mrp_copy_wizard_delete" model="ir.model.access">
            <field name="name">tw_mrp_copy_wizard delete</field>
            <field name="model_id" ref="model_tw_mrp_copy_wizard"/>
            <field name="group_id" ref="group_extras_button_copy"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <!-- Admin Group -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_extras_button_copy')),
            ]"/>
        </record>
    </data>
</odoo>