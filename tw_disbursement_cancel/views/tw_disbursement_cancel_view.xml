<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
    	
    	<record id="disbursement_cancel_list_view" model="ir.ui.view">
            <field name="name">tw.disbursement.cancel.list</field>
            <field name="model">tw.disbursement.cancel</field>
            <field name="arch" type="xml">
                <list string="Disbursement Cancel">
                	<field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                	<field name="disbursement_id"/>
                    <field name="date"/>
                    <field name="state"/>
				</list>
			</field>
        </record>
        
        <record id="view_disbursement_cancel_search" model="ir.ui.view">
            <field name="name">tw.disbursement.cancel.search</field>
            <field name="model">tw.disbursement.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Disbursement Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="disbursement_id"/>
                    <field name="date" />
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Waiting For Approval" name="waiting_approval" domain="[('state','=','waiting_for_approval')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Outstanding" name="outstanding" domain="[('state','!=','confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                        <filter string="Branch" name="group_branch" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                        <filter string="Division" name="group_division" context="{'group_by': 'division'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <record id="inherit_disbursement_cancel_form_view" model="ir.ui.view">
            <field name="name">tw.disbursement.cancel.form</field>
            <field name="model">tw.disbursement.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <field name="transaction_name" position="after">
                    <field name="disbursement_id" required="1" readonly="state != 'draft'" 
                        options="{'no_create':True,'no_open':True}" 
                        domain="[('company_id','=',company_id),('division','=',division),('state', 'not in', ['draft','cancel'])]" 
                        invisible="context.get('default_model_type') != 'tw.disbursement' or (disbursement_id != False and state != 'draft')"/>
                </field>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_disbursement_cancel.group_tw_disbursement_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_disbursement_cancel.group_tw_disbursement_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_disbursement_cancel.group_tw_disbursement_cancel_approval_confirm</attribute>
                </xpath>
            </field>
        </record>
        
        <record id="disbursement_cancel_action" model="ir.actions.act_window">
            <field name="name">Disbursement Cancel</field>
            <field name="res_model">tw.disbursement.cancel</field>
            <field name="search_view_id" ref="view_disbursement_cancel_search"/>
            <field name="context" eval="{
                'default_model_id': ref('tw_disbursement.model_tw_disbursement'),
                'default_model_type': 'tw.disbursement',
                'search_default_outstanding':'1',
            }"/>
            <field name="domain">[('disbursement_id','!=',False),('model_id.model','=','tw.disbursement')]</field>
        </record>
        
        <record id="disbursement_cancel_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="disbursement_cancel_list_view"/>
            <field name="act_window_id" ref="disbursement_cancel_action"/>
        </record>
        
        <record id="disbursement_cancel_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_disbursement_cancel_form_view"/>
            <field name="act_window_id" ref="disbursement_cancel_action"/>
        </record>
        
	</data>
</odoo>