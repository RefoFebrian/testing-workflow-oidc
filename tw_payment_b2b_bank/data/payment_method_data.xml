<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <record id="payment_method_virtual_account" model="payment.method">
            <field name="name">Virtual Account</field>
            <field name="code">virtual_account</field>
            <field name="sequence">1000</field>
            <field name="active">False</field>
            <field name="support_tokenization">False</field>
            <field name="support_express_checkout">False</field>
            <field name="support_refund">none</field>
            <field name="supported_country_ids"
                eval="[Command.set([
                    ref('base.id'),
                ])]"
            />
            <field name="supported_currency_ids"
                eval="[Command.set([
                    ref('base.IDR'),
                ])]"
            />
        </record>
        
    </data>
</odoo>