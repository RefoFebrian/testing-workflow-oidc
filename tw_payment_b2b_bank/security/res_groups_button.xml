<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
    
        <!-- Generate API Payment Trx QRIS Button -->
		<record id="group_tw_payment_b2b_bank_button_generate_api_payment_qris" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Generate API Payment Trx QRIS</field>
        </record>
        <record id="access_tw_payment_b2b_bank_button_generate_api_payment_qris" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_payment"/>
            <field name="name">tw_payment_b2b_bank_button_generate_api_payment_qris update</field>
            <field name="group_id" ref="group_tw_payment_b2b_bank_button_generate_api_payment_qris"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Inquiry API Payment Trx QRIS Button -->
		<record id="group_tw_payment_b2b_bank_button_inquiry_api_payment_qris" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Inquiry API Payment Trx QRIS</field>
        </record>
        <record id="access_tw_payment_b2b_bank_button_inquiry_api_payment_qris" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_payment"/>
            <field name="name">tw_payment_b2b_bank_button_inquiry_api_payment_qris update</field>
            <field name="group_id" ref="group_tw_payment_b2b_bank_button_inquiry_api_payment_qris"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Generate API Payment Trx Virtual Account Button -->
		<record id="group_tw_payment_b2b_bank_button_generate_api_payment_va" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Generate API Payment Trx Virtual Account</field>
        </record>
        <record id="access_tw_payment_b2b_bank_button_generate_api_payment_va" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_payment"/>
            <field name="name">tw_payment_b2b_bank_button_generate_api_payment_va update</field>
            <field name="group_id" ref="group_tw_payment_b2b_bank_button_generate_api_payment_va"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Inquiry API Payment Trx Virtual Account Button -->
		<record id="group_tw_payment_b2b_bank_button_inquiry_api_payment_va" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Inquiry API Payment Trx Virtual Account</field>
        </record>
        <record id="access_tw_payment_b2b_bank_button_inquiry_api_payment_va" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_payment"/>
            <field name="name">tw_payment_b2b_bank_button_inquiry_api_payment_va update</field>
            <field name="group_id" ref="group_tw_payment_b2b_bank_button_inquiry_api_payment_va"/>
            <field name="perm_write">1</field>
        </record>

		<record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_payment_b2b_bank_button_generate_api_payment_qris')),
                (4,ref('group_tw_payment_b2b_bank_button_inquiry_api_payment_qris')),
                (4,ref('group_tw_payment_b2b_bank_button_generate_api_payment_va')),
                (4,ref('group_tw_payment_b2b_bank_button_inquiry_api_payment_va')),
            ]"/>
        </record>

	</data>
</odoo>