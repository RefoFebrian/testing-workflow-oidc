<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tw_payment_b2b_bank_account_payment_inherit_form_view" model="ir.ui.view">
        <field name="name">tw.payment.b2b.bank.account.payment.inherit.form</field>
        <field name="inherit_id" ref="tw_payment.tw_account_payment_form_view"/>
        <field name="model">tw.account.payment</field>
        <field name="arch" type="xml">
            <button name="action_post" position="after">
                <button name="action_generate_api_payment_qris" invisible="payment_method != 'qris' or state != 'in_process' or payment_transaction_id != False" string="Generate QRIS" type="object" groups="tw_payment_b2b_bank.group_tw_payment_b2b_bank_button_generate_api_payment_qris"/>
                <button name="action_inquiry_api_payment_qris" invisible="payment_method != 'qris' or state != 'in_process' or payment_transaction_id == False or payment_transaction_status == 'done'" string="Inquiry QRIS" type="object" groups="tw_payment_b2b_bank.group_tw_payment_b2b_bank_button_inquiry_api_payment_qris"/>
                <button name="action_generate_api_payment_va" invisible="payment_method != 'virtual_account' or state != 'in_process' or payment_transaction_id != False" string="Generate VA" type="object" groups="tw_payment_b2b_bank.group_tw_payment_b2b_bank_button_generate_api_payment_va"/>
                <button name="action_inquiry_api_payment_va" invisible="payment_method != 'virtual_account' or state != 'in_process' or payment_transaction_id == False or payment_transaction_status in ('draft', 'done')" string="Inquiry VA" type="object" groups="tw_payment_b2b_bank.group_tw_payment_b2b_bank_button_inquiry_api_payment_va"/>
            </button>

            <button name="action_validate" position="attributes">
                <attribute name="invisible">state != 'in_process' or move_id or payment_provider</attribute>
            </button>

            <field name="receipt_print_count" position="after">
                <field name="qris_qr_image" invisible="payment_method != 'qris' or payment_transaction_id == False" readonly="1" widget="image" options="{'size': [200, 253]}"/>
                <field name="va_no" invisible="not va_no" readonly="1"/>
                <field name="payment_transaction_status" readonly="1" invisible="not payment_transaction_status"/>
            </field>

            <field name="id" position="before">
                <widget name="web_ribbon" title="Paid" invisible="state != 'paid' or payment_transaction_status != 'done'"/>
            </field>
        </field>
    </record>

</odoo>