<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Scheduled Action for MFT Telegram Notification -->
        <record id="ir_cron_mft_telegram_notification" model="ir.cron">
            <field name="name">MFT Monitoring - Send Telegram Notification</field>
            <field name="model_id" search="[('model', '=', 'tw.mft.config')]"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_mft_telegram_notification()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
