<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_purchase_return_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Request Approval</field>
        </record>

        <record id="access_tw_purchase_return_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_purchase_return.model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_approval_rfa update</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Groups button approval Cancel -->

        <record id="group_tw_purchase_return_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Cancel</field>
        </record>
        <record id="access_tw_purchase_return_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_purchase_return.model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_approval_cancel update</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_return_picking_purchase_return_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking"/>
            <field name="name">stock.return.picking purchase return cancel</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_cancel"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_return_picking_line_purchase_return_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking_line"/>
            <field name="name">stock.return.picking.line purchase return cancel</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_cancel"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Groups button approval Reject -->

        <record id="group_tw_purchase_return_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Reject</field>
        </record>
        <record id="access_tw_purchase_return_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_purchase_return.model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_approval_reject update</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_reject"/>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_return_picking_purchase_return_approval_reject" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking"/>
            <field name="name">stock.return.picking purchase return reject</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_reject"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="access_stock_return_picking_line_purchase_return_approval_reject" model="ir.model.access">
            <field name="model_id" ref="stock.model_stock_return_picking_line"/>
            <field name="name">stock.return.picking.line purchase return reject</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_reject"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_purchase_return_approval_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Purchase Return Confirm After Approval</field>
        </record>

        <record id="access_tw_purchase_return_approval_confirm" model="ir.model.access">
            <field name="model_id" ref="tw_purchase_return.model_tw_purchase_return"/>
            <field name="name">tw_purchase_return_approval_confirm update</field>
            <field name="group_id" ref="group_tw_purchase_return_approval_confirm"/>
            <field name="perm_write">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_purchase_return_approval_rfa')),
                (4, ref('group_tw_purchase_return_approval_cancel')),
                (4, ref('group_tw_purchase_return_approval_reject')),
                (4, ref('group_tw_purchase_return_approval_confirm')),
            ]"/>
        </record>
    </data>

</odoo>
