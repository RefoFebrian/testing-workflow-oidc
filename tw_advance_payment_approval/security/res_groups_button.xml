<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
             
        <record id="group_tw_advance_payment_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Button Cancel Advance Payment</field>
        </record>
        <record id="access_tw_advance_payment_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment.model_tw_advance_payment"/>
            <field name="name">tw_advance_payment_approval_cancel update</field>
            <field name="group_id" ref="group_tw_advance_payment_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_tw_advance_payment_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Button Reject Advance Payment</field>
        </record>
        <record id="access_tw_advance_payment_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment.model_tw_advance_payment"/>
            <field name="name">tw_advance_payment_approval_reject update</field>
            <field name="group_id" ref="group_tw_advance_payment_approval_reject"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_advance_payment_approval_request" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Button Request Approval Advance Payment</field>
        </record>
        
        <record id="access_tw_advance_payment_approval_request" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment.model_tw_advance_payment"/>
            <field name="name">tw_advance_payment_approval_request update</field>
            <field name="group_id" ref="group_tw_advance_payment_approval_request"/>
            <field name="perm_write">1</field>
        </record>
        
	</data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_advance_payment_approval_cancel')),
                (4,ref('group_tw_advance_payment_approval_reject')),
                (4,ref('group_tw_advance_payment_approval_request')),
            ]">
			</field>
		</record>
	</data>
</odoo>