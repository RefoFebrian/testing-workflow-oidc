<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_b2b_api_monitoring_ev_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.api.monitoring.ev.form</field>
            <field name="model">tw.b2b.api.monitoring.ev</field>
            <field name="arch" type="xml">
                <form string="TW B2B API Monitoring EV" create="0" delete="0" duplicate="0">
                    <sheet>
                        <h1>Monitoring SL EV</h1>
                        <group>
                            <group>
                                <field name="company_id" required="1" options="{'no_create':True,'no_open':True}"/>
                                <field name="state" required="1"/>
                                <label for="start_date" string="Periode Tanggal"/>
                                <div>
                                    <field name="start_date" required="1" class="oe_inline" style="margin-right: 3px;" />&#160;-&#160;
                                    <field name="end_date" required="1" class="oe_inline" />
                                </div>
                            </group>
                        </group>
                        <button name="action_search" type="object" string="Search" class="oe_highlight"/>
                        <group>
                            <field name="line_ids" nolabel="1" readonly="1" widget="one2many_list">
                                <list string="Monitoring SL EV" edit="0" editable="bottom">
                                    <field name="company_id" options="{'no_create':True,'no_open':True}"/>
                                    <field name="ship_list_date"/>
                                    <field name="ship_list_number"/>
                                    <field name="total_unit"/>
                                    <field name="total_baterai"/>
                                    <field name="state"/>
                                    <button name="action_detail" type="object" string="Detail" class="oe_highlight"/>
                                </list>
                            </field>
                        </group>	
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_b2b_api_monitoring_ev_action" model="ir.actions.act_window">
            <field name="name">Monitoring EV</field>
            <field name="res_model">tw.b2b.api.monitoring.ev</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_b2b_api_monitoring_ev_form_view"/>
        </record>
    </data>
</odoo>