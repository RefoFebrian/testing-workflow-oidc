<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_b2b_api_ev_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.api.ev.list</field>
            <field name="model">tw.b2b.api.ev</field>
            <field name="arch" type="xml">
                <list string="B2B API EV" create="0" delete="0" duplicate="0">
                    <field name="company_id" options="{'no_open': True, 'no_create': True}"/>
                    <field name="ship_list_number"/>
                    <field name="packing_number"/>
					<field name="ship_list_date"/>
					<field name="hit_api_date"/>
                    <field name="jenis_acc"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="tw_b2b_api_ev_form_view" model="ir.ui.view">
            <field name="name">tw.b2b.api.ev.form</field>
            <field name="model">tw.b2b.api.ev</field>
            <field name="arch" type="xml">
                <form string="B2B API EV" create="0" edit="0" delete="0" duplicate="0">
                    <header>
                        <button name="action_process" invisible="state != 'draft'" string="Process" type="object" class="oe_highlight" groups="tw_b2b_api_ev.tw_b2b_api_ev_button_process_group"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting,assigned,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_open_picking" type="object" class="oe_stat_button" icon="fa-truck" string="Picking" invisible="not picking_id"/>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_open': True, 'no_create': True}"/>
                                <field name="ship_list_number"/>
                                <field name="packing_number"/>
                                <field name="md_code"/>
                            </group>
                            <group>
                                <field name="ship_list_date"/>
                                <field name="voucher_acc"/>
                            </group>
                        </group>
                        <notebook>   
                            <page string="Details">
                                <field name="line_ids" widget="one2many_list" readonly="1">
                                    <list string="B2B API Line" create="0" delete="0">
                                        <field name="serial_number"/>
                                        <field name="part_code"/>
                                        <field name="part_desc"/>
                                        <field name="type_acc"/>
                                        <field name="box_number"/>
                                        <field name="carton_number"/>
                                        <field name="state"/>
                                        <button name="action_open_lot" type="object" string="View Detail Lot" optional="show"/>
                                    </list>
                                </field>
                            </page>		                 
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"></field>
                                        <field name="create_date" readonly="1"></field>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"></field>
                                        <field name="write_date" readonly="1"></field>
                                    </group>
                                </group>
                            </page>		                 
		                </notebook>	
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_b2b_api_ev_search_view" model="ir.ui.view">
            <field name="name">tw.b2b.api.ev.search</field>
            <field name="model">tw.b2b.api.ev</field>
            <field name="arch" type="xml">
                <search string="Search B2B API EV">
                    <field name="ship_list_number"/>
                    <field name="packing_number"/>
                    <field name="state"/>
                    <field name="jenis_acc"/>
                    <field name="hit_api_date"/>
                    <field name="ship_list_date"/>
                    <filter name="state_draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="state_waiting" string="Waiting" domain="[('state','=','waiting')]"/>
                    <filter name="state_assigned" string="Ready" domain="[('state','=','assigned')]"/>
                    <filter name="state_done" string="Done" domain="[('state','=','done')]"/>
                    <filter name="state_error" string="Error" domain="[('state','=','error')]"/>
                    <filter name="state_duplicate" string="Duplicate" domain="[('state','=','duplicate')]"/>
                    <filter name="jenis_acc_rem" string="REM" domain="[('jenis_acc','=','REM')]"/>
                    <filter name="jenis_acc_oem" string="OEM" domain="[('jenis_acc','=','OEM')]"/>
                    <group expand="0" string="Group By">
						<filter name="ship_list_number" string="Ship List Number" context="{'group_by': 'ship_list_number'}" />
						<filter name="packing_number" string="Packing Number" context="{'group_by': 'packing_number'}" />
						<filter name="jenis_acc" string="Jenis Acc" context="{'group_by': 'jenis_acc'}" />
						<filter name="hit_api_date" string="Hit API Date" context="{'group_by': 'hit_api_date'}" />
						<filter name="ship_list_date" string="Ship List Date" context="{'group_by': 'ship_list_date'}" />
					</group>
                </search>
            </field>
        </record>

        <record id="tw_b2b_api_ev_action" model="ir.actions.act_window">
            <field name="name">B2B API EV</field>
            <field name="res_model">tw.b2b.api.ev</field>
            <field name="view_mode">list,form</field>
            <field name="context">{
                "search_default_state_draft":1,
                "search_default_state_waiting":1,
                "search_default_state_assigned":1
            }</field>
        </record>
    </data>
</odoo>