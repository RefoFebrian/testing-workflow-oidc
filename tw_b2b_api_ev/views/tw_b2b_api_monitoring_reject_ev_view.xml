<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_b2b_api_monitoring_reject_ev_list_view" model="ir.ui.view">
            <field name="name">tw.b2b.api.monitoring.reject.ev.list</field>
            <field name="model">stock.lot</field>
            <field name="arch" type="xml">
                <list string="Reject EV" create="0" edit="0" delete="0" duplicate="0">
                    <field name="name"/>
                    <field name="ship_list_number"/>
                    <field name="packing_number"/>
					<field name="ship_list_date"/>
                    <field name="jenis_acc"/>
                    <field name="category_acc"/>
					<field name="note_api_ev"/>
					<field name="actual_ev_md_receive_date"/>
                    <field name="state"/>
                    <button name="action_reset_status_ev" type="object" string="Reset" class="oe_highlight"/>
                </list>
            </field>
        </record>

        <record id="tw_b2b_api_monitoring_reject_ev_action" model="ir.actions.act_window">
            <field name="name">Monitoring Reject EV</field>
            <field name="res_model">stock.lot</field>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_b2b_api_monitoring_reject_ev_list_view"/>
            <field name="domain">[('actual_ev_md_receive_date', '!=', False),('note_api_ev', '!=', False)]</field>
        </record>

        <record id="action_tw_b2b_api_monitoring_reject_ev_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_b2b_api_monitoring_reject_ev_list_view"/>
            <field name="act_window_id" ref="tw_b2b_api_monitoring_reject_ev_action"/>
        </record>

    </data>
</odoo>