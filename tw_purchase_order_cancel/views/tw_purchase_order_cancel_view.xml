<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
    
    <!-- PO Cancellation -->
    	
    	<record model="ir.ui.view" id="purchase_order_cancel_list_view">
            <field name="name">tw.purchase.order.cancel.list</field>
            <field name="model">tw.purchase.order.cancel</field>
            <field name="arch" type="xml">
                <list string="Purchase Order Cancel">
                	<field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                	<field name="purchase_order_id"/>
                    <field name="date"/>
                    <field name="state"/>
				</list>
			</field>
        </record>
        
        <record id="view_purchase_order_cancel_search" model="ir.ui.view">
            <field name="name">tw.purchase.order.cancel.search</field>
            <field name="model">tw.purchase.order.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Purchase Order Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="purchase_order_id"/>
                    <field name="date"/>
                    <field name="division"/>
                    <filter string="Waiting For Approval" name="waiting_approval" domain="[('state','=','waiting_approval')]"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
					<group string="Group By" name="groupby">
                        <filter name="state_groupby" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="name_groupby" string="Name" context="{'group_by': 'name'}"/>
                        <filter name="date" string="Date" context="{'group_by': 'date'}"/>
                        <filter name="division" string="Division" context="{'group_by': 'division'}"/>
                        <filter name="company_id" string="Branch" context="{'group_by': 'company_id'}"/>
                        <filter name="purchase_order_id" string="Purchase Order" context="{'group_by': 'purchase_order_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <record model="ir.ui.view" id="inherit_purchase_order_cancel_form_view">
            <field name="name">tw.purchase.order.cancel.form</field>
            <field name="model">tw.purchase.order.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <!-- Smart Buttons -->
                <div name="button_box" position="inside">
                    <button name="action_view_purchase_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not purchase_order_id">
                        <field name="purchase_order_id" string="Purchase Order" widget="statinfo" options="{'label_field': 'name'}"/>
                    </button>
                    <button name="action_view_pickings" type="object" class="oe_stat_button" icon="fa-truck" invisible="picking_count == 0">
                        <field name="picking_count" string="Pickings" widget="statinfo"/>
                    </button>
                </div>

                 <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_purchase_order_cancel.group_tw_purchase_order_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_purchase_order_cancel.group_tw_purchase_order_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_purchase_order_cancel.group_tw_purchase_order_cancel_approval_confirm</attribute>
                </xpath>
                
                <!-- Purchase Order Field -->
                <field name="transaction_name" position="after">
                    <field name="purchase_order_id" required="1" readonly="state != 'draft'" 
                           options="{'no_create':True,'no_open':True}" 
                           domain="[('company_id','=',company_id),('division','=',division),('state', 'not in', ['draft','waiting_for_approval','cancel']),('partner_id.code', '!=', 'AHM')]"
                           invisible="context.get('default_model_type') != 'purchase.order'"/>
                </field>
            </field>
        </record>

        
        <record model="ir.actions.act_window" id="purchase_order_cancel_unit_action">
            <field name="name">Purchase Order Unit Cancel</field>
            <field name="res_model">tw.purchase.order.cancel</field>
            <field name="search_view_id" ref="view_purchase_order_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('purchase.model_purchase_order'),
            'default_model_type': 'purchase.order',
            'default_division': 'Unit',
            'search_default_draft': '1',
            'search_default_waiting_approval': '1',
            'search_default_confirmed': '1',
            }
            "/>
            <field name="domain">[('division','=','Unit'),'|',('purchase_order_id','!=',False),('model_id.model','=','purchase.order')]</field>
        </record>
        
        <record model="ir.actions.act_window" id="purchase_order_cancel_sparepart_action">
            <field name="name">Purchase Order Sparepart Cancel</field>
            <field name="res_model">tw.purchase.order.cancel</field>
            <field name="search_view_id" ref="view_purchase_order_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('purchase.model_purchase_order'),
            'default_model_type': 'purchase.order',
            'default_division': 'Sparepart',
            'search_default_draft': '1',
            'search_default_waiting_approval': '1',
            'search_default_confirmed': '1',
            }
            "/>
            <field name="domain">[('division','=','Sparepart'),'|',('purchase_order_id','!=',False),('model_id.model','=','purchase.order')]</field>
        </record>
        
        <record id="purchase_order_cancel_unit_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="purchase_order_cancel_list_view"/>
            <field name="act_window_id" ref="purchase_order_cancel_unit_action"/>
        </record>
        
        <record id="purchase_order_cancel_unit_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_purchase_order_cancel_form_view"/>
            <field name="act_window_id" ref="purchase_order_cancel_unit_action"/>
        </record>
     
        <record id="purchase_order_cancel_sparepart_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="purchase_order_cancel_list_view"/>
            <field name="act_window_id" ref="purchase_order_cancel_sparepart_action"/>
        </record>
        
        <record id="purchase_order_cancel_sparepart_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_purchase_order_cancel_form_view"/>
            <field name="act_window_id" ref="purchase_order_cancel_sparepart_action"/>
        </record>
        
	</data>
</odoo>