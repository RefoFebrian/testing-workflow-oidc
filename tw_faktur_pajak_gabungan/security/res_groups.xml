<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_fpg_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Gabungan Read</field>
        </record>

        <record id="group_fpg_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Gabungan Update</field>
        </record>

        <record id="group_fpg_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Faktur Pajak Gabungan Delete</field>
        </record>

        <!-- Generate Faktur Pajak Out Wizard Group -->
        <record id="group_tw_generate_faktur_pajak_wizard_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Generate Faktur Pajak Out</field>
            <field name="implied_ids" eval="[(4, ref('group_fpg_read'))]"/>
        </record>

        <record id="access_master_model_pajak_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_master_model_pajak"/>
            <field name="name">tw_master_model_pajak read</field>
            <field name="group_id" ref="group_fpg_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_fpg_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan"/>
            <field name="name">tw_faktur_pajak_gabungan read</field>
            <field name="group_id" ref="group_fpg_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_fpg_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan_line"/>
            <field name="name">tw_faktur_pajak_gabungan_line read</field>
            <field name="group_id" ref="group_fpg_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_master_model_pajak_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_master_model_pajak"/>
            <field name="name">tw_master_model_pajak update</field> 
            <field name="group_id" ref="group_fpg_update"/>
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>
        <record id="access_fpg_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan"/>
            <field name="name">tw_faktur_pajak_gabungan update</field> 
            <field name="group_id" ref="group_fpg_update"/>
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>
        <record id="access_fpg_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan_line"/>
            <field name="name">tw_faktur_pajak_gabungan_line update</field> 
            <field name="group_id" ref="group_fpg_update"/>
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

        <record id="access_master_model_pajak_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_master_model_pajak"/>
            <field name="name">tw_master_model_pajak delete</field>
            <field name="group_id" ref="group_fpg_delete"/>
            <field name="perm_unlink">1</field>
        </record>
        <record id="access_fpg_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan"/>
            <field name="name">tw_faktur_pajak_gabungan delete</field>
            <field name="group_id" ref="group_fpg_delete"/>
            <field name="perm_unlink">1</field>
        </record>
        <record id="access_fpg_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_faktur_pajak_gabungan_line"/>
            <field name="name">tw_faktur_pajak_gabungan_line delete</field>
            <field name="group_id" ref="group_fpg_delete"/>
            <field name="perm_unlink">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_fpg_read')),
                (4, ref('group_fpg_update')),
                (4, ref('group_fpg_delete')),
                (4, ref('group_tw_generate_faktur_pajak_wizard_read')),
            ]"/>
        </record>
    </data>
</odoo>