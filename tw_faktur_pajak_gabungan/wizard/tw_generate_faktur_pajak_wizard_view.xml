<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Message Result Form View -->
        <record id="tw_generate_faktur_pajak_wizard_message_form" model="ir.ui.view">
            <field name="name">tw.generate.faktur.pajak.wizard.message.form</field>
            <field name="model">tw.generate.faktur.pajak.wizard</field>
            <field name="arch" type="xml">
                <form string="Result">
                    <sheet>
                        <group>
                            <field name="message" readonly="1" nolabel="1" widget="text"/>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Close" class="btn-primary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Main Wizard Form View -->
        <record id="tw_generate_faktur_pajak_wizard_form" model="ir.ui.view">
            <field name="name">tw.generate.faktur.pajak.wizard.form</field>
            <field name="model">tw.generate.faktur.pajak.wizard</field>
            <field name="arch" type="xml">
                <form string="Generate Faktur Pajak">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <span class="o_form_label">Generate Faktur Pajak</span>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="master_model_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                                <field name="transaction" placeholder="Masukkan minimal 10 karakter..."/>
                            </group>
                            <group>
                                <label for="start_date" string="Periode"/>
                                <div class="o_row">
                                    <field name="start_date" class="oe_inline"/>
                                    <span class="mx-1">-</span>
                                    <field name="end_date" class="oe_inline"/>
                                </div>
                                <field name="is_found" invisible="1"/>
                                <field name="message" invisible="not message" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <button name="action_search" type="object" string="Search" class="btn-secondary" icon="fa-search"/>
                        </group>
                        <notebook invisible="not is_found">
                            <page string="Transactions">
                                <field name="transaction_ids" nolabel="1">
                                    <list create="false" edit="false" delete="false">
                                        <field name="model_id" optional="hide"/>
                                        <field name="transaction_name"/>
                                        <field name="release_date"/>
                                        <field name="thn_penggunaan"/>
                                        <field name="transaction_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <footer>
                        <button name="action_generate_all" type="object" string="Generate" class="btn-primary" invisible="not is_found"/>
                        <button string="Discard" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- Wizard Action -->
        <record id="action_tw_generate_faktur_pajak_wizard" model="ir.actions.act_window">
            <field name="name">Generate Faktur Pajak Out</field>
            <field name="res_model">tw.generate.faktur.pajak.wizard</field>
            <field name="type">ir.actions.act_window</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_generate_faktur_pajak_wizard_form"/>
            <field name="target">new</field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_tw_generate_faktur_pajak_wizard" name="Generate Faktur Pajak Out" parent="menu_tw_faktur_pajak_gabungan" action="action_tw_generate_faktur_pajak_wizard" sequence="30" groups="group_tw_generate_faktur_pajak_wizard_read"/>

    </data>
</odoo>
