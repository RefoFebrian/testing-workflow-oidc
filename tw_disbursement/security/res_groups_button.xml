<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Disbursement Post -->
		<record id="group_tw_disbursement_post" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Disbursement Post</field>
        </record>

        <!-- Disbursement Cancel -->
		<record id="group_tw_disbursement_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Disbursement Cancel</field>
        </record>

        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_tw_disbursement_post')),
				(4,ref('group_tw_disbursement_cancel')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>