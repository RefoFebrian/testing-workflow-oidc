<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_tw_disbursement_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Disbursement EDC Read</field>
        </record>

        <record id="access_tw_disbursement_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement"/>
            <field name="name">tw_disbursement read</field>
            <field name="group_id" ref="group_tw_disbursement_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_disbursement_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement_line"/>
            <field name="name">tw_disbursement_line read</field>
            <field name="group_id" ref="group_tw_disbursement_read"/>
            <field name="perm_read">1</field>
        </record>
            
        <record id="group_tw_disbursement_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Disbursement EDC Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_disbursement_read'))]"/>
        </record>

        <record id="access_tw_disbursement_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement"/>
            <field name="name">tw_disbursement update</field>
            <field name="group_id" ref="group_tw_disbursement_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_disbursement_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement_line"/>
            <field name="name">tw_disbursement_line update</field>
            <field name="group_id" ref="group_tw_disbursement_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_disbursement_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Disbursement EDC Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_disbursement_read'))]"/>
        </record>

        <record id="access_tw_disbursement_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement"/>
            <field name="name">tw_disbursement delete</field>
            <field name="group_id" ref="group_tw_disbursement_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_disbursement_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_disbursement_line"/>
            <field name="name">tw_disbursement_line delete</field>
            <field name="group_id" ref="group_tw_disbursement_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_disbursement_read')),
                (4, ref('group_tw_disbursement_update')),
                (4, ref('group_tw_disbursement_delete')),
            ]"/>
        </record>
    </data>
</odoo>
