<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category Payment Request -->
        <record id="tw_module_category_payment_request" model="ir.module.category">
            <field name="name">TW Payment Request</field>
        </record>
        
        <!-- Read Access -->
        <record id="group_payment_request_read" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Read</field>
        </record>

        <!-- Update Access -->
        <record id="group_payment_request_update" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Update</field>
            <field name="implied_ids" eval="[(4, ref('group_payment_request_read'))]"/>
        </record>

        <!-- Delete Access -->
        <record id="group_payment_request_delete" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_payment_request_read'))]"/>
        </record>

        <!-- Payment Request Type Groups -->
        <record id="group_payment_request_type_read" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Type Read</field>
        </record>

        <record id="group_payment_request_type_update" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Type Update</field>
            <field name="implied_ids" eval="[(4, ref('group_payment_request_type_read'))]"/>
        </record>

        <record id="group_payment_request_type_delete" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Type Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_payment_request_type_read'))]"/>
        </record>

        <!-- Payment Request Report -->
        <record id="group_payment_request_report" model="res.groups">
            <field name="category_id" ref="tw_payment_request.tw_module_category_payment_request"/>
            <field name="name">TW Payment Request Report</field>
            <field name="implied_ids" eval="[(4, ref('tw_payment_request.group_payment_request_read'))]"/>
        </record>

        <record id="access_payment_request_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_payment_request_report"/>
            <field name="name">tw.payment.request.report access</field>
            <field name="group_id" ref="group_payment_request_report"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_payment_request_read')),
                (4, ref('group_payment_request_update')),
                (4, ref('group_payment_request_delete')),
                (4, ref('group_payment_request_type_read')),
                (4, ref('group_payment_request_type_update')),
                (4, ref('group_payment_request_type_delete')),
                (4, ref('group_payment_request_report')),
            ]"/>
        </record>
    </data>
</odoo>
