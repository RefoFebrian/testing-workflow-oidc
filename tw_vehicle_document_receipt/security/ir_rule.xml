<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Company Rules for Main Model -->
        <record id="tw_vehicle_registration_receipt_comp_rule" model="ir.rule">
            <field name="name">Vehicle Registration Receipt: Company</field>
            <field name="model_id" ref="model_tw_vehicle_registration_receipt"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('tw_vehicle_document_receipt.group_tw_vehicle_registration_receipt_read'))]"/>
        </record>

        <record id="tw_vehicle_ownership_receipt_comp_rule" model="ir.rule">
            <field name="name">Vehicle Ownership Receipt: Company</field>
            <field name="model_id" ref="model_tw_vehicle_ownership_receipt"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('tw_vehicle_document_receipt.group_vehicle_ownership_receipt_read'))]"/>
        </record>
    </data>
</odoo>
