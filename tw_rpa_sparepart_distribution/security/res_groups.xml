<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="group_tw_schedule_shipment_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Schedule Shipment Read</field>
        </record>

        <record id="access_tw_schedule_shipment" model="ir.model.access">
            <field name="model_id" ref="model_tw_schedule_shipment" />
            <field name="name">access_tw_schedule_shipment</field>
            <field name="group_id" ref="group_tw_schedule_shipment_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_schedule_shipment_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Schedule Shipment Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_schedule_shipment_read'))]"/>
        </record>

        <record id="access_tw_schedule_shipment_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_schedule_shipment" />
            <field name="name">access_tw_schedule_shipment</field>
            <field name="group_id" ref="group_tw_schedule_shipment_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_master_dealer_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Dealer Group Read</field>
        </record>

        <record id="access_tw_master_dealer_group" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection" />
            <field name="name">access_tw_master_dealer_group</field>
            <field name="group_id" ref="group_tw_master_dealer_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_master_dealer_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Dealer Group Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_master_dealer_group_read'))]"/>
        </record>

        <record id="access_tw_master_dealer_group_update" model="ir.model.access">
            <field name="model_id" ref="tw_selection.model_tw_selection" />
            <field name="name">access_tw_master_dealer_group</field>
            <field name="group_id" ref="group_tw_master_dealer_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_schedule_shipment_read')),
                (4, ref('group_tw_schedule_shipment_update')),
                (4, ref('group_tw_master_dealer_group_read')),
                (4, ref('group_tw_master_dealer_group_update')),
            ]" />
        </record>
    </data>

</odoo>
