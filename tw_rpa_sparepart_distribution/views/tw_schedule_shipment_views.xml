<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- list View with Archive Option -->
        <record id="view_schedule_shipment_list" model="ir.ui.view">
            <field name="name">tw.schedule.shipment.list</field>
            <field name="model">tw.schedule.shipment</field>
            <field name="arch" type="xml">
                <list string="Jadwal Pengiriman" decoration-muted="active == False" delete="false" editable="top">
                    <field name="model_id" string="Model"/>
                    <field name="day" string="Hari"/>
                    <field name="shipment_term" string="Termin"/>
                    <field name="shipment_day" string="Hari Pengiriman"/>
                    <field name="active" widget="boolean_toggle"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="action_schedule_shipment" model="ir.actions.act_window">
            <field name="name">Jadwal Pengiriman</field>
            <field name="res_model">tw.schedule.shipment</field>
            <field name="view_mode">list</field>
            <field name="context">{'search_default_active': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Buat jadwal pengiriman pertama Anda
                </p>
            </field>
        </record>
    </data>
</odoo>
