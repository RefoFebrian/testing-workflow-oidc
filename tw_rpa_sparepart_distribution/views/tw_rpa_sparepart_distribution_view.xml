<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_rpa_sparepart_distribution_form_view" model="ir.ui.view">
            <field name="name">tw.rpa.sparepart.distribution.form</field>
            <field name="model">tw.stock.distribution</field>
            <field name="inherit_id" ref="tw_stock_distribution.tw_stock_distribution_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='confirm_date']" position="after">
                    <field name="is_rpa" readonly="1" widget="boolean_button"/>
                </xpath>
            </field>
        </record>

        <record id="tw_rpa_sparepart_distribution_search" model="ir.ui.view">
            <field name="name">tw.rpa.sparepart.distribution.search</field>
            <field name="model">tw.stock.distribution</field>
            <field name="inherit_id" ref="tw_stock_distribution.tw_stock_distribution_search"/>
            <field name="arch" type="xml">
                <xpath expr="//filter[@name='state_done']" position="after">
                    <filter string="RPA" domain="[('is_rpa','=','True')]" name="sd_is_rpa_filter"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>