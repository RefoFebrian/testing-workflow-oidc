<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- Popeye Report -->
        <record id="group_tw_api_popeye_report_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_backoffice"/>
            <field name="name">Laporan Popeye Read</field>
        </record>

        <record id="access_tw_api_popeye_report_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_api_popeye_report"/>
            <field name="name">tw_api_popeye_report read</field>
            <field name="group_id" ref="group_tw_api_popeye_report_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_api_popeye_report_update" model="ir.model.access">
