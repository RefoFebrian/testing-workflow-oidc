<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>

		<record id="view_tw_api_popeye_report_wizard" model="ir.ui.view">
			<field name="name">tw.api.popeye.report.wizard</field>
			<field name="model">tw.api.popeye.report</field>
			<field name="type">form</field>
			<field name="arch" type="xml">
				<form string="Report Popeye">
					<group colspan="4" invisible="state_x == 'get'">
                        <field name="option" required="1"/>
          	            <field name="type" required="1"/>
                        <label for="start_date" string="Periode"/>
                        <div>
                            <field name="start_date" required="1" placeholder="Start Date" class="oe_inline" /> - <field name="end_date" required="1" placeholder="End Date" class="oe_inline"/>
                        </div>
                    </group>
                	<field invisible="1" name="state_x"/>
                    <notebook colspan="4" invisible="state_x == 'get'">
                        <page string="Branches">
                            <field name="company_ids" colspan="4" nolabel="1"/>
                        </page>
                    </notebook>
                	<newline/>
                	<group col="4" fill="0" invisible="state_x != 'get'">
	                    <separator colspan="4" string="Excel Export Generated. Click link below to download ..." invisible="state_x == 'choose'"/>
	                    <field name="file" width="100" invisible="state_x == 'choose'"/>
	                    <field name="data_x" nolabel="1" readonly="0" width="100" filename="file" invisible="state_x == 'choose'"/>
	                </group>
	                <footer>
	                    <button name="generate_data" invisible="state_x == 'get'" string="Export Report" type="object" class="oe_highlight"/>
	                    <button string="Cancel" special="cancel" class="btn btn-default" invisible="state_x == 'get'"/>
	                </footer>
				</form>
			</field>
		</record>

		<record id="action_tw_api_popeye_report_wizard" model="ir.actions.act_window">
			<field name="name">Laporan Popeye</field>
			<field name="res_model">tw.api.popeye.report</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="view_tw_api_popeye_report_wizard"/>
			<field name="target">new</field>
		</record>

        <menuitem id="menuitem_tw_api_popeye_report_wizard" parent="tw_menu.submenu_tw_backoffice_report" groups="group_tw_api_popeye_report_read" action="action_tw_api_popeye_report_wizard" sequence="4"/>

	</data>
</odoo>