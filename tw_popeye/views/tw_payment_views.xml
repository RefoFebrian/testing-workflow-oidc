<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <record id="tw_payment_popeye_inherit_form_view" model="ir.ui.view">
            <field name="name">tw.payment.popeye.form</field>
            <field name="inherit_id" ref="tw_payment.tw_account_payment_form_view"/>
            <field name="model">tw.account.payment</field>
            <field name="arch" type="xml">
                <button name="action_post" position="after">
                    <button name="action_send_to_popeye" string="Send to Popeye" type="object" invisible="state != 'draft' or type != 'supplier_payment' or payment_method != 'popeye' "/>
                    <button name="action_check_status_popeye" string="Check Status Popeye" type="object" invisible="status_api_payment == 'draft' or type != 'supplier_payment' or payment_method != 'popeye' or not send_uid"/>
                    <button name="action_open_cancel_popeye_wizard" string="Cancel Popeye" type="object" class="btn-danger" invisible="state != 'wfp' or type != 'supplier_payment' or payment_method != 'popeye'"/>
                </button>

                <xpath expr="//header[last()]" position="after">
                    <header>
                        <field name="status_api_payment" invisible="type != 'supplier_payment' or payment_method != 'popeye' or not send_uid" widget="statusbar" statusbar_visible="draft,send,waiting_request_approval,paid"/>
                    </header>
                </xpath>

                <field name="payment_method_id" position="after">
					<field name="bulky_type" required="type == 'supplier_payment' and payment_method == 'popeye'" invisible="type != 'supplier_payment' or payment_method != 'popeye'" readonly="state != 'draft'"/>
    			</field>
                <field name="schedule_date" position="attributes">
					<attribute name="required">type == 'supplier_payment' and payment_method == 'popeye'</attribute>
    			</field>
    			<field name="journal_id" position="after">
                        <field name="partner_bank_id" required="state == 'draft' and require_partner_bank_account" domain="[('partner_id','=',partner_id)]" readonly="not partner_id or status_api_payment in ('done') or state != 'draft'"/>
                        <field name="payment_reference_number" readonly="1" invisible="not payment_reference_number"/>
                        <field name="payment_payment_number" readonly="1" invisible="not payment_payment_number"/>
                        <field name="reason_reject" readonly="1" invisible="not reason_reject"/>
    			</field>
                
                <field name="validate_date" position="after">
					<field name="send_uid" readonly="1"/>
					<field name="send_date" readonly="1"/>					
					<field name="wfp_uid" readonly="1"/>
					<field name="wfp_date" readonly="1"/>
					<field name="verifying_uid" readonly="1"/>
					<field name="verifying_date" readonly="1"/>
					<field name="on_approval_uid" readonly="1"/>
					<field name="on_approval_date" readonly="1"></field>
					<field name="queuing_uid" readonly="1"></field>
					<field name="queuing_date" readonly="1"></field>
					<field name="paid_uid" readonly="1"></field>
					<field name="paid_date" readonly="1"></field>
					<field name="reject_api_uid" readonly="1"></field>
					<field name="reject_api_date" readonly="1"></field>
					<field name="cancel_popeye_uid" readonly="1" invisible="not cancel_popeye_uid"/>
					<field name="cancel_popeye_date" readonly="1" invisible="not cancel_popeye_uid"/>
					<field name="cancel_popeye_reason" readonly="1" invisible="not cancel_popeye_reason"/>
				</field>
            </field>
        </record>
    </data>

</odoo>
