<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
	<!-- Master Sparepart Substitusi -->
        <record id="group_tw_sparepart_substitusi_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Sparepart Substitusi Read</field> 
        </record>

        <record id="tw_sparepart_substitusi_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_sparepart_substitusi"/>
            <field name="name">tw_sparepart_substitusi read</field> 
            <field name="group_id" ref="group_tw_sparepart_substitusi_read"/>  
            <field name="perm_read">1</field> 
        </record> 
                
        <record id="group_tw_sparepart_substitusi_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Sparepart Substitusi Update</field>  
            <field name="implied_ids" eval="[(4, ref('group_tw_sparepart_substitusi_read'))]"/>
        </record>

        <record id="tw_sparepart_substitusi_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_sparepart_substitusi"/>
            <field name="name">tw_sparepart_substitusi update</field> 
            <field name="group_id" ref="group_tw_sparepart_substitusi_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

        <record id="group_tw_sparepart_substitusi_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Master Sparepart Substitusi Delete</field>  
            <field name="implied_ids" eval="[(4, ref('group_tw_sparepart_substitusi_read'))]"/>
        </record>

        <record id="tw_sparepart_substitusi_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_sparepart_substitusi"/>
            <field name="name">tw_sparepart_substitusi delete</field> 
            <field name="group_id" ref="group_tw_sparepart_substitusi_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>

	</data>
</odoo>