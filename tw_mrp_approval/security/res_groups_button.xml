<odoo>
    <data noupdate="1">

        <!-- MRP Bundling -->
        <record id="group_button_mrp_request_approval" model="res.groups">
            <field name="category_id" ref="tw_mrp.tw_module_category_mrp"/>
            <field name="name">TW Button MRP Request Approval</field>
        </record>

        <record id="group_button_mrp_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_mrp.tw_module_category_mrp"/>
            <field name="name">TW Button MRP Reject Approval</field>
        </record>

        <record id="group_button_mrp_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_mrp.tw_module_category_mrp"/>
            <field name="name">TW Button MRP Cancel Approval</field>
        </record>

        <record id="group_button_mrp_confirm_approval" model="res.groups">
            <field name="category_id" ref="tw_mrp.tw_module_category_mrp"/>
            <field name="name">TW Button MRP Confirm Approval</field>
        </record>
    </data>

    <data>
        <!-- Admin Group -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_button_mrp_request_approval')),
                (4, ref('group_button_mrp_reject_approval')),
                (4, ref('group_button_mrp_cancel_approval')),
                (4, ref('group_button_mrp_confirm_approval')),
            ]"/>
        </record>
    </data>
</odoo>