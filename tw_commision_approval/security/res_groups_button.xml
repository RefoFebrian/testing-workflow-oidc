<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- RFA Commission -->
        <record id="group_commission_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button RFA Commission</field>
        </record>
        <record id="access_commission_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_approval_rfa update</field>
            <field name="group_id" ref="group_commission_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Approval Commission -->
        <record id="group_commission_approval_approve" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Approve Commission</field>
        </record>
        <record id="access_commission_approval_approve" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_approval_approve update</field>
            <field name="group_id" ref="group_commission_approval_approve"/>
            <field name="perm_write">1</field>
        </record>
             
        <record id="group_commission_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Commission</field>
        </record>

        <record id="access_commission_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_approval_cancel update</field>
            <field name="group_id" ref="group_commission_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_commission_approval_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Commission</field>
        </record>
        <record id="access_commission_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_approval_reject update</field>
            <field name="group_id" ref="group_commission_approval_reject"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="group_commission_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Commission</field>
        </record>

        <record id="access_commission_confirm" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_confirm update</field>
            <field name="group_id" ref="group_commission_confirm"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_commission_extend_periode" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Perpanjang Periode Commission</field>
        </record>

        <record id="access_commission_extend_periode" model="ir.model.access">
            <field name="model_id" ref="tw_commission.model_tw_commission"/>
            <field name="name">commission_extend_periode update</field>
            <field name="group_id" ref="group_commission_extend_periode"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_commission_approval_rfa')),
                (4,ref('group_commission_approval_approve')),
                (4,ref('group_commission_approval_cancel')),
                (4,ref('group_commission_approval_reject')),
                (4,ref('group_commission_confirm')),
                (4,ref('group_commission_extend_periode')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>