<odoo>
    <data>

        <record id="view_account_list_simple" model="ir.ui.view">
            <field name="name">account.account.list.simple</field>
            <field name="model">account.account</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="account_type"/>
                    <field name="company_currency_id"/>
                </list>
            </field>
        </record>

        <record id="view_partner_list_simple" model="ir.ui.view">
            <field name="name">res.partner.list.simple</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list>
                    <field name="complete_name"/>
                    <field name="phone"/>
                    <field name="email"/>
                </list>
            </field>
        </record>

        <record id="view_journal_list_simple" model="ir.ui.view">
            <field name="name">account.journal.list.simple</field>
            <field name="model">account.journal</field>
            <field name="arch" type="xml">
                <list>
                    <field name="code"/>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="create_uid" string="User"/>
                </list>
            </field>
        </record>

        <record id="view_tw_report_payment_form" model="ir.ui.view">
            <field name="name">tw.report.payment.form</field>
            <field name="model">tw.report.payment</field>
            <field name="arch" type="xml">
                <form string="Report Payment">
                    <group>
                        <group>
                            <field name="option"/>
                            <field name="division"/>
                            <label for="start_date" string="Tanggal"/>
                            <div class="o_row">
                                <field name="start_date" widget="date" class="oe_inline"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="Arrow icon" title="Arrow"/>
                                <field name="end_date" widget="date" class="oe_inline"/>
                            </div>
                        </group>
                    </group>

                    <notebook>
                        <page string="Branch">
                            <field name="company_ids"/>
                        </page>
                        <page string="Accounts">
                            <field name="account_ids" context="{'list_view_ref': 'tw_report_payment.view_account_list_simple', 'list_view_ref': 'tw_report_payment.view_account_list_simple'}"/>
                        </page>
                        <page string="Journals">
                            <field name="journal_ids" context="{'list_view_ref': 'tw_report_payment.view_journal_list_simple', 'list_view_ref': 'tw_report_payment.view_journal_list_simple'}"/>
                        </page>
                        <page string="Partners">
                            <field name="partner_ids" context="{'list_view_ref': 'tw_report_payment.view_partner_list_simple', 'list_view_ref': 'tw_report_payment.view_partner_list_simple'}"/>
                        </page>
                    </notebook>

                    <footer>
                        <button name="action_print_report" string="Print Report" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tw_report_payment" model="ir.actions.act_window">
            <field name="name">Laporan Payment</field>
            <field name="res_model">tw.report.payment</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

    </data>
</odoo>