<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data>
        <record id="tw_hr_employee_mekanik_mitra_view_form" model="ir.ui.view">
            <field name="name">tw.hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="priority" eval="100"/>
            <field name="arch" type="xml">
                <form edit="0" create="0" delete="0">
                    <sheet>
                        <group>
                            <group>
								<field name="company_id" string="Branch" required="1" options="{'no_open':True,'no_create':True}"/>
                                <field name="name" string="Nama Mekanik" required="1"/>
								<field name="agreement_to" required="1"/>
								<field name="start_date" required="1"/>
								<field name="end_date" required="1"/>
								<field name="description"/>
							</group>
							<group>
								<field name="bank_id" required="1"/>
								<field name="acc_number" required="1"/>
								<field name="acc_holder_name"/>
								<field name="agreement_letter" required="1"/>
								<field name="absen_finger"/>
							</group>
                        </group>
                        <notebook>
                            <page name="audit_trail" string="Audit Trail">
                                <group>
									<group>
										<field name="create_uid" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
									</group>
									<group>							
										<field name="write_uid" readonly="1"></field>
										<field name="write_date" readonly="1"></field>
									</group>
								</group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        
        <record id="tw_hr_employee_mekanik_mitra_view_list" model="ir.ui.view">
            <field name="name">tw.hr.employee.form</field>
            <field name="model">hr.employee</field>
            <field name="priority" eval="100"/>
            <field name="arch" type="xml">
                <list edit="0" create="0" delete="0">
                    <field name="company_id" string="Branch" options="{'no_open':True,'no_create':True}"/>
                    <field name="name" string="Nama Mekanik"/>
                    <field name="agreement_to"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
					<field name="bank_id"/>
                    <field name="acc_holder_name"/>
                    <field name="agreement_letter"/>
                </list>
            </field>
        </record>  

    <record model="ir.actions.act_window" id="tw_master_mekanik_mitra_action">
        <field name="name">Mekanik Mitra</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('job_id.sales_force_id.value','=','mechanic'),
            ('category_ids.name','=','Mitra')
        ]</field>
    </record>

    <record id="tw_master_mekanik_mitra_action_list" model="ir.actions.act_window.view">
        <field eval="1" name="sequence"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="tw_mekanik_mitra.tw_hr_employee_mekanik_mitra_view_list"/>
        <field name="act_window_id" ref="tw_master_mekanik_mitra_action"/>
    </record>

    <record id="tw_master_mekanik_mitra_action_form" model="ir.actions.act_window.view">
        <field eval="2" name="sequence"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="tw_mekanik_mitra.tw_hr_employee_mekanik_mitra_view_form"/>
        <field name="act_window_id" ref="tw_master_mekanik_mitra_action"/>
    </record>
    </data>
</odoo>
