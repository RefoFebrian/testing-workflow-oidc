<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<data>
		<record id="tw_report_mekanik_mitra_view_wizard" model="ir.ui.view">
			<field name="name">tw.report.mekanik.mitra.wizard</field>
			<field name="model">tw.report.mekanik.mitra.wizard</field>
			<field name="arch" type="xml">
				<form string="Report Mekanik">
					<group>
						<label for="bulan" string="Periode"/> 
						<div>
							<field name="bulan" class="oe_inline" placeholder="Bulan" required="1"/> - 
							<field name="tahun" class="oe_inline" placeholder="Tahun" required="1"/>
						</div>
					</group>
					<notebook>
                        <page string="Dealer" >
                            <field name="company_ids"  colspan="4" nolabel="1"/>
                        </page>
                    </notebook>
	                <footer>
	                    <button name="excel_report" string="Export Data" type="object" class="oe_highlight" />
	                    <span>or</span>
	                    <button string="Cancel" special="cancel" class="btn btn-default"/>
	                </footer>
				</form>
			</field>
		</record>

		<record id="tw_report_mekanik_mitra_action_wizard" model="ir.actions.act_window">
			<field name="name">Laporan Mekanik Mitra</field> 
			<field name="res_model">tw.report.mekanik.mitra.wizard</field>
			<field name="view_mode">form</field>
			<field name="view_id" ref="tw_mekanik_mitra.tw_report_mekanik_mitra_view_wizard"/>
			<field name="target">new</field>
		</record>
	</data>
</odoo>
