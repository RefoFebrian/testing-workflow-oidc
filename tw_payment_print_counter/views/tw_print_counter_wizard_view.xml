<odoo>
    <data>
        <record id="tw_print_counter_reason_wizard_form_view" model="ir.ui.view">
            <field name="name">tw.print.counter.reason.wizard.form</field>
            <field name="model">tw.print.counter</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Print Kwitansi">
                    <group col="2" colspan="2">
                        <group>
                            <field name="is_ekwitansi"/>
                            <field name="kwitansi_line_id" domain="[('state','=','open'), ('company_id','=', company_id), ('type', '=', is_ekwitansi and 'ekwitansi' or 'kwitansi')]" options="{'no_create': True,'no_open': True}" required="1"/>
                            <field name="reason" invisible="not is_invisible" required="is_invisible"/>
                            <field name="company_id" invisible="1"/>
                            <field name="receipt_print_count" invisible="1"/>
                        </group>
                        <group>
                            <field name="transaction_id" invisible="1"/>
                            <field name="print_counter" invisible="1"/>
                            <field name="report_id" invisible="1"/>
                            <field name="model_name" invisible="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_print_kwitansi" string="Print" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
