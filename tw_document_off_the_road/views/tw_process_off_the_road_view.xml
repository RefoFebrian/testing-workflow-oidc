<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data> 
		
		<record model="ir.ui.view" id="tw_process_off_the_road_view_list">
		    <field name="name">tw.process.off.the.road.list</field>
		    <field name="model">tw.process.off.the.road</field>
		    <field name="arch" type="xml">
		        <list string="List Pengurusan STNK dan BPKB Off The Road">
		        	<field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>		            
		            <field name="partner_id"/>	
		            <field name="process_date"/>	  
		            <field name="state"/>	            
		        </list>
		     </field>
		</record>
 
		<record model="ir.ui.view" id="tw_process_off_the_road_view_form">
		    <field name="name">tw.process.off.the.road.form</field>
		    <field name="model">tw.process.off.the.road</field>
		    <field name="arch" type="xml">
		        <form string="Form Pengurusan STNK dan BPKB Off The Road">
				<header>
                    <!-- <button name="view_invoice" type="object" invisible="state != 'confirm'" string="View PO" class="oe_highlight"></button> -->
                    <button name="action_confirm" groups='tw_document_off_the_road.group_tw_process_off_the_road_confirm' type="object" invisible="state != 'draft'" string="Confirm" class="oe_highlight"/>
                    <button name="action_cancel" groups='tw_document_off_the_road.group_tw_process_off_the_road_cancel' type="object" invisible="state not in ['draft','confirm','approved']" string="Cancel" confirm="Apa anda yakin ingin membatalkan transaksi ini ?"/>
                    <button name="action_create_invoice" groups='tw_document_off_the_road.group_tw_process_off_the_road_confirm' type="object" invisible="state != 'confirm'" string="Create Invoice" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,done" statusbar_colors='{"draft":"red","approved":"blue"}'/>	
           		</header>		        	
		        	<sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="invoice_count == 0">
                                <field name="invoice_count" widget="statinfo" string="Invoices" />
                            </button>
                        </div>
			        	<div class="oe_title">
			        		<h2>
				                Pengurusan STNK dan BPKB Off The Road    			
				 				<field name="name" class="oe_inline"/>
			 				</h2>
			        	</div>       
						<group>   
							<group>
								<field name="company_id" options="{'no_create': True,'no_open': True}" readonly="state != 'draft' or name != False" required="1"/>
                                <field name="partner_id" required="1" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" domain="[('id', 'in', available_partner_ids)]" />								    	
                                <field name="available_partner_ids" invisible="1"/>
                                <field name="customer_id" required="1" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
                                <field name="invoice_count" readonly="1" invisible="1"/>
							</group>            
						    <group>
	                    		<field name="division" required="1" readonly="state != 'draft'" />
                                <field name="process_date" required="1" readonly="1"/>						               
	                    	</group>
						</group>	
						
						<notebook colspan="5">
		                    <page string="Engine line">
		                        <field colspan="4" name="process_otr_line_ids" nolabel="1" widget="one2many_list" readonly="state != 'draft'">
		                            <list string="" editable="bottom">
						                <field name="lot_id" options="{'no_create': True,'no_open': True}" domain="[('id', 'in', available_lot_ids)]"/>
						                <field name="available_lot_ids" options="{'no_create': True,'no_open': True}" column_invisible="1"/>
						                <field name="customer_stnk_id" required="1" options="{'no_create': True,'no_open': True}"/>
						                <field name="plate_id" required="1" options="{'no_create': True,'no_open': True}"/>																	                       																		                
						             </list>
		                        </field>
		                    </page>
							<page string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
										<field name="confirm_uid" readonly="1"></field>
										<field name="confirm_date" readonly="1"></field>
									</group>
									<group>							
										<field name="write_uid" readonly="1"></field>
										<field name="write_date" readonly="1"></field>
										<field name="cancel_uid" readonly="1"></field>
										<field name="cancel_date" readonly="1"></field>
									</group>
								</group>
							</page>			                    
		                </notebook>				
		           </sheet>
		        </form>
		    </field>
		</record>

 		<record id="tw_process_off_the_road_view_filter" model="ir.ui.view">
            <field name="name">tw.process.off.the.road.view.filter</field>
            <field name="model">tw.process.off.the.road</field>
            <field name="arch" type="xml">
                <search string="Search Pengurusan STNK dan BPKB Off The Road">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/> 
                    <field name="partner_id" string="Biro Jasa"/> 
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="confirm" string="Confirmed" domain="[('state','=','confirm')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_branch" string="Branch" icon="terp-partner" domain="[]" context="{'group_by':'company_id'}"/>
                        <filter name="group_date" string="Tanggal" icon="terp-go-month" domain="[]" context="{'group_by':'process_date'}"/>                    
                    </group>
                </search>
            </field>
        </record>		
		<record model="ir.actions.act_window" id="action_tw_process_off_the_road">
		    <field name="name">Pengurusan STNK dan BPKB Off The Road</field>
		    <field name="res_model">tw.process.off.the.road</field>
		    <field name="view_mode">list,form</field>
		    <field name="search_view_id" ref="tw_process_off_the_road_view_filter"/>
			<field name="context">{"search_default_draft":1}</field>		    
		    			    
		</record>
					
		
	</data>
</odoo>
															
