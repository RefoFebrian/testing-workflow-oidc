<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_tw_submission_off_the_road_post" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Submission Off The Road Post</field> 
        </record>
    
        <record id="group_tw_process_off_the_road_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Process Off The Road Confirm</field> 
        </record>
        
        <record id="group_tw_process_off_the_road_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Process Off The Road Cancel</field> 
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_submission_off_the_road_post')),
                (4, ref('group_tw_process_off_the_road_confirm')),
                (4, ref('group_tw_process_off_the_road_cancel')),
            ]"/>
        </record>
    </data>
    

</odoo>
