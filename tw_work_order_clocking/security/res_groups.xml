<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    <!-- TW Start Stop WO Group Read -->
        <record id="tw_start_stop_wo_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Start Stop WO Read</field>
        </record>

        <record id="tw_start_stop_wo_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_start_stop_wo" />
            <field name="name">tw_start_stop_wo read</field>
            <field name="group_id" ref="tw_start_stop_wo_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_start_stop_wo_group_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Start Stop WO Update</field>
            <field name="implied_ids" eval="[(4, ref('tw_start_stop_wo_group_read'))]" />
        </record>

        <record id="tw_start_stop_wo_access_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_start_stop_wo" />
            <field name="name">tw_start_stop_wo update</field>
            <field name="group_id" ref="tw_start_stop_wo_group_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_start_stop_wo_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Start Stop WO Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_start_stop_wo_group_read'))]" />
        </record>

        <record id="tw_start_stop_wo_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_start_stop_wo" />
            <field name="name">tw_start_stop_wo delete</field>
            <field name="group_id" ref="tw_start_stop_wo_group_delete" />
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('tw_start_stop_wo_group_read')),
                (4,ref('tw_start_stop_wo_group_update')),
                (4,ref('tw_start_stop_wo_group_delete')),
            ]" />
        </record>
    </data>
</odoo>