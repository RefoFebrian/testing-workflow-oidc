<?xml version="1.0" encoding="UTF-8"?>
<!-- Copied from MRP Module -->
<templates id="tw_work_order_timer" xml:space="preserve">
    <t t-name="tw_work_order.WoTimer">
        <span t-esc="durationFormatted"/>
    </t>

    <t t-name="tw_work_order.WoTimerField">
        <WoTimer t-if="props.readonly" value="duration" ongoing="ongoing"/>
        <input t-else="" t-att-id="props.id" t-ref="numpadDecimal" t-att-placeholder="props.placeholder" inputmode="numeric" class="o_input" />
    </t>
</templates>