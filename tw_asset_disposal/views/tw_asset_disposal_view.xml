<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data> 
    	
		<record model="ir.ui.view" id="tw_disposal_asset_list_view">
		    <field name="name">tw.asset.disposal.list.view</field>
		    <field name="model">tw.asset.disposal</field>
		    <field name="arch" type="xml">
		        <list string="List Disposal Asset" default_order="id desc">
		        	<field name="name"/>
		            <field name="company_id"/>
					<field name="division"/>            		            			            	
		            <field name="date"/>
		            <field name="type"/>
		            <field name="partner_id"/>
		            <field name="state"/>            
		        </list>
		     </field>
		</record>
		    	
		<record model="ir.ui.view" id="tw_disposal_asset_form_view">
		    <field name="name">tw.asset.disposal.form.view</field>
		    <field name="model">tw.asset.disposal</field>
		    <field name="arch" type="xml">		       	        	
				<form>
					<header>
						<button name="action_print_asset_disposal" string="Print" type="object" invisible="state not in ('draft', 'waiting_for_approval', 'confirm')" groups="tw_asset_disposal.group_asset_disposal_read"/>
						<button name="action_confirm" invisible="state != 'approved'" data-hotkey="q" string="Confirm" type="object" class="oe_highlight" groups="tw_asset_disposal.tw_asset_disposal_button_confirm_group"/>
						<field name="state" widget="statusbar" statusbar_visible="draft,confirm"/>	
	           		</header>
					<sheet>  
	        			<div class="oe_title">
                            <h1 invisible="name"><span>Draft</span></h1>
                            <h1 invisible="not name"><field name="name" readonly="1"/></h1>
                        </div>	        							        	 
						<group>   
							<group>
								<field name="company_id" required="1" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'"/>
								<field name="type" required="1" readonly="state != 'draft'"/>																																
								<field name="partner_id" required="type == 'sold'" invisible="type == 'scrap'" readonly="state != 'draft'" options="{'no_create': True,'no_open': True}"/>
								<field name="payment_term_id" required="1" readonly="state != 'draft'" options="{'no_create': True,'no_open': True}"/>
							</group>  
							<group>
								<field name="division" readonly="1"/>																
								<field name="date" readonly="1"/>																	
							</group>
						</group>
	                    <notebook colspan="5">
	                        <page name="disposal_detail" string="Disposal Detail">
	                        	<field name="disposal_line_sold_ids" nolabel="1" widget="one2many_list" readonly="state != 'draft'" invisible="type != 'sold'">
	                        		<list editable="bottom">
		                            	<field name="company_id" options="{'no_create': True,'no_open': True}" column_invisible="True"/>
						                <field name="asset_id" required="1" options="{'no_create': True,'no_open': True}"/>
										<field name="category_id" readonly="1"/>             
						                <field name="amount" required="1" string="Harga Jual"/>
						                <field name="tax_id" widget="many2many_tags" options="{'no_open':True,'no_create':True}" required="1"/>
						                <field name="amount_subtotal"/>
						            </list>
	                        	</field>
	                        	<group invisible="type != 'sold'">
                                    <group>
                                        <field colspan="2" name="notes" nolabel="1" placeholder="Define your terms and conditions ..."/>
                                    </group>
                                    <group class="oe_subtotal_footer">
                                        <field name="tax_totals" widget="account-tax-totals-field" nolabel="1" readonly="1"/>
                                    </group>
                                </group>
                                <div invisible="type != 'sold'" class="clearfix"/>

								<field name="disposal_line_scrap_ids" nolabel="1" widget="one2many_list" readonly="state != 'draft'" invisible="type != 'scrap'">
									<list editable="bottom">
										<field name="company_id" options="{'no_create': True,'no_open': True}" column_invisible="True"/>
						                <field name="asset_id" required="1" options="{'no_create': True,'no_open': True}"/>
										<field name="category_id" readonly="1"/>             
						                <field name="nilai_asset" readonly="1" string="Harga Beli"/>
						                <field name="nilai_penyusutan" readonly="1"/>
										<field name="amount_depreciated" readonly="1"/>
										<field name="book_value" readonly="1"/>
									</list>
								</field>                            
	                        </page>                    
	                        <page string="Journal Items" invisible="state in ('draft', 'approved', 'waiting_for_approval')">
	                        	<field name="move_ids" readonly="1"/>                       
	                        </page>                   
							<page name="audit_trail" string="Audit Trail">
								<group>
									<group>
										<field name="create_uid" readonly="1"/>
										<field name="create_date" readonly="1"/>
										<field name="confirm_uid" readonly="1"/>
										<field name="confirm_date" readonly="1"/>										
									</group>
									<group>							
										<field name="write_uid" readonly="1"/>
										<field name="write_date" readonly="1"/>
									</group>
								</group>
							</page>	                                              
	                    </notebook>							   		                																
					</sheet>
				</form>	
		    </field>
		</record>
		
 		<record id="view_tw_disposal_asset" model="ir.ui.view">
            <field name="name">tw.asset.disposal.list.select</field>
            <field name="model">tw.asset.disposal</field>
            <field name="arch" type="xml">
                <search string="Search Disposal Asset">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/> 
                    <field name="division"/>
                    <filter name="Outstanding" string="Outstanding" domain="[('state','in',('draft','waiting_for_approval'))]"/>
                </search>
            </field>
        </record>		

		<record id="view_tw_disposal_asset_search" model="ir.ui.view">
            <field name="name">tw.asset.disposal.list.select</field>
            <field name="model">tw.asset.disposal</field>
            <field name="arch" type="xml">
                <search string="Search Disposal Asset">
                    <field name="name" string="Reference"/>
                    <field name="company_id"/>
                    <field name="partner_id"/> 
                    <field name="division"/>
                    <field name="date"/>
                    <!-- <field name="koprol_code"/> -->
					<field name="payment_term_id"/>
					<field name="disposal_line_sold_ids" string="Asset No" filter_domain="[('disposal_line_sold_ids.asset_id','ilike', self)]"/>
					<field name="disposal_line_sold_ids" string="Disposal Detail Category" filter_domain="[('disposal_line_sold_ids.category_id','ilike', self)]"/>
					<filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
					<filter name="confirm" string="Confirmed" domain="[('state', '=', 'confirm')]"/>
					<filter name="cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                    <filter name="Outstanding" string="Outstanding" domain="[('state','!=','confirm')]"/>
					<group expand="0" string="Group By">
                        <filter string="Branch" name="group_by_company" context="{'group_by': 'company_id'}"/>
                        <filter string="Division" name="group_by_division" context="{'group_by': 'division'}"/>
						<filter string="Date" name="group_by_date" context="{'group_by': 'date'}"/>
						<filter string="Type" name="group_by_type" context="{'group_by': 'type'}"/>
						<filter string="Payment Terms" name="group_by_payment_term" context="{'group_by': 'payment_term_id'}"/>
						<filter string="Partner" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
						
                    </group>
                </search>
            </field>
        </record>

		<record model="ir.actions.act_window" id="tw_disposal_asset_action">
		    <field name="name">Disposal Asset</field>
		    <field name="res_model">tw.asset.disposal</field>	
		    <field name="view_mode">list,form</field>
		    <field name="context">{"search_default_Outstanding":1,'default_division': 'Umum'}</field>		
		    <field name="search_view_id" ref="view_tw_disposal_asset_search"/>
		</record>
					
		
        	        		
	</data>
</odoo>