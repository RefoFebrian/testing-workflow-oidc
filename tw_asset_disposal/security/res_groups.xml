<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Read -->
        <record id="group_asset_disposal_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Disposal Asset Read</field>
        </record>    

        <record id="access_asset_disposal_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal"/>
            <field name="name">tw_asset_disposal read</field>
            <field name="group_id" ref="group_asset_disposal_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_asset_disposal_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal_line"/>
            <field name="name">tw_asset_disposal_line read</field>
            <field name="group_id" ref="group_asset_disposal_read"/>
            <field name="perm_read">1</field>
        </record>

        
        <record id="access_tw_disposal_asset_account_asset_read" model="ir.model.access">
            <field name="model_id" ref="om_account_asset.model_account_asset_asset" />
            <field name="name">tw_disposal_asset_account_asset read</field>
            <field name="group_id" ref="group_asset_disposal_read"/>
            <field name="perm_read">1</field>
        </record>

        <!-- Update -->
       
        <record id="group_asset_disposal_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Disposal Asset Update</field>
			<field name="implied_ids" eval="[(4, ref('group_asset_disposal_read'))]"/>
        </record>
        <record id="access_tw_disposal_asset_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal"/>
            <field name="name">tw_disposal_asset update</field>
            <field name="group_id" ref="group_asset_disposal_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        <record id="access_tw_disposal_asset_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal_line"/>
            <field name="name">tw_disposal_asset_line update</field>
            <field name="group_id" ref="group_asset_disposal_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>
        
        <!-- Delete -->
        <record id="group_asset_disposal_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Disposal Asset Delete</field>
			<field name="implied_ids" eval="[(4, ref('group_asset_disposal_read'))]"/>
        </record>        
		<record id="access_tw_disposal_asset_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal"/>
            <field name="name">tw_disposal_asset delete</field>
            <field name="group_id" ref="group_asset_disposal_delete"/>
            <field name="perm_unlink">1</field>
        </record>
		<record id="access_tw_disposal_asset_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_disposal_line"/>
            <field name="name">tw_disposal_asset_line delete</field>
            <field name="group_id" ref="group_asset_disposal_delete"/>
            <field name="perm_unlink">1</field>
        </record>


    </data>

    <data>

    <!-- Add all access to admin -->
    <record id="tw_base.group_system_admin" model="res.groups">
        <field name="implied_ids" eval="[
            (4,ref('group_asset_disposal_read')),	
            (4,ref('group_asset_disposal_update')),	
            (4,ref('group_asset_disposal_delete')),				
        ]"/> 
    </record>

    </data>
</odoo>
