<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="tw_work_order_voucher_view_form" model="ir.ui.view">
        <field name="name">tw.work.order.voucher</field>
        <field name="model">tw.work.order</field>
        <field name="inherit_id" ref="tw_work_order.tw_work_order_form_view" />
        <field name="arch" type="xml">
			<xpath expr="//page[@name='other_information']" position="after">
				<page name="sales_voucher" string="Tunas Honda Voucher">
					<field name="sales_voucher_ids" readonly="1" force_save="1">
						<list name="sales_voucher_list">
							<field name="name"/>
							<field name="voucher_id" options="{'no_open':True, 'no_create':True}"/>
							<field name="partner_id" options="{'no_open':True, 'no_create':True}"/>
							<field name="amount"/>
							<field name="used_amount"/>
							<field name="residual_amount"/>
						</list>
					</field>
				</page>
			</xpath>
        </field>
    </record>
</odoo>