<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="tw_branch_setting_whatsapp_inherit_form_view" model="ir.ui.view">
        <field name="name">tw.branch.setting.whatsapp.inherit.form</field>
        <field name="model">tw.branch.setting</field>
        <field name="inherit_id" ref="tw_branch_setting.tw_branch_setting_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_4']" position="after">
                <page string="WhatsApp API Configuration" name="wa_config_page">
                    <group>
                        <field name="official_wa_config_id" options="{'no_create': True,'no_open': True}"
                            domain="[('api_type_id.value', '=', 'Whatsapp')]"/>
                    </group>
                    <group>
                        <field name="unofficial_wa_config_id" options="{'no_create': True,'no_open': True}"
                            domain="[('api_type_id.value', '=', 'Whatsapp'), ('company_id', '=', company_id)]"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
