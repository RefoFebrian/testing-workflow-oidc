<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_whatsapp_message_inbox_list_view" model="ir.ui.view">
            <field name="name">tw.whatsapp.message.tree</field>
            <field name="model">tw.whatsapp.message</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="WhatsApp Inbox" create="0" edit="0" delete="0">
                    <field name="whatsapp_id"/>
                    <field name="phone_number"/>
                    <field name="sender_name"/>
                    <field name="date"/>
                </list>
            </field>
        </record>

        <record id="tw_whatsapp_message_inbox_form_view" model="ir.ui.view">
            <field name="name">tw.whatsapp.message.form</field>
            <field name="model">tw.whatsapp.message</field>
            <field name="type">form</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <form string="WhatsApp Inbox" create="0" edit="0" delete="0">
                    <header>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="sender_name" readonly="1" invisible="sender_name == False"/>
                                <field name="phone_number" readonly="1"/>
                                <field name="message" readonly="1"/>
                                <field name="whatsapp_id" readonly="1"/>
                                <field name="sender_number" readonly="1"/>
                            </group>
                            <group>
                                <field name="date" readonly="1"/>
                                <field name="message_received_date" readonly="1"/>
                                <field name="attachment_name" readonly="1" invisible="attachment_name == False"/>
                                <field name="attachment_url" readonly="1" widget="url" invisible="attachment_url == False"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1" options="{'no_open': True, 'no_create': True}"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="tw_whatsapp_message_inbox_view_search" model="ir.ui.view">
            <field name="name">tw.whatsapp.message.inbox.search</field>
            <field name="model">tw.whatsapp.message</field>
            <field name="arch" type="xml">
                <search string="Search for...">
                    <field name="whatsapp_id" select="True"/>
                    <field name="phone_number" select="True"/>
                    <field name="sender_name" select="True"/>
                </search>
            </field>
        </record>

        <record id="tw_whatsapp_message_inbox_action" model="ir.actions.act_window">
            <field name="name">Inbox</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.whatsapp.message</field>
            <field name="view_mode">list,form</field>
            <field name="context">{"readonly_by_pass": 1}</field>
            <field name="domain">[('message_type', '=', 'inbox')]</field>
            <field name="search_view_id" ref="tw_whatsapp_message_inbox_view_search"/>
        </record>

        <record id="tw_whatsapp_message_inbox_action_list" model="ir.actions.act_window.view">
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_whatsapp_message_inbox_list_view"/>
            <field name="act_window_id" ref="tw_whatsapp_message_inbox_action"/>
            <field name="sequence" eval="1"/>
        </record>

        <record id="tw_whatsapp_message_inbox_action_form" model="ir.actions.act_window.view">
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_whatsapp_message_inbox_form_view"/>
            <field name="act_window_id" ref="tw_whatsapp_message_inbox_action"/>
            <field name="sequence" eval="2"/>
        </record>

    </data>
</odoo>