<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- List View -->
        <record model="ir.ui.view" id="advance_payment_cancel_list_view">
            <field name="name">tw.advance.payment.cancel.list</field>
            <field name="model">tw.advance.payment.cancel</field>
            <field name="arch" type="xml">
                <list string="Advance Payment Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="advance_payment_id"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_advance_payment_cancel_search" model="ir.ui.view">
            <field name="name">tw.advance.payment.cancel.search</field>
            <field name="model">tw.advance.payment.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Advance Payment Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="advance_payment_id"/>
                    <field name="date"/>
                    <field name="division"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Waiting For Approval" name="waiting_approval" domain="[('state','=','waiting_for_approval')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <group string="Group By" name="groupby">
                        <filter name="state_groupby" string="Status" context="{'group_by': 'state'}"/>
                        <filter name="date_groupby" string="Date" context="{'group_by': 'date'}"/>
                        <filter name="division_groupby" string="Division" context="{'group_by': 'division'}"/>
                        <filter name="company_groupby" string="Branch" context="{'group_by': 'company_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form View (Inherit from tw_cancellation) -->
        <record model="ir.ui.view" id="inherit_advance_payment_cancel_form_view">
            <field name="name">tw.advance.payment.cancel.form</field>
            <field name="model">tw.advance.payment.cancel</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <!-- Buttons xpath -->
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_advance_payment_cancel.group_tw_advance_payment_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_approval']" position="attributes">
                    <attribute name="groups">tw_advance_payment_cancel.group_tw_advance_payment_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_advance_payment_cancel.group_tw_advance_payment_cancel_approval_confirm</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel']" position="attributes">
                    <attribute name="groups">tw_advance_payment_cancel.group_tw_advance_payment_cancel_approval_cancel</attribute>
                </xpath>

                <!-- Smart Button -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_advance_payment"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-money"
                            invisible="not advance_payment_id"
                            groups="tw_advance_payment_cancel.group_tw_advance_payment_cancel_read">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Advance</span>
                            <span class="o_stat_text">Payment</span>
                        </div>
                    </button>
                </xpath>

                <!-- Advance Payment Field -->
                <field name="transaction_name" position="after">
                    <field name="advance_payment_id" required="1" readonly="state != 'draft'" 
                           options="{'no_create':True,'no_open':True}" 
                           domain="[('company_id','=',company_id),('state', 'in', ('confirm', 'posted')),('division','=',division)]"
                           invisible="context.get('default_model_type') != 'tw.advance.payment'"/>
                </field>
            </field>
        </record>

        <!-- Action -->
        <record model="ir.actions.act_window" id="advance_payment_cancel_action">
            <field name="name">Advance Payment Cancel</field>
            <field name="res_model">tw.advance.payment.cancel</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_advance_payment_cancel_search"/>
            <field name="context" eval="{
                'default_model_id': ref('tw_advance_payment.model_tw_advance_payment'),
                'default_model_type': 'tw.advance.payment',
                'search_default_draft': '1',
            }"/>
            <field name="domain">['|', ('advance_payment_id', '!=', False), ('model_id.model', '=', 'tw.advance.payment')]</field>
        </record>

        <record id="advance_payment_cancel_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="advance_payment_cancel_list_view"/>
            <field name="act_window_id" ref="advance_payment_cancel_action"/>
        </record>

        <record id="advance_payment_cancel_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_advance_payment_cancel_form_view"/>
            <field name="act_window_id" ref="advance_payment_cancel_action"/>
        </record>

    </data>
</odoo>
