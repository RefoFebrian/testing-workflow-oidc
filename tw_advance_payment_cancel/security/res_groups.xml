<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Advance Payment Cancel -->
        <record id="group_tw_advance_payment_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Advance Payment Cancel Read</field>
        </record>

        <record id="access_tw_advance_payment_cancel_read" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment_cancel.model_tw_advance_payment_cancel"/>
            <field name="name">tw_advance_payment_cancel read</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_advance_payment_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Advance Payment Cancel Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_advance_payment_cancel_read'))]"/>
        </record>

        <record id="access_tw_advance_payment_cancel_update" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment_cancel.model_tw_advance_payment_cancel"/>
            <field name="name">tw_advance_payment_cancel update</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_advance_payment_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_advance_payment.tw_module_category_advance_payment"/>
            <field name="name">TW Advance Payment Cancel Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_advance_payment_cancel_read'))]"/>
        </record>

        <record id="access_tw_advance_payment_cancel_delete" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment_cancel.model_tw_advance_payment_cancel"/>
            <field name="name">tw_advance_payment_cancel delete</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Access to related models for cancel logic -->
        
        <!-- Advance Payment - Read/Write -->
        <record id="access_tw_advance_payment_read_for_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment.model_tw_advance_payment"/>
            <field name="name">tw_advance_payment read for cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_tw_advance_payment_write_for_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_advance_payment.model_tw_advance_payment"/>
            <field name="name">tw_advance_payment write for cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_update"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Account Move - Read/Write/Create -->
        <record id="access_account_move_read_for_cancel" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move"/>
            <field name="name">account.move read for avp_cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_account_move_write_for_cancel" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move"/>
            <field name="name">account.move write for avp_cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Account Move Line - Read/Write -->
        <record id="access_account_move_line_read_for_cancel" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="name">account.move.line read for avp_cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_account_move_line_write_for_cancel" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move_line"/>
            <field name="name">account.move.line write for avp_cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- Account Move Reversal - Create -->
        <record id="access_account_move_reversal_create_for_cancel" model="ir.model.access">
            <field name="model_id" ref="account.model_account_move_reversal"/>
            <field name="name">account.move.reversal create for avp_cancel</field>
            <field name="group_id" ref="group_tw_advance_payment_cancel_update"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
        </record>

    </data>

    <data>
        <!-- Add to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_advance_payment_cancel_read')),
                (4, ref('group_tw_advance_payment_cancel_update')),
                (4, ref('group_tw_advance_payment_cancel_delete')),
            ]"/>
        </record>
    </data>
</odoo>
