<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
    
    <!-- Payment Cancellation -->
    	
    	<record model="ir.ui.view" id="payment_cancel_list_view">
            <field name="name">tw.payment.cancel.list</field>
            <field name="model">tw.payment.cancel</field>
            <field name="arch" type="xml">
                <list string="Payment Cancel">
                	<field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                	<field name="account_payment_id"/>
                    <field name="date"/>
                    <field name="state"/>
				</list>
			</field>
        </record>
        
        <record id="view_payment_cancel_search" model="ir.ui.view">
            <field name="name">tw.payment.cancel.search</field>
            <field name="model">tw.payment.cancel</field>
            <field name="arch" type="xml">
                <search string="Search Payment Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="account_payment_id"/>
                    <field name="reason"/>
                    <field name="date"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Waiting For Approval" name="waiting_approval" domain="[('state','=','waiting_for_approval')]"/>
                    <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                    <filter string="Outstanding" name="outstanding" domain="[('state','!=','confirmed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                        <filter string="Branch" name="group_branch" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                        <filter string="Account Payment" name="group_account" context="{'group_by': 'account_payment_id'}"/>
                        <filter string="Division" name="group_division" context="{'group_by': 'division'}"/>
                    </group>
                </search>
            </field>
        </record>
        
        <record model="ir.ui.view" id="inherit_payment_cancel_form_view">
            <field name="name">tw.payment.cancel.form</field>
            <field name="model">tw.payment.cancel</field>
            <field name="priority">1</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancellation_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet/div[@name='button_box']" position="inside">
                    <button name="button_open_journal_entry" type="object" class="oe_stat_button" icon="fa-bars" invisible="not move_id" groups="account.group_account_user,account.group_account_readonly">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Journal Entry</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//button[@name='action_request_approval']" position="attributes">
                    <attribute name="groups">tw_payment_cancel.group_tw_payment_cancel_rfa_approve</attribute>
                </xpath>
                <xpath expr="//button[@name='action_reject_or_cancel' and contains(@context, 'Cancel')]" position="attributes">
                    <attribute name="groups">tw_payment_cancel.group_tw_payment_cancel_approval_cancel</attribute>
                </xpath>
                <xpath expr="//button[@name='action_confirm']" position="attributes">
                    <attribute name="groups">tw_payment_cancel.group_tw_payment_cancel_approval_confirm</attribute>
                </xpath>
               <field name="transaction_name" position="after">
                    <field name="payment_type" required="1" readonly="state != 'draft'"/>
                    <field name="account_payment_id" required="payment_type == 'account_payment'" invisible="context.get('default_model_type') != 'tw.account.payment' or payment_type != 'account_payment'" domain="[('company_id','=',company_id),('division','=',division),('state','not in',('draft','canceled','rejected')),('move_id', '!=', False)]" readonly="state != 'draft'" options="{'no_create':True,'no_open':True}"/>
                    <field name="other_receivable_id" required="payment_type == 'other_receivable'" invisible="context.get('default_model_type') != 'tw.account.payment' or payment_type != 'other_receivable'" domain="[('company_id','=',company_id),('division','=',division),('state','not in',('draft','canceled','rejected')),('move_id', '!=', False)]" readonly="state != 'draft'" options="{'no_create':True,'no_open':True}"/>
                    <field name="payment_request_id" required="payment_type == 'payment_request'" invisible="context.get('default_model_type') != 'tw.account.payment' or payment_type != 'payment_request'" domain="[('company_id','=',company_id),('division','=',division),('state','not in',('draft','canceled','rejected')),('move_id', '!=', False)]" readonly="state != 'draft'" options="{'no_create':True,'no_open':True}"/>
                </field>
            </field>
        </record>
        
        <record id="payment_cancel_action" model="ir.actions.act_window">
            <field name="name">Payment Cancel</field>
            <field name="res_model">tw.payment.cancel</field>
            <field name="search_view_id" ref="view_payment_cancel_search"/>
            <field name="context" eval="
            {
            'default_model_id': ref('tw_payment.model_tw_account_payment'),
            'default_model_type': 'tw.account.payment',
            'search_default_outstanding':'1',
            }
            "/>
            <field name="domain">['|',('account_payment_id','!=',False),('model_id.model','=','tw.account.payment')]</field>
        </record>
        
        <record id="payment_cancel_action_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="payment_cancel_list_view"/>
            <field name="act_window_id" ref="payment_cancel_action"/>
        </record>
        
        <record id="payment_cancel_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="inherit_payment_cancel_form_view"/>
            <field name="act_window_id" ref="payment_cancel_action"/>
        </record>
        
	</data>
</odoo>