<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_payment_cancel_branch_setting_form_view" model="ir.ui.view">
            <field name="name">tw.payment.cancel.branch.setting.inherit.form</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_cancellation.tw_cancel_account_setting_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group[@name='backoffice_journal_cancel']" position="inside">
                    <field name="journal_payment_cancel_id" options="{'no_create': True}"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>