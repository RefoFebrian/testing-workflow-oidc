<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_payment_cancel_rfa_approve" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button RFA Payment Cancel</field>
        </record>

        <record id="access_tw_payment_cancel_rfa_approve" model="ir.model.access">
            <field name="model_id" ref="model_tw_payment_cancel"/>
            <field name="name">tw_payment_cancel_rfa_approve update</field>
            <field name="group_id" ref="group_tw_payment_cancel_rfa_approve"/>
            <field name="perm_write">1</field>
        </record>
    
        <record id="group_tw_payment_cancel_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Payment Cancel</field>
        </record>

        <record id="access_tw_payment_cancel_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_payment_cancel"/>
            <field name="name">tw_payment_cancel_approval_cancel update</field>
            <field name="group_id" ref="group_tw_payment_cancel_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_payment_cancel_approval_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Payment Cancel</field>
        </record>

        <record id="access_tw_payment_cancel_approval_confirm" model="ir.model.access">
            <field name="model_id" ref="model_tw_payment_cancel"/>
            <field name="name">tw_payment_cancel_approval_confirm update</field>
            <field name="group_id" ref="group_tw_payment_cancel_approval_confirm"/>
            <field name="perm_write">1</field>
        </record>

        <record id="access_account_full_reconcile_payment_cancel_confirm" model="ir.model.access">
            <field name="model_id" ref="account.model_account_full_reconcile"/>
            <field name="name">account_full_reconcile_payment_cancel_confirm</field>
            <field name="group_id" ref="group_tw_payment_cancel_approval_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_account_partial_reconcile_payment_cancel_confirm" model="ir.model.access">
            <field name="model_id" ref="account.model_account_partial_reconcile"/>
            <field name="name">account_partial_reconcile_payment_cancel_confirm</field>
            <field name="group_id" ref="group_tw_payment_cancel_approval_confirm"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
    
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_payment_cancel_rfa_approve')),
                (4,ref('group_tw_payment_cancel_approval_cancel')),
                (4,ref('group_tw_payment_cancel_approval_confirm')),
            ]">
			</field>
		</record>
    
    </data>
    
    

</odoo>
