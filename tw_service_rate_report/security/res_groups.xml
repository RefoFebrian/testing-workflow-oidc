<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_module_category_service_rate_report" model="ir.module.category">
            <field name="name">TW Service Rate Report</field>
        </record>

        <record id="group_tw_service_rate_report_read" model="res.groups">
            <field name="category_id" ref="tw_module_category_service_rate_report" />
            <field name="name">TW Service Rate Report Read</field>
        </record>

        <record id="access_tw_service_rate_report_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_rate_report" />
            <field name="name">access_tw_service_rate_report_read</field>
            <field name="group_id" ref="group_tw_service_rate_report_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_service_rate_report_update" model="res.groups">
            <field name="category_id" ref="tw_module_category_service_rate_report" />
            <field name="name">TW Service Rate Report Update</field>
        </record>

        <record id="access_tw_service_rate_report_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_rate_report" />
            <field name="name">access_tw_service_rate_report_update</field>
            <field name="group_id" ref="group_tw_service_rate_report_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_service_rate_report_delete" model="res.groups">
            <field name="category_id" ref="tw_module_category_service_rate_report" />
            <field name="name">TW Service Rate Report Delete</field>
        </record>

        <record id="access_tw_service_rate_report_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_service_rate_report" />
            <field name="name">access_tw_service_rate_report_delete</field>
            <field name="group_id" ref="group_tw_service_rate_report_delete" />
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_service_rate_report_read')),
                (4, ref('group_tw_service_rate_report_update')),
                (4, ref('group_tw_service_rate_report_delete')),
            ]" />
        </record>
    </data>

</odoo>
