<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_service_rate_report_wizard_view" model="ir.ui.view">
            <field name="name">tw.service.rate.report.wizard</field>
            <field name="model">tw.service.rate.report</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group name="periode" colspan="2">
                            <label for="start_date" string="Periode"/>
                            <div>
                                <field name="start_date" required="1" class="oe_inline"/> - <field name="end_date" required="1" class="oe_inline"/>
                            </div>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_export_report" string="Export" type="object" class="oe_highlight"/>
                        <button special="cancel" string="Cancel" class="oe_highlight"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tw_service_rate_report" model="ir.actions.act_window">
            <field name="name">Laporan Service Rate</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.service.rate.report</field>
            <field name="view_id" ref="tw_service_rate_report_wizard_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>