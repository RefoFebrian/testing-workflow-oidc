<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Asset Report Group -->
        <record id="group_tw_asset_report" model="res.groups">
            <field name="category_id" ref="tw_base.tw_module_category_asset"/>
            <field name="name">TW Laporan Asset</field>
        </record>
        <record id="access_tw_asset_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_report"/>
            <field name="name">tw_asset_report</field>
            <field name="group_id" ref="group_tw_asset_report"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>
        <record id="access_tw_asset_purchase_report" model="ir.model.access">
            <field name="model_id" ref="model_tw_asset_purchase_report"/>
            <field name="name">tw_asset_purchase_report</field>
            <field name="group_id" ref="group_tw_asset_report"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_asset_report')),
            ]"/>
        </record>
    </data>
</odoo>