<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_loss_demand_report_form_view" model="ir.ui.view">
            <field name="name">tw.loss.demand.report.form</field>
            <field name="model">tw.loss.demand.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report" create="false" delete="false">
                    <group col="2" colspan="2">
                        <group>
                            <label for="start_date" string="Periode"/> 
                            <div>
                                <field name="start_date" class="oe_inline" placeholder="Start"/> - 
                                <field name="end_date" class="oe_inline" placeholder="End"/>
                            </div>
						    <field name="company_ids" widget="many2many_tags"/>
                        </group>
                        <group>
						    <field name="division" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_generate_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_loss_demand_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Loss Demand</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.loss.demand.report</field>
            <field name="view_id" ref="tw_loss_demand_report_form_view"/>
            <field name="target">new</field>
        </record>

	  	<record id="tw_loss_demand_showroom_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Loss Demand</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.loss.demand.report</field>
            <field name="view_id" ref="tw_loss_demand_report_form_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Unit'}</field>
        </record>

	  	<record id="tw_loss_demand_workshop_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Loss Demand</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.loss.demand.report</field>
            <field name="view_id" ref="tw_loss_demand_report_form_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Sparepart'}</field>
        </record>

    </data>
</odoo>