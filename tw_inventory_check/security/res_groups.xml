<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- TW Pricelist Transient Group Read -->
        <record id="tw_pricelist_transient_group_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Check Prices Read</field>
        </record>

        <record id="tw_pricelist_transient_access_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_pricelist_transient" />
            <field name="name">tw_pricelist_transient read</field>
            <field name="group_id" ref="tw_pricelist_transient_group_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="tw_inventory_check_product_pricelist_read" model="ir.model.access">
            <field name="model_id" ref="product.model_product_pricelist" />
