            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_pricelist_transient_group_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role" />
            <field name="name">TW Check Prices Delete</field>
            <field name="implied_ids" eval="[(4, ref('tw_pricelist_transient_group_read'))]" />
        </record>

        <record id="tw_pricelist_transient_access_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_pricelist_transient" />
