<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="tw_loss_demand_rule" model="ir.rule">
            <field name="name">tw.loss.demand.rule</field>
            <field name="model_id" ref="tw_inventory_check.model_tw_loss_demand"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

        <record id="tw_pricelist_transient_rule" model="ir.rule">
            <field name="name">tw.pricelist.transient.rule</field>
            <field name="model_id" ref="tw_inventory_check.model_tw_pricelist_transient"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>