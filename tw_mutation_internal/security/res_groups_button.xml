    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_mutation_internal_button_confirm_read')),
                (4,ref('group_tw_mutation_internal_button_validate_read')),
                (4,ref('group_tw_mutation_internal_button_renew_available_read')),
