<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">  
        
        <record id="group_tw_mutation_internal_button_confirm_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
