<odoo>
  <data>
    <record id="tw_dgi_mapping_master_jasa_view_list" model="ir.ui.view">
      <field name="name">tw.dgi.mapping.master.jasa.view.list</field>
      <field name="model">tw.dgi.mapping.master.jasa</field>
      <field name="arch" type="xml">
        <list string="Mapping Master Jasa">
          <field name="main_dealer_id"/>
          <field name="company_id"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="tw_dgi_mapping_master_jasa_view_form" model="ir.ui.view">
      <field name="name">tw.dgi.mapping.master.jasa.view.form</field>
      <field name="model">tw.dgi.mapping.master.jasa</field>
      <field name="arch" type="xml">
        <form string="Mapping Master Jasa">
          <header>
            
            
          </header>
          <sheet>
            <group>
              <field name="main_dealer_id" domain="[('category_id.name', 'ilike', 'Principle')]" options="{'no_create': True, 'no_open': True}"/>
              <field name="company_id" options="{'no_create': True, 'no_open': True}" placeholder="Visible to all"/>
              <field name="active"/>
            </group>
            <notebook>
              <page string="Lines">
                <button name="action_upload_mapping_jasa_wizard" string="Upload" type="object" class="oe_highlight" groups="tw_dgi_mapping_master_jasa.tw_dgi_mapping_master_jasa_group_button_import"/>
                <field name="line_ids">
                  <list editable="bottom">
                    <field name="product_id" domain="[('categ_id.name', 'ilike', 'Service')]" options="{'no_create': True, 'no_open': True}"/>
                    <field name="product_md"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id="tw_dgi_mapping_master_jasa_search_view" model="ir.ui.view">
			<field name="name">tw.dgi.mapping.master.jasa.search</field>
			<field name="model">tw.dgi.mapping.master.jasa</field>
			<field name="arch" type="xml">
				<search string="Search DGI">
					<field name='main_dealer_id' />
					<field name='company_id' />
          <field name='line_ids' string="Produk Jasa" filter_domain="[('line_ids.product_id', 'ilike', self)]"/>
					<filter name="active" string="Active" domain="[('active','=',True)]" />
					<group expand="0" string="Group By">
              <filter name="group_by_main_dealer" string="Main Dealer" context="{'group_by': 'main_dealer_id'}"/>
              <filter name="group_by_branch" string="Branch" context="{'group_by': 'company_id'}"/>
          </group>
				</search>
			</field>
		</record>

    <record id="tw_dgi_mapping_master_jasa_action" model="ir.actions.act_window">
      <field name="name">Mapping Master Jasa</field>
      <field name="res_model">tw.dgi.mapping.master.jasa</field>
      <field name="view_mode">list,form</field>
      <field name="context">{'search_default_active': 1}</field>
    </record>

    
  </data>
</odoo>
