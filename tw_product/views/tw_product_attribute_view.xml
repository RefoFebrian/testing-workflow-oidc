<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
       <record id="product_attribute_list_view" model="ir.ui.view">
            <field name="name">product.attribute.tree</field>
            <field name="model">product.attribute</field>
            <field name="arch" type="xml">
                <list string="Product Attribute" create="true" editable="top">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="product_attribute_value_list_view" model="ir.ui.view">
            <field name="name">product.attribute.value.tree</field>
            <field name="model">product.attribute.value</field>
            <field name="arch" type="xml">
                <list string="Product Attribute value" create="true" editable="top">
                    <field name="sequence" widget="handle"/>
                    <field name="attribute_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="name"/>
                    <field name="code" required="1"/>
                </list>
            </field>
        </record>

        <record id="tw_product_attribute_value_filter" model="ir.ui.view">
            <field name="name">tw.product.attribute.value.filter</field>
            <field name="model">product.attribute.value</field>
            <field name="arch" type="xml">
                <search string="Search Product Attribute Value">
                    <field name="name"/>
                    <field name="code"/>
                </search>
            </field>
        </record>  
        
        <record id="product_attribute_action_tree" model="ir.actions.act_window">
            <field name="name">Attribute</field>
            <field name="res_model">product.attribute</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="product_attribute_list_view"></field>
        </record> 

        <record id="product_attribute_value_action_tree" model="ir.actions.act_window">
            <field name="name">Attribute Value</field>
            <field name="res_model">product.attribute.value</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="product_attribute_value_list_view"></field>
        </record>

    </data>
</odoo>
