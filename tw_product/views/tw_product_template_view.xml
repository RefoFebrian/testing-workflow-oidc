<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_product_template_inherit_list_view" model="ir.ui.view">
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <field name="uom_id" position="attributes">
                    <attribute name="optional">hide</attribute>
                </field>
                <field name="uom_id" position="after">
                    <field name="division"/>
                </field>
            </field>
        </record>
        
        <record id="tw_product_product_template_only_inherit_form_view" model="ir.ui.view">
            <field name="name">product.template.only.inherit.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_only_form_view" />
            <field name="arch" type="xml">
                <xpath expr="//page[@name='variants']" position="attributes">
                    <attribute name="invisible">context.get('has_variant') != 1</attribute>
                </xpath>
                <xpath expr="//page[@name='sales']" position="attributes">
                    <attribute name="groups">tw_base.group_system_admin</attribute>
                </xpath>
                <xpath expr="//page[@name='purchase']" position="attributes">
                    <attribute name="groups">tw_base.group_system_admin</attribute>
                </xpath>
                <xpath expr="//page[@name='inventory']" position="attributes">
                    <attribute name="groups">tw_base.group_system_admin</attribute>
                </xpath>
                <xpath expr="//page[@name='invoicing']" position="attributes">
                    <attribute name="groups">tw_base.group_system_admin</attribute>
                </xpath>
                <field name="barcode" position="after">
                    <field name="part_unit_id" invisible="division != 'Unit'" options="{'no_open':True, 'no_create':True}" />
                </field>
                <field name="default_code" position="attributes">
                    <attribute name="invisible">0</attribute>
                    <attribute name="required">True</attribute>
                    <attribute name="string">Default Code</attribute>
                </field>
                <field name="categ_id" position="attributes">
                    <attribute name="options">{'no_create': True}</attribute>
                </field>
                <field name="default_code" position="after">
                    <field name="product_origin_id" domain="[('categ_id','=',categ_id),('sale_ok','=',True),('purchase_ok','=',True)]" options="{'no_open':True, 'no_create':True}"/>
                    <field name="engine_code" invisible="division != 'Unit'"/>
                    <field name="factur_code" invisible="division != 'Unit'"/>
                </field>
                <field name="categ_id" position="attributes">
                    <attribute name="string">Internal Category</attribute>
                </field>
            </field>
        </record>
        
        <record id="tw_product_product_template_inherit_form_view" model="ir.ui.view">
            <field name="name">product.template.inherit.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view" />
            <field name="arch" type="xml">
                <field name="categ_id" position="after">
                    <field name="division" readonly="1" force_save="1"/>
                </field>
                <xpath expr="//field[@name='is_storable']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
                <xpath expr="//field[@name='lot_valuated']" position="attributes">
                    <attribute name="readonly">1</attribute>
                    <attribute name="widget">boolean</attribute>
                </xpath>
                <xpath expr="//field[@name='type']" position="attributes">
                    <attribute name="readonly">1</attribute>
                </xpath>
            </field>
        </record>

        <record id="tw_product_template_unit_action" model="ir.actions.act_window">
            <field name="name">Products (Unit)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Unit')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
                'default_tracking': 'serial',
                'default_categ_id': ref('tw_product.product_category_unit'),
                'default_is_storable': 1,
                'default_lot_valuated': 1,
                'search_default_unit': 1,
                'action_name':'Unit',
                'has_variant':1,
			}"/>
        </record>

        <record id="tw_product_template_sparepart_action" model="ir.actions.act_window">
            <field name="name">Products (Sparepart)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Sparepart')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
                'default_categ_id': ref('tw_product.product_category_sparepart'),
                'default_is_storable': 1,
                'search_default_sparepart': 1,
                'action_name':'Sparepart',
                'has_variant':0,
			}"/>
        </record>

        <record id="tw_product_template_service_action" model="ir.actions.act_window">
            <field name="name">Products (Service)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Service')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'service',
                'default_categ_id': ref('tw_product.product_category_service'),
                'default_is_storable': 1,
                'search_default_service': 1,
                'action_name': 'Service',
                'has_variant': 0,
			}"/>
        </record>

        <record id="tw_product_template_extras_action" model="ir.actions.act_window">
            <field name="name">Products (Extras)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Extras')]"/>
            <field name="context" eval="{
                'default_sale_ok': False,
                'default_purchase_ok': True,
                'default_categ_id': ref('tw_product.product_category_extras'),
                'search_default_extras': 1,
                'action_name': 'Extras',
                'has_variant': 1,
                'default_is_storable': 1,
			}"/>
        </record>

        <record id="tw_product_template_direct_gift_action" model="ir.actions.act_window">
            <field name="name">Products (Direct Gift)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Direct Gift')]"/>
            <field name="context" eval="{
                'default_sale_ok': False,
                'default_purchase_ok': True,
                'default_categ_id': ref('tw_product.product_category_direct_gift'),
                'search_default_direct_gift': 1,
                'action_name': 'Umum',
                'has_variant': 1,
                'default_is_storable': 1,
			}"/>
        </record>

        <record id="tw_product_template_all_action" model="ir.actions.act_window">
            <field name="name">Products (All)</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
                'default_is_storable': 1,
                'has_variant': 0,
			}"/>
        </record>

    </data>
</odoo>
