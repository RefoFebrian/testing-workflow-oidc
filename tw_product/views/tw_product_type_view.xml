<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_product_type_tree" model="ir.ui.view">
            <field name="name">tw.product.type.tree</field>
            <field name="model">tw.product.type</field>
            <field name="arch" type="xml">
                <list string="Product Type" editable="top">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="division" required="1"/>
                </list>
            </field>
        </record>

        <record id="tw_product_type_filter" model="ir.ui.view">
            <field name="name">tw.product.type.filter</field>
            <field name="model">tw.product.type</field>
            <field name="arch" type="xml">
                <search string="Search Product Type">
                    <field name="name"/>
                    <group expand="1" string="Group By">
						<filter string="Division" name="group_by_division" context="{'group_by':'division'}"/>
					</group>
                </search>
            </field>
        </record>  
        
        <record id="action_tw_product_type_tree" model="ir.actions.act_window">
            <field name="name">Product Types</field>
            <field name="res_model">tw.product.type</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>