<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="tw_product_list_view" model="ir.ui.view">
            <field name="name">tw.product.list</field>
            <field name="model">product.product</field>
            <field eval="7" name="priority"/>
            <field name="arch" type="xml">
                <list string="Product Variants" multi_edit="1" duplicate="false" sample="1">
                    <field name="default_code" optional="show" readonly="1"/>
                    <field name="name" readonly="1"/>
                    <field name="product_template_variant_value_ids" widget="many2many_tags" groups="product.group_product_variant" readonly="1"/>
                    <field name="categ_id" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="tw_product_product_inherit_list_view" model="ir.ui.view">
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <field name="uom_id" position="attributes">
                    <attribute name="optional">hide</attribute>
                </field>
                <field name="uom_id" position="after">
                    <field name="division"/>
                </field>
            </field>
        </record>


        <record id="tw_product_product_variant_inherit_form_view" model="ir.ui.view">
            <field name="name">product.product.inherit.form</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view" />
            <field name="arch" type="xml">
                <field name="default_code" position="attributes">
                    <attribute name="required">True</attribute>
                </field>
                <field name="categ_id" position="attributes">
                    <attribute name="string">Internal Category</attribute>
                </field>
            </field>
        </record>

        <record id="tw_product_product_variants_unit_action" model="ir.actions.act_window">
            <field name="name">Product Variants (Unit)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Unit')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
                'default_tracking': 'serial',
				'default_division': 'Unit',
                'default_is_storable': 1,
                'search_default_unit': 1,
                'action_name': 'Unit'
			}"/>
        </record>

        <record id="tw_product_product_variants_sparepart_action" model="ir.actions.act_window">
            <field name="name">Product Variants (Sparepart)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Sparepart')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
				'default_division': 'Sparepart',
                'default_is_storable': 1,
                'search_default_sparepart': 1,
                'action_name': 'Sparepart'
			}"/>
        </record>

        <record id="tw_product_product_variants_service_action" model="ir.actions.act_window">
            <field name="name">Product Variants (Service)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Service')]"/>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'service',
				'default_division': 'Service',
                'default_is_storable': 1,
                'search_default_service': 1,
                'action_name': 'Service'
			}"/>
        </record>

        <record id="tw_product_product_variants_extras_action" model="ir.actions.act_window">
            <field name="name">Product Variants (Extras)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Extras')]"/>
            <field name="context" eval="{
                'default_sale_ok': False,
                'default_purchase_ok': True,
				'default_division': 'Extras',
                'search_default_extras': 1,
                'action_name': 'Extras',
                'default_is_storable': 1,
			}"/>
        </record>

        <record id="tw_product_product_variants_direct_gift_action" model="ir.actions.act_window">
            <field name="name">Product Variants (Direct Gift)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="domain" eval="[('categ_id', 'ilike', 'Direct Gift')]"/>
            <field name="context" eval="{
                'default_sale_ok': False,
                'default_purchase_ok': True,
				'default_division': 'Direct Gift',
                'search_default_direct_gift': 1,
                'action_name': 'Umum',
                'default_is_storable': 1,
			}"/>
        </record>

        <record id="tw_product_product_variants_all_action" model="ir.actions.act_window">
            <field name="name">Product Variants (All)</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">list,form</field>
            <field name="context" eval="{
                'default_sale_ok': True,
                'default_purchase_ok': True,
                'default_type': 'consu',
                'default_is_storable': 1,
			}"/>
        </record>
    </data>
</odoo>