<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="tw_module_category_dealer_spk" model="ir.module.category">
            <field name="name">TW Dealer SPK</field>
        </record>

        <!-- Dealer SPK -->
        <record id="group_tw_dealer_spk_read" model="res.groups">
            <field name="category_id" ref="tw_module_category_dealer_spk" />
            <field name="name">TW Dealer SPK Read</field>
        </record>

        <record id="access_tw_dealer_spk_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk" />
            <field name="name">access_tw_dealer_spk read</field>
            <field name="group_id" ref="group_tw_dealer_spk_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_dealer_spk_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk_line" />
            <field name="name">access_tw_dealer_spk_line read</field>
            <field name="group_id" ref="group_tw_dealer_spk_read" />
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_dealer_spk_update" model="res.groups">
            <field name="category_id" ref="tw_module_category_dealer_spk" />
            <field name="name">TW Dealer SPK Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_dealer_spk_read'))]" />
        </record>

        <record id="access_tw_dealer_spk_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk" />
            <field name="name">access_tw_dealer_spk update</field>
            <field name="group_id" ref="group_tw_dealer_spk_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="access_tw_dealer_spk_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk_line" />
            <field name="name">access_tw_dealer_spk_line update</field>
            <field name="group_id" ref="group_tw_dealer_spk_update" />
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_dealer_spk_delete" model="res.groups">
            <field name="category_id" ref="tw_module_category_dealer_spk" />
            <field name="name">TW Dealer SPK Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_dealer_spk_read'))]" />
        </record>

        <record id="access_tw_dealer_spk_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk" />
            <field name="name">access_tw_dealer_spk delete</field>
            <field name="group_id" ref="group_tw_dealer_spk_delete" />
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_dealer_spk_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk_line" />
            <field name="name">access_tw_dealer_spk_line delete</field>
            <field name="group_id" ref="group_tw_dealer_spk_delete" />
            <field name="perm_unlink">1</field>
        </record>
        
        <record id="group_tw_dealer_spk_report_read" model="res.groups">
            <field name="category_id" ref="tw_module_category_dealer_spk" />
            <field name="name">TW Dealer SPK Report Read</field>
        </record>

        <record id="access_tw_dealer_spk_report_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_dealer_spk_report" />
            <field name="name">access_tw_dealer_spk_report read</field>
            <field name="group_id" ref="group_tw_dealer_spk_report_read" />
            <field name="perm_read">1</field>
        </record>

    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_dealer_spk_read')),
                (4, ref('group_tw_dealer_spk_update')),
                (4, ref('group_tw_dealer_spk_delete')),
                (4, ref('group_tw_dealer_spk_report_read')),
            ]" />
        </record>
    </data>
</odoo>
