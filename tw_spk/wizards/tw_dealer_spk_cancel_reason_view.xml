<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<record id="tw_dealer_spk_cancel_reason_view" model="ir.ui.view">
			<field name="name">tw.dealer.spk.cancel.reason.form</field>
			<field name="model">tw.dealer.spk.cancel.reason</field>
			<field name="arch" type="xml">
				<form>
					<group>
						<field name="spk_id" invisible="1"/>
						<field name="reason"/>
					</group>
					<footer>
						<button name="action_cancel" string="Cancel" type="object" class="btn-danger" />
						<button special="cancel" string="Close" class="btn-secondary" />
					</footer>
				</form>
			</field>
		</record>

	</data>
</odoo>