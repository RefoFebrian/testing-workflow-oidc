<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Confirm Stock Opname -->
        <record id="group_tw_stock_opname_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Confirm Stock Opname approval</field>
        </record>

        <record id="access_tw_stock_opname_confirm" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname.model_tw_stock_opname"/>
            <field name="name">tw_stock_opname_confirm update</field>
            <field name="group_id" ref="group_tw_stock_opname_confirm"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Approval Stock Opname -->
        <record id="group_tw_stock_opname_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Request Approval Stock Opname</field>
        </record>

        <record id="access_tw_stock_opname_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname.model_tw_stock_opname"/>
            <field name="name">tw_stock_opname_approval_rfa update</field>
            <field name="group_id" ref="group_tw_stock_opname_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_tw_stock_opname_approval_done" model="res.groups">
			<field name="category_id" ref="tw_base.tw_role"/>
			<field name="name">TW Button Confirm Stock Opname</field>
		</record>

		<record id="access_tw_stock_opname_approval_done" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname.model_tw_stock_opname"/>
            <field name="name">tw_stock_opname_approval_done update</field>
            <field name="group_id" ref="group_tw_stock_opname_approval_done"/>
            <field name="perm_write">1</field>
        </record>
             
        <record id="group_tw_stock_opname_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Stock Opname</field>
        </record>
        <record id="access_tw_stock_opname_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname.model_tw_stock_opname"/>
            <field name="name">tw_stock_opname_approval_cancel update</field>
            <field name="group_id" ref="group_tw_stock_opname_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>
                     
        <!-- group_tw_stock_opname_approval_reject reuses the group already defined in tw_stock_opname -->
        <record id="access_tw_stock_opname_approval_reject" model="ir.model.access">
            <field name="model_id" ref="tw_stock_opname.model_tw_stock_opname"/>
            <field name="name">tw_stock_opname_approval_reject update</field>
            <field name="group_id" ref="tw_stock_opname.group_tw_stock_opname_button_reject"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_stock_opname_approval_rfa')),
                (4,ref('group_tw_stock_opname_approval_done')),
                (4,ref('group_tw_stock_opname_approval_cancel')),
                (4,ref('tw_stock_opname.group_tw_stock_opname_button_reject')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>