<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<record id="tw_stock_opname_approval_form_view" model="ir.ui.view">
			<field name="name">tw.stock.opname.approval.form</field>
			<field name="model">tw.stock.opname</field>
			<field name="inherit_id" ref="tw_stock_opname.tw_stock_opname_retail_form"/>
			<field name="arch" type="xml">
				<button name="action_done" position="replace">
					<button name="action_rfa" invisible="state != 'in_progress'" string="RFA" type="object" class="oe_highlight" groups="tw_stock_opname_approval.group_tw_stock_opname_approval_rfa"/>
					<button name="action_approval" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight"/>
					<button name="action_done" invisible="state != 'approved'" string="Confirm" type="object" class="oe_highlight" groups="tw_stock_opname.group_tw_stock_opname_button_done"/>
					<button name="action_reject_or_cancel" invisible="state != 'waiting_for_approval'" string="Reject" type="object" context="{'window_title': 'Reject'}"/>
					<button name="action_reject_or_cancel" invisible="state not in ('waiting_for_approval', 'approved')" string="Cancel Approval" type="object" groups="tw_stock_opname_approval.group_tw_stock_opname_approval_cancel" context="{'window_title': 'Cancel'}"/>
				</button>

				<xpath expr="//page[@name='audit_trail']" position="before">
					<page string="Approval">
						<field name="approval_ids" readonly="True">
						</field>
					</page>
				</xpath>
			</field>
		</record>

		<record id="tw_stock_opname_approval_wizard_view" model="ir.ui.view">
			<field name="name">tw.stock.opname.approval.wizard</field>
			<field name="model">tw.stock.opname</field>
			<field name="inherit_id" ref="tw_stock_opname.view_force_done_wizard"/>
			<field name="arch" type="xml">
				<button name="action_force_done" position="replace">
					<button name="action_request_approval" invisible="state != 'in_progress'" string="Save" type="object" class="oe_highlight" groups="tw_stock_opname_approval.group_tw_stock_opname_approval_rfa"/>
				</button>
			</field>
		</record>

	</data>
</odoo>