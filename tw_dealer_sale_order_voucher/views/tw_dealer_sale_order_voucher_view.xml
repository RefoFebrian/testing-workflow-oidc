<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_dealer_order_voucher_inherit_view_form" model="ir.ui.view">
			<field name="name">tw.dealer.order.voucher.inherit.view.form</field>
			<field name="model">tw.dealer.sale.order</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_order_view_form"/>
			<field name="priority">80</field>
			<field name="arch" type="xml">
				<group name="amount_discount" position="inside">
                    <field name="amount_voucher" readonly="1" />
				</group>
				
                <field name="amount_dealer_expense" position="after">
                    <field name="amount_voucher" readonly="1" />
                </field>

				<xpath expr="//field[@name='summary_discount_ids']/list//field[@name='discount_regular']" position="after">
					<field name="amount_voucher" readonly="1" optional="hide"/>
				</xpath>

				<xpath expr="//field[@name='summary_discount_ids']/form//field[@name='discount_regular']" position="after">
					<field name="amount_voucher" readonly="1" optional="hide"/>
				</xpath>
			</field>
        </record>

        <record id="tw_dealer_order_line_voucher_inherit_view_form" model="ir.ui.view">
			<field name="name">tw.dealer.order.line.voucher.inherit.view.form</field>
			<field name="model">tw.dealer.sale.order.line</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sale_order_line_view_form"/>
			<field name="priority">80</field>
			<field name="arch" type="xml">
				<xpath expr="//page[@name='page_lines']" position="after">
					<page string="Voucher Line" name="dso_line_voucher">
						<field name="voucher_ids" readonly="parent.state != 'draft'">
                            <list editable="bottom" create="0" delete="0" edit="0">
                                <field name="voucher_id" />
                                <field name="amount" />
                            </list>
                        </field>
						<button name="action_set_voucher" icon="fa-refresh" string=" " type="object" class="oe_highlight" invisible="parent.state != 'draft'"/>
					</page>
				</xpath>
			</field>
		</record>

		<record id="tw_dealer_order_line_voucher_inherit_view_list" model="ir.ui.view">
			<field name="name">tw.dealer.order.line.voucher.inherit.view.list</field>
			<field name="model">tw.dealer.sale.order.line</field>
			<field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sale_order_line_view_list"/>
			<field name="priority">80</field>
			<field name="arch" type="xml">
				<xpath expr="//field[@name='discount_total']" position="after">
					<field name="amount_voucher" string="Disc Voucher" readonly="1" optional="hide"/>
				</xpath>
			</field>
		</record>
    </data>
</odoo>