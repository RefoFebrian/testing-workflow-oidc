<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Button Groups -->
        <record id="group_tw_collecting_confirm" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Collecting Confirm</field>
        </record>
        <record id="access_tw_collecting_confirm_button" model="ir.model.access">
            <field name="name">access_tw_collecting_confirm_button</field>
            <field name="model_id" ref="tw_collecting.model_tw_collecting"/>
            <field name="group_id" ref="group_tw_collecting_confirm"/>
            <field name="perm_write" eval="1"/>
        </record>

        
        
    </data>
    <data>
        <!-- Add all button groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_collecting_confirm')),
            ]" />
        </record>
    </data>
</odoo>
