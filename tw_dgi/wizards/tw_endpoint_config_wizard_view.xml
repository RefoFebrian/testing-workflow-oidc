<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Endpoint Configuration Wizard Form -->
        <record id="view_tw_endpoint_config_wizard_form" model="ir.ui.view">
            <field name="name">tw.endpoint.config.wizard.form</field>
            <field name="model">tw.endpoint.config.wizard</field>
            <field name="arch" type="xml">
                <form string="Configure Endpoint">
                    <sheet>
                        <!-- Header Info -->
                        <group>
                            <group string="Endpoint URL">
                                <field name="full_url" readonly="1"/>
                            </group>
                            <group>
                                <field name="endpoint_id" invisible="1" options="{'no_open': True}"/>
                            </group>
                        </group>

                        <!-- URL &amp; Auth Override -->
                        <group string="Override Configuration">
                            <group string="URL">
                                <field name="base_url_override"
                                       placeholder="Kosongkan jika sama dengan API Config induk"/>
                            </group>
                            <group string="Auth (HMAC Override)">
                                <field name="auth_api_key_override"
                                       placeholder="Kosongkan jika pakai API Key dari API Config induk"/>
                                <field name="auth_api_secret_override"
                                       placeholder="Kosongkan jika pakai API Secret dari API Config induk"
                                       password="True"/>
                            </group>
                        </group>

                        <!-- Guide Section -->
                        <div class="alert alert-info" role="alert">
                            <h4>
                                <i class="fa fa-info-circle" title="Info"/>
 Mapping Configuration Guide</h4>
                            <ul class="mb-0">
                                <li>
                                    <strong>JSON Path</strong>: Path ke data di response API (e.g., unit.nomorMesin, dealerId)</li>
                                <li>
                                    <strong>Target Field</strong>: Nama field output Odoo tujuan (e.g., partner_id, company_id).
                                    <em>Kosongkan hanya jika rule ingin berlaku generik berdasarkan JSON Path dan tidak dikunci ke field output tertentu</em>
                                </li>
                                <li>
                                    <strong>Field Type</strong>: Direct (langsung), Relation (lookup/validasi), Validation (filter)</li>
                                <li>
                                    <strong>Create if Not Found</strong>: Buat record baru jika lookup gagal</li>
                                <li>
                                    <strong>Create Field Mappings</strong>: JSON untuk field create, contoh: {"name": "namaCustomer"}</li>
                            </ul>
                        </div>

                        <separator string="Response Mappings"/>
                        <field name="mapping_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="json_path" placeholder="unit.nomorMesin"/>
                                <field name="field_type"/>
                                <field name="target_field" placeholder="partner_id (kosongkan jika validasi saja)"/>
                                <!-- Line Group for array items -->
                                <field name="line_group" placeholder="spk_lines"/>
                                <field name="derived_value_type" invisible="field_type != 'derived'"/>
                                <!-- Relation Fields - Basic -->
                                <field name="relation_model_id" options="{'no_create': True}" invisible="field_type != 'relation'"/>
                                <field name="relation_lookup_field" invisible="field_type != 'relation'" placeholder="identification_number"/>
                                <field name="create_if_not_found" invisible="field_type != 'relation'"/>
                                <!-- Validation Filter Fields - Basic -->
                                <field name="validation_operator" invisible="field_type != 'validation'"/>
                                <field name="expected_value" invisible="field_type != 'validation'" placeholder="8"/>
                                <!-- Common -->
                                <field name="is_required"/>
                                <!-- Rules Button -->
                                <button name="action_open_rules" type="object" string="Rules" icon="fa-cog" class="btn-link" title="Configure advanced rules (default value, search domain, fallback, create mappings)"/>
                            </list>
                        </field>

                        <separator string="Output Template"/>

                        <!-- Output Template Note -->
                        <div class="alert alert-warning" role="alert">
                            <strong>
                                <i class="fa fa-lightbulb-o" title="Tip"/>
 Tips:</strong>
                            <ul class="mb-0">
                                <li>Isi <strong>Target Field</strong> pada setiap mapping untuk menghasilkan output template otomatis</li>
                                <li>
                                    <strong>Line Group</strong>: Isi untuk mengelompokkan field ke dalam array (misal: <code>spk_lines</code>). Kosongkan untuk field header.</li>
                                <li>
                                    <strong>Dot notation</strong>: Gunakan format <code>parent.child</code> pada JSON Path (misal: <code>unit.kodeTipeUnit</code>) untuk array items</li>
                                <li>
                                    <strong>Static value</strong>: Gunakan <code>json_path="__default__"</code> dan isi <code>Default Value</code>.
                                    Static string akan di-generate sebagai <code>{"_value": "draft"}</code>, sedangkan boolean/number tetap literal biasa.</li>
                                <li>
                                    <strong>Derived field</strong>: Gunakan <code>Field Type = Derived Field</code> dan isi <code>JSON Path</code> dengan path dari parsed result, misal <code>company_id.default_supplier_id</code> untuk generate field inline seperti <code>"partner_id": {"_from_result": "...", "_type": "m2o"}</code></li>
                                <li>
                                    <strong>Auto-Generated</strong>: Template dibuat dari mappings yang punya Target Field</li>
                                <li>
                                    <strong>Current Saved</strong>: Template yang tersimpan di endpoint (bisa edit manual)</li>
                                <li>Klik "Apply Generated" untuk mengganti saved output template dengan hasil generate terbaru</li>
                            </ul>
                        </div>

                        <group>
                            <group string="Auto-Generated Preview">
                                <field name="output_template_preview" widget="ace" nolabel="1" readonly="1"/>
                            </group>
                            <group string="Current Saved Template">
                                <field name="output_template_json" widget="ace" nolabel="1"/>
                            </group>
                        </group>

                        <div class="text-center">
                            <button name="action_apply_generated_template" type="object" string="Apply Generated Template to Saved" class="btn-secondary" icon="fa-magic" confirm="This will replace the Current Saved Template with Auto-Generated Preview. Continue?"/>
                        </div>
                    </sheet>
                    <footer>
                        <button name="action_save_and_close" type="object" string="Save &amp; Close" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
