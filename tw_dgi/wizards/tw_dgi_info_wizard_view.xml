<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_dgi_info_wizard_form" model="ir.ui.view">
        <field name="name">tw.dgi.info.wizard.form</field>
        <field name="model">tw.dgi.info.wizard</field>
        <field name="arch" type="xml">
            <form string="DGI Information" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h2>DGI Information</h2>
                        <div class="text-muted">
                            Detail sinkronisasi dan referensi data dari integrasi DGI.
                        </div>
                    </div>
                    <group id="dgi_info_group" col="2">
                        <group id="dgi_sync_info_group" string="Synchronization Info">
                            <field name="dgi_get_date" invisible="not dgi_get_date"/>
                            <field name="dgi_get_uid" invisible="not dgi_get_uid"/>
                        </group>
                        <group id="dgi_reference_group" string="Reference Info"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
