<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- List View -->
        <record id="tw_api_url_list_view" model="ir.ui.view">
            <field name="name">tw.api.url.list</field>
            <field name="model">tw.api.url</field>
            <field name="type">list</field>
            <field name="arch" type="xml">
                <list string="API URL">
                    <field name="api_config_id"/>
                    <field name="type"/>
                    <field name="url"/>
                    <field name="is_relative"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="tw_api_url_form_view" model="ir.ui.view">
            <field name="name">tw.api.url.form</field>
            <field name="model">tw.api.url</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="API URL">
                    <sheet>
                        <group>
                            <group>
                                <field name="api_config_id" options="{'no_open': True, 'no_create_edit': True}" required="1"/>
                                <field name="type" required="1"/>
                            </group>
                            <group>
                                <field name="url" required="1"/>
                                <field name="is_relative"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1"/>
                                        <field name="create_date" readonly="1"/>
                                    </group>
                                    <group>
                                        <field name="write_uid" readonly="1"/>
                                        <field name="write_date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="tw_api_url_search_view" model="ir.ui.view">
            <field name="name">tw.api.url.search</field>
            <field name="model">tw.api.url</field>
            <field name="arch" type="xml">
                <search string="API URL">
                    <field name="api_config_id" select="True"/>
                    <field name="url" select="True"/>
                    <field name="type" select="True"/>
                    <filter name="is_relative" string="is relative" domain="[('is_relative', '=', True)]" />
                    <group string="Group By..">
                        <filter string="API Config" domain="[]" name="group_by_api_config_id" context="{'group_by': 'api_config_id'}"/>
                        <filter string="Type" domain="[]" name="group_by_type" context="{'group_by': 'type'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action View -->
        <record id="tw_api_url_action" model="ir.actions.server">
            <field name="name">API URL</field>
            <field name="model_id" ref="tw_b2b_bank.model_tw_api_url"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.api.url'].action_api_url_tree()
            </field>
        </record>
        
    </data>
</odoo>