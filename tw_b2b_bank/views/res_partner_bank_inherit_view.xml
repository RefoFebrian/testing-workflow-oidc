<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Create New Form Partners Bank Accounts -->
    <record id="res_partner_bank_b2b_bank_form_view" model="ir.ui.view">
        <field name="name">res.partner.b2b.bank.form</field>
        <field name="model">res.partner.bank</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Bank account" name="bank_account_form">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="sequence" invisible="1"/>
                            <field name="acc_type" invisible="1"/>
                            <field name="bank_id" required="1" options="{'no_create': True}"/>
                            <field name="acc_number" string="Nomor Rekening" required="1"/>
                            <field name="acc_holder_name" string="Nama Pemilik Rek" required="1"/>
                            <field name="code" string="Identifier Code"/>
                            <field name="partner_id" options="{'no_create': True,'no_open': True}"/>
                            <field name="plafon" invisible="api_config_id == False" readonly="1"/>
                            <field name="currency_id" invisible="api_config_id == False" readonly="1"/>
                            <field name="is_fetch_statement" invisible="api_config_id == False" readonly="1"/>
                            <field name="last_balance_check" invisible="api_config_id == False" readonly="1"/>
                            <field name="last_fetch" invisible="api_config_id == False" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" readonly="0" groups="base.group_multi_company" options="{'no_create': True}"/>
                            <field name="currency_id" groups="base.group_multi_currency" options="{'no_create': True}"/>
                            <field name="allow_out_payment" widget="boolean_toggle"/>
                            <field name="api_config_id" required="1" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="company_id" invisible="api_config_id == False" required="api_config_id != False" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="account_id" invisible="api_config_id == False" required="api_config_id != False" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="schedule_id" invisible="api_config_id == False" options="{'no_open': True, 'no_create_edit': True}"/>
                            <field name="float_amount" invisible="api_config_id == False" readonly="1"/>
                            <field name="hold_amount" invisible="api_config_id == False" readonly="1"/>
                            <field name="available_balance" invisible="api_config_id == False" readonly="1"/>
                            <field name="balance" invisible="api_config_id == False" readonly="1"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <footer replace="0">
                    <button name="action_archive_bank" type="object" string="Archive" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action View -->
    <record id="res_partner_bank_b2b_bank_action" model="ir.actions.server">
        <field name="name">Bank Accounts</field>
        <field name="model_id" ref="tw_b2b_bank.model_res_partner_bank"/>
        <field name="state">code</field>
        <field name="code">
            action = env['res.partner.bank'].action_partner_bank_b2b_bank_tree()
        </field>
    </record>

</odoo>