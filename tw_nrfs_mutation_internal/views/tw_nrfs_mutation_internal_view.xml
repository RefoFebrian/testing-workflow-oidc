<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_nrfs_sparepart_mutation_internal_form_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.sparepart.mutation.internal.form</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs_sparepart.tw_nrfs_sparepart_form_view"/>
            <field name="arch" type="xml">
        		<xpath expr="//sheet/div[@name='button_box']" position="inside">
                    <button name="action_open_internal_transfer" type="object" class="oe_stat_button" icon="fa-list-alt" string="Internal Transfer" invisible="not picking_id" groups="tw_nrfs_mutation_internal.group_tw_nrfs_view_internal_transfer_button_read"/>
                </xpath>
                <field name="company_id" position="before">
                    <field name="picking_id" invisible="1"/>
                </field>
            </field>
        </record>

        <record id="tw_nrfs_inherit_mutation_internal_form_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.inherit.mutation.internal.form</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs.tw_nrfs_form_view"/>
            <field name="arch" type="xml">
        		<xpath expr="//sheet" position="inside">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_internal_transfer" type="object" class="oe_stat_button" icon="fa-list-alt" string="Internal Transfer" invisible="not picking_id"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>