<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_boom_task_report_form_wizard" model="ir.ui.view">
            <field name="name">tw.boom.task.report.wizard</field>
            <field name="model">tw.boom.task.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Laporan Boom Task">
                    <group>
                        <group>
                            <label for="start_date" string="Periode"/>
                            <div>
                                <field name="start_date" required="1" placeholder="Start date" style="width: 47%; margin-right: 3px;"/>
                                <field name="end_date" required="1" placeholder="End date" style="width: 47%; margin-right: 3px;"/>
                            </div>
                            <field name="main_category_id" options="{'no_open':True,'no_create':True}"/>
                            <field name="period"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="pic_job_id" options="{'no_open':True,'no_create':True}"/>
                            <field name="classification"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids" colspan="4" nolabel="1" options="{'no_show':True,'no_create':True,'no_open':True}">
                            </field>
                        </page> 
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Export Report" type="object" class="oe_highlight"/>
                        <button string="Cancel" special="cancel" class="btn btn-default"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_tw_boom_task_report_wizard" model="ir.actions.act_window">
            <field name="name">Laporan BOOM Task</field>
            <field name="path">report-boom-task</field>
            <field name="res_model">tw.boom.task.report</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_tw_boom_task_report_form_wizard" />
            <field name="target">new</field>
        </record>
    </data>
</odoo>