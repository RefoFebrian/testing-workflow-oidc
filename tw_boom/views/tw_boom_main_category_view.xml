<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_tw_boom_main_category_list" model="ir.ui.view">
            <field name="name">tw.boom.main.category.list</field>
            <field name="model">tw.boom.main.category</field>
            <field name="arch" type="xml">
                <list editable="bottom" delete="0">
                    <field name="name"/>
                </list>
            </field>
        </record>

        <record id="action_tw_boom_main_category" model="ir.actions.act_window">
            <field name="name">Main Kategori</field>
            <field name="res_model">tw.boom.main.category</field>
            <field name="path">master-main-category</field>
            <field name="view_mode">list</field>
            <field name="context"></field>
        </record>
    </data>
</odoo>