<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_tw_boom_task_delegated" model="ir.actions.server">
            <field name="name">BOOM Task Delegated</field>
            <field name="path">boom-task-delegated</field>
            <field name="model_id" ref="tw_boom.model_tw_boom_task"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.boom.task'].action_tw_boom_task({'done_delegate': True})
            </field>
        </record>
    </data>
</odoo>