<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_tw_boom_task_history_log_list" model="ir.ui.view">
            <field name="name">tw.boom.task.history.log.list</field>
            <field name="model">tw.boom.task.history</field>
            <field name="arch" type="xml">
                <list create="0" edit="0" delete="0">
                    <field name="category_id"/>
                    <field name="name" />
                    <field name="no_transaction" />
                    <field name="source_transaction" />
                    <field name="state" />
                </list>
            </field>
        </record>

        <record id="view_tw_boom_task_history_log_form" model="ir.ui.view">
            <field name="name">tw.boom.task.history.log.form</field>
            <field name="model">tw.boom.task.history</field>
            <field name="arch" type="xml">
                <form create="0" edit="0" delete="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="category_id" options="{'no_open':True,'no_create':True}" class="oe_inline" readonly="1"/>
                                <field name="no_transaction" readonly="1"/>
                                <field name="source_transaction" readonly="1"/>
                                <field name="state" readonly="1"/>
                                <field name="execution_time" readonly="1"/>
                            </group>
                            <group>
                                <field name="cron_name" readonly="1"/>
                                <field name="method_name" readonly="1"/>
                                <field name="error_message" readonly="1"/>
                                <field name="error_traceback" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_tw_boom_task_history_log_filter" model="ir.ui.view">
            <field name="name">tw.boom.task.history.logfilter</field>
            <field name="model">tw.boom.task.history</field>
            <field name="arch" type="xml">
                <search string="History Task BOOM">
                    <field name="category_id"/>
                    <field name="no_transaction"/>
                    <field name="source_transaction"/>
                    <field name="state"/>
                    <group string="Group By..">
                        <filter name="group_by_state" string="Status" context="{'group_by': 'state'}" />
                        <filter name="group_by_category_id" string="Category" context="{'group_by': 'category_id'}" />
                    </group>
                </search>
            </field>
        </record>

        <record id="action_tw_boom_task_history" model="ir.actions.act_window">
            <field name="name">History Log BOOM Task</field>
            <field name="path">history_log-boom-task</field>
            <field name="res_model">tw.boom.task.history</field>
            <field name="view_mode">list,form</field>
            <field name="domain"></field>
            <field name="search_view_id" ref="view_tw_boom_task_history_log_filter"/>
        </record>
    </data>
</odoo>