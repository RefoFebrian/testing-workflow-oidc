<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="tw_work_order_collecting_get_detail_button" model="res.groups">
            <field name="name">TW Button Get Detail Work Order Collecting</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>
        <record id="access_tw_work_order_collecting_get_detail_button" model="ir.model.access">
            <field name="name">tw_work_order_collecting_get_detail_button update</field>
            <field name="model_id" ref="model_tw_work_order_collecting"/>
            <field name="group_id" ref="tw_work_order_collecting_get_detail_button"/>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_work_order_collecting_confirm_button" model="res.groups">
            <field name="name">TW Button Confirm Work Order Collecting</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>
        <record id="access_tw_work_order_collecting_confirm_button" model="ir.model.access">
            <field name="name">tw_work_order_collecting_confirm_button update</field>
            <field name="model_id" ref="model_tw_work_order_collecting"/>
            <field name="group_id" ref="tw_work_order_collecting_confirm_button"/>
            <field name="perm_write">1</field>

        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids"
                eval="[
                (4,ref('tw_work_order_collecting_get_detail_button')),
                (4,ref('tw_work_order_collecting_confirm_button')),
                ]" />
        </record>
    </data>
    

</odoo>
