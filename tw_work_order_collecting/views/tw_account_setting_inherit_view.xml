<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="tw_account_setting_account_journal_wo_claim_form_view" model="ir.ui.view">
        <field name="name">tw.account.setting.account.journal.wo.claim</field>
        <field name="model">tw.account.setting</field>
        <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view" />
        <field name="arch" type="xml">

            <xpath expr="//group[@name='group_work_order']" position="inside">
                <field name="journal_wo_collecting_claim_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>