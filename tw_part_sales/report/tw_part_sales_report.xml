<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_tw_part_sales_print_thermal" model="report.paperformat">
            <field name="name">Part Sales Thermal</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">5</field>
            <field name="margin_left">5</field>
            <field name="margin_right">5</field>
            <field name="header_line" eval="False"/>
            <field name="css_margins" eval="True"/>
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>
        <!-- Thermal Print Report -->
        <record id="print_part_sales_thermal_action" model="ir.actions.report">
            <field name="name">Part Sales Thermal</field>
            <field name="model">tw.part.sales</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_part_sales.tw_part_sales_print_thermal</field>
            <field name="report_file">tw_part_sales.tw_part_sales_print_thermal</field>
            <field name="print_report_name">'Part Sales - %s' % object.name</field>
            <field name="paperformat_id" ref="paperformat_tw_part_sales_print_thermal"/>
        </record>

        <record id="print_picking_part_sales_thermal_action" model="ir.actions.report">
            <field name="name">Picking Part Sales Thermal</field>
            <field name="model">tw.part.sales</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">tw_part_sales.tw_part_sales_picking_print_thermal</field>
            <field name="report_file">tw_part_sales.tw_part_sales_picking_print_thermal</field>
            <field name="paperformat_id" ref="paperformat_tw_part_sales_print_thermal" />
        </record>
    </data>
</odoo>
