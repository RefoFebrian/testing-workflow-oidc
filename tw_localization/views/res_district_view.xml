<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_res_district_list_view" model="ir.ui.view">
			<field name="name">tw.res.district.tree</field>
			<field name="model">res.district</field>
			<field name="arch" type="xml">
				<list string="Kecamatan">
					<field name="code"/>
				    <field name="name" string="Kecamatan"/>
				    <field name="city_id"/>
				    <field name="state_id"/>
					<field name="sequence" widget="handle"/>
				</list>
			</field>
		</record>

		<record id="tw_res_district_form_view" model="ir.ui.view">
			<field name="name">tw.res.district.form</field>
			<field name="model">res.district</field>
			<field name="arch" type="xml">
				<form string="Kecamatan">
			    	<group>
			    		<field name="code"/>
			    		<field name="name" string="Kecamatan"/>
			    		<field name="city_id"/>
			    		<field name="state_id"/>
						<field name="sequence" widget="handle"/>
				    </group>	
				</form>
			</field>
		</record>


        <record id="tw_localization_res_city_inherit_form_view" model="ir.ui.view">
            <field name="name">res.city.inherit.form</field>
            <field name="model">res.city</field>
            <field name="inherit_id" ref="tw_localization.tw_res_city_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//group" position="after">
                    <notebook>
	                	<page string="Kecamatan">
		                    <field name="district_ids" nolabel="1" colspan="4">
		                    	<list string="Kecamatan">
		                    		<field name="code"/>
		                    		<field name="name"/>
		                    	</list>
		                    </field>
	               		</page>
						<page string="Audit Trail">
							<group>
								<group>
									<field name="create_uid" readonly="1"></field>
									<field name="create_date" readonly="1"></field>
								</group>
								<group>							
									<field name="write_uid" readonly="1"></field>
									<field name="write_date" readonly="1"></field>
								</group>
							</group>
						</page>	                   		 
	                </notebook>
		    	</xpath>
            </field>
        </record>

        <record id="tw_res_district_view_search" model="ir.ui.view">
            <field name="name">tw_res_district.search</field>
            <field name="model">res.district</field>
            <field name="arch" type="xml">
                <search string="Search Kecamatan">
                    <field name='name'/>
                    <field name='code'/>
                    <field name='city_id'/>    
                    <field name='state_id'/>   
					<filter name="city" string="city" context="{'group_by': 'city_id'}" />
					<filter name="state" string="state" context="{'group_by': 'state_id'}" /> 
                </search>
            </field>
        </record>

	    <record id="tw_res_district_action_tree" model="ir.actions.act_window">
            <field name="name">Kecamatan</field>
            <field name="res_model">res.district</field>
            <field name="view_mode">list,form</field>
			<field name="search_view_id" ref="tw_res_district_view_search"/>
            <field name="view_id" ref="tw_res_district_list_view"/>
        </record>

	</data>
</odoo>
