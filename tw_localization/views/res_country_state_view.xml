<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<record id="tw_res_country_state_list_view" model="ir.ui.view">
			<field name="name">tw.res.country.state.tree</field>
            <field name="model">res.country.state</field>
            <field name="arch" type="xml">
                <list string="Countries">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="country_id"/>
                    <field name="sequence" widget="handle"/>
                </list>
            </field>
		</record>

        <record id="tw_res_country_state_search_view" model="ir.ui.view">
            <field name="name">tw.res.country.state.search</field>
            <field name="model">res.country.state</field>
            <field name="priority">0</field>
            <field name="arch" type="xml">
                <search string="Country State Search">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="country_id"/>
                    <filter name="country" string="Country" context="{'group_by': 'country_id'}" />
                </search>
            </field>
        </record>

		<record id="tw_res_country_state_action_tree" model="ir.actions.act_window">
            <field name="name">Provinsi</field>
            <field name="res_model">res.country.state</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_res_country_state_search_view"/>
        </record>

    </data>
</odoo>