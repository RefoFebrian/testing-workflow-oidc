    <!-- Inherit Main Lead Form to add button if DGI mandatory -->
    <record id="view_tw_lead_form_dgi_spk_inherit" model="ir.ui.view">
        <field name="name">tw.lead.form.dgi.spk.inherit</field>
        <field name="model">tw.lead</field>
        <field name="inherit_id" ref="tw_lead.tw_lead_crm_lead_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="is_dgi_dso_required" invisible="1"/>
                <button name="action_open_dgi_required_form" type="object" class="oe_stat_button" icon="fa-pencil-square-o" invisible="not is_dgi or not is_dgi_dso_required">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text text-warning">Lengkapi Data</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
