<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tw_lead_dgi_edit_primary_form" model="ir.ui.view">
        <field name="name">tw.lead.dgi.edit.primary.form</field>
        <field name="model">tw.lead</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="tw_lead.tw_lead_crm_lead_form_view"/>
        <field name="arch" type="xml">
            <!-- Replace Header with simple save/cancel for popup -->
            <xpath expr="//header" position="replace">
                <header>
                    <button string="Simpan Data" type="object" name="action_save_dgi_popup" class="btn-primary" />
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </header>
            </xpath>

            <!-- Add a warning block -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning text-center" role="alert" style="margin-bottom:0px;">
                    <strong>Data DGI Belum Lengkap!</strong> Silakan lengkapi data wajib (Nama, KTP, dll) di bawah ini sebelum melanjutkan Confirm DSO.
                </div>
            </xpath>

            <!-- Unlock readonly fields for this specific view -->
            <xpath expr="//field[@name='customer_name']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='identification_number']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='identification_family_number']" position="attributes">
                <attribute name="readonly">0</attribute>
            </xpath>
            <xpath expr="//field[@name='birthplace']" position="attributes">
