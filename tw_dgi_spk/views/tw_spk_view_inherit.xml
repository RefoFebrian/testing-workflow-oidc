<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Inherit SPK List View - Add DGI Sync Button -->
        <record id="view_tw_dealer_spk_list_dgi" model="ir.ui.view">
            <field name="name">tw.dealer.spk.list.dgi</field>
            <field name="model">tw.dealer.spk</field>
            <field name="inherit_id" ref="tw_spk.tw_dealer_spk_list_view"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <header>
                        <button name="action_open_dgi_spk_wizard" string="Sync from DGI" data-hotkey="d" type="object" class="btn-secondary" icon="fa-cloud-download" display="always" groups="tw_dgi_spk.tw_dgi_spk_button_group"/>
                    </header>
                </xpath>
            </field>
        </record>

        <!-- Inherit SPK Form View - Show Integration Fields -->
        <record id="view_tw_dealer_spk_form_dgi" model="ir.ui.view">
            <field name="name">tw.dealer.spk.form.dgi</field>
            <field name="model">tw.dealer.spk</field>
            <field name="inherit_id" ref="tw_spk.tw_dealer_spk_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="is_dgi" invisible="1"/>
                    <field name="source_document" invisible="1"/>
                    <button name="action_show_dgi_info" type="object" class="oe_stat_button" icon="fa-cloud-download" invisible="not is_dgi">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">From DGI</span>
                        </div>
                    </button>
                </xpath>
            </field>
        </record>

        <!-- Inherit DSO List View - Add DGI Sync Button -->
        <record id="view_tw_dealer_sale_order_list_dgi" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.list.dgi</field>
            <field name="model">tw.dealer.sale.order</field>
            <field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sale_order_view_list"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <header>
                        <button name="action_open_dgi_spk_wizard" string="GET DGI DSO" data-hotkey="d" type="object" class="btn-secondary" icon="fa-cloud-download" display="always" groups="tw_dgi_spk.tw_dgi_spk_button_group"/>
                    </header>
                </xpath>
            </field>
        </record>

        <!-- Inherit DSO Form View - Show Integration Fields -->
        <record id="view_tw_dealer_sale_order_form_dgi" model="ir.ui.view">
            <field name="name">tw.dealer.sale.order.form.dgi</field>
            <field name="model">tw.dealer.sale.order</field>
            <field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_order_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@name='button_box']" position="inside">
                    <field name="is_dgi" invisible="1"/>
                    <field name="source_document" invisible="1"/>
                    <button name="action_show_dgi_info" type="object" class="oe_stat_button" icon="fa-cloud-download" invisible="not is_dgi">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_text">From DGI</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//notebook" position="before">
                    <div class="alert alert-warning mb-2" role="alert" invisible="not is_dgi">
                        <i class="fa fa-warning me-1"></i>
                        <strong>Perhatian:</strong> DSO ini bersumber dari DGI. Pastikan ketika di NMS pilih serial lot number yang sama seperti di TEDS.
                    </div>
                </xpath>
            </field>
        </record>

    </data>


    <!-- Inherit Search View - Add DGI filters -->
    <record id="tw_dealer_spk_view_filter_dgi_inherit" model="ir.ui.view">
        <field name="name">tw.dealer.spk.view.filter.dgi.inherit</field>
        <field name="model">tw.dealer.spk</field>
        <field name="inherit_id" ref="tw_spk.tw_dealer_spk_view_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="source_document" string="DGI SPK ID"/>
                <separator/>
                <filter name="filter_is_dgi" string="From DGI" domain="[('is_dgi', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Search View DSO - Add DGI filters -->
    <record id="tw_dealer_sale_order_view_filter_dgi_inherit" model="ir.ui.view">
        <field name="name">tw.dealer.sale.order.view.filter.dgi.inherit</field>
        <field name="model">tw.dealer.sale.order</field>
        <field name="inherit_id" ref="tw_dealer_sale_order.tw_dealer_sales_order_view_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="source_document" string="DGI SPK ID"/>
                <separator/>
                <filter name="filter_is_dgi" string="From DGI" domain="[('is_dgi', '=', True)]"/>
            </xpath>
        </field>
    </record>
</odoo>
