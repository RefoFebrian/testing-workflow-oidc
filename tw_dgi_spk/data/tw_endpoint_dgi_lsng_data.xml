<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
        =============================================================
        DGI LSNG (Leasing) Endpoint Configurations
        
        Endpoint untuk sync Leasing data dari DGI API
        Dipanggil ketika tipePembayaran = Credit
        
        Note: Normalisasi field leasing mengikuti response_mapping_ids.
        =============================================================
        -->

        <!-- ==================== HSO ==================== -->
        <record id="tw_endpoint_dgi_lsng_hso" model="tw.endpoint.configuration">
            <field name="code">dgi_lsng</field>
            <field name="version">1</field>
            <field name="url_path">lsng/read</field>
            <field name="method">post</field>
            <field name="config_id" ref="tw_dgi.tw_api_config_dgi_hso"/>
            <field name="mode">read</field>
            <field name="dgi_division_id" ref="tw_dgi.tw_selection_division_dgi_h1"/>
        </record>

