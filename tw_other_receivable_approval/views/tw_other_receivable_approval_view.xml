<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="tw_other_receivable_inherit_approval_form_view">
            <field name="name">tw.other.receivable.inherit.approval.form</field>
            <field name="model">tw.other.receivable</field>
            <field name="inherit_id" ref="tw_other_receivable.view_other_receivable_form"/>
            <field name="arch" type="xml">
                <field name="state" position="replace">
                    <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,paid"/>
                </field>

                <button name="action_post" position="attributes">
                    <attribute name="invisible">state != 'approved'</attribute>
                </button>
                
                <button name="action_post" position="after">
                    <button name="action_request_approval" data-hotkey="r" groups="tw_other_receivable_approval.group_tw_other_receivable_rfa" invisible="state != 'draft'" string="RFA" type="object" class="oe_highlight"/>
                    <button name="action_approval" data-hotkey="a" invisible="state != 'waiting_for_approval'" string="Approve" type="object" class="oe_highlight"/>
                    <button name="%(tw_approval.tw_approval_reject_wizard_action)d" invisible="state != 'waiting_for_approval'" string="Reject" type="action" context="{'model_name':'tw.other.receivable','update_value':{'state':'draft'}}"/>
                    <button name="%(tw_approval.tw_approval_cancel_wizard_action)d" invisible="state not in ('waiting_for_approval','approved')" string="Cancel Approval" groups="tw_other_receivable_approval.group_tw_other_receivable_cancel_approval" type="action" context="{'model_name':'tw.other.receivable','update_value':{'state':'draft'}}"/>																					
                </button>

                <page name="audit_trail" position="before">
                    <page string="Approval">
                        <field name="approval_ids" />
                    </page>
                </page>
            </field>
        </record>

        <record model="ir.ui.view" id="tw_other_receivable_approval_search_view">
            <field name="name">tw.other.receivable.approval.search</field>
            <field name="model">tw.other.receivable</field>
            <field name="inherit_id" ref="tw_other_receivable.view_other_receivable_search"/>
            <field name="arch" type="xml">
                <filter name="draft" position="after">
                    <filter string="Waiting Approval" name="waiting_approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                </filter>
            </field>
        </record>
        
        <!-- Need to be separated, because it cant read its own ID on install -->
        <record id="tw_other_receivable.action_other_receivable" model="ir.actions.act_window">
            <field name="context" eval="
                {
                    'default_type': 'other_receivable',
                    'default_payment_type': 'inbound',
                    'default_partner_type': 'customer',
                    'action_id': ref('tw_other_receivable.action_other_receivable'),
                    'search_default_draft': 1,
                    'search_default_waiting_approval': 1,
                    'search_default_approved': 1,
                }
            " />
        </record>

    </data>
</odoo>
