<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Request for Approval Group -->
        <record id="group_tw_other_receivable_rfa" model="res.groups">
            <field name="category_id" ref="tw_other_receivable.tw_module_category_other_receivable"/>
            <field name="name">TW Button Request Approval Other Receivable</field>
        </record>
        
        <record id="access_tw_other_receivable_rfa" model="ir.model.access">
            <field name="model_id" ref="tw_other_receivable.model_tw_other_receivable"/>
            <field name="name">tw_other_receivable RFA</field>
            <field name="group_id" ref="group_tw_other_receivable_rfa"/>
            <field name="perm_write">1</field>
        </record>

        <!-- Cancel Approval Group -->
        <record id="group_tw_other_receivable_cancel_approval" model="res.groups">
            <field name="category_id" ref="tw_other_receivable.tw_module_category_other_receivable"/>
            <field name="name">TW Button Cancel Other Receivable</field>
        </record>
        <record id="access_tw_other_receivable_cancel_approval" model="ir.model.access">
            <field name="model_id" ref="tw_other_receivable.model_tw_other_receivable"/>
            <field name="name">tw_other_receivable Cancel Approval</field>
            <field name="group_id" ref="group_tw_other_receivable_cancel_approval"/>
            <field name="perm_write">1</field>
        </record>

        <!-- reject Approval Group -->
        <record id="group_tw_other_receivable_reject_approval" model="res.groups">
            <field name="category_id" ref="tw_other_receivable.tw_module_category_other_receivable"/>
            <field name="name">TW Button Reject Other Receivable</field>
        </record>
        <record id="access_tw_other_receivable_reject_approval" model="ir.model.access">
            <field name="model_id" ref="tw_other_receivable.model_tw_other_receivable"/>
            <field name="name">tw_other_receivable Reject Approval</field>
            <field name="group_id" ref="group_tw_other_receivable_reject_approval"/>
            <field name="perm_write">1</field>
        </record>
    </data>

    <data>
        <!-- Add groups to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_other_receivable_rfa')),
                (4, ref('group_tw_other_receivable_cancel_approval')),
                (4, ref('group_tw_other_receivable_reject_approval')),
            ]" />
        </record>
    </data>
</odoo>
