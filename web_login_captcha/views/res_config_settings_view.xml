<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.web.login.captcha</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='reacaptcha_configuration_settings']" position="before">
                 <div class="mt16 row">
                    <label for="recaptcha_version" class="col-3 o_light_label"/>
                    <field name="recaptcha_version"/>
                 </div>
                 <div class="mt16" invisible="recaptcha_version != 'v3_invisible'">
                    <p class="text-muted">
                        ReCAPTCHA v3 returns a score for each request without user interaction.
                    </p>
                </div>
                <div class="mt16" invisible="recaptcha_version != 'v2_checkbox'">
                    <p class="text-muted">
                        ReCAPTCHA v2 requires the user to click a "I'm not a robot" checkbox.
                    </p>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
