<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- READ -->
        <record id="group_tw_account_setting_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Account Setting Read</field>
        </record>

        <record id="access_tw_account_setting_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_setting"/>
            <field name="name">tw_account_setting read</field>
            <field name="group_id" ref="group_tw_account_setting_read"/>
            <field name="perm_read">1</field>
        </record>
        <record id="access_tw_account_setting_branch_read" model="ir.model.access">
            <field name="model_id" ref="tw_branch_setting.model_tw_branch_setting"/>
            <field name="name">tw_account_setting read</field>
            <field name="group_id" ref="group_tw_account_setting_read"/>
            <field name="perm_read">1</field>
        </record>
            
        <!-- UPDATE -->
        <record id="group_tw_account_setting_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Account Setting Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_setting_read'))]"/>
        </record>

        <record id="access_tw_account_setting_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_setting"/>
            <field name="name">tw_account_setting update</field>
            <field name="group_id" ref="group_tw_account_setting_update"/>
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- DELETE -->
        <record id="group_tw_account_setting_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">Account Setting Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_setting_read'))]"/>
        </record>

        <record id="access_tw_account_setting_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_setting"/>
            <field name="name">tw_account_setting delete</field>
            <field name="group_id" ref="group_tw_account_setting_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_account_setting_read')),
                (4, ref('group_tw_account_setting_update')),
                (4, ref('group_tw_account_setting_delete')),
            ]"/>
        </record>
    </data>

</odoo>
