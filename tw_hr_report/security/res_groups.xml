<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="group_tw_employee_laporan" model="res.groups">
			<field name="category_id" ref="tw_base.tw_role" />
			<field name="name">TW Laporan Employee</field>
		</record>

        <record id="access_tw_employee_laporan" model="ir.model.access">
            <field name="model_id" ref="model_tw_employee_report"/>
            <field name="name">tw_employee_laporan</field>
            <field name="group_id" ref="group_tw_employee_laporan"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
			<field name="perm_write">1</field>
			<field name="perm_unlink">1</field>
        </record>
        
        <record id="group_tw_employee_historical_laporan" model="res.groups">
			<field name="category_id" ref="tw_base.tw_role" />
			<field name="name">TW Laporan Employee Historical</field>
		</record>

        <record id="access_tw_employee_historical_laporan" model="ir.model.access">
            <field name="model_id" ref="model_tw_employee_historical_report"/>
            <field name="name">tw_employee_historical_laporan</field>
            <field name="group_id" ref="group_tw_employee_historical_laporan"/>
            <field name="perm_read">1</field>
            <field name="perm_create">1</field>
			<field name="perm_write">1</field>
			<field name="perm_unlink">1</field>
        </record>
    
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_employee_laporan')),
                (4, ref('group_tw_employee_historical_laporan')),
				]"/>
        </record>
    
    </data>
    

</odoo>
