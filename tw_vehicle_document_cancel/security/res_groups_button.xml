<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="tw_vehicle_document_receive_cancel_confirm_button" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">TW Button Vehicle Document Receive Cancel Confirm</field>
        </record>
        <record id="access_tw_vehicle_document_receive_cancel_confirm_button" model="ir.model.access">
            <field name="model_id" ref="tw_vehicle_document_cancel.model_tw_vehicle_document_cancel"/>
            <field name="name">tw_vehicle_document_receive_cancel_confirm_button update</field>
            <field name="group_id" ref="tw_vehicle_document_cancel.tw_vehicle_document_receive_cancel_confirm_button"/>
            <field name="perm_write">1</field>
        </record>

        <record id="tw_vehicle_document_request_cancel_confirm_button" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
