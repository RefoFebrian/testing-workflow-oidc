            <field name="group_id" ref="tw_vehicle_document_cancel.tw_vehicle_document_request_cancel_confirm_button"/>
            <field name="perm_write">1</field>
        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
            (4,ref('tw_vehicle_document_receive_cancel_confirm_button')),
            (4,ref('tw_vehicle_document_request_cancel_confirm_button')),
            ]"/>
        </record>
    </data>
    

</odoo>
