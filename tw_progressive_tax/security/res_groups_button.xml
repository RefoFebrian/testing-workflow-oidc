<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_progressive_tax_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Pajak Progressive Confirm</field> 
            <field name="implied_ids" eval="[(4, ref('group_progressive_tax_read'))]"/>    
        </record>
        
        <record id="access_progressive_tax_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_progressive_tax"/>
            <field name="name">progressive_tax update</field> 
            <field name="group_id" ref="group_progressive_tax_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

        <record id="access_progressive_tax_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_progressive_tax_line"/>
            <field name="name">progressive_tax_line update</field> 
            <field name="group_id" ref="group_progressive_tax_update"/>  
            <field name="perm_create">1</field>
            <field name="perm_write">1</field> 
        </record>
    
    </data>
    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
				(4,ref('group_progressive_tax_update')),				
			]"/> 
		</record>
    </data>

</odoo>
