<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="tw_account_setting_birojasa_progressive_view" model="ir.ui.view">
            <field name="name">tw.account.setting.birojasa.progressive.view</field>
            <field name="model">tw.account.setting</field>
            <field name="inherit_id" ref="tw_birojasa_billing_process.tw_account_settings_birojasa_inherit_view" />
            <field name="arch" type="xml">
                <xpath expr="//group[@name='tagihan_birojasa']" position="inside">
                    <field name="journal_birojasa_progressive_id" options="{ 'no_open': True, 'no_create': True }" />
                </xpath>
            </field>
        </record>
    </data>
</odoo>