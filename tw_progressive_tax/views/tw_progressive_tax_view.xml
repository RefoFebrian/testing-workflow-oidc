<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
    	<record model="ir.ui.view" id="tw_progressive_tax_list_view">
		    <field name="name">tw.progressive.tax.list</field>
		    <field name="model">tw.progressive.tax</field>
		    <field name="arch" type="xml">
		        <list string="List Pajak Progressive">
		            <field name="name" />
		            <field name="company_id"/>
		            <field name="division"/>
		            <field name="state" /> 
		        </list>
		    </field>
    	</record>

    	<record model="ir.ui.view" id="tw_progressive_tax_form_view">
		    <field name="name">tw.progressive.tax.form</field>
		    <field name="model">tw.progressive.tax</field>
		    <field name="arch" type="xml">
		        <form string="Form Pajak Progressive">
		        <header>
		        	<button name="action_confirm_invoice" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_progressive_tax.group_progressive_tax_update"/>
		            <field name="state" widget="statusbar" statusbar_visible="draft,confirmed" />
		        </header>
		        	<sheet>
			        	<div class="oe_title">
			        		<h2>
	                            <field name="name" class="oe_inline" readonly="1"/>    				
			 				</h2>
			        	</div> 
			        	<group col="2" colspan="2">   
							<group>
								<field name="company_id" options="{'no_create': True,'no_open': True}" required="1" readonly="state != 'draft' or name != False"/>
								<field name="biro_jasa_id" required="1" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" domain="[('id', 'in', available_biro_jasa_ids)]"/>
								<field name="available_biro_jasa_ids" options="{'no_create': True,'no_open': True}" readonly="state != 'draft'" invisible="1"/>
		        			</group>
		        			<group>
		        				<field name="division" readonly="state != 'draft'" required="1"/>
		        				<field name="date" readonly="1"/>
		        			</group>	
		        		</group>
		        		<notebook>
		        			<page string="Pajak Progresive">
		        				<field  name="progressive_tax_line_ids" nolabel="1" widget="one2many_list" readonly="state != 'draft'" context="{'form_view_ref': 'tw_proses_stnk.tw_progressive_tax_line_form_view'}">
		        					<list>
										<field name="lot_id" options="{'no_create': True,'no_open': True}"/>
										<field name="customer_stnk_id"/>
										<field name="progressive_tax_amount"/>
										<field name="name" readonly="1"/>
										<field name="invoice_id" readonly="1"/>
										<field name="status" readonly="1"/>
									</list>								    
								</field>
							</page>
							<page string="Audit Trail">
								<group>
									<group>
 										<field name="create_uid" readonly="1"></field>
										<field name="create_date" readonly="1"></field>
										<field name="confirm_uid" readonly="1"></field>
										<field name="confirm_date" readonly="1"></field>
 									</group>
									<group>
 										<field name="write_uid" readonly="1"></field>
										<field name="write_date" readonly="1"></field> 										
									</group>
								</group>
							</page>
						</notebook>
		           </sheet>
		        </form>
		     </field>
		</record>

		<record id="view_tw_progressive_tax_filter" model="ir.ui.view">
		    <field name="name">tw.progressive.tax.filter</field>
		    <field name="model">tw.progressive.tax</field>
		    <field name="arch" type="xml">
		        <search string="Search Pajak Progressive">
		            <field name="name" string="No Reference"/>
		            <field name="progressive_tax_line_ids" filter_domain="[('progressive_tax_line_ids.lot_id', '=', self)]" string="No Engine"/>
		            <field name="progressive_tax_line_ids" filter_domain="[('progressive_tax_line_ids.name', '=', self)]" string="PPD"/>
		            <field name="company_id"/>
		            <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                    <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                    <filter name="cancelled" string="Cancelled" domain="[('state','=','cancelled')]"/>
		        </search>
		    </field>
		</record>

    	<record model="ir.actions.act_window" id="action_tw_progressive_tax">
		    <field name="name">Pajak Progressive</field>
		    <field name="res_model">tw.progressive.tax</field>
		    <field name="view_mode">list,form</field>
		</record>

		<record model="ir.ui.view" id="tw_progressive_tax_line_form_view">
		    <field name="name">tw.progressive.tax.line.form</field>
		    <field name="model">tw.progressive.tax.line</field>
		    <field name="arch" type="xml">
		    	<form string="PPD Detail">
		    		<header>
		        		<field name="status" widget="statusbar" statusbar_visible="draft,confirmed,cancelled" />
		        	</header>
		    		<sheet>
		    			<div class="oe_title">
			        		<h2>
	                            <field name="name" class="oe_inline" readonly="1"/>    				
			 				</h2>
			        	</div> 
		    			<group col="2">
		    				<group>
			    				<field name="invoice_id" invisible="status == 'draft'"/>
			    				<field name="lot_id" options="{'no_create': True,'no_open': True}"/>
			    				<field name="customer_stnk_id"/>
		    				</group>
		    				<group>
		    					<field name="progressive_tax_amount" required="1"/>
		    					<field name="cancel_uid" invisible="status != 'cancelled'" readonly="1"/>
		    					<field name="cancel_date" invisible="status != 'cancelled'" readonly="1"/>
		    				</group>
		    			</group>

		    		</sheet>
		    	</form>
		    </field>
		</record>

    </data>
</odoo> 
