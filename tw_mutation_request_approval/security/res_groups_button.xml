<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data noupdate="1">
        <!-- Approval Mutation Request -->
        <record id="group_tw_mutation_request_approval_rfa" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button RFA Mutation Request</field>
        </record>

        <record id="access_tw_mutation_request_approval_rfa" model="ir.model.access">
            <field name="model_id" ref="model_tw_mutation_request"/>
            <field name="name">TW Button RFA Mutation Request</field>
            <field name="group_id" ref="group_tw_mutation_request_approval_rfa"/>
            <field name="perm_write">1</field>
        </record>
             
        <record id="group_tw_mutation_request_approval_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Mutation Request</field>
        </record>

        <record id="access_tw_mutation_request_approval_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_mutation_request"/>
            <field name="name">TW Button Cancel Mutation Request</field>
            <field name="group_id" ref="group_tw_mutation_request_approval_cancel"/>
            <field name="perm_write">1</field>
        </record>
        
        <record id="tw_base.group_system_admin" model="res.groups">
			<field name="implied_ids" eval="[
                (4,ref('group_tw_mutation_request_approval_rfa')),
                (4,ref('group_tw_mutation_request_approval_cancel')),
            ]">
			</field>
		</record>
	
	</data>
</odoo>