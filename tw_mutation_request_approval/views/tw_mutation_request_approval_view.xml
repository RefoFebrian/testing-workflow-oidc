<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="tw_mutation_request_approval_form_view" model="ir.ui.view">
			<field name="name">tw.mutation.request.approval.form</field>
			<field name="model">tw.mutation.request</field>
			<field name="type">form</field>
			<field name="inherit_id" ref="tw_mutation_request.tw_mutation_request_form_view"/>
			<field name="arch" type="xml">
				<xpath expr="//button[@name='action_confirm_order']" position="replace">
				</xpath>
				<field name="state" position="attributes">
					<attribute name="statusbar_visible">"draft,waiting_for_approval,confirm,open,done"</attribute>
				</field>
				<xpath expr="//button[@name='action_cancel']" position="before">
					<button name="action_rfa" string="RFA" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_mutation_request_approval.group_tw_mutation_request_approval_rfa"/>
					<button name="action_approval" string="Approve" type="object" class="oe_highlight" invisible="state != 'waiting_for_approval'"/>
					<button name="action_reject_or_cancel" string="Reject" type="object" invisible="state != 'waiting_for_approval'"/>
					<button name="action_reject_or_cancel" string="Cancel Approval" type="object" invisible="state not in ('waiting_for_approval', 'approved')" groups="tw_mutation_request_approval.group_tw_mutation_request_approval_cancel"/>
				</xpath>
				<xpath expr="//page[@name='request_line']" position="after">
					<page string="Approval">
						<field name="approval_ids" readonly="True"/>
					</page>
				</xpath>
			</field>
		</record>
	</data>
</odoo>