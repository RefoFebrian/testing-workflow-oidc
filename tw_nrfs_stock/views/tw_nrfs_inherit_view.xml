<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_nrfs_vendor_stock_lot_list_view" model="ir.ui.view">
            <field name="name">tw.nrfs.vendor.stock.lot.list</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs.tw_nrfs_vendor_list_view" />
            <field name="arch" type="xml">
                <field name="product_id" position="before">
                    <field name="lot_id"/>
                    <field name="chassis_number"/>
                </field>
            </field>
        </record>

        <record id="tw_nrfs_vendor_stock_lot_form_view" model="ir.ui.view">
            <field name="name">tw.nrfs.vendor.stock.lot.form</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs.tw_nrfs_vendor_form_view" />
            <field name="arch" type="xml">
                <field name="product_id" position="before">
                    <field name="lot_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                    <field name="chassis_number" readonly="1" />
                    <field name="ship_list_number" readonly="1" />
                    <field name="unit_receipt_date" readonly="1" />
                </field>
                <field name="nrfs_type" position="after">
                    <field name="stock_inbound_id" readonly="1" options="{'no_create': True, 'no_open': True}" />
                </field>
            </field>
        </record>

        <record id="tw_nrfs_vendor_stock_lot_search_view" model="ir.ui.view">
            <field name="name">tw.nrfs.vendor.stock.lot.search</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs.tw_nrfs_vendor_search_view" />
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="lot_id" string="Nomor Mesin"/>
                </field>
            </field>
        </record>

        <record id="tw_nrfs_stock_lot_list_view" model="ir.ui.view">
