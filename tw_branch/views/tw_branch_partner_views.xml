<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action for Branch Partner -->
    <record id="action_tw_branch_partner" model="ir.actions.act_window">
        <field name="name">Branch</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_type','=','company'),('category_id.name','=','Branch')]</field>
        <field name="context" eval="
            {   
                'form_type': 'Branch',
                'is_readonly': True,
                'default_company_type': 'company',
                'default_category_id': [ref('tw_partner.contact_tags_branch')]
            }
        "/>
    </record>

    <!-- Menu Items -->
     
    <menuitem id="menu_tw_branch_partner" 
              name="Branch" 
              parent="tw_menu.submenu_tw_partner"
              action="action_tw_branch_partner"
              sequence="10"
              groups="tw_res_branch_group_read"/>
</odoo>
