<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    
        <!-- TW Expedition Price -->
        <!-- READ  -->
        <record id="group_tw_expedition_price_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Pricelist Expedition Read</field>
        </record>

        <record id="access_tw_expedition_price_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price"/>
            <field name="name">tw_expedition_price read</field>
            <field name="group_id" ref="group_tw_expedition_price_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="access_tw_expedition_price_line_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price_line"/>
            <field name="name">tw_expedition_price_line read</field>
            <field name="group_id" ref="group_tw_expedition_price_read"/>  
            <field name="perm_read">1</field>
        </record>

        <!-- UPDATE  -->
        <record id="group_tw_expedition_price_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Pricelist Expedition Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_expedition_price_read'))]"/>
        </record>

        <record id="access_tw_expedition_price_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price"/>
            <field name="name">tw_expedition_price update</field> 
            <field name="group_id" ref="group_tw_expedition_price_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>

        <record id="access_tw_expedition_price_line_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price_line"/>
            <field name="name">tw_expedition_price_line update</field> 
            <field name="group_id" ref="group_tw_expedition_price_update"/>  
            <field name="perm_create">1</field>
            <field name="perm_write">1</field>
        </record>

        <!-- DELETE  -->
        <record id="group_tw_expedition_price_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Pricelist Expedition Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_expedition_price_read'))]"/>            	            	
        </record>

        <record id="access_tw_expedition_price_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price"/>
            <field name="name">tw_expedition_price delete</field>
            <field name="group_id" ref="group_tw_expedition_price_delete"/>
            <field name="perm_unlink">1</field>
        </record>

        <record id="access_tw_expedition_price_line_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_expedition_price_line"/>
            <field name="name">tw_expedition_price_line delete</field>
            <field name="group_id" ref="group_tw_expedition_price_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_expedition_price_read')),
                (4, ref('group_tw_expedition_price_update')),
                (4, ref('group_tw_expedition_price_delete')),
            ]"/>
        </record>
    </data>

</odoo>
