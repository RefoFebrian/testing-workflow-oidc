<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_expedition_price_list_view" model="ir.ui.view">
		    <field name="name">tw.expedition.price.list</field>
		    <field name="model">tw.expedition.price</field>
		    <field name="arch" type="xml">
		    	<list>
        			<field name="company_id"/>
        			<field name="expedition_id"/>
        			<field name="name"/>
        			<field name="active"/>
		    	</list>
		    </field>
		</record>
		
		<record id="tw_expedition_price_form_view" model="ir.ui.view">
		    <field name="name">tw.expedition.price.form</field>
		    <field name="model">tw.expedition.price</field>
		    <field name="arch" type="xml">
		    	<form>
		    		<sheet>
		        		<group>
                            <group>
                                <field name="name" required="1"/>
                                <field name="company_id" options="{'no_create': True}" required="1"/>
                                <field name="expedition_id" options="{'no_create': True}" required="1"/>
                            </group>
                            <group>
                                <field name="active"/>
                                <label for="start_date" string="Effective Date"/>	
                                <div>
                                    <field name="start_date" class="oe_inline" required="1"/> - <field name="end_date" class="oe_inline" required="1"/>
                                </div>
                            </group>
		        		</group>
                        <notebook>
                            <page name="expedition_price_ids" string="Detail">
		                        <field colspan="4" name="expedition_price_ids" nolabel="1" widget="one2many_list">
		                            <list string="Detail" editable="top">
						                <field name="product_tmpl_id" options="{'no_open':True, 'no_create':True}" required="1"/>
						                <field name="cost" required="1"/>
		                            </list>
		                        </field>
							</page>
                        </notebook>
		        	</sheet>
		    	</form>
		    </field>
		</record>
		
		<record id="tw_expedition_price_action" model="ir.actions.act_window">
		    <field name="name">Expedition Price</field>
		    <field name="res_model">tw.expedition.price</field>
		    <field name="view_mode">list,form</field>
		</record>
		
    </data>
</odoo>