<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
        <record id="group_button_action_request" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Request Approval Work Order</field>
        </record>    
        <record id="access_button_action_request" model="ir.model.access">
            <field name="model_id" ref="model_tw_work_order"/>
            <field name="name">button_action_request</field>
            <field name="group_id" ref="group_button_action_request"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_button_action_cancel" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Cancel Work Order</field>
        </record>
        <record id="access_button_action_cancel" model="ir.model.access">
            <field name="model_id" ref="model_tw_work_order"/>
            <field name="name">button_action_cancel</field>
            <field name="group_id" ref="group_button_action_cancel"/>
            <field name="perm_write">1</field>
        </record>

        <record id="group_button_action_reject" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Button Reject Work Order</field>
        </record>
        <record id="access_button_action_reject" model="ir.model.access">
            <field name="model_id" ref="model_tw_work_order"/>
            <field name="name">button_action_reject</field>
            <field name="group_id" ref="group_button_action_reject"/>
            <field name="perm_write">1</field>
        </record>
    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_button_action_request')),
                (4, ref('group_button_action_cancel')),
                (4, ref('group_button_action_reject')),
            ]" />
        </record>
    </data>

</odoo>
