<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_nrfs_report_view" model="ir.ui.view">
            <field name="name">tw.nrfs.report.wizard</field>
            <field name="model">tw.nrfs.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="NRFS Report">
                    <group>
                        <group>
                            <field name="state" required="1"/>
                            <label for="start_date" string="Periode"/> 
                            <div>
                                <field name="start_date" class="oe_inline" placeholder="Start Date" required="1"/> - <field name="end_date" class="oe_inline" placeholder="End Date" required="1"/>
                            </div>
                        </group>
                    </group>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_nrfs_report_action" model="ir.actions.act_window">
            <field name="name">Laporan NRFS</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.nrfs.report</field>
            <field name="view_id" ref="tw_nrfs_report_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>