<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_stock_report_view" model="ir.ui.view">
            <field name="name">tw.stock.report.wizard</field>
            <field name="model">tw.stock.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Report Stock">
                    <group>
                        <field name="is_locked_division" invisible="1"/>
                        <field name="division" required="1" readonly="is_locked_division"/>
                        <field name="options_unit" required="division == 'Unit'" invisible="division != 'Unit'"/>
                        <field name="options_sparepart" required="division == 'Sparepart'" invisible="division != 'Sparepart'"/>
                        <field name="location_status" required="division != 'Unit'" invisible="division == 'Unit'"/>
                        <field name="categ_ev" required="options_unit == 'EV' or options_sparepart == 'EV'" invisible="options_unit != 'EV' and options_sparepart != 'EV'"/>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="code" readonly="1" force_save="1"/>
                                    <field name="name" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Products" invisible="options_unit == 'location'">
                            <field name="product_ids" domain="[('division', '=', division)]" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="default_code" readonly="1" force_save="1"/>
                                    <field name="name" readonly="1" force_save="1"/>
                                    <field name="product_template_variant_value_ids" widget="many2many_tags" options="{'no_open': True, 'no_create': True}" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Location">
                            <field name="location_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="name" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

        <record id="tw_stock_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.report</field>
            <field name="view_id" ref="tw_stock_report_view"/>
            <field name="target">new</field>
        </record>

        <record id="tw_stock_showroom_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock Showroom</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.report</field>
            <field name="view_id" ref="tw_stock_report_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Unit', 'default_is_locked_division': True}</field>
        </record>

        <record id="tw_stock_workshop_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock Workshop</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.report</field>
            <field name="view_id" ref="tw_stock_report_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Sparepart', 'exclude_unit': True}</field>
        </record>

        <record id="tw_stock_umum_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock Umum</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.report</field>
            <field name="view_id" ref="tw_stock_report_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Umum', 'default_is_locked_division': True}</field>
        </record>

        <record id="tw_stock_extras_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock Extras</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.report</field>
            <field name="view_id" ref="tw_stock_report_view"/>
            <field name="target">new</field>
            <field name="context">{'default_division': 'Extras', 'default_is_locked_division': True}</field>
        </record>
    </data>
</odoo>