<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_stock_movement_report_view" model="ir.ui.view">
            <field name="name">tw.stock.movement.report.wizard</field>
            <field name="model">tw.stock.movement.report</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form string="Stock Movement Report" >
                    <group>
                        <group>
                            <field name="options" required="1"/>
                            <field name="picking_type" required="1"/>
                        </group>
                        <group>
                            <field name="division" required="1"/>
                            <label for="start_date" string="Periode"/> 
                            <div>
                                <field name="start_date" required="1" class="oe_inline" placeholder="Start Date"/> - 
                                <field name="end_date" required="1" class="oe_inline" placeholder="End Date"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="company_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="code" readonly="1" force_save="1"/>
                                    <field name="name" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Products">
                            <field name="product_ids" domain="[('division', '=', division)]" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="default_code" readonly="1" force_save="1"/>
                                    <field name="name" readonly="1" force_save="1"/>
                                    <field name="product_template_variant_value_ids" widget="many2many_tags" options="{'no_open': True, 'no_create': True}" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Product Categories">
                            <field name="categ_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="display_name" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Partners">
                            <field name="partner_ids" options="{'no_open': True, 'no_create': True, 'no_quick_create': True, 'no_create_edit': True, 'no_export': True}" context="{'list_view_ref': False, 'form_view_ref': False, 'form_view_no_many2many_dropdown': True, 'no_breadcrumbs': True}">
                                <list create="0" edit="0" delete="0" decoration-muted="1" limit="100" editable="top">
                                    <field name="code" readonly="1" force_save="1"/>
                                    <field name="name" readonly="1" force_save="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_export_report" string="Generate" type="object" class="oe_highlight"/>
                        <button string="Cancel" class="oe_link" special="cancel" />
                    </footer>
                </form>
            </field>
        </record>

	  	<record id="tw_stock_movement_report_action" model="ir.actions.act_window">
            <field name="name">Laporan Stock Movement</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.stock.movement.report</field>
            <field name="view_id" ref="tw_stock_movement_report_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>