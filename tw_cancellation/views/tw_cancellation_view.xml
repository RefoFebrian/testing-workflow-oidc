<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
    
    <!-- PO Cancellation -->
        
        <record model="ir.ui.view" id="tw_cancellation_list_view">
            <field name="name">tw.cancellation.list</field>
            <field name="model">tw.cancellation</field>
            <field name="arch" type="xml">
                <list string="Cancel Transaction">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="transaction_name"/>
                    <field name="date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>
        
        <record id="view_tw_cancellation_search" model="ir.ui.view">
            <field name="name">tw.cancellation.search</field>
            <field name="model">tw.cancellation</field>
            <field name="arch" type="xml">
                <search string="Search Transaction Cancel">
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="division"/>
                    <field name="transaction_name"/>
                    <field name="state"/>
                    <filter string="draft" name="draft" domain="[('state', '=', 'draft')]"/>
                    <filter string="waiting for approval" name="waiting_for_approval" domain="[('state', '=', 'waiting_for_approval')]"/>
                    <filter string="approved" name="approved" domain="[('state', '=', 'approved')]"/>
                    <filter string="confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                    <filter string="Model" name="group_by_model_id" context="{'group_by':'model_id'}"/>
                    <filter string="Branch" name="group_by_branch_id" context="{'group_by':'company_id'}"/>    
                    <filter string="Division" name="group_by_division_id" context="{'group_by':'division'}"/>                                        	
                </search>
            </field>
        </record>
        
        <record model="ir.ui.view" id="tw_cancellation_form_view">
            <field name="name">tw.cancellation.form</field>
            <field name="model">tw.cancellation</field>
            <field name="arch" type="xml">
                <form string="Cancel Form">
                    <header>
                        <button name="action_request_approval" data-hotkey="q" string="RFA" type="object" class="oe_highlight" invisible="state != 'draft'" groups="tw_cancellation.group_tw_cancellation_approval_rfa"/>
                        <button name="action_approval" data-hotkey="q" string="Approve" type="object" class="oe_highlight" invisible="state != 'waiting_for_approval'"/>
                        <button name="action_confirm" data-hotkey="r" invisible="state != 'approved'" string="Confirm" type="object" class="oe_highlight" groups="tw_cancellation.group_tw_cancellation_approval_confirm"/>
                        <button name="action_reject_or_cancel" string="Reject" type="object" invisible="state != 'waiting_for_approval'" context="{'window_title': 'Reject'}"/>
                        <button name="action_reject_or_cancel" string="Cancel Approval" type="object" invisible="state not in ('waiting_for_approval', 'approved')" groups="tw_cancellation.group_tw_cancellation_approval_cancel" context="{'window_title': 'Cancel'}"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,waiting_for_approval,approved,confirmed"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                        </div>
                        <div class="oe_title">
                            <h1 invisible="name"><span>Draft Cancellation</span></h1>
                            <h1 invisible="not name"><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="company_id" options="{'no_create':True,'no_open':True}" required="True" readonly="state != 'draft'"/>
                                <field name="transaction_name" readonly="state != 'draft'" invisible="context.get('default_model_type')"/>
                                <field name="reason" readonly="state != 'draft'" required="state == 'draft'"/>
                            </group>
                            <group col="4">
                                <field name="division" required="True" readonly="state != 'draft' or context.get('readonly_division')"/>
                                <field name="date" readonly="True"/>
                                <field name="model_id" required="1" options="{'no_create':True,'no_open':True}" readonly="context.get('default_model_type') or state != 'draft'" invisible="context.get('default_model_type')"/>
                                <field name="transaction_cancel_id" readonly="1" invisible="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="approval" string="Approval">
                                <field name="approval_ids" readonly="True"/>
                            </page>
                            <page name="journal_items" string="Journal Items" invisible="state not in ['confirmed'] or not move_ids">
                                <group col="4">
                                    
                                </group>
                                <field name="move_ids" readonly="1"/>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group string="User">
                                        <field name="create_uid" string="Created By" options="{'no_create':True,'no_open':True}" readonly="1"/>
                                        <field name="write_uid" string="Last Updated By" options="{'no_create':True,'no_open':True}" readonly="1"/>
                                        <field name="confirm_uid" string="Confirmed By" readonly="1"/>
                                    </group>
                                    <group string="Date">
                                        <field name="create_date" string="Created Date" readonly="1"/>
                                        <field name="write_date" string="Last Updated Date" readonly="1"/>
                                        <field name="confirm_date" string="Confirmed Date" readonly="1"/>
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter>
	                    <field name="message_follower_ids" widget="mail_followers"/>
	                    <field name="message_ids" widget="mail_thread"/>
	                </chatter>		    
                </form>
                
            </field>
        </record>
        
        <record model="ir.actions.act_window" id="tw_cancellation_action">
            <field name="name">Transaction Cancel</field>
            <field name="res_model">tw.cancellation</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_tw_cancellation_search"/>
            <field name="context" eval="
            {
            'search_default_group_by_model_id': 1,
            'readonly_by_pass': 1,
            }"/>
            <field name="domain">[]</field>
        </record>
        
        <record id="tw_cancellation_action_list" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_cancellation_list_view"/>
            <field name="act_window_id" ref="tw_cancellation_action"/>
        </record>
        
        <record id="tw_cancellation_action_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_cancellation_form_view"/>
            <field name="act_window_id" ref="tw_cancellation_action"/>
        </record>
        
    </data>
</odoo>