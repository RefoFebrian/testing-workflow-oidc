<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="tw_ir_cron_generate_b2b_api_statement_bank_bri" model="ir.cron">
            <field name="name">B2B API Statement BRI</field>
            <field name="interval_number">3</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall" eval="(DateTime.now().replace(hour=2, minute=0) + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="model_id" ref="model_tw_api_configuration"/>
            <field name="code">model.schedule_statements_bri()</field>
            <field eval="False" name="active"/>
            <field name="user_id" ref="base.user_root"/>
        </record>
        
    </data>
</odoo>