<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        <record id="group_tw_account_report_filter_read" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Account Report Filter Read</field>
        </record>
        <record id="access_tw_account_report_filter_read" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_report_filter"/>
            <field name="name">tw_account_report_filter read</field>
            <field name="group_id" ref="group_tw_account_report_filter_read"/>
            <field name="perm_read">1</field>
        </record>

        <record id="group_tw_account_report_filter_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Account Report Filter Update</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_report_filter_read'))]"/>
        </record>
        <record id="access_tw_account_report_filter_update" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_report_filter"/>
            <field name="name">tw_account_report_filter update</field>
            <field name="group_id" ref="group_tw_account_report_filter_update"/>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
        </record>

        <record id="group_tw_account_report_filter_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Account Report Filter Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_tw_account_report_filter_read'))]"/>
        </record>
        <record id="access_tw_account_report_filter_delete" model="ir.model.access">
            <field name="model_id" ref="model_tw_account_report_filter"/>
            <field name="name">tw_account_report_filter delete</field>
            <field name="group_id" ref="group_tw_account_report_filter_delete"/>
            <field name="perm_unlink">1</field>
        </record>
    
    </data>

    <data>
    
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_tw_account_report_filter_read')),
                (4, ref('group_tw_account_report_filter_update')),
                (4, ref('group_tw_account_report_filter_delete')),
            ]"/>
        </record>
    
    </data>
    
    

</odoo>
