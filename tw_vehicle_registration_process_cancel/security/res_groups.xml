<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ===========================================
            SECURITY GROUPS
        ============================================ -->
        <!-- Cancel Proses STNK Groups -->
        <record id="group_vehicle_registration_process_cancel_read" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Cancel Proses STNK Read</field>
        </record>

        <record id="group_vehicle_registration_process_cancel_update" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Cancel Proses STNK Update</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_registration_process_cancel_read'))]"/>
        </record>

        <record id="group_vehicle_registration_process_cancel_delete" model="res.groups">
            <field name="category_id" ref="tw_vehicle_document.tw_document_handling"/>
            <field name="name">Cancel Proses STNK Delete</field>
            <field name="implied_ids" eval="[(4, ref('group_vehicle_registration_process_cancel_update'))]"/>
        </record>

        <!-- ===========================================
            ACCESS RIGHTS
        ============================================ -->
        <!-- Main Model Access -->
        <record id="access_tw_vehicle_registration_process_cancel_read" model="ir.model.access">
            <field name="name">tw_vehicle_registration_process_cancel_read</field>
            <field name="model_id" ref="model_tw_registration_process_cancel"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_tw_vehicle_registration_process_cancel_update" model="ir.model.access">
            <field name="name">tw_vehicle_registration_process_cancel_update</field>
            <field name="model_id" ref="model_tw_registration_process_cancel"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_tw_vehicle_registration_process_cancel_delete" model="ir.model.access">
            <field name="name">tw_vehicle_registration_process_cancel_delete</field>
            <field name="model_id" ref="model_tw_registration_process_cancel"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Line Model Access -->
        <record id="access_tw_vehicle_registration_cancel_line_read" model="ir.model.access">
            <field name="name">tw_vehicle_registration_cancel_line_read</field>
            <field name="model_id" ref="model_tw_registration_process_cancel_line"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_tw_vehicle_registration_cancel_line_update" model="ir.model.access">
            <field name="name">tw_vehicle_registration_cancel_line_update</field>
            <field name="model_id" ref="model_tw_registration_process_cancel_line"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_update"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_tw_vehicle_registration_cancel_line_delete" model="ir.model.access">
            <field name="name">tw_vehicle_registration_cancel_line_delete</field>
            <field name="model_id" ref="model_tw_registration_process_cancel_line"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_delete"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- ===========================================
            RELATED MODELS ACCESS
        ============================================ -->
        <!-- Stock Lot Access -->
        <record id="access_tw_vehicle_registration_cancel_stock_lot_read" model="ir.model.access">
            <field name="name">tw_vehicle_registration_cancel_stock_lot_read</field>
            <field name="model_id" ref="stock.model_stock_lot"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Registration Process Access -->
        <record id="access_tw_vehicle_registration_process_read" model="ir.model.access">
            <field name="name">tw_vehicle_registration_process_read</field>
            <field name="model_id" ref="tw_vehicle_registration_process.model_tw_vehicle_registration_process"/>
            <field name="group_id" ref="group_vehicle_registration_process_cancel_read"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>

        <!-- Include to System Admin -->
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4, ref('group_vehicle_registration_process_cancel_delete')),
                (4, ref('group_vehicle_registration_process_cancel_update')),
                (4, ref('group_vehicle_registration_process_cancel_read')),
            ]"/>
        </record>
    </data>
</odoo>
