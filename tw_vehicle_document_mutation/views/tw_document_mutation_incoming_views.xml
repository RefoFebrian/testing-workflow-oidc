<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Incoming Document Search View -->
        <record id="tw_document_mutation_incoming_view_search" model="ir.ui.view">
            <field name="name">tw.document.mutation.incoming.search</field>
            <field name="model">tw.document.mutation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name" />
                    <field name="company_id" />
                    <field name="source_branch_id" />
                    <field name="document_mutation_line_ids" string="Engine No" filter_domain="[('document_mutation_line_ids.lot_id', 'ilike', self)]"/>
                    <field name="document_mutation_line_ids" string="Customer BPKB" filter_domain="[('document_mutation_line_ids.customer_bpkb_id', 'ilike', self)]"/>
                    <field name="document_mutation_line_ids" string="BPKB No" filter_domain="[('document_mutation_line_ids.document_number', 'ilike', self)]"/>
                    <field name="state" />
                    <filter name="draft" string="Draft" domain="[('state','=','draft')]" />
                    <filter name="done" string="Done" domain="[('state','=','done')]" />
                    <separator/>
                    <filter name="group_by_state" string="Group by State" context="{'group_by':'state'}" />
                    <filter name="group_by_branch" string="Branch" context="{'group_by':'company_id'}" />
                    <filter name="group_by_source" string="Group by Source" context="{'group_by':'source_branch_id'}" />
                </search>
            </field>
        </record>

        <!-- Incoming Document List View -->
        <record id="tw_document_mutation_incoming_view_list" model="ir.ui.view">
            <field name="name">tw.document.mutation.incoming.list</field>
            <field name="model">tw.document.mutation</field>
            <field name="arch" type="xml">
                <list create="false" edit="false" delete="false">
                    <field name="name" />
                    <field name="date" />
                    <field name="source_branch_id" />
                    <field name="company_id" string="Branch" />
                    <field name="document_type" />
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" />
                </list>
            </field>
        </record>

        <!-- Incoming Document Form View -->
        <record id="tw_document_mutation_incoming_view_form" model="ir.ui.view">
            <field name="name">tw.document.mutation.incoming.form</field>
            <field name="model">tw.document.mutation</field>
            <field name="arch" type="xml">
                <form create="false" edit="false" delete="false">
                    <header>
                        <button name="action_confirm" data-hotkey="c"
                            invisible="state != 'draft' or transfer_type != 'incoming'" 
                            string="Confirm" type="object"
                            class="oe_highlight"
                            confirm="Are you sure you want to confirm receipt of these documents?"
                            groups="tw_vehicle_document_mutation.group_document_mutation_outgoing_confirm_button"/>
                        <field name="state" widget="statusbar"
                            statusbar_visible="draft,done" />
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_outgoing"
                                type="object"
                                class="o_stat_button"
                                icon="fa-arrow-up"
                                invisible="not outgoing_mutation_id">
                                <div class="o_field_widget o_stat_info">
                                    <span class="o_stat_text">Outgoing</span>
                                </div>
                            </button>
                        </div>
                        <div class="oe_title">
                            <span class="o_form_label">Incoming Document</span>
                            <h1>
                                <field name="name" class="oe_inline" />
                            </h1>
                        </div>
                        <group>
                            <group string="Source">
                                <field name="transfer_type" invisible="1" />
                                <field name="source_branch_id" readonly="1" />
                                <field name="bpkb_source_location_id" string="Transit Location"
                                    invisible="document_type != 'bpkb'" readonly="1" />
                                <field name="stnk_source_location_id" string="Transit Location"
                                    invisible="document_type != 'stnk'" readonly="1" />
                                <field name="document_type" readonly="1" />
                            </group>
                            <group string="Destination">
                                <field name="company_id" string="Branch" readonly="1" />
                                <field name="bpkb_dest_location_id" string="BPKB Location"
                                    invisible="document_type != 'bpkb'"
                                    options="{'no_create': True,'no_open': True}"
                                    readonly="state != 'draft'" required="document_type == 'bpkb'" />
                                <field name="stnk_dest_location_id" string="STNK Location"
                                    invisible="document_type != 'stnk'"
                                    options="{'no_create': True,'no_open': True}"
                                    readonly="state != 'draft'" required="document_type == 'stnk'" />
                                <field name="date" readonly="1" />
                            </group>
                        </group>
                        <notebook>
                            <page string="Document Lines">
                                <field name="document_mutation_line_ids" readonly="1">
                                    <list>
                                        <field name="lot_id" />
                                        <field name="chassis_number" />
                                        <field name="document_number" />
                                        <field name="bpkb_current_location_id" string="Current Location"
                                            invisible="parent.document_type != 'bpkb'" />
                                        <field name="stnk_current_location_id" string="Current Location"
                                            invisible="parent.document_type != 'stnk'" />
                                    </list>
                                </field>
                            </page>
                            <page string="References">
                                <group>
                                    <field name="ownership_mutation_request_id" readonly="1" />
                                    <field name="outgoing_mutation_id" readonly="1" />
                                </group>
                            </page>
                            <page string="Audit Trail">
                                <group>
                                    <group>
                                        <field name="create_uid" readonly="1" />
                                        <field name="done_uid" readonly="1" />
                                    </group>
                                    <group>
                                        <field name="create_date" readonly="1" />
                                        <field name="done_date" readonly="1" />
                                    </group>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Incoming Document Action -->
        <record id="tw_document_mutation_incoming_action" model="ir.actions.act_window">
            <field name="name">On Incoming Document</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tw.document.mutation</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('transfer_type', '=', 'incoming')]</field>
            <field name="context" eval="{'default_transfer_type': 'incoming', 'default_document_type': 'bpkb', 'search_default_draft': 1, 'create': False}"/>
        </record>

        <record id="tw_document_mutation_incoming_action_list" model="ir.actions.act_window.view">
            <field name="sequence" eval="10" />
            <field name="view_mode">list</field>
            <field name="view_id" ref="tw_document_mutation_incoming_view_list" />
            <field name="act_window_id" ref="tw_document_mutation_incoming_action" />
        </record>

        <record id="tw_document_mutation_incoming_action_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="20" />
            <field name="view_mode">form</field>
            <field name="view_id" ref="tw_document_mutation_incoming_view_form" />
            <field name="act_window_id" ref="tw_document_mutation_incoming_action" />
        </record>

    </data>
</odoo>
