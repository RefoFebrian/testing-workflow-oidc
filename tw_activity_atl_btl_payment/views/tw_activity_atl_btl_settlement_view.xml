<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_activity_atl_btl_settlement_list_view" model="ir.ui.view">
            <field name="name">tw.activity.atl.btl.settlement.list</field>
            <field name="model">tw.activity.atl.btl.line</field>
            <field name="priority">10</field> 
            <field name="arch" type="xml">
                <list create="false" edit="false" delete="false">
                    <field name="activity_id"/>
                    <field name="mapping_activity_id"/>
                    <field name="city_id"/>
                    <field name="district_id"/>
                    <field name="pic_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <!-- <field name="expense_source"/> -->
                    <field name="target_unit"/>
                    <field name="target_customer"/>
                    <field name="expense_amount"/>
                    <button name="action_settlement" type="object" string="Settlement" class="oe_highlight" invisible="state != 'confirmed'" groups="tw_activity_atl_btl_payment.group_tw_activity_atl_btl_settlement_button"/>
                </list>
            </field>
        </record>

        <record id="tw_activity_atl_btl_settlement_filter" model="ir.ui.view">
            <field name="name">tw.activity.atl.btl.settlement.filter</field>
            <field name="model">tw.activity.atl.btl.line</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name='activity_id'/>  
                    <field name="company_id"/>
                    <field name='pic_id'/>
                    <field name='mapping_activity_id'/>  
                    <field name='state_id'/>  
                    <field name='city_id'/>  
                    <field name='district_id'/> 
                    <group expand="1" string="Group By">
                        <filter string="Activity Plan" name="activity_groupby" context="{'group_by':'activity_id'}"/>
                        <filter string="Branch" name="branch_groupby" context="{'group_by':'company_id'}"/>
                    </group>     
                </search>
            </field>
        </record>

        <record id="action_tw_activity_atl_btl_settlement" model="ir.actions.server">
            <field name="name">Settlement Activity Plan</field>
            <field name="model_id" ref="tw_activity_atl_btl.model_tw_activity_atl_btl_line"/>
            <field name="state">code</field>
            <field name="code">
                action = env['tw.activity.atl.btl.line'].action_settlement_list()
            </field>
            <field name="help" type="html">
                <p>Use this menu to insert actual amount and create settlement payment your Activity Plan by
                    Expense source, PIC, Expense Amount, Actual Expense Amount, etc.</p>
            </field>
        </record>

    </data>
</odoo>