<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="tw_master_expense_source_list_view" model="ir.ui.view">
            <field name="name">tw.master.expense.source.list</field>
            <field name="model">tw.master.expense.source</field>
            <field name="type">list</field>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <list string="Master Activity Type" delete="0" editable="top">
                    <field name="name" required="1"/>
                    <field name="expense_source_id"/>
                    <field name="is_nc" column_invisible="1"/>
                    <field name="account_id" required="is_nc" optional="show" options="{'no_open':True,'no_create':True}"/>
                </list>
            </field>
        </record>

        <record id="tw_master_expense_source_search_view" model="ir.ui.view">
            <field name="name">tw.master.expense.source.search</field>
            <field name="model">tw.master.expense.source</field>
            <field name="type">search</field>
            <field name="arch" type="xml">
                <search string="Search Master Expense Source">
                    <field name="name"/>
                    <field name="expense_source_id"/>
                    <field name="account_id"/>
                </search>
            </field>
        </record>

        <record id="action_tw_master_expense_source" model="ir.actions.act_window">
            <field name="name">Expense Source</field>
            <field name="res_model">tw.master.expense.source</field>
            <field name="path">master-expense-source</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="tw_master_expense_source_search_view"/>
        </record>
    </data>
</odoo>