<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
        <record id="tw_nrfs_sparepart_sale_order_form_view" model="ir.ui.view" >
            <field name="name">tw.nrfs.sparepart.sale.order.form</field>
            <field name="model">tw.nrfs</field>
            <field name="inherit_id" ref="tw_nrfs_sparepart.tw_nrfs_sparepart_form_view"/>
            <field name="arch" type="xml">
        		<xpath expr="//sheet/div[@name='button_box']" position="inside">
                    <button name="action_open_sale_order" type="object" class="oe_stat_button" icon="fa-list-alt" string="Sales Order" invisible="not sale_order_id"/>
                </xpath>
                <field name="company_id" position="before">
                    <field name="sale_order_id" invisible="1"/>
                </field>
            </field>
        </record>
    </data>
</odoo>