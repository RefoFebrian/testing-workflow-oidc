<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_tw_stock_outstanding_delivery_read" model="res.groups">
            <field name="name">TW Stock Outstanding Delivery Read</field>
            <field name="category_id" ref="tw_base.tw_role"/>
        </record>

        <record id="access_tw_stock_outstanding_delivery_read" model="ir.model.access">
            <field name="model_id" ref="model_stock_picking"/>
            <field name="name">tw_stock_outstanding_delivery read</field> 
            <field name="group_id" ref="group_tw_stock_outstanding_delivery_read"/>  
            <field name="perm_read">1</field> 
        </record> 
                
        <record id="group_tw_stock_outstanding_delivery_update" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Stock Outstanding Delivery Update</field> 
            <field name="implied_ids" eval="[(4, ref('group_tw_stock_outstanding_delivery_read'))]"/>                             
        </record>

        <record id="access_tw_stock_outstanding_delivery_update" model="ir.model.access">
            <field name="model_id" ref="model_stock_picking"/>
            <field name="name">tw_stock_outstanding_delivery update</field> 
            <field name="group_id" ref="group_tw_stock_outstanding_delivery_update"/>  
            <field name="perm_create">1</field> 
            <field name="perm_write">1</field> 
        </record>      

        <record id="group_tw_stock_outstanding_delivery_delete" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Stock Outstanding Delivery Delete</field> 
            <field name="implied_ids" eval="[(4, ref('group_tw_stock_outstanding_delivery_read'))]"/>                             
        </record>

        <record id="access_tw_stock_outstanding_delivery_delete" model="ir.model.access">
            <field name="model_id" ref="model_stock_picking"/>
            <field name="name">tw_stock_outstanding_delivery delete</field> 
            <field name="group_id" ref="group_tw_stock_outstanding_delivery_delete"/>  
            <field name="perm_unlink">1</field> 
        </record>

        <record id="group_tw_stock_picking_delivery_gmaps_wizard" model="res.groups">
            <field name="category_id" ref="tw_base.tw_role"/>
            <field name="name">TW Stock Outstanding Delivery Gmaps Wizard</field> 
            <field name="implied_ids" eval="[(4, ref('group_tw_stock_outstanding_delivery_read'))]"/>                             
        </record>

        <record id="access_tw_stock_picking_delivery_gmaps_wizard" model="ir.model.access">
            <field name="model_id" ref="model_tw_stock_picking_delivery_gmaps_wizard"/>
            <field name="name">tw_stock_outstanding_delivery gmaps wizard</field> 
            <field name="group_id" ref="group_tw_stock_picking_delivery_gmaps_wizard"/>  
            <field name="perm_read">1</field> 
            <field name="perm_write">1</field> 
            <field name="perm_create">1</field> 
            <field name="perm_unlink">1</field> 
        </record>


    </data>

    <data>
        <record id="tw_base.group_system_admin" model="res.groups">
            <field name="implied_ids" eval="[
                (4,ref('group_tw_stock_outstanding_delivery_read')),
                (4,ref('group_tw_stock_outstanding_delivery_update')),
                (4,ref('group_tw_stock_outstanding_delivery_delete')),
                (4,ref('group_tw_stock_picking_delivery_gmaps_wizard')),
            ]"/>
        </record>
    </data>
</odoo>
