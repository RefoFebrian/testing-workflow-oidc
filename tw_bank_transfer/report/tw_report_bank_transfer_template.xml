<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="tw_bank_transfer_payment_request_report" name="Teto Report Bank Transfer Payment Request">
        <t t-call="web.html_container">
            <t t-call="tw_web.teto_report_layout">
                <t t-call="tw_web.teto_report_styles_base" />
                <t t-foreach="docs" t-as="o">
                    <div class="page font-sm">
                        
                        <div class="row my-1">
                            <div class="col-6">
                                <t t-call="tw_web.teto_report_partner_address">
                                    <t t-set="partner" t-value="o.company_id.partner_id"/>
                                </t>
                            </div>
                            <div class="col-6">
                                <span class="bolder font-md">PERMINTAAN PEMBAYARAN</span>
                                <br />
                                <table class="table-borderless">
                                    <tr>
                                        <td width="20%">No</td>
                                        <td>:</td>
                                        <td width="79%"><t t-esc="o.name" /></td>
                                    </tr>
                                    <tr>
                                        <td>Tanggal</td>
                                        <td>:</td>
                                        <td><t t-esc="o.date.strftime('%d-%m-%Y') if o.date else ''" /></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row my-1">
                            <div class="col-6">
                                <table class="table-borderless">
                                    <tr>
                                        <td width="20%">Cabang</td>
                                        <td>:</td>
                                        <td width="79%"><t t-esc="o.company_id.name" /></td>
                                    </tr>
                                    <tr>
                                        <td>Total</td>
                                        <td>:</td>
                                        <td class="text-end"><t t-esc="'{:,.2f}'.format(o.amount)"/></td>
                                    </tr>
                                    <tr>
                                        <td>Terbilang</td>
                                        <td>:</td>
                                        <td class="text-end">## <t t-esc="terbilang(o.amount)" /></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table-borderless">
                                    <tr>
                                        <td width="20%">Description</td>
                                        <td>:</td>
                                        <td width="79%"><t t-esc="o.description" /></td>
                                    </tr>
                                    <tr>
                                        <td>Bank</td>
                                        <td>:</td>
                                        <td><t t-esc="o.journal_id.name" /></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="row my-1">
                            <div class="col-12">
                                <table class="teto-table-content">
                                    <thead>
                                        <tr>
                                            <th width="3%">No</th>
                                            <th width="15%">No Reimburse</th>
                                            <th width="32%">Bank</th>
                                            <th width="35%">Description</th>
                                            <th width="15%">Jumlah</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-set="number" t-value="1" />
                                        <tr t-foreach="o.line_ids" t-as="line">
                                            <td class="text-center"><t t-esc="number" /></td>
                                            <td><t t-esc="line.reimbursement_id.name" /></td>
                                            <td><t t-esc="line.payment_to_id.name" /></td>
                                            <td><t t-esc="line.description" /></td>
                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(line.amount)"/></td>
                                            <t t-set="number" t-value="number + 1" />
                                        </tr>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td></td>
                                            <td colspan="3">Total</td>
                                            <td class="text-end"><t t-esc="'{:,.2f}'.format(o.amount)"/></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>

                        <div class="row my-1">
                            <div class="col-3 text-center">
                                Approved by<br /><br /><br />
                            </div>
                            <div class="col-3 text-center">
                                Finance<br /><br /><br /><t t-esc="user.name" />
                            </div>
                            <div class="col-3 text-center">
                                Posting<br /><br /><br /><t t-esc="o.confirm_uid.name" />
                            </div>
                            <div class="col-3 text-center">
                                Penerima<br /><br /><br />
                            </div>
                        </div>

                        <div class="row my-1">
                            <div class="col-12">
                                Lembar ke-1 Finance / Lembar ke-2 Accounting, <t t-esc="user.name" /> <t t-esc="print_datetime()" />
                            </div>
                        </div>

                    </div>
                </t>
            </t>

        </t>
    </template>

    <record id="action_report_tw_bank_transfer_payment_request_report" model="ir.actions.report">
        <field name="name">Bank Transfer Payment Request Report</field>
        <field name="model">tw.bank.transfer</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">tw_bank_transfer.tw_bank_transfer_payment_request_report</field>
        <field name="report_file">tw_bank_transfer.tw_bank_transfer_payment_request_report</field>
        <field name="print_report_name">'Bank Transfer - %s' % object.name</field>
        <field name="paperformat_id" ref="tw_web.tw_report_paperformat_a4"/>
    </record>

</odoo>
