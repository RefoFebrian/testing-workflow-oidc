<odoo>
    <data>
      <record id="tw_bank_transfer_account_setting_inherit_form_view" model="ir.ui.view">
          <field name="name">tw.bank.transfer.account.setting.inherit.view.form</field>
          <field name="model">tw.account.setting</field>
          <field name="inherit_id" ref="tw_account_setting.tw_account_setting_form_view"/>
          <field name="arch" type="xml">
              <xpath expr="//group[@name='backoffice_bank_transfer']" position="inside">
                  <field name="account_bank_transfer_fee_id" options="{'no_create': True}"/>             
              </xpath>
          </field>
      </record>
    </data>
  </odoo>
  